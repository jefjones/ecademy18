/****** Object:  StoredProcedure [dbo].[GetLockerStudentAssign]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetLockerStudentAssign]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')

SELECT
	LockerStudentAssignId,
	Person.PersonId,
	Person.Fname,
	Person.Lname,
	Locker.LockerId,
	Locker.Name as LockerName,
	Locker.Level as PositionLevel,
	Locker.Combination as LockerCombination,
	Locker.Note as LockerNote,
	PaddleLock.PaddlelockId,
	Paddlelock.SerialNumber,
	Paddlelock.Combination as PaddlelockCombination,
	Paddlelock.Note as PaddlelockNote,
	LockerStudentAssign.Note as LockerStudentAssignNote,
	LockerStudentAssign.EntryPersonId,
	LockerStudentAssign.EntryDate
FROM LockerStudentAssign
	INNER JOIN Locker on (Locker.LockerId = LockerStudentAssign.LockerId)
	LEFT JOIN Paddlelock on (Paddlelock.PaddlelockId = LockerStudentAssign.PaddlelockId)
	INNER JOIN Person on (Person.PersonId = LockerStudentAssign.PersonId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = Locker.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

END
GO
/****** Object:  StoredProcedure [dbo].[GetLunchReducedApply]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetLunchReducedApply]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = 'f431cc2d-014c-4844-901f-2fc2ac33ac1d' --(select personid from person where fname = 'olivia' and lname = 'aldrich')

--0
SELECT top 1
	LunchReducedApplyTableId,
	Person.PersonId,
	Person.fname + ' ' + Person.lname as PersonName,
	Snap,
	SnapCaseNumber,
	Tanf,
	TanfCaseNumber,
	Fdpir,
	FdpirCaseNumber,
	SnapTanfFdpirDescription,
	TotalChildIncome,
	TotalChildIncomeFrequencyId,
	Frequency.Name as TotalChildIncomeFrequencyName,
	PrimaryWageEarnerSsn,
	NoSsn,
	LunchReducedApplyTable.StreetAddress,
	LunchReducedApplyTable.City,
	LunchReducedApplyTable.UsStateId,
	UsState.Name as UsStateName,
	LunchReducedApplyTable.PostalCode,
	LunchReducedApplyTable.Phone,
	LunchReducedApplyTable.EmailAddress,
	Signature,
	ConfirmComplete,
	LunchReducedApplyTable.EntryDate
INTO #lunchReducedApplyTable
From LunchReducedApplyTable
	LEFT JOIN Frequency on (Frequency.FrequencyId = LunchReducedApplyTable.TotalChildIncomeFrequencyId)
	INNER JOIN Person on (Person.PersonId = LunchReducedApplyTable.PersonId)
	LEFT JOIN UsState on (UsState.UsStateId = LunchReducedApplyTable.UsStateId)
WHERE Person.PersonId = @personId

select * from #lunchReducedApplyTable

--1
Select
	LunchReducedApplyStudentId,
	LunchReducedApplyTableId,
	FirstName,
	MiddleName,
	LastName,
	SchoolName,
	IsStudent,
	FosterChild,
	HomelessRunawayMigrant,
	HispanicOrLatino,
	LunchReducedApplyStudent.RaceId,
	Race.Name as RaceName
From LunchReducedApplyStudent
	LEFT JOIN Race on (Race.RaceId = LunchReducedApplyStudent.RaceId)
Where lunchReducedApplyTableId = (Select LunchReducedApplyTableId from #lunchReducedApplyTable)


--2
Select
	LunchReducedApplyAdultId,
	FirstName,
	LastName,
	Earnings,
	EarningsFrequencyId,
	EarningsFrequency.Name as EarningsFrequencyName,
	PublicAssistChildSupportAlimony,
	PublicAssistChildSupportAlimonyFrequencyId,
	PublicAssistChildSupportAlimonyFrequency.Name as PublicAssistChildSupportAlimonyFrequencyName,
	PensionsRetirementOther,
	PensionsRetirementOtherFrequencyId,
	PensionsRetirementOtherFrequency.Name as PensionsRetirementOtherFrequencyName
From LunchReducedApplyAdult
	LEFT JOIN Frequency as EarningsFrequency on (EarningsFrequency.FrequencyId = LunchReducedApplyAdult.EarningsFrequencyId)
	LEFT JOIN Frequency as PublicAssistChildSupportAlimonyFrequency on (PublicAssistChildSupportAlimonyFrequency.FrequencyId = LunchReducedApplyAdult.PublicAssistChildSupportAlimonyFrequencyId)
	LEFT JOIN Frequency as PensionsRetirementOtherFrequency on (PensionsRetirementOtherFrequency.FrequencyId = LunchReducedApplyAdult.PensionsRetirementOtherFrequencyId)
Where lunchReducedApplyTableId = (Select LunchReducedApplyTableId from #lunchReducedApplyTable)


--3
Select
	FrequencyId,
	Name,
	Description,
	Sequence
From Frequency


--4
Select
	RaceId,
	Name,
	Description,
	Sequence
From Race

Drop table if exists #lunchReducedApplyTable


END
GO
/****** Object:  StoredProcedure [dbo].[GetMessageReplies]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetMessageReplies]
	@announcementId uniqueidentifier
AS
BEGIN
--Declare @announcementId  as uniqueidentifier
--SET @announcementId  = '3519b767-9887-461f-8911-b34da57776c3'


--0
SELECT
	Announcement.AnnouncementId,
	Subject,
	Message,
	Person.PersonId as FromPersonId,
	Person.Fname as FromPersonFirstName,
	Person.Lname as FromPersonLastName,
	Announcement.EntryDate
FROM Announcement
	INNER JOIN Person on (Person.PersonId = Announcement.EntryPersonId)
WHERE Announcement.ReplyToAnnouncementId = @announcementId

END
GO
/****** Object:  StoredProcedure [dbo].[GetMessagesByRecipient]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetMessagesByRecipient]
	@personId uniqueidentifier
AS
BEGIN
--Declare @personId  as uniqueidentifier
--SET @personId  = '4E66E25A-8EA6-4801-8BA2-922F65BB3D02'

SELECT
	Announcement.AnnouncementId,
    Subject,
    Message,
    Person.PersonId as FromPersonId,
    Person.Fname as FromPersonFirstName,
    Person.Lname as FromPersonLastName,
    Announcement.EntryDate
FROM Announcement
	INNER JOIN AnnouncementPersonAssign	 on (AnnouncementPersonAssign.AnnouncementId  = Announcement.AnnouncementId)
    INNER JOIN Person on (Person.PersonId = Announcement.EntryPersonId)
WHERE AnnouncementPersonAssign.SendOnDateTime <= getDate()
	and AnnouncementPersonAssign.ToPersonId = @personId
	and (HideByRecipient is null or HideByRecipient != 1)
Order by Announcement.EntryDate desc

END
GO
/****** Object:  StoredProcedure [dbo].[GetMessagesBySender]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetMessagesBySender]
	@personId uniqueidentifier
AS
BEGIN
--Declare @personId  as uniqueidentifier
--SET @personId  = '4E66E25A-8EA6-4801-8BA2-922F65BB3D02'

SELECT distinct
	Announcement.AnnouncementId,
    Subject,
    Message,
    Announcement.EntryDate
INTO #announcements
FROM Announcement
WHERE Announcement.EntryPersonId = @personId
Order by Announcement.EntryDate desc

--1
select * from #announcements

--1
SELECT
	Announcement.AnnouncementId,
    Person.PersonId,
    Person.Fname as FirstName,
    Person.Lname as LastName,
	Person.EmailAddress,
	Person.Phone as CellPhone,
	AnnouncementPersonAssign.SeenOn,
	AccessRoleLearner.Name as AccessRoleName
FROM Announcement
	INNER JOIN AnnouncementPersonAssign on (AnnouncementPersonAssign.AnnouncementId = Announcement.AnnouncementId)
    INNER JOIN Person on (Person.PersonId = AnnouncementPersonAssign.ToPersonId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.personId = Person.PersonId)
	INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
WHERE Announcement.AnnouncementId in (select AnnouncementId from #announcements)
Order by Person.Fname, Person.LName

END
GO
/****** Object:  StoredProcedure [dbo].[GetMessageSingle]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetMessageSingle]
	@announcementId uniqueidentifier
AS
BEGIN
--Declare @announcementId  as uniqueidentifier
--SET @announcementId  =


--0
SELECT top 1
	Announcement.AnnouncementId,
    Subject,
    Message,
    Person.PersonId as FromPersonId,
    Person.Fname as FromPersonFirstName,
    Person.Lname as FromPersonLastName,
    Announcement.EntryDate
FROM Announcement
    INNER JOIN Person on (Person.PersonId = Announcement.EntryPersonId)
WHERE Announcement.AnnouncementId = @announcementId

--1
SELECT
    Person.PersonId,
    Person.Fname as FirstName,
    Person.Lname as LastName,
	Person.EmailAddress,
	Person.Phone as CellPhone,
	AnnouncementPersonAssign.SeenOn,
	AccessRoleLearner.Name as AccessRoleName
FROM Announcement
	INNER JOIN AnnouncementPersonAssign on (AnnouncementPersonAssign.AnnouncementId = Announcement.AnnouncementId)
    INNER JOIN Person on (Person.PersonId = AnnouncementPersonAssign.ToPersonId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.personId = Person.PersonId)
	INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
WHERE Announcement.AnnouncementId = @announcementId
Order by Person.Fname, Person.LName

END
GO
/****** Object:  StoredProcedure [dbo].[GetMessagesRecipientDiscarded]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetMessagesRecipientDiscarded]
	@personId uniqueidentifier
AS
BEGIN
--Declare @personId  as uniqueidentifier
--SET @personId  = '4E66E25A-8EA6-4801-8BA2-922F65BB3D02'

SELECT
	Announcement.AnnouncementId,
    Subject,
    Message,
    Person.PersonId as FromPersonId,
    Person.Fname as FromPersonFirstName,
    Person.Lname as FromPersonLastName,
    Announcement.EntryDate
FROM Announcement
	INNER JOIN AnnouncementPersonAssign	 on (AnnouncementPersonAssign.AnnouncementId  = Announcement.AnnouncementId)
    INNER JOIN Person on (Person.PersonId = AnnouncementPersonAssign.ToPersonId)
WHERE AnnouncementPersonAssign.ToPersonId = @personId
	and HideByRecipient = 1
Order by Announcement.EntryDate desc

END
