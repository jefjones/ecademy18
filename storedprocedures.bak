/****** Object:  StoredProcedure [dbo].[GetMyWorkFileTreeExplorer]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetMyWorkFileTreeExplorer]
	@personId uniqueidentifier,
	@mineOrOthers nvarchar(10),
	@workFolderId uniqueidentifier
AS
BEGIN
--Declare @mineOrOthers as nvarchar(10)
--Declare @personId as UniqueIdentifier
--Declare @workFolderId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'shirlyn') --'8E4DCE30-789B-4A8A-A900-B886C812B100'
--SET @mineOrOthers = 'Others'
--Set @workFolderId = '4265903B-8813-49BE-9539-AFE43D70FE2A'

IF (@mineOrOthers = 'Mine')
	BEGIN
		select distinct
			Work.WorkId,
			Work.LanguageId,
			Person.Fname as FirstName,
			Person.Lname as LastName,
			--TopRecentWorks.ChapterId,
			--WordCount
			--sentenceCount
			--edits pending
			--edits processed
			Work.PersonId,
			Work.WorkName,
			Work.Description,
			Work.Sequence,
			Work.WorkFolderId,
			Work.EntryDate,
			Assignment.TotalPoints,
			StudentAssignmentResponse.StudentAssignmentResponseId,
			StudentAssignmentResponse.IsPenspringSubmitted,
			StudentAssignmentResponse.PenspringSubmittedDate,
			StudentAssignmentScore.Score,
			AssignmentGradedBy.GradingType,
			Work.IsDistributableAssignment,
			Work.PublishedDate,
			Work.DistributedWorkId,
			AccessRoleLearner.Name as AccessRoleName
		into #mineWorks
		from Work
			LEFT JOIN WorkFolder on (Work.WorkFolderId = WorkFolder.WorkFolderId)
			INNER JOIN Person on (Work.PersonId = Person.PersonId)
			LEFT JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = Person.PersonId)
			LEFT JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
			INNER JOIN WorkStatus on (WorkStatus.WorkStatusId = Work.WorkStatusId)
			LEFT JOIN StudentAssignmentResponse on (StudentAssignmentResponse.PenspringWorkId = Work.WorkId
				and StudentAssignmentResponse.PersonId = Work.PersonId)
			LEFT JOIN Assignment on (StudentAssignmentResponse.AssignmentId = Assignment.AssignmentId)
			LEFT JOIN StudentAssignmentScore on (StudentAssignmentScore.StudentPersonId = Work.PersonId
				and StudentAssignmentResponse.AssignmentId = StudentAssignmentScore.AssignmentId
				and StudentAssignmentResponse.PersonId = Work.PersonId)
			LEFT JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Work.PersonId)
			LEFT JOIN AssignmentGradedBy ON (AssignmentGradedBy.AssignmentId = Assignment.AssignmentId
				and RegistrationStudent.CourseTypeId = AssignmentGradedBy.CourseTypeId)
		where Work.PersonId = @personId
			and (Work.WorkFolderId = @workFolderId
					or ((@workFolderId is null or @workFolderId = '00000000-0000-0000-0000-000000000000')
						and (Work.WorkFolderId is null or Work.WorkFolderId = '00000000-0000-0000-0000-000000000000')))
			and WorkStatus.Name = 'In Progress'

		--0
		select * from #mineWorks

		--1
		select distinct
			WorkFolderId,
			PersonId,
			MineOrOthers,
			Sequence,
			IsExpanded,
			FolderName,
			FolderType,
			ParentWorkFolderId,
			AssignmentId,
			CompanyId,
			SchoolYearId,
			IntervalId,
			CourseScheduledId,
			CourseEntryId,
			EntryDate
		from WorkFolder
		where WorkFolder.PersonId = @personId
			and WorkFolder.MineOrOthers = @mineOrOthers
			and (WorkFolder.ParentWorkFolderId = @workFolderId
					or ((@workFolderId is null or @workFolderId = '00000000-0000-0000-0000-000000000000')
						and (WorkFolder.ParentWorkFolderId is null or WorkFolder.ParentWorkFolderId = '00000000-0000-0000-0000-000000000000')))

		--2
		Select
			PersonId,
			Chapter.WorkId,
			Chapter.ChapterId,
			Chapter.ChapterNbr,
			RecentDate,
			Chapter.WordCount,
			Chapter.SentenceCount
		From RecentWorks
			INNER JOIN Chapter on (Chapter.ChapterId = RecentWorks.ChapterId)
		Where RecentWorks.WorkId in (Select WorkId from #mineWorks)
			and RecentWorks.PersonId = @personId

		--3
		Select
			Work.WorkId,
			ChapterId,
			Chapter.ChapterNbr,
			WordCount,
			SentenceCount
		From Work
			INNER JOIN Chapter on (Chapter.WorkId = Work.WorkId)
		Where Work.WorkId in (Select WorkId from #mineWorks)
			and Work.PersonId = @personId

		--4
		SELECT distinct
			Chapter.ChapterId,
			EditType.Name as EditTypeName,
			isComment,
			EditDetail.PersonId,
			EditDetail.HrefId,
			Language.LanguageId,
			Language.Name as LanguageName,
			EditDetail.PendingFlag,
			EditDetail.AgreeCount,
			EditDetail.DisagreeCount,
			EditDetail.TrollCount,
			EditDetail.CopyCount,
			EditDetail.AuthorAccepted,
			EditDetail.Score,
			EditDetail.EntryDate
		FROM EditDetail
			INNER JOIN Chapter on (Chapter.ChapterId = EditDetail.ChapterId)
			INNER JOIN EditType on (EditType.EditTypeId = EditDetail.EditTypeId)
			INNER JOIN Language on (Language.LanguageId = EditDetail.LanguageId)
		WHERE Chapter.WorkId in (select WorkId from #mineWorks)

	END

ELSE IF (@mineOrOthers = 'Others')
	BEGIN
		select distinct
			Work.WorkId,
			Work.LanguageId,
			Person.Fname as FirstName,
			Person.Lname as LastName,
			--TopRecentWorks.ChapterId,
			--WordCount
			--sentenceCount
			--edits pending
			--edits processed
			Work.PersonId,
			Work.WorkName,
			Work.Description,
			Work.Sequence,
			FriendWorkAssign.WorkFolderId,
			Work.EntryDate,
			Assignment.TotalPoints,
			StudentAssignmentResponse.StudentAssignmentResponseId,
			StudentAssignmentResponse.IsPenspringSubmitted,
			StudentAssignmentResponse.PenspringSubmittedDate,
			StudentAssignmentScore.Score,
			AssignmentGradedBy.GradingType,
			Work.IsDistributableAssignment,
			Work.PublishedDate,
			Work.DistributedWorkId,
			AccessRoleLearner.Name as AccessRoleName
		into #othersWorks
		from Work
			INNER JOIN Person on (Work.PersonId = Person.PersonId)
			INNER JOIN FriendWorkAssign on (FriendWorkAssign.WorkId = Work.WorkId)
			LEFT JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = FriendWorkAssign.Friend_PersonId)
			LEFT JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
			LEFT JOIN WorkFolder on (WorkFolder.WorkFolderId = FriendWorkAssign.WorkFolderId)
			INNER JOIN WorkStatus on (WorkStatus.WorkStatusID = Work.WorkStatusId)
			LEFT JOIN StudentAssignmentResponse on (StudentAssignmentResponse.PenspringWorkId = Work.WorkId
				and StudentAssignmentResponse.PersonId = Work.PersonId)
			LEFT JOIN Assignment on (StudentAssignmentResponse.AssignmentId = Assignment.AssignmentId)
			LEFT JOIN StudentAssignmentScore on (StudentAssignmentScore.StudentPersonId = Work.PersonId
				and StudentAssignmentResponse.AssignmentId = StudentAssignmentScore.AssignmentId
				and StudentAssignmentResponse.PersonId = Work.PersonId)
			LEFT JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Work.PersonId)
			LEFT JOIN AssignmentGradedBy ON (AssignmentGradedBy.AssignmentId = Assignment.AssignmentId
				and RegistrationStudent.CourseTypeId = AssignmentGradedBy.CourseTypeId)
		where FriendWorkAssign.Friend_PersonID = @personId
			and (FriendWorkAssign.WorkFolderId = @workFolderId
					or ((@workFolderId is null or @workFolderId = '00000000-0000-0000-0000-000000000000')
						and (FriendWorkAssign.WorkFolderId is null or FriendWorkAssign.WorkFolderId = '00000000-0000-0000-0000-000000000000')))
			and WorkStatus.Name = 'In Progress'

		--0
		select * from #othersWorks

		--1
		select distinct
			WorkFolderId,
			PersonId,
			MineOrOthers,
			Sequence,
			IsExpanded,
			FolderName,
			FolderType,
			ParentWorkFolderId,
			AssignmentId,
			CompanyId,
			SchoolYearId,
			IntervalId,
			CourseScheduledId,
			CourseEntryId,
			EntryDate
		from WorkFolder
		where WorkFolder.PersonId = @personId
			and WorkFolder.MineOrOthers = @mineOrOthers
			and WorkFolder.ParentWorkFolderId = @workFolderId
			and (WorkFolder.ParentWorkFolderId = @workFolderId
					or ((@workFolderId is null or @workFolderId = '00000000-0000-0000-0000-000000000000')
						and (WorkFolder.ParentWorkFolderId is null or WorkFolder.ParentWorkFolderId = '00000000-0000-0000-0000-000000000000')))

		--2
		Select
			PersonId,
			Chapter.WorkId,
			Chapter.ChapterId,
			Chapter.ChapterNbr,
			RecentDate,
			Chapter.WordCount,
			Chapter.SentenceCount
		From RecentWorks
			INNER JOIN Chapter on (Chapter.ChapterId = RecentWorks.ChapterId)
		Where RecentWorks.WorkId in (Select WorkId from #othersWorks)
			and RecentWorks.PersonId = @personId

		--3
		Select
			Work.WorkId,
			ChapterId,
			Chapter.ChapterNbr,
			WordCount,
			SentenceCount
		From Work
			INNER JOIN Chapter on (Chapter.WorkId = Work.WorkId)
		Where Work.WorkId in (Select WorkId from #othersWorks)

		--4
		SELECT distinct
			Chapter.ChapterId,
			EditType.Name as EditTypeName,
			isComment,
			EditDetail.PersonId,
			EditDetail.HrefId,
			Language.LanguageId,
			Language.Name as LanguageName,
			EditDetail.PendingFlag,
			EditDetail.AgreeCount,
			EditDetail.DisagreeCount,
			EditDetail.TrollCount,
			EditDetail.CopyCount,
			EditDetail.AuthorAccepted,
			EditDetail.Score,
			EditDetail.EntryDate
		FROM EditDetail
			INNER JOIN Chapter on (Chapter.ChapterId = EditDetail.ChapterId)
			INNER JOIN EditType on (EditType.EditTypeId = EditDetail.EditTypeId)
			INNER JOIN Language on (Language.LanguageId = EditDetail.LanguageId)
		WHERE Chapter.WorkId in (select WorkId from #othersWorks)
			--This is going to need to take into consideration the chapters specifically if this user only has access to fewer than all of them in any work.

	END

--5 AccessRole of the user (to determine teacher or student)
SELECT top 1
	AccessRoleLearner.Name as AccessRoleName,
	Company.StudentNameFirst
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
	INNER JOIN Company on (Company.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonId = @personId

drop table if exists #mineWorks
drop table if exists #othersWorks

END
GO
/****** Object:  StoredProcedure [dbo].[GetOverallGrade]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetOverallGrade]
	(@courseScheduledId AS UniqueIdentifier,
	 @studentPersonId AS UniqueIdentifier,
	 @companyId AS UniqueIdentifier,
	 @intervalId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @courseScheduledId AS UniqueIdentifier
--Declare @studentPersonId AS UniqueIdentifier
--Declare @companyId AS UniqueIdentifier
--Declare @intervalId AS UniqueIdentifier
--Set @courseScheduledId = ''
--Set @studentPersonId  = ''
--Set @companyId = ''
--Set @intervalId = ''

--0
Select top 1
	StudentGradeOverwriteId,
	GradePercent,
	Incomplete,
	Passed
From StudentGradeOverwrite
Where CourseScheduledId = @courseScheduledId
	and StudentPersonId = @studentPersonId
	and IntervalId = @intervalId

--1 Weighted score (the TotalPossible and AccumulatedScore are set to 0 in the calling function to start with so they can accumulate their scores)
Select
	ContentTypeId,
    ScorePercent
from CourseWeightedScore
	INNER JOIN CourseScheduled on (CourseWeightedScore.CourseEntryId = CourseScheduled.CourseEntryId)
Where CourseScheduled.CourseScheduledId = @courseScheduledId

--2
Select distinct
	Assignment.ContentTypeId,
	Assignment.TotalPoints as PossibleScore,
	StudentAssignmentScore.Score,
	Assignment.Sequence
From Assignment
	INNER JOIN ContentType on (Assignment.ContentTypeId = ContentType.ContentTypeId)
	INNER JOIN StudentAssignmentScore on (Assignment.AssignmentId = StudentAssignmentScore.AssignmentId)
	INNER JOIN StudentAssignmentAssign on (Assignment.AssignmentId = StudentAssignmentAssign.AssignmentId)
Where StudentAssignmentScore.StudentPersonId = @studentPersonId
    and StudentAssignmentAssign.StudentPersonId = StudentAssignmentScore.StudentPersonId
    and StudentAssignmentScore.CourseScheduledId = @courseScheduledId
    and StudentAssignmentScore.Score is not null
    and (StudentAssignmentScore.ScoreNotIncluded is null or StudentAssignmentScore.ScoreNotIncluded != 1)
    and (StudentAssignmentScore.IsPrevScore is null or StudentAssignmentScore.IsPrevScore != 1)
    and contentType.Code != 'BENCHMARK'
    and Assignment.IntervalId = @intervalId
Order By Sequence


--3
Select
    GradeScaleDetailId,
    GradeScaleTable.GradeScaleTableId,
    Letter,
    LowValue,
    HighValue,
    Scale40Value
From GradeScaleTable
    INNER JOIN CourseScheduled on (CourseScheduled.GradeScaleTableId = GradeScaleTable.GradeScaleTableId)
    INNER JOIN GradeScaleDetail on (GradeScaleDetail.GradeScaleTableId = GradeScaleTable.GradeScaleTableId)
    where CourseScheduledId = @courseScheduledId


END
GO
/****** Object:  StoredProcedure [dbo].[GetParentGuardianList]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO


CREATE PROCEDURE [dbo].[GetParentGuardianList]
( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personId from person where username = 'ssorensen') --'A2812ACA-BA8D-445F-BFAB-86EF44B9C27F' --'91E033D9-6D29-4A4C-A767-29D499A6D11D'

DECLARE @companyId as UniqueIdentifier
DECLARE @schoolYearId as UniqueIdentifier
DECLARE @intervalId as UniqueIdentifier
DECLARE @accessRoleName as varchar(15)
DECLARE @companyName as varchar(100)

SELECT
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName,
	Company.StudentNameFirst,
	PersonConfigure.SchoolYearId as PersonConfigureSchoolYearId,
	Company.SchoolYearId as CompanySchoolYearId,
	PersonConfigure.IntervalId as PersonConfigureIntervalId,
	Company.IntervalId as CompanyIntervalId
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId)
WHERE PersonAccessRoleAssign.PersonId = @personId

SET @companyId = (SELECT top 1 CompanyId FROM #selectedAccess)
SET @accessRoleName = (SELECT top 1 AccessRoleName FROM #selectedAccess)
SET @companyName = (SELECT top 1 CompanyName FROM #selectedAccess)

SET @schoolYearId = (SELECT top 1 PersonConfigureSchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
SET @schoolYearId = (SELECT top 1 CompanySchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
SET @schoolYearId = (SELECT SchoolYearId from SchoolYear where YearInt = 2020)

SET @intervalId = (SELECT top 1 PersonConfigureIntervalId from #selectedAccess)
if (@intervalId is null or @intervalId = '00000000-0000-0000-0000-000000000000')
SET @intervalId = (SELECT top 1 CompanyIntervalId from #selectedAccess)


IF (@accessRoleName IN ('Admin', 'Counselor') OR (@accessRoleName = 'Facilitator' and @companyName = 'Manheim Central'))

	BEGIN

	SELECT distinct
		PersonAccessRoleAssign.CompanyId,
		ParentPerson.PersonId as ParentPersonId,
		ParentPerson.Fname as ParentFirstName,
		ParentPerson.Lname as ParentLastName,
		ParentPerson.EmailAddress,
		ParentPerson.Phone,
		ParentPerson.BestContactEmail,
		ParentPerson.BestContactPhoneText,
		RegistrationGuardianContact.PersonType,
		RegistrationTable.SchoolYearId
	INTO #selectedStudents_1
	FROM RegistrationTable
		LEFT JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		LEFT JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationTable.PersonId)
		LEFT JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationTable.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN Person as ParentPerson on (ParentPerson.PersonId = RegistrationGuardianContact.PersonId)
		INNER JOIN PersonAccessGradeLevel on (PersonAccessGradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and PersonAccessGradeLevel.PersonId = @personId
		and RegistrationTable.SchoolYearId = @schoolYearId

	Select * from #selectedStudents_1

	Select distinct
		RegistrationGuardianContact.PersonId as ParentPersonId,
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.Fname as StudentFirstName
	FROM RegistrationTable
		INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationStudent.StudentPersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = RegistrationStudent.StudentPersonId)
	WHERE RegistrationGuardianContact.PersonId in (Select ParentPersonId from #selectedStudents_1)
		and RegistrationStudent.SchoolYearId = @schoolYearId

	END

ELSE IF (@accessRoleName = 'Facilitator')
	BEGIN
	SELECT distinct
		PersonAccessRoleAssign.CompanyId,
		ParentPerson.PersonId as ParentPersonId,
		ParentPerson.Fname as ParentFirstName,
		ParentPerson.Lname as ParentLastName,
		ParentPerson.EmailAddress,
		ParentPerson.Phone,
		ParentPerson.BestContactEmail,
		ParentPerson.BestContactPhoneText,
		RegistrationGuardianContact.PersonType,
		RegistrationTable.SchoolYearId
	INTO #selectedStudents_2
	FROM RegistrationTable
		INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationStudent.StudentPersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
		and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN Person as ParentPerson on (ParentPerson.PersonId = RegistrationGuardianContact.PersonId)
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.PersonId = RegistrationStudent.StudentPersonId)
		INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and TeacherCourseAssign.PersonId = @personId
		and CourseIntervalAssign.IntervalId = @intervalId
		and RegistrationTable.SchoolYearId = @schoolYearId

	Select * from #selectedStudents_2

	Select distinct
		RegistrationGuardianContact.PersonId as ParentPersonId,
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.Fname as StudentFirstName
	FROM RegistrationTable
		INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationStudent.StudentPersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = RegistrationStudent.StudentPersonId)
	WHERE RegistrationGuardianContact.PersonId in (Select ParentPersonId from #selectedStudents_2)
		and RegistrationStudent.SchoolYearId = @schoolYearId

	END

ELSE IF (@accessRoleName = 'Observer')

	BEGIN

	SELECT distinct
		PersonAccessRoleAssign.CompanyId,
		ParentPerson.PersonId as ParentPersonId,
		ParentPerson.Fname as ParentFirstName,
		ParentPerson.Lname as ParentLastName,
		ParentPerson.EmailAddress,
		ParentPerson.Phone,
		ParentPerson.BestContactEmail,
		ParentPerson.BestContactPhoneText,
		RegistrationGuardianContact.PersonType,
		RegistrationTable.SchoolYearId
	INTO #selectedStudents_3
	FROM RegistrationTable
		INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationStudent.StudentPersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationGuardianContact as ThisGuardian on (ThisGuardian.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
		and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN Person as ParentPerson on (ParentPerson.PersonId = RegistrationGuardianContact.PersonId)
	WHERE ThisGuardian.PersonId = @personId
		and PersonAccessRoleAssign.CompanyId = @companyId
		and RegistrationTable.SchoolYearId = @schoolYearId

	Select * from #selectedStudents_3

	Select distinct
		RegistrationGuardianContact.PersonId as ParentPersonId,
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.Fname as StudentFirstName
	FROM RegistrationTable
		INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationStudent.StudentPersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = RegistrationStudent.StudentPersonId)
	WHERE RegistrationGuardianContact.PersonId in (Select ParentPersonId from #selectedStudents_3)
		and RegistrationStudent.SchoolYearId = @schoolYearId

	END

ELSE IF (@accessRoleName = 'Learner')

	BEGIN

	SELECT distinct
		@companyId as CompanyId,
		ParentPerson.PersonId as ParentPersonId,
		ParentPerson.Fname as ParentFirstName,
		ParentPerson.Lname as ParentLastName,
		ParentPerson.EmailAddress,
		ParentPerson.Phone,
		ParentPerson.BestContactEmail,
		ParentPerson.BestContactPhoneText,
		RegistrationGuardianContact.PersonType,
		RegistrationTable.SchoolYearId
	INTO #selectedStudents_4
	FROM RegistrationTable
		INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
		and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN Person as ParentPerson on (ParentPerson.PersonId = RegistrationGuardianContact.PersonId)
	WHERE RegistrationStudent.StudentPersonId = @personId
		and RegistrationTable.SchoolYearId = @schoolYearId

	Select * from #selectedStudents_4

	Select distinct
		RegistrationGuardianContact.PersonId as ParentPersonId,
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.Fname as StudentFirstName
	FROM RegistrationTable
		INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationStudent.StudentPersonId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = RegistrationStudent.StudentPersonId)
	WHERE RegistrationGuardianContact.PersonId in (Select ParentPersonId from #selectedStudents_4)
		and RegistrationStudent.SchoolYearId = @schoolYearId

	END


DROP TABLE #selectedAccess
IF OBJECT_ID('tempdb.dbo.#selectedStudents_1', 'U') IS NOT NULL
  DROP TABLE #selectedStudents_1;
IF OBJECT_ID('tempdb.dbo.#selectedStudents_2', 'U') IS NOT NULL
  DROP TABLE #selectedStudents_2;
IF OBJECT_ID('tempdb.dbo.#selectedStudents_3', 'U') IS NOT NULL
  DROP TABLE #selectedStudents_3;
IF OBJECT_ID('tempdb.dbo.#selectedStudents_4', 'U') IS NOT NULL
  DROP TABLE #selectedStudents_4;

END
GO
