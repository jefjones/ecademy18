GO
CREATE PROCEDURE [dbo].[GetJefFeature]
 AS
 BEGIN

--0 Gather absences for combined days - the unexcused absence trumps.
SELECT
    JefFeatureId,
    Name,
    Description,
    Category,
    Sequence,
    MonthlyCost,
    AnnualCost,
    NotActive
FROM JefFeature
WHERE NotActive is null or NotActive = 0

--1
SELECT
    JefFeatureId,
    Description,
    VideoOrScreenshot,
    Length,
    FileUploadId,
    FileUrl,
	MainFile
FROM JefFeatureFile

END
