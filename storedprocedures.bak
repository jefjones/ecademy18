USE [eCademyDB]
GO
/****** Object:  StoredProcedure [dbo].[DeleteCompanyDemoRecords]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[DeleteCompanyDemoRecords]
	(@companyId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @companyId as UniqueIdentifier
--Set @companyId = (Select CompanyId from Company where companyId = '8E01EF62-50E4-4C71-B72B-0403DA39EC96')

SELECT
	Person.PersonId
INTO #deletePerson
FROM Person
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = Person.PersonId)
WHERE PersonAccessRoleAssign.CompanyId = @companyId
	and PersonAccessRoleAssign.AccessRoleLearnerId != (Select AccessroleLearnerId from AccessRoleLearner where Name = 'Admin')
	and Person.DemoRecord = 1

delete from Person where PersonId in (select PersonId from #deletePerson)
delete from RegistrationTable where PersonId in (select PersonId from #deletePerson)
delete from RegistrationGuardianContact where PersonId in (select PersonId from #deletePerson)
delete from RegistrationStudent where StudentPersonId in (select PersonId from #deletePerson)
delete from PersonConfigInterval where PersonId in (select PersonId from #deletePerson)
delete from PersonConfigInterval where PersonId in (select PersonId from #deletePerson)

SELECT
	CourseEntry.CourseEntryId
INTO #deleteCourseEntry
FROM CourseEntry
WHERE CourseEntry.CompanyId = @companyId
	and CourseEntry.DemoRecord = 1

delete from CourseEntry where CourseEntryId in (select CourseEntryId from #deleteCourseEntry)

SELECT
	CourseScheduled.CourseScheduledId
INTO #deleteCourseScheduled
FROM CourseScheduled
WHERE CourseScheduled.CompanyId = @companyId
	and CourseScheduled.CourseEntryId in (select CourseEntryId from #deleteCourseEntry)

delete from CourseScheduled where CourseScheduledId in (select CourseScheduledId from #deleteCourseScheduled)
delete from DaysScheduled where CourseScheduledId in (select CourseScheduledId from #deleteCourseScheduled)

SELECT
	Assignment.AssignmentId
INTO #deleteAssignment
FROM Assignment
WHERE Assignment.CourseEntryId in (select CourseEntryId from #deleteCourseEntry)

delete from Assignment where AssignmentId in (select AssignmentId from #deleteAssignment)
delete from AssignmentFile where AssignmentId in (select AssignmentId from #deleteAssignment)
delete from AssignmentCourseSpecific where AssignmentId in (select AssignmentId from #deleteAssignment)

Drop Table If Exists #deletePerson
Drop Table If Exists #deleteCourse
Drop Table If Exists #deleteAssignment

END
GO
/****** Object:  StoredProcedure [dbo].[GetAbsenceUnexcused]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[GetAbsenceUnexcused]
( @personId AS UniqueIdentifier,
  @isPendingApproval AS nvarchar(20))
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--DECLARE @isPendingApproval AS nvarchar(20)
--Set @personId = (Select top 1 PersonId from person where username = 'kdunford')
--Set @isPendingApproval = ''

DECLARE @accessRoleName as varchar(15)

SELECT top 1
	AccessRoleLearner.Name as AccessRoleName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
WHERE PersonAccessRoleAssign.PersonId = @personId

SET @accessRoleName = (SELECT top 1 AccessRoleName FROM #selectedAccess)

IF (@accessRoleName = 'Observer') BEGIN

	SELECT distinct
		ExcusedAbsence.ExcusedAbsenceId,
	    CourseAttendance.CourseAttendanceId,
        Person.PersonId as StudentPersonId,
        Person.Fname + ' ' + Person.Lname as StudentName,
		RegistrationTable.PersonId as ParentPersonId,
        CourseScheduled.CourseScheduledId,
        CourseEntry.CourseName,
        CourseAttendance.AttendanceDate,
        ExcusedAbsence.EntryPersonId,
		AccessRoleLearner.Name as EntryPersonRole,
        EntryPerson.Fname + ' ' + EntryPerson.Lname as EntryPersonName,
        ExcusedAbsence.DoctorPersonnel,
        EntryPerson.Address1 as DoctorAddress,
        EntryPerson.City as DoctorCity,
        USState.Name as DoctorState,
        EntryPerson.Phone as DoctorPhone,
        EntryPerson.EmailAddress as DoctorEmailAddress,
		null as UserSubmitted
	INTO #observerList
	FROM CourseAttendance
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = CourseAttendance.CourseScheduledId
			and CourseAttendance.AttendanceDate >= CourseScheduled.FromDate and CourseAttendance.AttendanceDate <= CourseScheduled.ToDate)
		INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = CourseAttendance.PersonId) --RegistrationStudent.RegApprovedOrDenied = 'Approved'
		INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN Person on (Person.PersonId = RegistrationStudent.StudentPersonId)
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = RegistrationTable.PersonId
			and CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId
			and RegistrationStudent.SchoolYearId = PersonConfigure.SchoolYearId)
		LEFT JOIN ExcusedAbsence on (ExcusedAbsence.CourseAttendanceId = CourseAttendance.CourseAttendanceId)
		LEFT JOIN Person as EntryPerson on (ExcusedAbsence.EntryPersonId = EntryPerson.PersonId)
		LEFT JOIN PersonAccessRoleAssign as EntryPersonAssign on (EntryPersonAssign.PersonId = EntryPerson.PersonId)
		LEFT JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = EntryPersonAssign.AccessRoleLearnerId)
		LEFT JOIN UsState on (USState.UsStateId = EntryPerson.UsStateId)
	WHERE CourseAttendance.IsAbsent = 1
		and RegistrationTable.PersonId = @personId
		and CourseAttendance.CourseAttendanceId not in (Select CourseAttendanceId from ExcusedAbsence where UserSubmitted = 1)

	--0 Absence Unexcused
	select * from #observerList

	--1 File Uploads
	SELECT top 1
		CourseAttendanceId,
		FileUploadId,
		FileUrl,
		Note
	From ExcusedAbsenceFile
		INNER JOIN ExcusedAbsence on (ExcusedAbsence.ExcusedAbsenceid = ExcusedAbsenceFile.ExcusedAbsenceId)
	WHERE ExcusedAbsence.ExcusedAbsenceId in (select ExcusedAbsenceId from #observerList)

	END

ELSE IF (@accessRoleName = 'Learner') BEGIN

	SELECT distinct
		ExcusedAbsence.ExcusedAbsenceId,
	    CourseAttendance.CourseAttendanceId,
        Person.PersonId as StudentPersonId,
        Person.Fname + ' ' + Person.Lname as StudentName,
		RegistrationTable.PersonId as ParentPersonId,
        CourseScheduled.CourseScheduledId,
        CourseEntry.CourseName,
        CourseAttendance.AttendanceDate,
        ExcusedAbsence.EntryPersonId,
		AccessRoleLearner.Name as EntryPersonRole,
        EntryPerson.Fname + ' ' + EntryPerson.Lname as EntryPersonName,
        ExcusedAbsence.DoctorPersonnel,
        EntryPerson.Address1 as DoctorAddress,
        EntryPerson.City as DoctorCity,
        USState.Name as DoctorState,
        EntryPerson.Phone as DoctorPhone,
        EntryPerson.EmailAddress as DoctorEmailAddress,
		null as UserSubmitted
	INTO #learnerList
	FROM CourseAttendance
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = CourseAttendance.CourseScheduledId
			and CourseAttendance.AttendanceDate >= CourseScheduled.FromDate and CourseAttendance.AttendanceDate <= CourseScheduled.ToDate)
		INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
		INNER JOIN Person on (Person.PersonId = CourseAttendance.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Person.PersonId)
		INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = CourseAttendance.PersonId
			and CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId
			and RegistrationStudent.SchoolYearId = PersonConfigure.SchoolYearId)
		LEFT JOIN ExcusedAbsence on (ExcusedAbsence.CourseAttendanceId = CourseAttendance.CourseAttendanceId)
		LEFT JOIN Person as EntryPerson on (ExcusedAbsence.EntryPersonId = EntryPerson.PersonId)
		LEFT JOIN PersonAccessRoleAssign as EntryPersonAssign on (EntryPersonAssign.PersonId = EntryPerson.PersonId)
		LEFT JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = EntryPersonAssign.AccessRoleLearnerId)
		LEFT JOIN UsState on (USState.UsStateId = EntryPerson.UsStateId)
	WHERE CourseAttendance.IsAbsent = 1
		and CourseAttendance.PersonId = @personId
		and CourseAttendance.CourseAttendanceId not in (Select CourseAttendanceId from ExcusedAbsence where UserSubmitted = 1)

	--0 Absence Unexcused
	Select * from #learnerList

	--1 File Uploads
	SELECT top 1
		CourseAttendanceId,
		FileUploadId,
		FileUrl,
		Note
	From ExcusedAbsenceFile
		INNER JOIN ExcusedAbsence on (ExcusedAbsence.ExcusedAbsenceid = ExcusedAbsenceFile.ExcusedAbsenceId)
	WHERE ExcusedAbsence.ExcusedAbsenceId in (select ExcusedAbsenceId from #learnerList)

	END

ELSE IF (@accessRoleName = 'Admin' or @accessRoleName = 'Doctor')
	BEGIN

		SELECT distinct
			ExcusedAbsence.ExcusedAbsenceId,
			CourseAttendance.CourseAttendanceId,
			Person.PersonId as StudentPersonId,
			Person.Fname + ' ' + Person.Lname as StudentName,
			RegistrationTable.PersonId as ParentPersonId,
			CourseScheduled.CourseScheduledId,
			CourseEntry.CourseName,
			CourseAttendance.AttendanceDate,
			ExcusedAbsence.EntryPersonId,
			AccessRoleLearner.Name as EntryPersonRole,
			EntryPerson.Fname + ' ' + EntryPerson.Lname as EntryPersonName,
			ExcusedAbsence.DoctorPersonnel,
			EntryPerson.Address1 as DoctorAddress,
			EntryPerson.City as DoctorCity,
			USState.Name as DoctorState,
			EntryPerson.Phone as DoctorPhone,
			EntryPerson.EmailAddress as DoctorEmailAddress,
			ExcusedAbsence.UserSubmitted
		INTO #adminList
		FROM CourseAttendance
			INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = CourseAttendance.CourseScheduledId
				and CourseAttendance.AttendanceDate >= CourseScheduled.FromDate and CourseAttendance.AttendanceDate <= CourseScheduled.ToDate)
			INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
			INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = CourseAttendance.PersonId) --RegistrationStudent.RegApprovedOrDenied = 'Approved'
			INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
			INNER JOIN PersonConfigure on (CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId
				and RegistrationStudent.SchoolYearId = PersonConfigure.SchoolYearId)
			INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseScheduled.CompanyId
				and PersonAccessRoleAssign.PersonId = PersonConfigure.PersonId)
			INNER JOIN Person on (Person.PersonId = CourseAttendance.PersonId)
			LEFT JOIN ExcusedAbsence on (ExcusedAbsence.CourseAttendanceId = CourseAttendance.CourseAttendanceId)
			LEFT JOIN Person as EntryPerson on (ExcusedAbsence.EntryPersonId = EntryPerson.PersonId)
			LEFT JOIN PersonAccessRoleAssign as EntryPersonAssign on (EntryPersonAssign.PersonId = EntryPerson.PersonId)
			LEFT JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = EntryPersonAssign.AccessRoleLearnerId)
			LEFT JOIN UsState on (USState.UsStateId = EntryPerson.UsStateId)
		WHERE CourseAttendance.IsAbsent = 1
			and PersonAccessRoleAssign.PersonId = @personId


		If @isPendingApproval = 'pendingApproval' BEGIN
			--0 Absence Unexcused
			select * from #adminList where UserSubmitted = 1

			--1 File Uploads
			SELECT
				CourseAttendanceId,
				FileUploadId,
				FileUrl,
				Note
			From ExcusedAbsenceFile
				INNER JOIN ExcusedAbsence on (ExcusedAbsence.ExcusedAbsenceid = ExcusedAbsenceFile.ExcusedAbsenceId)
			WHERE ExcusedAbsence.ExcusedAbsenceId in (select ExcusedAbsenceId from #adminList where UserSubmitted = 1)

			END
		else BEGIN
			--0 Absence Unexcused
			select * from #adminList where UserSubmitted != 1 or userSubmitted is null

			--1 File Uploads
			SELECT
				CourseAttendanceId,
				FileUploadId,
				FileUrl,
				Note
			From ExcusedAbsenceFile
				INNER JOIN ExcusedAbsence on (ExcusedAbsence.ExcusedAbsenceid = ExcusedAbsenceFile.ExcusedAbsenceId)
			WHERE ExcusedAbsence.ExcusedAbsenceId in (select ExcusedAbsenceId from #adminList where UserSubmitted != 1 or userSubmitted is null)
		END
	END

Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #observerList
Drop Table IF EXISTS #learnerList
Drop Table IF EXISTS #adminList

END
GO
/****** Object:  StoredProcedure [dbo].[GetAdminResponsePending]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetAdminResponsePending]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'jef')

--Person configure settings
SELECT top 1
	SchoolYear.SchoolYearId,
	SchoolYear.Name as SchoolYearName,
	PersonAccessRoleAssign.CompanyId,
	PersonConfigure.IntervalId
into #personSettings
FROM PersonConfigure
	INNER JOIN SchoolYear on (PersonConfigure.SchoolYearId = SchoolYear.SchoolYearId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = PersonConfigure.PersonId)
WHERE PersonConfigure.PersonId = @personId

Declare @schoolYearId as Uniqueidentifier
Declare @schoolYearName as nvarchar(250)
Declare @companyId as Uniqueidentifier
Declare @intervalId as Uniqueidentifier
Set @schoolYearId = (Select schoolYearId from #personSettings)
Set @schoolYearName = (Select schoolYearName from #personSettings)
Set @companyId = (Select CompanyId from #personSettings)
Set @intervalId = (Select IntervalId from #personSettings)

--0 Gather absences for combined days - the unexcused absence trumps.
SELECT
        RequestType,
        RequestTypeName,
		Sequence,
        RequestId,
		RequesterName,
        RequestPersonId,
        EntryDate,
		FileUploadId,
		FileUrl,
		Description,
		CheckInOrOut
INTO #requests
FROM (
	SELECT
			'SafetyAlert' as RequestType,
			'Safety Alert' as RequestTypeName,
			1 as Sequence,
			SafetyAlert.SafetyAlertId as RequestId,
			RequestPerson.Fname + ' ' + RequestPerson.Lname as RequesterName,
			RequestPerson.PersonId as RequestPersonId,
			SafetyAlert.EntryDate,
			SafetyAlert.FileUploadId,
			SafetyAlert.FileUrl,
			SafetyAlertType.Name + ' - ' + SafetyAlert.AlertNote as Description,
			null as CheckInOrOut
	FROM Person as RequestPerson
		INNER JOIN SafetyAlert on (SafetyAlert.PersonId = RequestPerson.PersonId)
		INNER JOIN SafetyAlertType on (SafetyAlertType.SafetyAlertTypeId = SafetyAlert.SafetyAlertTypeId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = SafetyAlert.PersonId
			and PersonAccessRoleAssign.CompanyId = @companyId)
		LEFT JOIN AdminResponsePending on (AdminResponsePending.RequestId = SafetyAlert.SafetyAlertId)
	WHERE (SafetyAlert.DismissFlag is null or SafetyAlert.DismissFlag = 0)
		and SafetyAlert.ApprovedDate is null

	UNION
	SELECT
			'CurbsideCheckInOrOut' as RequestType,
			'Curbside' as RequestTypeName,
			2 as Sequence,
			CurbsideCheckInOrOut.CurbsideCheckInOrOutId as RequestId,
			RequestPerson.Fname + ' ' + RequestPerson.Lname as RequesterName,
			RequestPerson.PersonId as RequestPersonId,
			CurbsideCheckInOrOut.EntryDate,
			CurbsideCheckInOrOut.FileUploadId,
			CurbsideCheckInOrOut.FileUrl,
			CurbsideCheckInOrOut.CheckInOrOut + ' - ' + CheckInOrOutReasonType.Name + ' - ' + ReasonOther + ' - ' + ParentComment as Description,
			CurbsideCheckInOrOut.CheckInOrOut
	FROM Person as RequestPerson
		INNER JOIN CurbsideCheckInOrOut on (CurbsideCheckInOrOut.PersonId = RequestPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = CurbsideCheckInOrOut.PersonId)
		LEFT JOIN CheckInOrOutReasonType on (CheckInOrOutReasonType.CheckInOrOutReasonTypeId = CurbsideCheckInOrOut.CheckInOrOutReasonTypeId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and CurbsideCheckInOrOut.AcknowledgedDate is null
		and CurbsideCheckInOrOut.EntryDate > DATEADD(day, -1, getDate())

	UNION
	SELECT
			'VolunteerCheckInOrOut' as RequestType,
			'Volunteer' as RequestTypeName,
			3 as Sequence,
			VolunteerEvent.VolunteerEventId as RequestId,
			RequestPerson.Fname + ' ' + RequestPerson.Lname as RequesterName,
			RequestPerson.PersonId as RequestPersonId,
			CASE WHEN VolunteerEvent.ConfirmCheckIn is null THEN VolunteerEvent.CheckIn ELSE VolunteerEvent.CheckOut END as EntryDate,
			VolunteerEvent.FileUploadId,
			VolunteerEvent.FileUrl,
			CASE WHEN VolunteerEvent.ConfirmCheckIn is null THEN 'Check in' ELSE 'Check out' END + ' - ' + VolunteerNote as Description,
			CASE WHEN VolunteerEvent.ConfirmCheckIn is null THEN 'Check in' ELSE 'Check out' END as CheckInOrOut
	FROM Person as RequestPerson
		INNER JOIN VolunteerEvent on (VolunteerEvent.VolunteerPersonId = RequestPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = VolunteerEvent.VolunteerPersonId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and ((VolunteerEvent.CheckIn is not null and VolunteerEvent.ConfirmCheckIn is null)
			or (VolunteerEvent.CheckOut is not null and VolunteerEvent.ConfirmCheckOut is null))
) QueryUnion

--0
Select * from #requests

--1
SELECT
	SafetyAlertStudentInvolved.SafetyAlertId as RequestId,
	StudentPerson.Fname + ' ' + StudentPerson.Lname as StudentName
FROM SafetyAlertStudentInvolved
	INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = SafetyAlertStudentInvolved.StudentPersonId)
WHERE SafetyAlertStudentInvolved.SafetyAlertId in (select RequestId from #requests)

UNION
SELECT
	CurbsideCheckInOrOutStudent.CurbsideCheckInOrOutId as RequestId,
	StudentPerson.Fname + ' ' + StudentPerson.Lname as StudentName
FROM CurbsideCheckInOrOutStudent
	INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = StudentPersonId)
WHERE CurbsideCheckInOrOutStudent.CurbsideCheckInOrOutId in (select RequestId from #requests)



Drop Table If Exists #personSettings
Drop Table If Exists #requests

END
GO
/****** Object:  StoredProcedure [dbo].[GetAssessment]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetAssessment]
	(@personId AS UniqueIdentifier,
	 @assessmentId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @assessmentId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')
--Set @assessmentId  = '444DB91B-927A-4935-A898-32C89410C06B'

SELECT
	Assessment.AssessmentId,
	Assessment.Name,
	Assessment.Description,
	Assessment.PersonId,
	Assignment.CourseEntryId,
	Assignment.TotalPoints,
	Assignment.EntryDate,
	Assessment.IsPublished,
	Assessment.BigTextDisplay,
	Assessment.OneAtAtimeView,
	Assessment.RetakeCount,
	Assessment.DoNotShowAnswersImmediately,
	Assessment.ForceAllAnswers
FROM Assessment
	INNER JOIN Assignment on (Assignment.AssessmentId = Assessment.AssessmentId)
WHERE Assessment.AssessmentId = @assessmentId

UNION

SELECT
	Assessment.AssessmentId,
	Assessment.Name,
	Assessment.Description,
	Assessment.PersonId,
	BenchmarkTest.BenchmarkTestId as CourseEntryId,
	BenchmarkTest.PointsPossible as TotalPoints,
	BenchmarkTest.EntryDate,
	Assessment.IsPublished,
	Assessment.BigTextDisplay,
	Assessment.OneAtAtimeView,
	Assessment.RetakeCount,
	Assessment.DoNotShowAnswersImmediately,
	Assessment.ForceAllAnswers
FROM Assessment
	INNER JOIN BenchmarkTest on (BenchmarkTest.AssessmentId = Assessment.AssessmentId)
WHERE Assessment.AssessmentId = @assessmentId

END
GO
/****** Object:  StoredProcedure [dbo].[GetAssessmentCorrectSummary]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetAssessmentCorrectSummary]
	(@personId AS UniqueIdentifier,
	@assessmentId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @assessmentId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')
--Set @assessmentId = 'D78A3712-724B-4FDE-B550-CC12C15ADA99'

--0
SELECT distinct
    CourseEntry.CourseEntryId,
    CourseEntry.CourseName,
	Assignment.AssignmentId,
	Assignment.Title as AssignmentTitle,
	Assignment.TotalPoints
FROM Assessment
	INNER JOIN Assignment on (Assignment.AssessmentId = Assessment.AssessmentId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = Assignment.CourseEntryId)
WHERE Assessment.AssessmentId = @assessmentId

--1
SELECT
    AssessmentLearnerAnswerId,
    PersonId,
    AssessmentLearnerAnswer.AssessmentQuestionId,
    LearnerAnswer,
    CorrectAnswer,
    FileUploadId,
    AssessmentLearnerAnswer.FileUrl,
    PendingCorrection,
    Score,
    TeacherEssayResponse,
    EssayCorrectionWorkId,
    IsCorrect,
    AssessmentLearnerAnswer.EntryDate,
    AssessmentId,
    QuestionTypeId,
    QuestionText,
    PointsPossible,
    Sequence,
    IsSubmitted
FROM AssessmentQuestion
	LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId)
WHERE AssessmentQuestion.AssessmentId = @assessmentId

--2
SELECT distinct
	Person.PersonId,
	Person.Fname + ' ' + Person.Lname as StudentName,
	Sum(AssessmentLearnerAnswer.Score) as TotalScore
FROM AssessmentQuestion
	INNER JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId)
	INNER JOIN Person on (Person.PersonId = AssessmentLearnerAnswer.PersonId)
WHERE AssessmentQuestion.AssessmentId = @assessmentId
	and AssessmentLearnerAnswer.IsSubmitted = 1
Group by Person.PersonId, Person.Fname + ' ' + Person.Lname

END
GO
/****** Object:  StoredProcedure [dbo].[GetAssessmentQuestions]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetAssessmentQuestions]
	(@personId AS UniqueIdentifier,
	@studentPersonId AS UniqueIdentifier,
	@assessmentId AS UniqueIdentifier,
	@assignmentId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Declare @assessmentId as UniqueIdentifier
--Declare @assignmentId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'jef')
--Set @studentPersonId = '57445DFC-FEE3-4BC6-B0C4-D5EAB1A758A2'
--Set @assessmentId = '923A1FC7-A4DC-4F28-B044-C24EB9F10808'
--Set @assignmentId = 'B5182200-959F-4D59-9F72-81955AF3FE34'

--select * from benchmarktest where benchmarktestid = '7F0F9B3F-FD76-4233-AC9F-F3C790D6770F'
--select * from assignment where assessmentid = '923A1FC7-A4DC-4F28-B044-C24EB9F10808'
--select * from assignment where title like '%bench%' order by entrydate desc

--0 Assessment questions
SELECT
	AssessmentQuestionId,
    Assessment.AssessmentId,
    QuestionText,
	ToMatchText,
	CASE WHEN Assessment.PersonId = @personId THEN 1 ELSE 0 END as IsOwner,
    Sequence,
    AssessmentQuestion.IsInactive,
    QuestionType.QuestionTypeId,
    QuestionType.Code as QuestionTypeCode,
    PointsPossible,
    CorrectAnswer,
	KeywordCountAccuracy,
    QuestionFileUploadId,
    QuestionFileUrl,
    QuestionRecordingFileUploadId,
    QuestionRecordingFileUrl,
    SolutionText,
    SolutionFileUploadId,
    SolutionFileUrl,
    SolutionRecordingFileUploadId,
    SolutionRecordingFileUrl,
	AnswerNumberOnly,
    AssessmentQuestion.EntryDate
INTO #assessmentQuestions
FROM Assessment
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
	INNER JOIN QuestionType on (QuestionType.QuestionTypeId = AssessmentQuestion.QuestionTypeId)
WHERE Assessment.AssessmentId = @assessmentId
	and (AssessmentQuestion.IsInactive is null or AssessmentQuestion.IsInactive != 1)

--0
Select * from #assessmentQuestions

--1
SELECT
    AssessmentLearnerAnswerId,
    AssignmentId,
    PersonId,
    AssessmentQuestionId,
    LearnerAnswer,
    FileUploadId,
    PendingCorrection,
    Score,
    EssayCorrectionWorkId,
    IsCorrect,
    EntryDate,
    IsSubmitted,
    IsTeacherCorrected,
    TeacherEssayResponse,
    PenspringWorkId,
    FileUrl,
    RecordingFileUrl,
    RecordingFileUploadId
FROM AssessmentLearnerAnswer
WHERE AssessmentLearnerAnswer.PersonId = @studentPersonId
	and AssessmentLearnerAnswer.AssessmentQuestionId in (Select AssessmentQuestionId from #assessmentQuestions)
	and AssessmentLearnerAnswer.AssignmentId = @assignmentId

--2
SELECT
	AssessmentQuestionAnswerOptionId,
	AnswerText,
	Sequence,
	IsCorrect,
	AssessmentQuestionAnswerOption.AssessmentQuestionId,
	FileUploadId,
	FileUrl,
	RecordingFileUploadId,
	RecordingFileUrl,
	MatchingAnswer,
	IsMatchingRightSide
FROM AssessmentQuestionAnswerOption
WHERE AssessmentQuestionAnswerOption.AssessmentQuestionId in (Select AssessmentQuestionId from #assessmentQuestions)

--3
SELECT
	KeywordPhrase,
	AssessmentQuestionEssayKeyword.AssessmentQuestionId
FROM AssessmentQuestionEssayKeyword
WHERE AssessmentQuestionEssayKeyword.AssessmentQuestionId in (Select AssessmentQuestionId from #assessmentQuestions)

--4
SELECT
	WebsiteLink,
	AssessmentQuestionFileOrLink.AssessmentQuestionId
FROM AssessmentQuestionFileOrLink
WHERE AssessmentQuestionFileOrLink.AssessmentQuestionId in (Select AssessmentQuestionId from #assessmentQuestions)
	and AssessmentQuestionFileOrLink.WebsiteLink is not null
	and AssessmentQuestionFileOrLink.WebsiteLink != ''

--5
SELECT
	AnswerVariation,
	AssessmentAnswerVariation.AssessmentQuestionId
FROM AssessmentAnswerVariation
WHERE AssessmentAnswerVariation.AssessmentQuestionId in (Select AssessmentQuestionId from #assessmentQuestions)

--6
SELECT
	AssessmentQuestionToMatchOptionId,
	ToMatchText,
	Sequence,
	AssessmentQuestionToMatchOption.AssessmentQuestionId,
	FileUploadId,
	FileUrl,
	RecordingFileUploadId,
	RecordingFileUrl
FROM AssessmentQuestionToMatchOption
WHERE AssessmentQuestionToMatchOption.AssessmentQuestionId in (Select AssessmentQuestionId from #assessmentQuestions)

--7 Standards
SELECT distinct
	AssessmentQuestionId,
	StandardSchool.StandardSchoolId,
    LearningPathwayId,
    Code,
    Name,
    Description,
    ParentStandardSchoolId,
    EntryPersonId,
    EntryDate,
    Sequence
FROM AssessmentQuestionStandard
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssessmentQuestionStandard.StandardSchoolId)
WHERE AssessmentQuestionId in (Select AssessmentQuestionId from #assessmentQuestions)


Drop Table If Exists #assessmentQuestions

END
GO
/****** Object:  StoredProcedure [dbo].[GetAttendanceAdmin]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetAttendanceAdmin]
	(@personId AS UniqueIdentifier,
	@studentPersonId AS UniqueIdentifier,
	@includeSiblings AS bit,
	@dayFrom AS DateTime,
	@dayTo AS DateTime)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Declare @includeSiblings AS bit
--Declare @dayFrom AS DateTime
--Declare @dayTo AS DateTime
--Set @personId = (Select personid from person where username = 'jef')
--Set @studentPersonId = (Select personid from person where username = 'Katherine6CAB')
--Set @includeSiblings = 0
--Set @dayFrom = '2019-09-03'
--Set @dayTo  = '2019-09-05'

SELECT StudentPersonId
INTO #studentList
FROM (
	SELECT siblingRegStudent.StudentPersonId
	FROM RegistrationStudent as siblingRegStudent
		INNER JOIN RegistrationStudent as thisRegStudent on (thisRegStudent.RegistrationTableId = siblingRegStudent.RegistrationTableId)
	WHERE thisRegStudent.StudentPersonId = @studentPersonId
		and @includeSiblings = 1
	UNION
	SELECT @studentPersonId as StudentPersonId
	WHERE @includeSiblings = 0
) as UnionQuery


--0
SELECT
    CourseScheduled.CourseScheduledId,
    Person.PersonId as StudentPersonId,
    CourseEntry.CourseName,
    CourseScheduled.FacilitatorPersonId,
    Person.Fname + ' ' + Person.Lname as StudentFullName,
    CourseScheduled.FromDate,
    CourseScheduled.ToDate
INTO #coursesScheduled
FROM Person
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.PersonId = Person.PersonId)
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = CourseScheduled.SchoolYearId)
WHERE Person.PersonId in (select StudentPersonId from #studentList)
	and PersonConfigure.PersonId = @personId

select * from #coursesScheduled

--1
SELECT
	CourseScheduledId,
	ClassPeriod.StartTime,
	DayOfTheWeek
FROM DaysScheduled
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
WHERE DaysScheduled.CourseScheduledId in (select CourseScheduledId from #coursesScheduled)

--2
SELECT
	CourseAttendance.CourseAttendanceId,
    CourseScheduledId,
    PersonId,
    AttendanceDate,
    IsPresent,
    IsTardy,
    IsAbsent,
    IsExcusedAbsence,
    IsLeftEarly
INTO #courseAttendance
FROM CourseAttendance
WHERE CourseAttendance.CourseScheduledId in (select CourseScheduledId from #coursesScheduled)
	and CourseAttendance.PersonId in (select StudentPersonid from #studentList)

select * from #courseAttendance

--3
Select
	ExcusedAbsence.CourseAttendanceId,
	FileUploadId,
	FileUrl,
	Note
From ExcusedAbsenceFile
	INNER JOIN ExcusedAbsence on (ExcusedAbsence.ExcusedAbsenceId = ExcusedAbsenceFile.ExcusedAbsenceId)
Where ExcusedAbsence.CourseAttendanceId in (select CourseAttendanceId from #courseAttendance)


Drop Table If Exists #studentList
Drop Table If Exists #coursesScheduled
Drop Table If Exists #courseAttendance


END
GO
/****** Object:  StoredProcedure [dbo].[GetAttendanceReport]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetAttendanceReport]
	(@personId AS UniqueIdentifier,
	 @studentPersonId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'jef')
--Set @studentPersonId = (Select personid from person where username = 'tiara')

--Person configure settings
SELECT top 1
	SchoolYear.SchoolYearId,
	SchoolYear.Name as SchoolYearName,
	PersonAccessRoleAssign.CompanyId,
	PersonConfigure.IntervalId
into #personSettings
FROM PersonConfigure
	INNER JOIN SchoolYear on (PersonConfigure.SchoolYearId = SchoolYear.SchoolYearId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = PersonConfigure.PersonId)
WHERE PersonConfigure.PersonId = @personId

Declare @schoolYearId as Uniqueidentifier
Declare @schoolYearName as nvarchar(250)
Declare @companyId as Uniqueidentifier
Declare @intervalId as Uniqueidentifier
Set @schoolYearId = (Select schoolYearId from #personSettings)
Set @schoolYearName = (Select schoolYearName from #personSettings)
Set @companyId = (Select CompanyId from #personSettings)
Set @intervalId = (Select IntervalId from #personSettings)

--0 Student info
SELECT
	StudentPerson.PersonId as StudentPersonId,
	StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentFullName,
	SchoolYear.SchoolYearId,
	SchoolYear.Name as SchoolYearName,
	GradeLevel.GradeLevelId,
	GradeLevel.Name as GradeLevelName,
	RegistrationStudent.Accredited as StudentAccredited
From SchoolYear, Person as StudentPerson
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId
		and RegistrationStudent.SchoolYearId = @schoolYearId)
	LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
Where SchoolYear.SchoolYearId = @schoolYearId
	and StudentPerson.PersonId = @studentPersonId

--1 Unique dates
SELECT distinct
	CourseAttendance.AttendanceDate
FROM CourseAttendance
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseAttendance.CourseScheduledId)
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
WHERE CourseIntervalAssign.IntervalId = @intervalId
	and CourseAttendance.PersonId = @studentPersonId
Order by CourseAttendance.AttendanceDate

--2 Courses Scheduled
SELECT
    CourseScheduled.CourseScheduledId,
    CourseEntry.CourseName,
	Interval.IntervalId
FROM CourseScheduled
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = coursescheduled.CourseEntryId and (CourseEntry.IsInactive is null or CourseEntry.IsInactive != 1))
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN Interval on (Interval.Intervalid = CourseIntervalAssign.IntervalId)
WHERE LearnerCourseAssign.PersonId = @studentPersonId
	and CourseScheduled.SchoolYearId = @schoolYearId
	and CourseIntervalAssign.IntervalId = @intervalId
	and CourseEntry.CourseName != 'Seminary'

--3 Course Attendance records
SELECT distinct
	CourseAttendance.CourseAttendanceId,
	CourseAttendance.CourseScheduledId,
	CourseAttendance.PersonId,
	CourseAttendance.AttendanceDate,
	CourseAttendance.IsPresent,
	CourseAttendance.IsTardy,
	CourseAttendance.IsAbsent,
	CourseAttendance.IsExcusedAbsence,
	CourseAttendance.IsLeftEarly,
	CourseAttendance.EntryPersonId,
	CourseAttendance.EntryDate,
	CourseIntervalAssign.IntervalId
INTO #courseAttendance
FROM CourseAttendance
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseAttendance.CourseScheduledId)
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
WHERE CourseAttendance.PersonId = @studentPersonId
	and CourseIntervalAssign.IntervalId = @intervalId

select * from #courseAttendance


--4 Excused absences files and notes
Select
	ExcusedAbsence.CourseAttendanceId,
	FileUploadId,
	FileUrl,
	Note
From ExcusedAbsenceFile
	INNER JOIN ExcusedAbsence on (ExcusedAbsence.ExcusedAbsenceId = ExcusedAbsenceFile.ExcusedAbsenceId)
Where ExcusedAbsence.CourseAttendanceId in (select CourseAttendanceId from #courseAttendance)


Drop Table If Exists #personSettings

END
GO
/****** Object:  StoredProcedure [dbo].[GetAttendanceSchool]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetAttendanceSchool]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'michelle@test.com')

--Person configure settings
SELECT top 1
	SchoolYear.SchoolYearId,
	SchoolYear.Name as SchoolYearName,
	PersonAccessRoleAssign.CompanyId,
	PersonConfigure.IntervalId
into #personSettings
FROM PersonConfigure
	INNER JOIN SchoolYear on (PersonConfigure.SchoolYearId = SchoolYear.SchoolYearId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = PersonConfigure.PersonId)
WHERE PersonConfigure.PersonId = @personId

Declare @schoolYearId as Uniqueidentifier
Declare @schoolYearName as nvarchar(250)
Declare @companyId as Uniqueidentifier
Declare @IntervalId as Uniqueidentifier
Set @schoolYearId = (Select schoolYearId from #personSettings)
Set @schoolYearName = (Select schoolYearName from #personSettings)
Set @companyId = (Select CompanyId from #personSettings)
Set @IntervalId = (Select IntervalId from #personSettings)

--0 Gather absences for combined days - the unexcused absence trumps.
SELECT
	StudentPerson.PersonId as StudentPersonId,
	StudentPerson.Fname as StudentFirstName,
	StudentPerson.Lname as StudentLastName,
	Interval.IntervalId,
	Interval.Name as IntervalName,
	courseAttendance.AttendanceDate,
	sum(CASE WHEN courseAttendance.IsAbsent = 1 THEN 1 ELSE 0 END) as AbsentUnexcused,
	sum(CASE WHEN courseAttendance.IsExcusedAbsence = 1 THEN 1 ELSE 0 END) as AbsentExcused
From Person as StudentPerson
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId
		and RegistrationStudent.SchoolYearId = @schoolYearId)
	INNER JOIN CourseAttendance on (CourseAttendance.PersonId = RegistrationStudent.StudentPersonId
		and (CourseAttendance.IsAbsent = 1 or CourseAttendance.IsExcusedAbsence = 1))
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseAttendance.CourseScheduledId
		and LearnerCourseAssign.PersonId = RegistrationStudent.StudentPersonId)
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
	INNER JOIN PersonConfigure on (PersonConfigure.IntervalId = Interval.IntervalId and PersonConfigure.PersonId = @personId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = StudentPerson.PersonId)
Where RegistrationStudent.SchoolYearId = @schoolYearId
	and PersonAccessRoleAssign.CompanyId = @companyId
Group by StudentPerson.PersonId, StudentPerson.Lname, StudentPerson.Fname, Interval.IntervalId,
	Interval.Name, courseAttendance.AttendanceDate

--1 Get tardies
SELECT
	StudentPerson.PersonId as StudentPersonId,
	StudentPerson.Fname as StudentFirstName,
	StudentPerson.Lname as StudentLastName,
	Interval.IntervalId,
	Interval.Name as IntervalName,
	sum(CASE WHEN courseAttendance.IsTardy = 1 THEN 1 ELSE 0 END) as TardyExcused,
	--sum(CASE WHEN courseAttendance.IsExcusedTardy = 1 THEN 1 ELSE 0 END) as TardyUnexcused
	0 as TardyUnexcused
From Person as StudentPerson
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId
		and RegistrationStudent.SchoolYearId = @schoolYearId)
	INNER JOIN CourseAttendance on (CourseAttendance.PersonId = RegistrationStudent.StudentPersonId
		and CourseAttendance.IsTardy = 1)
		--and (CourseAttendance.IsTardy = 1 or CourseAttendance.IsExcusedTardy = 1))
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseAttendance.CourseScheduledId
		and LearnerCourseAssign.PersonId = RegistrationStudent.StudentPersonId)
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
	INNER JOIN PersonConfigure on (PersonConfigure.IntervalId = Interval.IntervalId and PersonConfigure.PersonId = @personId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = StudentPerson.PersonId)
Where RegistrationStudent.SchoolYearId = @schoolYearId
	and PersonAccessRoleAssign.CompanyId = @companyId
Group by StudentPerson.PersonId, StudentPerson.Lname, StudentPerson.Fname, Interval.IntervalId,
	Interval.Name


Drop Table If Exists #personSettings

END
GO
/****** Object:  StoredProcedure [dbo].[GetBehaviorIncidents]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetBehaviorIncidents]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')

SELECT distinct
    BehaviorIncident.BehaviorIncidentId,
	EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
    BehaviorIncident.IncidentDate,
    BehaviorIncident.Note,
    BehaviorIncident.Level,
    BehaviorIncident.FileUploadId,
    BehaviorIncident.FileUrl,
    BehaviorIncident.EntryPersonId,
    BehaviorIncident.EntryDate,
    OtherTeacherResponse,
    OtherAdminResponse,
    HaveParentsBeenContacted,
    PlanToContactParents,
    ParentContactDateTime,
    ShouldAdminFollowUpStudent
INTO #behaviorIncidents
FROM BehaviorIncident
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = BehaviorIncident.EntryPersonId)
	INNER JOIN PersonAccessRoleAssign as AdminAccess on (AdminAccess.CompanyId = PersonAccessRoleAssign.CompanyId)
	INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = BehaviorIncident.EntryPersonId)
WHERE AdminAccess.PersonId = @personId
Order by BehaviorIncident.IncidentDate desc

--0
select * from #behaviorIncidents

--1
SELECT
	BehaviorIncidentTypeChoices.BehaviorIncidentId,
	BehaviorIncidentTypeChoices.BehaviorIncidentTypeId,
	BehaviorIncidentType.Name
FROM BehaviorIncidentTypeChoices
	INNER JOIN BehaviorIncidentType on (BehaviorIncidentType.BehaviorIncidentTypeId = BehaviorIncidentTypeChoices.BehaviorIncidentTypeId)
WHERE BehaviorIncidentTypeChoices.BehaviorIncidentId in (Select BehaviorIncidentId from #behaviorIncidents)

--2
SELECT
	BehaviorIncidentAccusedStudent.BehaviorIncidentId,
	BehaviorIncidentAccusedStudent.StudentPersonId,
	StudentPerson.fname + ' ' + StudentPerson.lname as Name
FROM BehaviorIncidentAccusedStudent
	INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = BehaviorIncidentAccusedStudent.StudentPersonId)
WHERE BehaviorIncidentAccusedStudent.BehaviorIncidentId in (Select BehaviorIncidentId from #behaviorIncidents)

--3
SELECT
	BehaviorIncidentOtherStudent.BehaviorIncidentId,
	BehaviorIncidentOtherStudent.StudentPersonId,
	StudentPerson.fname + ' ' + StudentPerson.lname as Name
FROM BehaviorIncidentOtherStudent
	INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = BehaviorIncidentOtherStudent.StudentPersonId)
WHERE BehaviorIncidentOtherStudent.BehaviorIncidentId in (Select BehaviorIncidentId from #behaviorIncidents)

--4
SELECT
	BehaviorIncidentStaff.BehaviorIncidentId,
	BehaviorIncidentStaff.PersonId,
	Person.fname + ' ' + Person.lname as Name
FROM BehaviorIncidentStaff
	INNER JOIN Person on (Person.PersonId = BehaviorIncidentStaff.PersonId)
WHERE BehaviorIncidentStaff.BehaviorIncidentId in (Select BehaviorIncidentId from #behaviorIncidents)

--5
SELECT
	BehaviorIncidentResponse.BehaviorIncidentId,
	BehaviorIncidentResponse.BehaviorIncidentResponseTypeId,
	BehaviorIncidentResponse.BehaviorIncidentResponseId,
	BehaviorIncidentResponseType.Name,
	BehaviorIncidentResponseType.AdminOrTeacher,
	BehaviorIncidentResponseType.Sequence
FROM BehaviorIncidentResponse
	INNER JOIN BehaviorIncidentResponseType on (BehaviorIncidentResponse.BehaviorIncidentResponseTypeId = BehaviorIncidentResponseType.BehaviorIncidentResponseTypeId)
WHERE BehaviorIncidentResponse.BehaviorIncidentId in (Select BehaviorIncidentId from #behaviorIncidents)


Drop Table If Exists #behaviorIncidents

END
GO
/****** Object:  StoredProcedure [dbo].[GetBenchmarkTestResults]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetBenchmarkTestResults]
(@personId AS UniqueIdentifier, @benchmarkTestId as Uniqueidentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @benchmarkTestId as Uniqueidentifier
--Set @personId = (select personid from person where username = 'kdunford')
--SET @benchmarkTestId = '7f0f9b3f-fd76-4233-ac9f-f3c790d6770f'

SELECT distinct
	StudentAssignmentScore.StudentPersonId,
	Assignment.AssignmentId,
	Assignment.BenchmarkTestId,
	Assignment.EntryDate,
	AssessmentLearnerAnswer.AssessmentLearnerAnswerId,
	AssessmentLearnerAnswer.AssessmentQuestionId,
	AssessmentQuestion.AssessmentId,
	AssessmentLearnerAnswer.Score,
	AssessmentQuestion.PointsPossible,
	AssessmentQuestion.Sequence,
	StudentAssignmentScore.CourseScheduledId,
	CourseEntry.CourseName,
	CourseEntry.standardsRatingTableId
INTO #scoredAnswers
FROM Assignment
	INNER JOIN BenchmarkTest on (BenchmarkTest.BenchmarkTestId = Assignment.BenchmarkTestId)
	INNER JOIN Assessment on (Assessment.AssessmentId = BenchmarkTest.AssessmentId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
	INNER JOIN AssessmentQuestionStandard on (AssessmentQuestionStandard.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId)
	INNER JOIN StudentAssignmentScore on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId)
	LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
		and AssessmentLearnerAnswer.PersonId = StudentAssignmentScore.StudentPersonId
		and AssessmentLearnerAnswer.IsSubmitted = 1
		and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = StudentAssignmentScore.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
WHERE Assignment.BenchmarkTestId = @benchmarkTestId

--0
SELECT distinct
	BenchmarkTestId,
	CourseScheduledId,
	standardsRatingTableId,
	CourseName
FROM #scoredAnswers
Order by CourseScheduledId

--1
SELECT distinct
	CourseScheduledId,
	AssignmentId,
	AssessmentId,
	EntryDate
FROM #scoredAnswers


--2 ScoredAnswers
SELECT distinct
	AssignmentId,
	BenchmarkTestId,
	AssessmentId,
	AssessmentQuestionId,
	StudentPersonId,
    PointsPossible,
    Score
FROM #scoredAnswers

--3 Standards
Select distinct
	AssessmentQuestion.AssessmentQuestionId,
	StandardSchool.StandardSchoolId,
	StandardSchool.LearningPathwayId,
	StandardSchool.Name,
	StandardSchool.Code,
	StandardSchool.Sequence
From AssessmentQuestionStandard
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentQuestionStandard.AssessmentQuestionId)
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssessmentQuestionStandard.StandardSchoolId)
Where AssessmentQuestion.AssessmentQuestionId in (Select AssessmentQuestionId from #scoredAnswers)

--4 Student Count
SELECT distinct
	CourseScheduled.CourseScheduledId,
	Count(distinct LearnerCourseAssign.PersonId) as StudentCount
FROM CourseScheduled
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId),
	Assignment
	INNER JOIN BenchmarkTest on (BenchmarkTest.BenchmarkTestId = Assignment.BenchmarkTestId)
	INNER JOIN Assessment on (Assessment.AssessmentId = BenchmarkTest.AssessmentId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
	INNER JOIN AssessmentQuestionStandard on (AssessmentQuestionStandard.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId)
	INNER JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
		and AssessmentLearnerAnswer.IsSubmitted = 1
		and AssessmentLearnerAnswer.AssignmentId = Assignment.Assignmentid)
WHERE CourseScheduled.CourseScheduledId in (Select CourseScheduledId from #scoredAnswers)
	and AssessmentLearnerAnswer.PersonId = LearnerCourseAssign.PersonId
	and Assignment.AssignmentId in (Select AssignmentId from #scoredAnswers)
Group by CourseScheduled.CourseScheduledId

--5 Teachers
SELECT distinct
	CourseScheduledId,
	Person.PersonId,
	Person.fname + ' ' + Person.lname as TeacherName
FROM Person
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.Personid = Person.PersonId)
WHERE CourseScheduledId in (select CourseScheduledId from #scoredAnswers)

--6 distinct standards for the entire test.
Select distinct
	StandardSchool.StandardSchoolId,
	StandardSchool.LearningPathwayId,
	StandardSchool.Name,
	StandardSchool.Code,
	StandardSchool.Sequence
From AssessmentQuestionStandard
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentQuestionStandard.AssessmentQuestionId)
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssessmentQuestionStandard.StandardSchoolId)
Where AssessmentQuestion.AssessmentQuestionId in (Select AssessmentQuestionId from #scoredAnswers)

--7 Students (this is specifically for the Student report version and not used in the class version since the testAssign just accumulates the ScoredAnswers for the entire class summary report
SELECT distinct
	TeacherCourseAssign.CourseScheduledId,
	Person.personId as StudentPersonId,
	Person.lname + ', ' + Person.fname as StudentName
FROM Person
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.PersonId = Person.PersonId)
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
WHERE TeacherCourseAssign.CourseScheduledId in (select CourseScheduledId from #scoredAnswers)


DROP TABLE if exists #scoredAnswers

END
GO
/****** Object:  StoredProcedure [dbo].[GetBenchmarkTests]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetBenchmarkTests]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'ssorensen')

--0  Tests
SELECT distinct
	BenchmarkTest.BenchmarkTestId,
	BenchmarkTest.Name,
	BenchmarkTest.Description,
	BenchmarkTest.AssessmentId,
	BenchmarkTest.EntryPersonId,
	Person.fname + ' ' + person.lname as EntryPersonName,
	BenchmarkTest.EntryDate,
	BenchmarkTest.IsPublic,
	BenchmarkTest.PointsPossible,
	BenchmarkTest.Sequence,
	Assessment.IsPublished
INTO #benchmarkTests
FROM BenchmarkTest
	INNER JOIN BenchmarkTestPersonAssign on (BenchmarkTestPersonAssign.BenchmarkTestId = BenchmarkTest.BenchmarkTestId)
	INNER JOIN Person on (Person.PersonId = BenchmarkTest.EntryPersonId)
	INNER JOIN Assessment on (Assessment.AssessmentId = BenchmarkTest.AssessmentId)
WHERE BenchmarkTestPersonAssign.PersonId = @personId

select * from #benchmarkTests

--1 Grade Levels
Select distinct
	BenchmarkTestGradeLevel.BenchmarkTestId,
	GradeLevel.GradeLevelId,
	GradeLevel.Code,
	GradeLevel.Name,
	GradeLevel.Sequence
From BenchmarkTestGradeLevel
	INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = BenchmarkTestGradeLevel.GradeLevelId)
Where BenchmarkTestId in (select BenchmarkTestId from #benchmarkTests)

--2 Assessment Questions
Select distinct
	AssessmentId,
	AssessmentQuestionId
INTO #assessmentQuestions
From AssessmentQuestion
Where AssessmentId in (select AssessmentId from #benchmarkTests)

select * from #assessmentQuestions

--3 Standards used
Select distinct
	AssessmentQuestion.AssessmentId,
	StandardSchool.StandardSchoolId,
	StandardSchool.Name,
	StandardSchool.Code
From AssessmentQuestionStandard
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentQuestionStandard.AssessmentQuestionId)
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssessmentQuestionStandard.StandardSchoolId)
Where AssessmentQuestion.AssessmentQuestionId in (select AssessmentQuestionId from #assessmentQuestions)

--4 Shared to teachers
Select distinct
	BenchmarkTestId,
	Person.PersonId,
	Person.fname + ' ' + Person.lname as PersonName
From BenchmarkTestPersonAssign
	INNER JOIN Person on (Person.PersonId = BenchmarkTestPersonAssign.PersonId)
Where BenchmarkTestId in (select BenchmarkTestId from #benchmarkTests)
	and BenchmarkTestPersonAssign.PersonId != @personId

--5 Rating
Select distinct
	BenchmarkTestId,
	EntryPersonId,
	Rating,
	Comment
From BenchmarkTestVoteRating
Where BenchmarkTestId in (select BenchmarkTestId from #benchmarkTests)

--6 Classes completed
Select distinct
	BenchmarkTestCompleteTable.BenchmarkTestId,
	BenchmarkTestCompleteTable.CourseScheduledId,
	Person.fname + ' ' + person.lname as TeacherName,
	CourseEntry.CourseName
From BenchmarkTestCompleteTable
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = BenchmarkTestCompleteTable.CourseScheduledId)
	INNER JOIN Person on (TeacherCourseAssign.PersonId = Person.PersonId)
	INNER JOIN CourseScheduled on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
Where BenchmarkTestId in (select BenchmarkTestId from #benchmarkTests)

--7 Students completed
Select distinct
	AssessmentId,
	Person.PersonId,
	Person.fname + ' ' + Person.lname as StudentName
From AssessmentLearnerAnswer
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentLearnerAnswer.AssessmentQuestionId)
	INNER JOIN Person on (Person.PersonId = AssessmentLearnerAnswer.PersonId)
Where AssessmentQuestion.AssessmentId in (select AssessmentId from #benchmarkTests)
	and AssessmentLearnerAnswer.isSubmitted = 1

--8 Public copies
Select distinct
	BenchmarkTest.BenchmarkTestId,
	BenchmarkTest.EntryPersonId,
	Person.fname + ' ' + Person.lname as PersonName
From BenchmarkTest
	INNER JOIN Person on (Person.PersonId = BenchmarkTest.EntryPersonId)
Where BenchmarkTestId in (Select DerivedFromBenchmarkTestId from #benchmarkTests)


Drop table if exists #benchmarkTests
Drop table if exists #assessmentQuestions

END
GO
/****** Object:  StoredProcedure [dbo].[GetBenchmarkTestStudentComparison]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetBenchmarkTestStudentComparison]
(@personId AS UniqueIdentifier, @benchmarkTestId as Uniqueidentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @benchmarkTestId as Uniqueidentifier
--Set @personId = (select personid from person where username = 'kdunford')
--SET @benchmarkTestId = '7f0f9b3f-fd76-4233-ac9f-f3c790d6770f'

SELECT distinct
	StudentAssignmentScore.StudentPersonId,
	Assignment.AssignmentId,
	Assignment.BenchmarkTestId,
	Assignment.EntryDate,
	AssessmentLearnerAnswer.AssessmentLearnerAnswerId,
	AssessmentLearnerAnswer.AssessmentQuestionId,
	AssessmentQuestion.AssessmentId,
	AssessmentLearnerAnswer.Score,
	AssessmentQuestion.PointsPossible,
	AssessmentQuestion.Sequence,
	StudentAssignmentScore.CourseScheduledId,
	CourseEntry.CourseName,
	CourseEntry.standardsRatingTableId
INTO #scoredAnswers
FROM Assignment
	INNER JOIN BenchmarkTest on (BenchmarkTest.BenchmarkTestId = Assignment.BenchmarkTestId)
	INNER JOIN Assessment on (Assessment.AssessmentId = BenchmarkTest.AssessmentId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
	INNER JOIN AssessmentQuestionStandard on (AssessmentQuestionStandard.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId)
	INNER JOIN StudentAssignmentScore on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId)
	LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
		and AssessmentLearnerAnswer.PersonId = StudentAssignmentScore.StudentPersonId
		and AssessmentLearnerAnswer.IsSubmitted = 1
		and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = StudentAssignmentScore.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
WHERE Assignment.BenchmarkTestId = @benchmarkTestId

--0  The classes to which the benchmark test is assigned or shared.
SELECT distinct
	BenchmarkTestId,
	CourseScheduledId,
	standardsRatingTableId,
	CourseName
FROM #scoredAnswers
Order by CourseScheduledId

--1 The times that the test was assigned to a class and person (differentiated by the AssignmentId for how many times the test is assigned during the year.
SELECT distinct
	StudentPersonId, --This is different here compared to the class comparison report
	CourseScheduledId,
	AssignmentId,
	AssessmentId,
	EntryDate
FROM #scoredAnswers

--2 ScoredAnswers by student and test assignment
SELECT distinct
	StudentPersonId,
	AssignmentId,
	BenchmarkTestId,
	AssessmentId,
	AssessmentQuestionId,
    PointsPossible,
    Score
FROM #scoredAnswers

--3 Standards
Select distinct
	AssessmentQuestion.AssessmentQuestionId,
	StandardSchool.StandardSchoolId,
	StandardSchool.LearningPathwayId,
	StandardSchool.Name,
	StandardSchool.Code,
	StandardSchool.Sequence
From AssessmentQuestionStandard
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentQuestionStandard.AssessmentQuestionId)
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssessmentQuestionStandard.StandardSchoolId)
Where AssessmentQuestion.AssessmentQuestionId in (Select AssessmentQuestionId from #scoredAnswers)

--4 Teachers
SELECT distinct
	CourseScheduledId,
	Person.PersonId,
	Person.fname + ' ' + Person.lname as TeacherName
FROM Person
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.Personid = Person.PersonId)
WHERE CourseScheduledId in (select CourseScheduledId from #scoredAnswers)

--5 distinct standards for the entire test.
Select distinct
	StandardSchool.StandardSchoolId,
	StandardSchool.LearningPathwayId,
	StandardSchool.Name,
	StandardSchool.Code,
	StandardSchool.Sequence
From AssessmentQuestionStandard
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentQuestionStandard.AssessmentQuestionId)
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssessmentQuestionStandard.StandardSchoolId)
Where AssessmentQuestion.AssessmentQuestionId in (Select AssessmentQuestionId from #scoredAnswers)

--6 Students (this is specifically for the Student report version and not used in the class version since the testAssign just accumulates the ScoredAnswers for the entire class summary report
SELECT distinct
	LearnerCourseAssign.CourseScheduledId,
	Person.personId as StudentPersonId,
	Person.lname + ', ' + Person.fname as StudentName
FROM Person
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.PersonId = Person.PersonId)
WHERE LearnerCourseAssign.CourseScheduledId in (select CourseScheduledId from #scoredAnswers)


DROP TABLE if exists #scoredAnswers

END
GO
/****** Object:  StoredProcedure [dbo].[GetBuildingAndFieldTreeExplorer]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetBuildingAndFieldTreeExplorer]
	@personId uniqueidentifier
AS
BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personId from person where username = 'jef')

--0
SELECT distinct
	BuildingAndField.BuildingAndFieldId,
	Name,
	GpsLink,
	Note,
	CASE WHEN BuildingAndFieldExpanded.Id is null THEN 0 ELSE 1 END as IsExpanded,
	CASE WHEN BuildingAndFieldFrequentMine.PersonId is null THEN 0 ELSE 1 END as IsFrequentMine,
	CASE WHEN SafetyAlertLocation.PersonId is null THEN 0 ELSE 1 END as IsSafetyAlertLocation
into #buildingAndFields
FROM BuildingAndField
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = BuildingAndField.CompanyId)
	LEFT JOIN BuildingAndFieldExpanded on (BuildingAndFieldExpanded.Id = BuildingAndField.BuildingAndFieldId
		and BuildingAndFieldExpanded.PersonId = @personId)
	LEFT JOIN BuildingAndFieldFrequentMine on (BuildingAndFieldFrequentMine.BuildingAndFieldId = BuildingAndField.BuildingAndFieldId
		and BuildingAndFieldFrequentMine.PersonId = @personId)
	LEFT JOIN SafetyAlertLocation on (SafetyAlertLocation.BuildingAndFieldId = BuildingAndField.BuildingAndFieldId
		and SafetyAlertLocation.PersonId = @personId)
WHERE PersonAccessRoleAssign.PersonId = @personId


select * from #buildingAndFields

--1
SELECT distinct
	BuildingAndFieldLevel.BuildingAndFieldId,
	BuildingAndFieldLevel.BuildingAndFieldLevelId,
	Name,
	GpsLink,
	Note,
	CASE WHEN BuildingAndFieldExpanded.Id is null THEN 0 ELSE 1 END as IsExpanded,
	CASE WHEN BuildingAndFieldFrequentMine.PersonId is null THEN 0 ELSE 1 END as IsFrequentMine,
	CASE WHEN SafetyAlertLocation.PersonId is null THEN 0 ELSE 1 END as IsSafetyAlertLocation
FROM BuildingAndFieldLevel
	LEFT JOIN BuildingAndFieldExpanded on (BuildingAndFieldExpanded.Id = BuildingAndFieldLevel.BuildingAndFieldLevelId
		and BuildingAndFieldExpanded.PersonId = @personId)
	LEFT JOIN BuildingAndFieldFrequentMine on (BuildingAndFieldFrequentMine.BuildingAndFieldLevelId = BuildingAndFieldLevel.BuildingAndFieldLevelId
		and BuildingAndFieldFrequentMine.PersonId = @personId)
	LEFT JOIN SafetyAlertLocation on (SafetyAlertLocation.BuildingAndFieldLevelId = BuildingAndFieldLevel.BuildingAndFieldLevelId
		and SafetyAlertLocation.PersonId = @personId)
WHERE BuildingAndFieldLevel.BuildingAndFieldId in (select BuildingAndFieldId from #buildingAndFields)

--2
SELECT distinct
	LevelEntrance.LevelEntranceId,
	LevelEntrance.BuildingAndFieldId,
	LevelEntrance.BuildingAndFieldLevelId,
	LevelEntrance.Name,
	MapDirection.MapDirectionId,
	MapDirection.Name as MapDirectionName,
	IsLockedDuringDay,
	GpsLink,
	Note,
	CASE WHEN BuildingAndFieldExpanded.Id is null THEN 0 ELSE 1 END as IsExpanded,
	CASE WHEN BuildingAndFieldFrequentMine.PersonId is null THEN 0 ELSE 1 END as IsFrequentMine,
	CASE WHEN SafetyAlertLocation.PersonId is null THEN 0 ELSE 1 END as IsSafetyAlertLocation
FROM LevelEntrance
	LEFT JOIN MapDirection on (MapDirection.MapDirectionId = LevelEntrance.MapDirectionId)
	LEFT JOIN BuildingAndFieldExpanded on (BuildingAndFieldExpanded.Id = LevelEntrance.LevelEntranceId
		and BuildingAndFieldExpanded.PersonId = @personId)
	LEFT JOIN BuildingAndFieldFrequentMine on (BuildingAndFieldFrequentMine.LevelEntranceId = LevelEntrance.LevelEntranceId
		and BuildingAndFieldFrequentMine.PersonId = @personId)
	LEFT JOIN SafetyAlertLocation on (SafetyAlertLocation.LevelEntranceId = LevelEntrance.LevelEntranceId
		and SafetyAlertLocation.PersonId = @personId)
WHERE LevelEntrance.BuildingAndFieldId in (select BuildingAndFieldId from #buildingAndFields)

--3
SELECT distinct
	Room.RoomId,
	Room.LevelEntranceId,
	Room.BuildingAndFieldId,
	Room.BuildingAndFieldLevelId,
	Room.Name,
	LevelEntrance.Name as LevelEntranceName,
	LevelEntranceMapDirection.Name as LevelEntranceMapDirectionName,
	RoomMapDirection.MapDirectionId,
	RoomMapDirection.Name as MapDirectionName,
	Room.GpsLink,
	OccupantCapacity,
	NumberOfDoorsAwayFromEntrance,
	SideOfHallwayFromEntrance,
	SurveillanceLocationMapDirection.Name as SurveillanceLocationMapDirectionName,
	Room.Note,
	CASE WHEN BuildingAndFieldExpanded.Id is null THEN 0 ELSE 1 END as IsExpanded,
	CASE WHEN BuildingAndFieldFrequentMine.PersonId is null THEN 0 ELSE 1 END as IsFrequentMine,
	CASE WHEN SafetyAlertLocation.PersonId is null THEN 0 ELSE 1 END as IsSafetyAlertLocation
into #rooms
FROM Room
	INNER JOIN BuildingAndFieldLevel on (BuildingAndFieldLevel.BuildingAndFieldLevelId = Room.BuildingAndFieldLevelId)
	LEFT JOIN LevelEntrance on (LevelEntrance.LevelEntranceId = Room.LevelEntranceId)
	LEFT JOIN MapDirection as LevelEntranceMapDirection on (LevelEntranceMapDirection.MapDirectionId = LevelEntrance.MapDirectionId)
	LEFT JOIN MapDirection as RoomMapDirection on (RoomMapDirection.MapDirectionId = Room.MapDirectionId)
	LEFT JOIN SurveillanceLocation on (SurveillanceLocation.RoomId = Room.RoomId)
	LEFT JOIN MapDirection as SurveillanceLocationMapDirection on (SurveillanceLocationMapDirection.MapDirectionId = SurveillanceLocation.MapDirectionId)
	LEFT JOIN BuildingAndFieldExpanded on (BuildingAndFieldExpanded.Id = Room.RoomId
		and BuildingAndFieldExpanded.PersonId = @personId)
	LEFT JOIN BuildingAndFieldFrequentMine on (BuildingAndFieldFrequentMine.RoomId = Room.RoomId
		and BuildingAndFieldFrequentMine.PersonId = @personId)
	LEFT JOIN SafetyAlertLocation on (SafetyAlertLocation.RoomId = Room.RoomId
		and SafetyAlertLocation.PersonId = @personId)
WHERE Room.BuildingAndFieldId in (select BuildingAndFieldId from #buildingAndFields)

select * from #rooms

--4
SELECT distinct
	RoomId,
	Person.PersonId,
	Person.Fname + ' ' + Person.Lname as PersonName
FROM RoomResponsiblePerson
	INNER JOIN Person on (Person.PersonId = RoomResponsiblePerson.PersonId)
WHERE RoomId in (select RoomId from #rooms)


drop table if exists #buildingAndFields
drop table if exists #rooms

END
GO
/****** Object:  StoredProcedure [dbo].[GetCalendarEvents]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCalendarEvents]
	(@personId AS UniqueIdentifier,
	@fromDate AS DateTime,
	@toDate AS DateTime)
 AS

 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @fromDate as DateTime
--Declare @toDate as DateTime
--Set @personId = '91E033D9-6D29-4A4C-A767-29D499A6D11D' --(select personid from person where username = 'jef')
--Set @fromDate = '2019-07-01 00:00:00'
--Set @toDate = '2020-07-01 23:59:59'

Declare @accessRoleName as nvarchar(25)
Declare @fromDayOfWeek as nvarchar(10)

Set @fromDayOfWeek = (SELECT top 1 Lower(DATENAME(weekday, @fromDate)));

Declare @teacherIdList as nvarchar(4000)
Set @teacherIdList = (select top 1 TeacherIdList from PersonConfigCalendar where PersonId = @personId)
if @teacherIdList = '' or @teacherIdList is null
	Set @teacherIdList= '00000000-0000-0000-0000-000000000000'

Declare @classIdList as nvarchar(4000)
Set @classIdList = (select top 1 ClassIdList from PersonConfigCalendar where PersonId = @personId)
if @classIdList = '' or @classIdList is null
	Set @classIdList = '00000000-0000-0000-0000-000000000000'

Declare @studentIdList as nvarchar(4000)
Set @studentIdList = (select top 1 StudentIdList from PersonConfigCalendar where PersonId = @personId)
if @studentIdList = '' or @studentIdList is null
	Set @studentIdList = '00000000-0000-0000-0000-000000000000'

Declare @homeworkClassIdList as nvarchar(4000)
Set @homeworkClassIdList = (select top 1 HomeworkClassIdList from PersonConfigCalendar where PersonId = @personId)
if @homeworkClassIdList = '' or @homeworkClassIdList is null
	Set @homeworkClassIdList = '00000000-0000-0000-0000-000000000000'

Set @accessRoleName = (Select top 1 AccessRoleLearner.Name
	From PersonAccessRoleAssign
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
	Where PersonAccessRoleAssign.PersonId = @personId);

WITH T(date)
AS
(
SELECT
	@fromDate
UNION ALL
SELECT DateAdd(day,1,T.date) FROM T WHERE T.date < @toDate
)
SELECT date INTO #dateList FROM T OPTION (MAXRECURSION 32767);

--0 Personal
--1 School
--2 Teachers' classes
--3 Students' classes
--4 Classes
--5 Homework list by class

--0 Personal
SELECT distinct
	CalendarEvent.CalendarEventId,
	'personal' as CalendarEventType,
	CalendarEvent.PersonId,
	CalendarEvent.EventName,
	CalendarEvent.Note,
	CalendarEvent.FromDate,
	CalendarEvent.ToDate,
	CalendarEvent.StartTime,
	CalendarEvent.Duration,
	CalendarEvent.IsAllDay
FROM CalendarEvent
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CalendarEvent.CompanyId)
	INNER JOIN PersonConfigCalendar on (PersonAccessRoleAssign.PersonID = PersonConfigCalendar.PersonId
		and PersonConfigCalendar.Personal = 1)
WHERE PersonConfigCalendar.PersonId = @personId
	and CalendarEvent.FromDate >= @fromDate and CalendarEvent.ToDate <= @toDate
	and CalendarEvent.CalendarEventType = 'personal'
	and CalendarEvent.personId = @personId

--1 School
SELECT distinct
	CalendarEvent.CalendarEventId,
	'school' as CalendarEventType,
	CalendarEvent.PersonId,
	CalendarEvent.EventName,
	CalendarEvent.Note,
	CalendarEvent.FromDate,
	CalendarEvent.ToDate,
	CalendarEvent.StartTime,
	CalendarEvent.Duration,
	CalendarEvent.IsAllDay
FROM CalendarEvent
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CalendarEvent.CompanyId)
	INNER JOIN PersonConfigCalendar on (PersonAccessRoleAssign.PersonID = PersonConfigCalendar.PersonId
		and PersonConfigCalendar.School = 1)
WHERE PersonConfigCalendar.PersonId = @personId
	and CalendarEvent.FromDate >= @fromDate and CalendarEvent.ToDate <= @toDate
	and CalendarEvent.CalendarEventType = 'school'

--2 Teachers' classes
SELECT distinct
	null as CalendarEventId,
	'teacher' as CalendarEventType,
	Person.PersonId,
	'(' + Person.Lname + ') ' + CourseEntry.CourseName as EventName,
	'Period: ' + ClassPeriod.PeriodNumber as Note,
	#dateList.date as FromDate,
	#dateList.date as ToDate,
	ClassPeriod.StartTime,
	DateDiff(minute, ClassPeriod.StartTime, ClassPeriod.EndTime) as Duration,
	0 as IsAllDay,
	CourseScheduled.CourseScheduledId
FROM CourseEntry
	INNER JOIN CourseScheduled on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = CourseScheduled.SchoolYearId
		and PersonConfigure.IntervalId = CourseIntervalAssign.IntervalId
		and PersonConfigure.PersonId = @personId)
	INNER JOIN DaysScheduled on (DaysScheduled.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
	INNER JOIN Person on (Person.PersonId = TeacherCourseAssign.PersonId)
	INNER JOIN #dateList on (DaysScheduled.DayOfTheWeek = Lower(DATENAME(weekday, date))
		and date >= CourseScheduled.FromDate and date <= CourseScheduled.ToDate)
WHERE TeacherCourseAssign.PersonId in (select Convert(uniqueidentifier, value) from STRING_SPLIT(@teacherIdList, ','))


--3 Students' classes
SELECT distinct
	null as CalendarEventId,
	'student' as CalendarEventType,
	null as PersonId,
	'(' + Person.Fname + ') ' + CourseEntry.CourseName as EventName,
	'Period: ' + ClassPeriod.PeriodNumber as Note,
	#dateList.date as FromDate,
	#dateList.date as ToDate,
	ClassPeriod.StartTime,
	DateDiff(minute, ClassPeriod.StartTime, ClassPeriod.EndTime) as Duration,
	0 as IsAllDay,
	CourseScheduled.CourseScheduledId,
	Person.Personid as StudentPersonId
FROM CourseEntry
	INNER JOIN CourseScheduled on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = CourseScheduled.SchoolYearId
		and PersonConfigure.IntervalId = CourseIntervalAssign.IntervalId
		and PersonConfigure.PersonId = @personId)
	INNER JOIN DaysScheduled on (DaysScheduled.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
	INNER JOIN Person on (Person.PersonId = LearnerCourseAssign.PersonId)
	INNER JOIN #dateList on (DaysScheduled.DayOfTheWeek = Lower(DATENAME(weekday, date))
		and date >= CourseScheduled.FromDate and date <= CourseScheduled.ToDate)
WHERE LearnerCourseAssign.PersonId in (select Convert(uniqueidentifier, value) from STRING_SPLIT(@studentIdList, ','))

--4 Classes
SELECT distinct
	null as CalendarEventId,
	'course' as CalendarEventType,
	@personId as PersonId,
	CourseEntry.CourseName as EventName,
	'Period: ' + ClassPeriod.PeriodNumber as Note,
	#dateList.date as FromDate,
	#dateList.date as ToDate,
	ClassPeriod.StartTime,
	DateDiff(minute, ClassPeriod.StartTime, ClassPeriod.EndTime) as Duration,
	0 as IsAllDay,
	CourseScheduled.CourseScheduledId
FROM CourseEntry
	INNER JOIN CourseScheduled on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = CourseScheduled.SchoolYearId
		and PersonConfigure.IntervalId = CourseIntervalAssign.IntervalId
		and PersonConfigure.PersonId = @personId)
	INNER JOIN DaysScheduled on (DaysScheduled.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
	INNER JOIN #dateList on (DaysScheduled.DayOfTheWeek = Lower(DATENAME(weekday, date))
		and date >= CourseScheduled.FromDate and date <= CourseScheduled.ToDate)
WHERE CourseScheduled.CourseScheduledId in (select Convert(uniqueidentifier, value) from STRING_SPLIT(@classIdList, ','))


--5 Homework list by class
SELECT distinct
	null as CalendarEventId,
	'homework' as CalendarEventType,
	null as PersonId,
	Assignment.Title + ' - ' + CourseEntry.CourseName as EventName,
	'Period: ' + ClassPeriod.PeriodNumber as Note,
	Assignment.DueDate as FromDate,
	Assignment.DueDate as ToDate,
	ClassPeriod.StartTime,
	DateDiff(minute, ClassPeriod.StartTime, ClassPeriod.EndTime) as Duration,
	0 as IsAllDay,
	CourseScheduled.CourseScheduledId,
	Assignment.AssignmentId
FROM CourseEntry
	INNER JOIN CourseScheduled on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	INNER JOIN DaysScheduled on (DaysScheduled.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
	INNER JOIN Assignment on (Assignment.CourseEntryId = CourseEntry.CourseEntryId)
WHERE CourseScheduled.CourseScheduledId in (select Convert(uniqueidentifier, value) from STRING_SPLIT(@homeworkClassIdList, ','))
	and Assignment.DueDate in (select date from #dateList)


Drop Table if exists #dateList

END
GO
/****** Object:  StoredProcedure [dbo].[GetCalendarEventTypes]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCalendarEventTypes]
	(@personId AS UniqueIdentifier,
	@fromDate AS DateTime,
	@toDate AS DateTime)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @fromDate as DateTime
--Declare @toDate as DateTime
--Set @personId = (select personid from person where username = 'tiara')
--Set @fromDate = '2019-05-26'
--Set @toDate = '2019-06-01'

Declare @accessRoleName as nvarchar(25)

Select top 1 AccessRoleLearner.Name
into #accessRole
From PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
Where PersonAccessRoleAssign.PersonId = @personId

Set @accessRoleName = (select Name from #accessRole);

if @accessRoleName = 'Learner'
	SELECT distinct
		CourseScheduled.CourseScheduledId,
		CourseEntry.CourseName,
		convert(nvarchar(10), CourseScheduled.CourseScheduledId) as CalendarEventType
	FROM CourseEntry
		INNER JOIN CourseScheduled on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
		INNER JOIN Assignment on (Assignment.CourseEntryId = CourseEntry.CourseEntryId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN Person as Facilitator on (facilitator.PersonID = TeacherCourseAssign.PersonId)
		INNER JOIN LearnerCourseAssign on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = LearnerCourseAssign.PersonId)
	WHERE (CourseEntry.IsInactive is null or CourseEntry.IsInactive != 1)
		and LearnerCourseAssign.PersonId = @personId
		and Assignment.DueDate >= @fromDate and Assignment.DueDate <= @toDate

	UNION

	SELECT distinct
		null as CourseScheduledId,
		null as CourseName,
		'school' as CalendarEventType

	UNION

	SELECT distinct
		null as CourseScheduledId,
		null as CourseName,
		'personal' as CalendarEventType

else if @accessRoleName = 'Facilitator'
	SELECT distinct
		CourseScheduled.CourseScheduledId,
		CourseEntry.CourseName,
		convert(nvarchar(10), CourseScheduled.CourseScheduledId) as CalendarEventType
	FROM CourseEntry
		INNER JOIN CourseScheduled on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
		INNER JOIN LearnerCourseAssign on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN TeacherCourseAssign on (CourseScheduled.CourseScheduledId = TeacherCourseAssign.CourseScheduledId)
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = TeacherCourseAssign.PersonId
			and PersonConfigure.SchoolYearId = CourseScheduled.SchoolYearId)
		INNER JOIN CalendarEventRelatedTo on (CalendarEventRelatedTo.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN CalendarEvent on (CalendarEvent.CalendarEventId = CalendarEventRelatedTo.CalendarEventId)
		INNER JOIN CalendarEventPersonConfig on (CalendarEventPersonConfig.PersonId = LearnerCourseAssign.PersonId
			and CalendarEventPersonConfig.CalendarEventType = CalendarEvent.CalendarEventType)
	WHERE (CourseEntry.IsInactive is null or CourseEntry.IsInactive != 1)
		and TeacherCourseAssign.PersonId = @personId
		and CalendarEvent.FromDate >= @fromDate and CalendarEvent.ToDate <= @toDate

	UNION

	SELECT distinct
		null as CourseScheduledId,
		null as CourseName,
		'school' as CalendarEventType

	UNION

	SELECT distinct
		null as CourseScheduledId,
		null as CourseName,
		'personal' as CalendarEventType

else

	SELECT distinct
		null as CourseScheduledId,
		null as CourseName,
		'school' as CalendarEventType

	UNION

	SELECT distinct
		null as CourseScheduledId,
		null as CourseName,
		'personal' as CalendarEventType

--End of the conditions and union queries.

DROP TABLE IF EXISTS #accessRole

END
GO
/****** Object:  StoredProcedure [dbo].[GetCarpool]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCarpool]
	( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'kqd3@yahoo.com')

--0
SELECT
	CarpoolAreaId,
	CarpoolArea.CompanyId,
	AreaName,
	Description,
	EntryPersonId,
	EntryDate
INTO #carpoolAreas
FROM PersonAccessRoleAssign
	INNER JOIN CarpoolArea on (PersonAccessRoleAssign.CompanyId = CarpoolArea.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

select * from #carpoolAreas

--1
SELECT
	CarpoolRequest.CarpoolRequestId,
	CarpoolArea.CarpoolAreaId,
	CarpoolRequest.CarpoolId,
	CarpoolRequestResponse.ResponseType,
	CarpoolRequestResponse.CarpoolRequestResponseId,
	FromPersonId,
	CarpoolRequest.SeatsAvailable,
	CarpoolRequest.SeatsNeeded,
	CarpoolRequest.Comment,
	CarpoolRequest.EntryDate,
	Person.Fname + ' ' + Person.Lname as PersonName,
	Person.City,
	Person.Address1 as StreetAddress,
	UsState.Abbreviation as UsStateName,
	CarpoolArea.AreaName,
	CarpoolArea.Description
into #carpoolRequest
FROM CarpoolRequest
	INNER JOIN Person on (Person.PersonId = CarpoolRequest.FromPersonId)
	INNER JOIN CarpoolArea on (CarpoolArea.CarpoolAreaId = CarpoolRequest.CarpoolAreaId)
	LEFT JOIN CarpoolRequestResponse on (CarpoolRequestResponse.CarpoolRequestId = CarpoolRequest.CarpoolRequestId
		and CarpoolRequestResponse.ResponsePersonId = @personId)
	LEFT JOIN UsState on (Person.USStateId = UsState.USStateId)
WHERE CarpoolRequest.carpoolAreaId in (Select carpoolAreaId from #carpoolAreas)

select * from #carpoolRequest

--2
SELECT
	CarpoolRequestId,
	DayOfWeek,
	CarpoolTimeId,
	GeneralDropOffOrPickUp
FROM CarpoolRequestCanDoDay
	INNER JOIN DaysOfWeek on (DaysOfWeek.name = CarpoolRequestCanDoDay.DayOfWeek)
WHERE CarpoolRequestId in (Select CarpoolRequestId from #carpoolRequest)
Order by DaysOfWeek.Sequence

--3
SELECT
	CarpoolRequestWatch.PersonId,
	CarpoolRequestWatch.CarpoolAreaId,
	AreaName,
	Description,
	SendEmail
FROM CarpoolRequestWatch
	INNER JOIN CarpoolArea on (CarpoolArea.CarpoolAreaId = CarpoolRequestWatch.CarpoolAreaId)
WHERE CarpoolRequestWatch.PersonId = @personId

--4
SELECT distinct
    Carpool.CarpoolId,
    Name,
	OwnerPerson.Fname + ' ' + OwnerPerson.Lname as PersonName,
    Destination,
    Carpool.Comment,
    Carpool.EntryPersonId,
    Carpool.EntryDate
INTO #carpools
FROM Carpool
	INNER JOIN CarpoolMember on (CarpoolMember.CarpoolId = Carpool.CarpoolId)
	INNER JOIN Person as OwnerPerson on (OwnerPerson.PersonId = Carpool.EntryPersonId)
WHERE CarpoolMember.PersonId = @personId

select * from #carpools

--5
SELECT distinct
	CarpoolId,
	CarpoolTimeId,
	DropOffOrPickUp,
	Time,
	FromDate,
	ToDate
FROM CarpoolTime
WHERE CarpoolTime.CarpoolId in (select CarpoolId from #carpools)

--6
SELECT
    CarpoolTime.CarpoolId,
    CarpoolTime.CarpoolTimeId,
    DayOfWeek
FROM CarpoolTimeDayOfWeek
	INNER JOIN DaysOfWeek on (DaysOfWeek.name = CarpoolTimeDayOfWeek.DayOfWeek)
	INNER JOIN CarpoolTime on (CarpoolTime.CarpoolTimeId = CarpoolTimeDayOfWeek.CarpoolTimeId)
WHERE CarpoolTime.CarpoolId in (Select CarpoolId from #carpools)

--7
SELECT
    CarpoolRequestId,
    Announcement.AnnouncementId
FROM Announcement
	INNER JOIN AnnouncementPersonAssign on (AnnouncementPersonAssign.AnnouncementId = Announcement.AnnouncementId)
WHERE CarpoolRequestId in (Select CarpoolRequestId from #carpoolRequest)
	and (Announcement.EntryPersonId = @personId or AnnouncementPersonAssign.ToPersonId = @personId)

--8
SELECT
	CarpoolRequestResponse.CarpoolRequestResponseId,
	CarpoolRequestId,
	InviteCarpoolId,
	ResponseType,
	AnswerType,
	ResponsePersonId,
	SeatsAvailable,
	SeatsNeeded,
	CarpoolRequestResponse.Comment,
	CarpoolRequestResponse.EntryDate,
	Person.Fname + ' ' + Person.Lname as PersonName
into #carpoolRequestResponse
FROM CarpoolRequestResponse
	INNER JOIN Person on (Person.PersonId = CarpoolRequestResponse.ResponsePersonId)
WHERE (CarpoolRequestResponse.CarpoolRequestId in (Select CarpoolRequestId from #carpoolRequest)
			or ResponsePersonId = @personId)

select * from #carpoolRequestResponse

--9
SELECT
	CarpoolRequestResponseId,
	DayOfWeek,
	CarpoolTimeId,
	GeneralDropOffOrPickUp
FROM CarpoolRequestResponseCanDoDay
	INNER JOIN DaysOfWeek on (DaysOfWeek.name = CarpoolRequestResponseCanDoDay.DayOfWeek)
WHERE CarpoolRequestResponseId in (Select CarpoolRequestResponseId from #carpoolRequestResponse)
Order by DaysOfWeek.Sequence

--10
SELECT
	CarpoolMember.CarpoolId,
	CarpoolMember.CarpoolMemberId,
	MemberPerson.PersonId,
	MemberPerson.fName as FirstName,
	MemberPerson.lName as LastName,
	MemberPerson.Address1 as StreetAddress,
	MemberPerson.City,
	UsState.Abbreviation as UsStateName
INTO #carpoolMembers
FROM CarpoolMember
	INNER JOIN Person as MemberPerson on (MemberPerson.PersonId = CarpoolMember.PersonId)
	LEFT JOIN UsState on (UsState.UsStateId = MemberPerson.UsStateId)
WHERE CarpoolId in (Select CarpoolId from #carpools)

select * from #carpoolMembers

--11
SELECT
	CarpoolMember.CarpoolId,
	CarpoolMember.CarpoolMemberId,
	CarpoolMember.PersonId as MemberPersonId,
	CarpoolMemberStudent.CarpoolMemberStudentId,
	CarpoolMemberStudent.IsIncluded,
	StudentPerson.PersonId as StudentPersonId,
	StudentPerson.fName as FirstName,
	StudentPerson.lName as LastName,
	CASE WHEN CarpoolMemberStudentId is not null THEN 1 ELSE 0 END as InCarpool
FROM RegistrationTable
	INNER JOIN CarpoolMember on (CarpoolMember.PersonId = RegistrationTable.PersonId)
	INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
	LEFT JOIN CarpoolMemberStudent on (CarpoolMemberStudent.CarpoolMemberId = CarpoolMember.CarpoolMemberId
		and RegistrationStudent.StudentPersonId = CarpoolMemberStudent.StudentPersonId)
	INNER JOIN Person as StudentPerson on (StudentPerson.Personid = RegistrationStudent.StudentPersonId)
	INNER JOIN PersonConfigure on (PersonConfigure.Personid = RegistrationTable.PersonId
		and PersonConfigure.SchoolYearId = RegistrationTable.SchoolYearId)
WHERE CarpoolId in (Select CarpoolId from #carpools)
	--and carpoolMember.PersonId = @personId
--UNION
--SELECT
--	CarpoolMember.CarpoolId,
--	CarpoolMember.CarpoolMemberId,
--	CarpoolMemberStudent.CarpoolMemberStudentId,
--	StudentPerson.PersonId as StudentPersonId,
--	StudentPerson.fName as FirstName,
--	StudentPerson.lName as LastName,
--	CASE WHEN CarpoolMemberStudentId is not null THEN 1 ELSE 0 END as InCarpool
--FROM RegistrationTable
--	INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationTable.RegistrationTableId
--		and RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN')
--	INNER JOIN CarpoolMember on (CarpoolMember.PersonId = RegistrationTable.PersonId)
--	INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
--	LEFT JOIN CarpoolMemberStudent on (CarpoolMemberStudent.CarpoolMemberId = CarpoolMember.CarpoolMemberId
--		and RegistrationStudent.StudentPersonId = CarpoolMemberStudent.StudentPersonId)
--	INNER JOIN Person as StudentPerson on (StudentPerson.Personid = RegistrationStudent.StudentPersonId)
--WHERE CarpoolId in (Select CarpoolId from #carpools)
--	and carpoolMember.PersonId = @personId

--12
SELECT
	CarpoolMember.CarpoolMemberId,
	DayOfWeek,
	CarpoolMemberCanDoDay.CarpoolTimeId
FROM CarpoolMember
	INNER JOIN CarpoolMemberCanDoDay on (CarpoolMemberCanDoDay.CarpoolMemberId = CarpoolMember.CarpoolMemberId)
	INNER JOIN DaysOfWeek on (DaysOfWeek.name = CarpoolMemberCanDoDay.DayOfWeek)
WHERE CarpoolMember.PersonId = @personId
Order by DaysOfWeek.Sequence

--13
SELECT
    CarpoolTime.CarpoolId,
    CarpoolTime.CarpoolTimeId,
    DriverPersonId,
	Person.Fname + ' ' + Person.Lname as DriverName,
    DriverDate,
    CarpoolAssignDriver.Comment,
    ArrivalNotice
FROM CarpoolAssignDriver
	INNER JOIN Person on (Person.PersonId = CarpoolAssignDriver.DriverPersonId)
	INNER JOIN CarpoolTime on (CarpoolTime.CarpoolTimeId = CarpoolAssignDriver.CarpoolTimeId)
WHERE CarpoolTime.CarpoolId in (Select CarpoolId from #carpools)


--14   CarpoolTimeStudentAssign
SELECT
	CarpoolId,
	CarpoolTimeId,
	CarpoolTimeStudentAssign.StudentPersonId,
	DropOffOrPickUp,
	DayOfWeek,
	Person.Fname as FirstName,
	Person.Lname as LastName
FROM CarpoolTimeStudentAssign
	INNER JOIN Person on (Person.personId = CarpoolTimeStudentAssign.StudentPersonId)
	INNER JOIN CarpoolMemberStudent on (CarpoolMemberStudent.StudentPersonId = CarpoolTimeStudentAssign.StudentPersonId
		and CarpoolMemberStudent.isIncluded = 1)
WHERE CarpoolId in (Select CarpoolId from #carpools)

--15 select * from CarpoolTimeStudentAssignDayChange
SELECT
	CarpoolTimeStudentAssignDayChange.CarpoolId,
	CarpoolTimeStudentAssignDayChange.CarpoolTimeId,
	CarpoolTimeStudentAssignDayChange.StudentPersonId,
	CarpoolTimeStudentAssignDayChange.DropOffOrPickUp,
	CarpoolTimeStudentAssignDayChange.DayOfWeek,
	CarpoolTimeStudentAssignDayChange.DateChange,
	Person.Fname as FirstName,
	Person.Lname as LastName
FROM CarpoolTimeStudentAssignDayChange
	INNER JOIN Person on (Person.personId = CarpoolTimeStudentAssignDayChange.StudentPersonId)
	LEFT JOIN CarpoolTime on (CarpoolTime.CarpoolTimeId = CarpoolTimeStudentAssignDayChange.CarpoolTimeId)
	INNER JOIN CarpoolMemberStudent on (CarpoolMemberStudent.StudentPersonId = CarpoolTimeStudentAssignDayChange.StudentPersonId)
WHERE CarpoolMemberStudent.CarpoolMemberId in (select carpoolmemberId from #carpoolMembers)


--16 Carpool Request DIRECT invitation
SELECT
    CarpoolRequestDirectId,
    CarpoolId,
    FromPersonId,
    FromPerson.fname + ' ' + FromPerson.lname as FromPersonName,
	FromPerson.City as FromCity,
	FromPerson.Address1 as FromStreetAddress,
	FromUsState.Abbreviation as FromUsStateName,
    ToPersonId,
    ToPerson.fname + ' ' + ToPerson.lname as ToPersonName,
	ToPerson.City as ToCity,
	ToPerson.Address1 as ToStreetAddress,
	ToUsState.Abbreviation as ToUsStateName,
    ToEmailAddress,
    AcceptOrDecline,
    CarpoolRequestDirect.Comment,
    ResponseDate,
    CarpoolRequestDirect.EntryDate
INTO #carpoolRequestDirect
FROM CarpoolRequestDirect
	INNER JOIN Person as FromPerson on (FromPerson.PersonId = CarpoolRequestDirect.FromPersonId)
	INNER JOIN Person as ToPerson on (ToPerson.PersonId = CarpoolRequestDirect.ToPersonId)
	LEFT JOIN UsState as FromUsState on (FromPerson.USStateId = FromUsState.USStateId)
	LEFT JOIN UsState as ToUsState on (ToPerson.USStateId = ToUsState.USStateId)
WHERE CarpoolRequestDirect.FromPersonId = @personId or CarpoolRequestDirect.ToPersonId = @personId

select * from #carpoolRequestDirect

--17
SELECT distinct
	CarpoolId,
	CarpoolTimeId,
	DropOffOrPickUp,
	Time,
	FromDate,
	ToDate
FROM CarpoolTime
WHERE CarpoolTime.CarpoolId in (select CarpoolId from #carpoolRequestDirect)

--18
SELECT
    CarpoolTime.CarpoolId,
    CarpoolTime.CarpoolTimeId,
    DayOfWeek
FROM CarpoolTimeDayOfWeek
	INNER JOIN DaysOfWeek on (DaysOfWeek.name = CarpoolTimeDayOfWeek.DayOfWeek)
	INNER JOIN CarpoolTime on (CarpoolTime.CarpoolTimeId = CarpoolTimeDayOfWeek.CarpoolTimeId)
WHERE CarpoolTime.CarpoolId in (Select CarpoolId from #carpoolRequestDirect)

--19
SELECT distinct
	CarpoolId,
	CarpoolTimeId,
	DropOffOrPickUp,
	Time,
	FromDate,
	ToDate
FROM CarpoolTime
WHERE CarpoolTime.CarpoolId in (select InviteCarpoolId from #carpoolRequestResponse)

--20
SELECT
    CarpoolTime.CarpoolId,
    CarpoolTime.CarpoolTimeId,
    DayOfWeek
FROM CarpoolTimeDayOfWeek
	INNER JOIN DaysOfWeek on (DaysOfWeek.name = CarpoolTimeDayOfWeek.DayOfWeek)
	INNER JOIN CarpoolTime on (CarpoolTime.CarpoolTimeId = CarpoolTimeDayOfWeek.CarpoolTimeId)
WHERE CarpoolTime.CarpoolId in (Select InviteCarpoolId from #carpoolRequestResponse)


Drop table if exists #carpoolAreas
Drop table if exists #carpoolRequest
Drop table if exists #carpools
Drop table if exists #carpoolRequestResponse
Drop table if exists #carpoolMembers
Drop table if exists #carpoolRequestDirect

END
GO
/****** Object:  StoredProcedure [dbo].[getCorrectedAssessment]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[getCorrectedAssessment]
	(@personId AS UniqueIdentifier,
	 @studentPersonId AS UniqueIdentifier,
	 @assignmentId AS UniqueIdentifier,
	 @assessmentId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId AS UniqueIdentifier
--Declare @assessmentId as UniqueIdentifier
--Declare @assignmentId as UniqueIdentifier
--Set @personId = '7c843b13-f6df-440b-8bcd-ad7faa8991c3' --(select personid from person where username = 'jef')
--Set @studentPersonId = '7c843b13-f6df-440b-8bcd-ad7faa8991c3' --(select personId from person where username = 'GraysonTA')
--Set @assessmentId  = '7059b51a-54a2-4712-95bf-c1a735a40210'
--Set @assignmentId  = '75a55b7d-49cc-4d17-8d2a-cc6717a0b596'

--1
SELECT
    AssessmentLearnerAnswer.AssessmentLearnerAnswerId,
    AssessmentLearnerAnswer.PersonId as StudentPersonId,
    AssessmentLearnerAnswer.AssessmentQuestionId,
    AssessmentLearnerAnswer.LearnerAnswer,
    AssessmentQuestion.CorrectAnswer,
    AssessmentLearnerAnswer.FileUploadId,
    AssessmentLearnerAnswer.PendingCorrection,
    AssessmentLearnerAnswer.Score,
    AssessmentLearnerAnswer.TeacherEssayResponse,
    AssessmentLearnerAnswer.EssayCorrectionWorkId,
    AssessmentLearnerAnswer.IsCorrect,
    AssessmentLearnerAnswer.EntryDate,
    AssessmentQuestion.AssessmentId,
    AssessmentQuestion.QuestionTypeId,
    AssessmentQuestion.QuestionText,
    AssessmentQuestion.PointsPossible,
    AssessmentQuestion.Sequence,
    AssessmentLearnerAnswer.IsSubmitted
FROM AssessmentQuestion
	LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
		and AssessmentLearnerAnswer.PersonId = @studentPersonId
		and AssessmentLearnerAnswer.AssignmentId = @assignmentId)
WHERE AssessmentQuestion.AssessmentId = @assessmentId

--1
SELECT distinct
	Person.PersonId,
	Person.fname + ' ' + Person.lname as StudentName
FROM Person
	INNER JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.PersonId = Person.PersonId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentLearnerAnswer.AssessmentQuestionId)
WHERE AssessmentQuestion.AssessmentId = @assessmentId
	and AssessmentLearnerAnswer.IsSubmitted = 1

--2
Select distinct
	AssessmentQuestion.AssessmentQuestionId,
	StandardSchool.StandardSchoolId,
	StandardSchool.LearningPathwayId,
	StandardSchool.Name,
	StandardSchool.Code
From AssessmentQuestionStandard
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentQuestionStandard.AssessmentQuestionId)
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssessmentQuestionStandard.StandardSchoolId)
Where AssessmentQuestion.AssessmentId = @assessmentId

--3
SELECT distinct
	Assignment.AssessmentId,
	Assignment.CourseEntryId,
	Assignment.AssignmentId,
	Assignment.Title as AssignmentTitle,
	CourseEntry.CourseName,
	CourseEntry.GradingType,
	CourseEntry.StandardsRatingTableId,
	Assignment.totalPoints
FROM Assignment
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = Assignment.CourseEntryId)
WHERE Assignment.AssessmentId = @assessmentId

UNION

SELECT distinct
	BenchmarkTest.AssessmentId,
	Assignment.CourseEntryId,
	Assignment.AssignmentId,
	Assignment.Title as AssignmentTitle,
	CourseEntry.CourseName,
	CourseEntry.GradingType,
	CourseEntry.StandardsRatingTableId,
	Assignment.totalPoints
FROM BenchmarkTest
	INNER JOIN Assignment on (Assignment.BenchmarkTestId = BenchmarkTest.BenchmarkTestId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = Assignment.CourseEntryId)
WHERE BenchmarkTest.AssessmentId = @assessmentId


--4 Can retake quiz
SELECT count(distinct ReTakeDate) as retakeCount
INTO #studentRetakeCount
FROM RetakeAssessmentLearnerAnswer
WHERE RetakeAssessmentLearnerAnswer.AssessmentId = @assessmentId
	and RetakeAssessmentLearnerAnswer.PersonId = @studentPersonId

SELECT
	RetakeCount
INTO #settingRetakeCount
FROM Assessment
Where Assessment.AssessmentId = @assessmentId

Select CASE WHEN #settingRetakeCount.RetakeCount - #studentRetakeCount.RetakeCount > 0 THEN 1 Else 0 End as CanRetakeQuiz
From #settingRetakeCount, #studentRetakeCount


Drop table if exists #studentRetakeCount
Drop table if exists #settingRetakeCount

END
GO
/****** Object:  StoredProcedure [dbo].[GetCounts]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[GetCounts]
( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select top 1 PersonId from person where username = 'jef')


DECLARE @companyId as UniqueIdentifier
DECLARE @accessRoleName as varchar(15)
DECLARE @companyName as varchar(100)
DECLARE @schoolYearId as UniqueIdentifier
DECLARE @intervalId as UniqueIdentifier
DECLARE @billingAmount as int
DECLARE @billingPaid as int

--0 The combined counts
--1 The Student count (separate because it is complex according to the user role)
--2 CoursesScheduled (separate because it is complex according to the user role)
--3 Personal billing balance (separate because it is complex according to the user role)
--4 AbsenceUnexcused (separate because it is complex according to the user role)
--5 ExcusedAbsenceRequests (separate because it is complex according to the user role)
--6 DoctorNoteInvitesPending (separate because it is complex according to the user role)

--The combined counts:
--1 Teachers
--2 ClipboardStudents
--3 ClipboardCourses
--4 OpenRegistration
--5 Registrations
--7 Messages
--8 AssignmentsWaitingForReview
--9 TestsWaitingForEssayResponse
--10 CourseRecommendations
--11 LearnerCourseAssigns
--12 CourseAssignments
--13 CurbsideCheckInOrOut
--14 VolunteerCheckInOrOut
--15 SafetyAlerts

SELECT top 1
		PersonAccessRoleAssign.CompanyId,
		AccessRoleLearner.Name as AccessRoleName,
		PersonConfigure.SchoolYearId as PersonConfigureSchoolYearId,
		Company.SchoolYearId as CompanySchoolYearId,
		PersonConfigure.IntervalId as PersonConfigureIntervalId,
		Company.IntervalId as CompanyIntervalId,
		Company.Name as CompanyName
	INTO #selectedAccess
	FROM PersonAccessRoleAssign
		INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
		LEFT JOIN PersonConfigure on (PersonAccessRoleAssign.PersonId = PersonConfigure.PersonId)
		INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
		INNER JOIN Person on (PersonAccessRoleAssign.PersonId = Person.PersonId)
	WHERE PersonAccessRoleAssign.PersonId = @personId

SET @companyId = (SELECT top 1 CompanyId FROM #selectedAccess)
SET @accessRoleName = (SELECT top 1 AccessRoleName FROM #selectedAccess)
SET @companyName = (Select top 1 CompanyName from #selectedAccess)

SET @schoolYearId = (SELECT PersonConfigureSchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (SELECT CompanySchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (Select SchoolYearId from SchoolYear where YearInt = 2020)

SET @intervalId = (SELECT PersonConfigureIntervalId from #selectedAccess)
if (@intervalId is null or @intervalId = '00000000-0000-0000-0000-000000000000')
	SET @intervalId = (SELECT CompanyIntervalId from #selectedAccess)

--0 The combined counts
SELECT
	RecordType,
	Count
FROM (
--1 Teachers
	SELECT 'Teachers' as RecordType,
		count(distinct PersonAccessRoleAssign.PersonId) as Count
	FROM PersonAccessRoleAssign
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
	WHERE AccessRoleLearner.Name= 'Facilitator'
		and PersonAccessRoleAssign.CompanyId = @companyId

--2 ClipboardStudents
	UNION
	SELECT 'ClipboardStudents' as RecordType,
		count(distinct UserPersonClipboardDetail.ChoosePersonId) as Count
	FROM UserPersonClipboardTable
		INNER JOIN UserPersonClipboardDetail on (UserPersonClipboardDetail.UserPersonClipboardTableId = UserPersonClipboardTable.UserPersonClipboardTableId)
	WHERE UserPersonClipboardTable.UserPersonId = @personId

--3 ClipboardCourses
	UNION
	SELECT 'ClipboardCourses' as RecordType,
		count(distinct CourseClipboardDetail.ChooseCourseId) as Count
	FROM CourseClipboardTable
		INNER JOIN CourseClipboardDetail on (CourseClipboardDetail.CourseClipboardTableId = CourseClipboardTable.CourseClipboardTableId)
	WHERE CourseClipboardTable.UserPersonId = @personId

--4 OpenRegistration
	UNION
	SELECT 'OpenRegistration' as RecordType,
		count(distinct OpenRegistrationTable.OpenRegistrationTableId) as Count
	FROM OpenRegistrationTable
		INNER JOIN OpenRegistrationStudent on (OpenRegistrationStudent.OpenRegistrationTableId = OpenRegistrationTable.OpenRegistrationTableId)
	WHERE OpenRegistrationTable.CompanyId = @companyId

--5 Registrations
	UNION
	SELECT 'Registrations' as RecordType,
		count(distinct RegistrationTable.RegistrationTableId) as Count
	FROM RegistrationTable
		INNER JOIN PersonAccessRoleAssign as regAccess on (regAccess.PersonId = RegistrationTable.PersonId
			and regAccess.CompanyId = @companyId)
		INNER JOIN PersonAccessRoleAssign as adminAccess on (adminAccess.CompanyId = regAccess.CompanyId)
	where adminAccess.PersonId = @personId
		and adminAccess.CompanyId = @companyId
		and ((RegistrationTable.PaidDate is null and RegistrationTable.FinalizedDate is not null)
			or RegistrationTable.RegistrationTableId in
				(select RegistrationStudent.RegistrationTableId
				 from RegistrationStudent
				 where RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId
					and FinalizedDate is not null
					and (RegistrationStudent.RegApprovedOrDenied is null or RegistrationStudent.RegApprovedOrDenied = '')))


--7 Messages
	UNION
	SELECT 'Messages' as RecordType,
		count(distinct Announcement.Announcementid) as Count
	FROM Announcement
		INNER JOIN AnnouncementPersonAssign on (AnnouncementPersonAssign.AnnouncementId = Announcement.AnnouncementId)
	WHERE AnnouncementPersonAssign.ToPersonId = @personId
		and (AnnouncementPersonAssign.HideByRecipient is null or AnnouncementPersonAssign.HideByRecipient != 1)

--8 AssignmentsWaitingForReview
	UNION
	SELECT 'AssignmentsWaitingForReview' as RecordType,
		count(distinct StudentResponsePendingReviewId) as Count
	FROM StudentResponsePendingReview
	WHERE FacilitatorPersonId = @personId
		and GradingType = 'TEACHER'

--9 TestsWaitingForEssayResponse
	UNION
	SELECT 'TestsWaitingForEssayResponse' as RecordType,
		count(distinct AssessmentLearnerAnswer.AssessmentQuestionId) as Count
	FROM Assessment
		INNER JOIN AssessmentQuestion on (Assessment.AssessmentId  = AssessmentQuestion.AssessmentId)
		INNER JOIN Assignment on (Assignment.AssessmentId = Assessment.AssessmentId)
		INNER JOIN CourseEntry on (Assignment.CourseEntryId = CourseEntry.CourseEntryId)
		INNER JOIN CourseScheduled on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
		INNER JOIN LearnerCourseAssign on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN AssessmentLearnerAnswer on (AssessmentQuestion.AssessmentQuestionId = AssessmentLearnerAnswer.AssessmentQuestionId
			and LearnerCourseAssign.PersonId = AssessmentLearnerAnswer.PersonId)
		INNER JOIN Work on (Work.WorkId = AssessmentLearnerAnswer.PenspringWorkId)
		INNER JOIN Person on (LearnerCourseAssign.PersonId = Person.PersonId)
		INNER JOIN Company on (CourseEntry.CompanyId = Company.CompanyId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = Company.CompanyId),
		(Select WorkId, sum(wordCount) as WordCount from Chapter group by workId) as WorkWordCount
	WHERE AssessmentLearnerAnswer.IsSubmitted = 1
		and AssessmentLearnerAnswer.PendingCorrection = 1
		and (AssessmentLearnerAnswer.Score = 0 or AssessmentLearnerAnswer.Score is null)
		and WorkWordCount.WorkId = Work.WorkId
		and CourseScheduled.FacilitatorPersonId = @personId

--10 CourseRecommendations
	UNION
	SELECT 'CoursesRecommended' as RecordType,
		count(distinct LearnerCourseRecommended.PersonId) as Count
	FROM LearnerCourseRecommended
	WHERE LearnerCourseRecommended.Entry_PersonId = @personId

--11 LearnerCourseAssigns
	UNION
	SELECT 'LearnerCourseAssigns' as RecordType,
		count(*) as Count
	FROM LearnerCourseAssign
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	WHERE CourseScheduled.CompanyId = @companyId
		and CourseIntervalAssign.IntervalId = @intervalId
		and CourseScheduled.SchoolYearId = @schoolYearId

--12 CourseAssignments
	UNION
	SELECT 'CourseAssignments' as RecordType,
		count(*) as Count
	FROM Assignment
		INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = Assignment.CourseEntryId)
	WHERE CourseEntry.CompanyId = @companyId

--13 CurbsideCheckInOrOut
	UNION
	SELECT 'CurbsideCheckInOrOuts' as RecordType,
		count(*) as Count
	FROM CurbsideCheckInOrOut
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = CurbsideCheckInOrOut.PersonId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and (CurbsideCheckInOrOut.AcknowledgedType is null or CurbsideCheckInOrOut.AcknowledgedType = '')
		and CurbsideCheckInOrOut.EntryDate > DATEADD(minute, -390, getDate())

--14 VolunteerCheckInOrOut
	UNION
	SELECT 'VolunteerCheckInOrOuts' as RecordType,
		count(*) as Count
	FROM VolunteerEvent
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = VolunteerEvent.VolunteerPersonId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and ((VolunteerEvent.CheckIn is not null and ConfirmCheckIn is null)
			or (VolunteerEvent.CheckOut is not null and ConfirmCheckOut is null))

--15 SafetyAlerts
	UNION
	SELECT 'SafetyAlerts' as RecordType,
		count(*) as Count
	FROM SafetyAlert
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = SafetyAlert.PersonId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and (SafetyAlert.DismissFlag is null or SafetyAlert.DismissFlag = 0)
		and SafetyAlert.ApprovedDate is null


) CountUnionQuery


--1  The Student Count  (separate because it is complex according to the user role)
IF (@accessRoleName IN ('Admin', 'Counselor', 'Doctor') OR (@accessRoleName = 'Facilitator' and @companyName = 'Manheim Central'))
	SELECT 'Students' as RecordType,
		count(distinct RegistrationStudent.StudentPersonId) as Count
	FROM RegistrationStudent
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationStudent.StudentPersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
	WHERE AccessRoleLearner.Name = 'Learner'
		and PersonAccessRoleAssign.CompanyId = @companyId
		and RegistrationStudent.SchoolYearId = @schoolYearId

ELSE IF (@accessRoleName = 'Facilitator')
	SELECT 'Students' as RecordType,
		count(distinct LearnerCourseAssign.PersonId) as Count
	FROM RegistrationStudent
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationStudent.StudentPersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.PersonId = RegistrationStudent.StudentPersonId)
		INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	WHERE AccessRoleLearner.Name = 'Learner'
		and PersonAccessRoleAssign.CompanyId = @companyId
		and CourseScheduled.FacilitatorPersonId = @personId
		and CourseScheduled.SchoolYearId = @schoolYearId
		and CourseIntervalAssign.IntervalId = @intervalId

ELSE IF (@accessRoleName = 'Observer')
	SELECT 'Students' as RecordType,
		count(distinct RegistrationStudent.StudentPersonId) as Count
	FROM RegistrationStudent
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = RegistrationStudent.StudentPersonId)
		INNER JOIN RegistrationTable on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN RegistrationGuardianContact on (RegistrationTable.RegistrationTableId = RegistrationGuardianContact.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and RegistrationGuardianContact.PersonId = @personId
		and RegistrationStudent.SchoolYearId = @schoolYearId

ELSE
	SELECT 'Students' as RecordType,
		count(distinct RegistrationStudent.StudentPersonId) as Count
	FROM RegistrationStudent
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = RegistrationStudent.StudentPersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
		INNER JOIN LearnerCourseAssign  on (LearnerCourseAssign.PersonId = RegistrationStudent.StudentPersonId)
		INNER JOIN LearnerCourseAssign as thisLearnerCourseAssign  on (thisLearnerCourseAssign.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	WHERE AccessRoleLearner.Name = 'Learner'
		and PersonAccessRoleAssign.CompanyId = @companyId
		and thisLearnerCourseAssign.PersonId = @personId
		and RegistrationStudent.SchoolYearId = @schoolYearId


--2 CoursesScheduled  (separate because it is complex according to the user role)
IF (@accessRoleName = 'Learner')
	SELECT 'CoursesScheduled' as RecordType,
		count(distinct CourseScheduled.CourseScheduledid) as Count
	FROM CourseScheduled
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	WHERE LearnerCourseAssign.PersonId = @personId
		and CourseScheduled.CompanyId = @companyId
		and CourseIntervalAssign.IntervalId = @intervalId
		and CourseScheduled.SchoolYearId = @schoolYearId

ELSE IF (@accessRoleName = 'Admin' or @accessRoleName = 'Doctor')
	SELECT 'CoursesScheduled' as RecordType,
		count(distinct CourseScheduled.CourseScheduledid) as Count
	FROM CourseScheduled
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	WHERE CourseScheduled.CompanyId = @companyId
		and CourseIntervalAssign.IntervalId = @intervalId
		and CourseScheduled.SchoolYearId = @schoolYearId

ELSE
	SELECT 'CoursesScheduled' as RecordType,
		count(distinct CourseScheduled.CourseScheduledid) as Count
	FROM CourseScheduled
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	WHERE CourseScheduled.CompanyId = @companyId
		and CourseIntervalAssign.IntervalId = @intervalId
		and CourseScheduled.SchoolYearId = @schoolYearId


--3 PersonalBillingBalance
SELECT distinct
	Person.PersonId,
	CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
	Person.Lname as LastName,
	RegistrationStudent.GradeLevelId,
	GradeLevel.Name as GradeLevelName,
	RegistrationGuardianContact.PersonId as PrimaryGuardianPersonId
INTO #studentListObserver
FROM Person
	INNER JOIN PersonAccessRoleAssign on (Person.PersonId = PersonAccessRoleAssign.PersonId )
	INNER JOIN RegistrationStudent on (Person.PersonId = RegistrationStudent.StudentPersonId)
	INNER JOIN RegistrationTable on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
	INNER JOIN RegistrationGuardianContact on (RegistrationTable.RegistrationTableId = RegistrationGuardianContact.RegistrationTableId
	and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
	INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
WHERE PersonAccessRoleAssign.CompanyId = @companyId
	and RegistrationGuardianContact.PersonId = @personId

SELECT
	sum(Amount) as BillingTotal
INTO #billing
FROM FinanceBilling
Where PersonId in (Select PersonId from #studentListObserver)
	and FinanceBillingId not in (Select FinanceBillingId from FinancePaymentDetail where FinanceBillingId is not null)

SET @billingAmount = (SELECT top 1 BillingTotal from #billing)

select top 1
	'PersonalBillingBalance' as RecordType,
	Convert(decimal(10,2), IsNull(@billingAmount, 0), 0) as Count


--4 Absence Unexcused
Declare @absentFeature as nvarchar(25)
Set @absentFeature = (select top 1 Feature from CompanyFeature where companyId = @companyId and feature = 'absenceExcused')

IF (@absentFeature is null or @absentFeature != 'absenceExcused')
	SELECT 'AbsenceUnexcused' as RecordType,
		0 as Count
ELSE
	IF (@accessRoleName = 'Observer')
		SELECT 'AbsenceUnexcused' as RecordType,
			count(*) as Count
		FROM CourseAttendance
			INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = CourseAttendance.CourseScheduledId
				and CourseAttendance.AttendanceDate >= CourseScheduled.FromDate and CourseAttendance.AttendanceDate <= CourseScheduled.ToDate)
			INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = CourseAttendance.PersonId) -- and RegistrationStudent.RegApprovedOrDenied = 'Approved'
			INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
			INNER JOIN PersonConfigure on (PersonConfigure.PersonId = RegistrationTable.PersonId
				and CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId)
		WHERE CourseAttendance.IsAbsent = 1
			and RegistrationTable.PersonId = @personId
			and CourseAttendance.CourseAttendanceId not in (select CourseAttendanceId from ExcusedAbsence)

	ELSE IF (@accessRoleName = 'Learner')
		SELECT 'AbsenceUnexcused' as RecordType,
			count(*) as Count
		FROM CourseAttendance
			INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = CourseAttendance.CourseScheduledId
				and CourseAttendance.AttendanceDate >= CourseScheduled.FromDate and CourseAttendance.AttendanceDate <= CourseScheduled.ToDate)
			INNER JOIN PersonConfigure on (PersonConfigure.PersonId = CourseAttendance.PersonId
				and CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId)
		WHERE CourseAttendance.IsAbsent = 1
			and CourseAttendance.PersonId = @personId
			and CourseAttendance.CourseAttendanceId not in (select CourseAttendanceId from ExcusedAbsence)

	ELSE IF (@accessRoleName = 'Admin' or @accessRoleName = 'Doctor')
		SELECT 'AbsenceUnexcused' as RecordType,
			count(*) as Count
		FROM CourseAttendance
			INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = CourseAttendance.CourseScheduledId
				and CourseAttendance.AttendanceDate >= CourseScheduled.FromDate and CourseAttendance.AttendanceDate <= CourseScheduled.ToDate)
			INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = CourseAttendance.PersonId) -- and RegistrationStudent.RegApprovedOrDenied = 'Approved'
			INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
			INNER JOIN PersonConfigure on (CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId)
			INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseScheduled.CompanyId
				and PersonAccessRoleAssign.PersonId = PersonConfigure.PersonId)
		WHERE CourseAttendance.IsAbsent = 1
			and PersonAccessRoleAssign.PersonId = @personId
			and CourseAttendance.CourseAttendanceId not in (select CourseAttendanceId from ExcusedAbsence)

--5 Excused Absence Requests
IF (@absentFeature is null or @absentFeature != 'absenceExcused')
	SELECT 'ExcusedAbsenceRequests' as RecordType,
		0 as Count
ELSE
	IF (@accessRoleName = 'Observer')
		SELECT 'ExcusedAbsenceRequests' as RecordType,
			count(*) as Count
		FROM CourseAttendance
			INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = CourseAttendance.CourseScheduledId
				and CourseAttendance.AttendanceDate >= CourseScheduled.FromDate and CourseAttendance.AttendanceDate <= CourseScheduled.ToDate)
			INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = CourseAttendance.PersonId) --and RegistrationStudent.RegApprovedOrDenied = 'Approved'
			INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
			INNER JOIN PersonConfigure on (PersonConfigure.PersonId = RegistrationTable.PersonId
				and CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId
				and RegistrationStudent.SchoolYearId = PersonConfigure.SchoolYearId)
			INNER JOIN ExcusedAbsence on (ExcusedAbsence.CourseAttendanceId = CourseAttendance.CourseAttendanceId)
		WHERE CourseAttendance.IsAbsent = 1
			and RegistrationTable.PersonId = @personId

	ELSE IF (@accessRoleName = 'Learner')
		SELECT 'ExcusedAbsenceRequests' as RecordType,
			count(*) as Count
		FROM CourseAttendance
			INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = CourseAttendance.CourseScheduledId
				and CourseAttendance.AttendanceDate >= CourseScheduled.FromDate and CourseAttendance.AttendanceDate <= CourseScheduled.ToDate)
			INNER JOIN PersonConfigure on (PersonConfigure.PersonId = CourseAttendance.PersonId
				and CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId)
			INNER JOIN ExcusedAbsence on (ExcusedAbsence.CourseAttendanceId = CourseAttendance.CourseAttendanceId)
		WHERE CourseAttendance.IsAbsent = 1
			and CourseAttendance.PersonId = @personId

	ELSE IF (@accessRoleName = 'Admin' or @accessRoleName = 'Doctor')
		SELECT 'ExcusedAbsenceRequests' as RecordType,
			count(*) as Count
		FROM CourseAttendance
			INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = CourseAttendance.CourseScheduledId
				and CourseAttendance.AttendanceDate >= CourseScheduled.FromDate and CourseAttendance.AttendanceDate <= CourseScheduled.ToDate)
			INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseScheduled.CompanyId)
			INNER JOIN ExcusedAbsence on (ExcusedAbsence.CourseAttendanceId = CourseAttendance.CourseAttendanceId
				and CourseAttendance.IsAbsent = 1)
		WHERE PersonAccessRoleAssign.PersonId = @personId

--6 Doctor Note Invites Pending
IF (@absentFeature is null or @absentFeature != 'absenceExcused')
	SELECT 'DoctorNoteInvitesPending' as RecordType,
		0 as Count
ELSE
	SELECT 'DoctorNoteInvitesPending' as RecordType,
		count(*) as Count
	FROM DoctorNoteInvite
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = DoctorNoteInvite.CompanyId)
	WHERE PersonAccessRoleAssign.PersonId = @personId


Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #assignmentsWaitingForReview
Drop Table IF EXISTS #assignmentsScoreResponse
Drop Table IF EXISTS #billing
Drop Table IF EXISTS #billingPaid
Drop Table IF EXISTS #studentListObserver

END
GO
/****** Object:  StoredProcedure [dbo].[GetCountsMessages]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCountsMessages]( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select top 1 PersonId from person where username = 'liahonaoffice1@liahonaed.com') --'A2812ACA-BA8D-445F-BFAB-86EF44B9C27F' --'91E033D9-6D29-4A4C-A767-29D499A6D11D'

--0  Recipient
SELECT count(distinct Announcement.Announcementid) as Count
FROM Announcement
	INNER JOIN AnnouncementPersonAssign on (AnnouncementPersonAssign.AnnouncementId = Announcement.AnnouncementId)
WHERE AnnouncementPersonAssign.ToPersonId = @personId
	and (AnnouncementPersonAssign.HideByRecipient is null or AnnouncementPersonAssign.HideByRecipient != 1)

--1  Sent
SELECT count(distinct Announcement.Announcementid) as Count
FROM Announcement
WHERE EntryPersonId = @personId

--2  Discarded
SELECT count(distinct Announcement.Announcementid) as Count
FROM Announcement
	INNER JOIN AnnouncementPersonAssign	 on (AnnouncementPersonAssign.AnnouncementId  = Announcement.AnnouncementId)
WHERE AnnouncementPersonAssign.ToPersonId = @personId
	and HideByRecipient = 1


END
GO
/****** Object:  StoredProcedure [dbo].[getCourseAssignByAdmin]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO


CREATE PROCEDURE [dbo].[getCourseAssignByAdmin]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

Select
	CourseAssignByAdminId,
	CourseEntry.CourseEntryId,
	CourseEntry.CourseName,
	CourseEntry.Credits,
	CourseAssignByAdmin.SchoolYearId,
	GradeLevel.GradeLevelId,
	GradeLevel.Name as GradeLevelName,
	null StudentPersonId,
	null StudentName,
	SuggestionOnly,
	1 as SortSequence
From CourseAssignByAdmin
	INNER JOIN GradeLevel on (CourseAssignByAdmin.GradeLevelId = GradeLevel.GradeLevelId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseAssignByAdmin.CourseEntryId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseEntry.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId
		and PersonConfigure.SchoolYearId = CourseAssignByAdmin.SchoolYearId)
Where PersonAccessRoleAssign.PersonId = @personId

UNION

Select
	CourseAssignByAdminId,
	CourseEntry.CourseEntryId,
	CourseEntry.CourseName,
	CourseEntry.Credits,
	CourseAssignByAdmin.SchoolYearId,
	null GradeLevelId,
	null GradeLevelName,
	Person.PersonId as StudentPersonId,
	Person.Fname + ' ' + Person.Lname as StudentName,
	SuggestionOnly,
	2 as SortSequence
From CourseAssignByAdmin
	INNER JOIN Person on (Person.PersonId = CourseAssignByAdmin.StudentPersonId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseAssignByAdmin.CourseEntryId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseEntry.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId
		and PersonConfigure.SchoolYearId = CourseAssignByAdmin.SchoolYearId)
Where PersonAccessRoleAssign.PersonId = @personId


END
GO
/****** Object:  StoredProcedure [dbo].[GetCourseAssignments]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCourseAssignments]
	( @personId AS UniqueIdentifier, @courseEntryId as Uniqueidentifier)
 AS
BEGIN
--Declare @personId as UniqueIdentifier
--Declare @courseEntryId as Uniqueidentifier
--Set @personId = (select Personid from person where username = 'ssorensen')
--SET @courseEntryId = '5A7072A1-7EC7-4ED3-8B28-F301AAD3D378'

--0
Select
    AssignmentId,
    CourseEntryId,
    ContentType.ContentTypeId,
    Assignment.IntervalId,
    ContentType.Code as ContentTypeCode,
    ContentType.Name as ContentTypeName,
    PersonConfigure.PersonId,
    Title,
    Subtitle,
    Assignment.Sequence,
    AssessmentId,
	BenchmarkTestId,
    ChatId,
    JournalId,
    SurveyId,
    EntryDate,
    Instructions,
    MustComplete,
    Gradable,
    DiscussionEntryId,
    DiscussionMinPost,
    DiscussionWordCount,
    DiscussionMinComment,
    TotalPoints,
    ExtraCredit,
    HideTest,
    DueDate
INTO #assignments
From Assignment
	INNER JOIN ContentType on (ContentType.ContentTypeId = Assignment.ContentTypeId)
	INNER JOIN PersonConfigure ON (PersonConfigure.IntervalId = Assignment.IntervalId)
WHERE PersonConfigure.PersonId = @personId
	and Assignment.CourseEntryId = @courseEntryId

select * from #assignments

--1
SELECT
	AssignmentId,
	CourseTypeId,
	GradingType
FROM AssignmentGradedBy
WHERE AssignmentGradedBy.AssignmentId in (select AssignmentId from #assignments)

--2
SELECT
	AssignmentId,
	CourseScheduledId
FROM AssignmentCourseSpecific
WHERE AssignmentCourseSpecific.AssignmentId in (select AssignmentId from #assignments)

--3
SELECT
	AssignmentId,
	StudentPersonId
FROM StudentAssignmentAssign
WHERE StudentAssignmentAssign.AssignmentId in (select AssignmentId from #assignments)

--4
Select
	Assessment.AssessmentId,
	AssessmentQuestionId,
	Assessment.IsPublished
FROM Assessment
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
WHERE Assessment.AssessmentId IN ( SELECT AssessmentId FROM #assignments)

--5
SELECT
	AssignmentId,
	FileUpload.FileUploadId,
	Url,
	Title
FROM AssignmentFile
	INNER JOIN FileUpload on (FileUpload.FileUPloadId = AssignmentFile.FileUploadId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #assignments)

--6
SELECT
	AssignmentId,
	WebsiteLink,
	AssignmentWebsiteLinkId
FROM AssignmentWebsiteLink
WHERE AssignmentId IN ( SELECT AssignmentId FROM #assignments)

--7 Penspring files
SELECT distinct
    AssignmentPenspringFile.AssignmentId,
    AssignmentPenspringFile.AssignmentPenspringFileId,
    AssignmentPenspringFile.PersonId,
    AssignmentPenspringFile.PenspringWorkId,
    AssignmentPenspringFile.EntryDate,
    Work.PublishedDate
FROM AssignmentPenspringFile
	INNER JOIN Work on (Work.WorkId = AssignmentPenspringFile.PenspringWorkId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #assignments)
	 and PenspringWorkId is not null
	 and PenspringWorkId != '00000000-0000-0000-0000-000000000000'

--8 Standards
SELECT distinct
	AssignmentId,
	StandardSchool.StandardSchoolId,
    LearningPathwayId,
    Code,
    Name,
    Description,
    ParentStandardSchoolId,
    EntryPersonId,
    EntryDate,
    Sequence
FROM AssignmentStandard
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssignmentStandard.StandardSchoolId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #assignments)

--9 Benchmark Tests' assessment questions (for count)
Select distinct
	BenchmarkTest.BenchmarkTestId,
	AssessmentQuestionId,
	BenchmarkTest.IsPublished
FROM BenchmarkTest
	INNER JOIN Assessment on (BenchmarkTest.AssessmentId = Assessment.AssessmentId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
	INNER JOIN BenchmarkTestPersonAssign on (BenchmarkTestPersonAssign.BenchmarkTestId = BenchmarkTest.BenchmarkTestId)
	--INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = BenchmarkTest.SchoolYearId)
WHERE BenchmarkTestPersonAssign.PersonId = @personId


DROP TABLE #assignments

END
GO
/****** Object:  StoredProcedure [dbo].[GetCourseEntries]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCourseEntries]
(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personId from person where username = 'ssorensen') --'4E66E25A-8EA6-4801-8BA2-922F65BB3D02'


SELECT distinct
    CourseEntry.CourseEntryId,
    CourseEntry.CourseName,
    CourseEntry.Credits,
    CourseEntry.Code,
    CourseEntry.GradingType,
    CourseEntry.StandardsRatingTableId,
    LearningPathway.LearningPathwayId,
    LearningPathway.Description as LearningPathwayName,
    CourseEntry.LearningFocusAreaId,
	0 as ContentCount,
    CourseEntry.ExternalId,
	CourseEntry.StateCourseId,
	CourseEntry.ExcludeFromGPA,
	CourseEntry.ExcludeFromClassRank,
	CourseEntry.ExcludeFromHonorRoll,
	CourseEntry.UseTheCourseForLunch,
	CourseEntry.ExcludeOnGradeReport,
	CourseEntry.ExcludeFromStateReports
INTO #courseEntries
FROM
	CourseEntry
	INNER JOIN PersonAccessRoleAssign on ( CourseEntry.CompanyId = PersonAccessRoleAssign.CompanyId)
	INNER JOIN LearningPathway on (CourseEntry.LearningPathwayId = LearningPathway.LearningPathwayId)
	INNER JOIN CourseEntryGradeLevel on (CourseEntryGradeLevel.CourseEntryId = CourseEntry.CourseEntryId)
	INNER JOIN PersonAccessGradeLevel on (PersonAccessGradeLevel.GradeLevelId = CourseEntryGradeLevel.GradeLevelId
		and PersonAccessGradeLevel.PersonId = PersonAccessRoleAssign.PersonId)
where PersonAccessRoleAssign.PersonId = @personId
	and (CourseEntry.IsInactive != 1 or CourseEntry.IsInactive is null)

--0
select * from #courseEntries

--1
SELECT
	CourseEntryId,
	count(*) as ContentCount
From Assignment
Where CourseEntryId in (select CourseEntryId from #courseEntries)
Group by CourseEntryId

--2
SELECT distinct
    CourseEntryGradeLevel.CourseEntryId,
    GradeLevel.GradeLevelId,
    Name,
    Code,
    Sequence
From CourseEntryGradeLevel
	INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = CourseEntryGradeLevel.GradeLevelId)
Where CourseEntryGradeLevel.CourseEntryId in (Select CourseEntryId from #courseEntries)


Drop table if exists #courseEntries

END
GO
/****** Object:  StoredProcedure [dbo].[GetCourseSeatStatistics]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCourseSeatStatistics]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = '22AchenbachM70') --'4F5CE197-F40E-49D3-A72C-7B8583A397B4' --'FCA622C9-1ED0-4A0D-B976-048CB62F691C' -- 'DD26DD2F-B384-416E-8BF0-1876E830B351' --'8392A37E-CAFA-4B27-B6DA-44B1729F6003'


Declare @isManheimStudent as nvarchar(100)
Declare @companyID as UniqueIdentifier
Declare @schoolYearId as UniqueIdentifier

Set @schoolYearId = (Select SchoolYearId from PersonConfigure where PersonId = @personId)

SELECT top 1
	Name,
	Company.CompanyId
INTO #manheimCompany
FROM Company, PersonAccessRoleAssign
WHERE Company.CompanyId = PersonAccessRoleAssign.CompanyId
	--and PersonAccessRoleAssign.AccessRoleLearnerId = 1
	and Name like 'Manheim%'
	and PersonId = @personId

Set @isManheimStudent = (Select Name from #manheimCompany)
Set @companyID = (Select CompanyId from #manheimCompany)

--0 Get getStudentList (courses and just the Ids of each student in that course)
--accumulate all of the tables to get the courses
IF (@isManheimStudent is null or @isManheimStudent = '')
	SELECT
		CourseScheduled.CourseScheduledId,
		CourseScheduled.FacilitatorPersonId,
		CourseScheduled.CourseEntryId,
		CourseScheduled.MaxSeats,
		CourseIntervalAssign.IntervalId,
		null as ClassPeriodId,
		CourseEntry.ExternalId as CourseId,
		CourseScheduled.MaxSeats,
		PersonAccessRoleAssign.PersonId as StudentPersonId,
		CASE WHEN Online = 1 THEN 'Online' ELSE '' END as OnlineName
	FROM LearnerCourseAssign
		INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseEntry.CompanyId)
	WHERE PersonAccessRoleAssign.PersonId = @personId
		and CourseScheduled.SchoolYearId = @schoolYearId
	Order by CourseScheduled.CourseScheduledId

ELSE
	SELECT distinct
		CourseScheduled.CourseScheduledId,
		CourseScheduled.FacilitatorPersonId,
		CourseScheduled.CourseEntryId,
		CourseScheduled.MaxSeats,
		CourseIntervalAssign.IntervalId,
		Interval.Code as IntervalCode,
		null as ClassPeriodId,
		CourseEntry.ExternalId as CourseId,
		CASE WHEN Online = 1 THEN 'Online' ELSE '' END as OnlineName,
		LearnerCourseAssign.PersonId as StudentPersonId
	FROM LearnerCourseAssign
		INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
		INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
	WHERE CourseScheduled.SchoolYearId = @schoolYearId
		and CourseEntry.CompanyId = @companyID

	UNION
	SELECT distinct
		ManheimMusicCombinedCourses.CourseScheduledIdGu as CourseScheduledId,
		null as FacilitatorPersonId,
		null as CourseEntryId,
		null as MaxSeats,
		null as IntervalId,
		null as IntervalCode,
		null as ClassPeriodId,
		null as CourseId,
		null as OnlineName,
		LearnerCourseAssign.PersonId as StudentPersonId
	FROM LearnerCourseAssign
		INNER JOIN ManheimMusicCombinedCourses on (LearnerCourseAssign.CourseScheduledId = ManheimMusicCombinedCourses.CourseScheduledIdGu)

	UNION
	SELECT distinct
		ManheimLearningSupportCombinedCourses.CourseScheduledIdGu as CourseScheduledId,
		null as FacilitatorPersonId,
		null as CourseEntryId,
		null as MaxSeats,
		null as IntervalId,
		null as IntervalCode,
		null as ClassPeriodId,
		null as CourseId,
		null as OnlineName,
		LearnerCourseAssign.PersonId as StudentPersonId
	FROM LearnerCourseAssign
		INNER JOIN ManheimLearningSupportCombinedCourses on (LearnerCourseAssign.CourseScheduledId = ManheimLearningSupportCombinedCourses.CourseScheduledIdGu)
	Order by CourseScheduled.CourseScheduledId


DROP TABLE #manheimCompany

END
GO
/****** Object:  StoredProcedure [dbo].[GetCourseSeatStatus]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCourseSeatStatus]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = 'BD11B536-0EE1-4282-928B-B49A1025BB47'

Declare @schoolYearId as UniqueIdentifier
Declare @companyId as UniqueIdentifier
Declare @firstClassPeriodId as UniqueIdentifier
Set @schoolYearId = (Select SchoolYearId from PersonConfigure where PersonId = @personId);
Set @firstClassPeriodId = (Select ClassPeriodId from ClassPeriod where CompanyId = @companyId and PeriodNumber = '1')


SELECT top 1
	Name,
	Company.CompanyId
INTO #manheimCompany
FROM Company
WHERE Name like 'Manheim%'

Set @companyId = (Select CompanyId from #manheimCompany)

--Big Group with UNIONS for Manheim courses
SELECT distinct
	Id,
	Value,
	Label,
	CourseEntryId,
	CourseScheduledId,
	HasFallSemester,
	HasSpringSemester,
	DepartmentId,
	LearningPathwayId,
	LearningPathwayName,
	CourseName,
	CourseTypeId,
	CourseTypeName,
	Credits,
	Description,
	Code,
	Section,
	SchoolYearId,
	ClassPeriodId,
	ClassPeriodName,
	FacilitatorPersonId,
	FacilitatorName,
	Location,
	OffCampusName,
	OnCampusName,
	OnlineName,
	SelfPacedName,
	FromDate,
	ToDate,
	MaxSeats,
	SectionId,
	CourseId
into #manheimCourses
FROM (
	--A  Manheim course list
	SELECT
		CourseScheduled.CourseScheduledId as Id,
		CourseScheduled.CourseScheduledId as Value,
		CourseName as Label,
		CourseScheduled.CourseEntryId,
		CourseScheduled.CourseScheduledId,
		Convert(bit,1) as HasFallSemester,
		Convert(bit,1) as HasSpringSemester,
		CourseEntry.DepartmentId,
		LearningPathway.LearningPathwayId,
		LearningPathway.Name as LearningPathwayName,
		CourseName,
		CourseType.CourseTypeId,
		CourseType.Name as CourseTypeName,
		Credits,
		CourseEntry.Description,
		CourseScheduled.Code,
		CourseScheduled.Section,
		CourseScheduled.SchoolYearId,
		null as ClassPeriodId,
		null ClassPeriodName,
		FacilitatorPersonId,
		facilitator.Lname + ', ' + facilitator.Fname as FacilitatorName,
		Location,
		CASE WHEN OffCampus = 1 THEN 'Off campus' ELSE '' END as OffCampusName,
		CASE WHEN OnCampus = 1 THEN 'On campus' ELSE '' END as OnCampusName,
		CASE WHEN Online = 1 THEN 'Online' ELSE '' END as OnlineName,
		CASE WHEN SelfPaced = 1 THEN 'Self-paced' ELSE '' END as SelfPacedName,
		FromDate,
		ToDate,
		MaxSeats,
		CourseScheduled.ExternalId as SectionId,
		CourseEntry.ExternalId as CourseId
	From CourseScheduled
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId
			and (CourseEntry.IsInactive is null or CourseEntry.IsInactive != 1))
		INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
		LEFT JOIN Person as Facilitator on (facilitator.PersonID = CourseScheduled.FacilitatorPersonId)
		LEFT JOIN CourseType on (CourseScheduled.CourseTypeId = CourseType.CourseTypeId)
		LEFT JOIN LearningPathway on (CourseEntry.LearningPathwayId = LearningPathway.LearningPathwayId),
		Company
	Where CourseScheduled.SchoolYearId = @schoolYearId
	and CourseScheduled.CompanyId = @companyId

	UNION

	--C getManheimMusicCombinedCourses
	SELECT
		CourseScheduledIdGu as Id,
		CourseScheduledIdGu as Value,
		CourseName + ' - (combined)' as Label,
		CourseScheduledIdGu as CourseEntryId,
		CourseScheduledIdGu as CourseScheduledId,
		Convert(bit,1) as HasFallSemester,
		CASE WHEN SpringFirst is not null and SpringFirst != '' THEN Convert(bit,1) ELSE Convert(bit,0) END as HasSpringSemester,
		Department.DepartmentId,
		LearningPathway.LearningPathwayId,
		LearningPathway.Name as LearningPathwayName,
		CourseName,
		null as CourseType,
		'Combined' as CourseTypeName,
		Credits,
		'Combined music classes' as Description,
		'Combined' as Code,
		null as Section,
		@schoolYearId as SchoolYearId,
		@firstClassPeriodId as ClassPeriodId,
		'1' as ClassPeriodName,
		null as FacilitatorPersonId,
		null as FacilitatorName,
		null as Location,
		null as OffCampusName,
		'On campus' as OnCampusName,
		null as OnlineName,
		null as SelfPacedName,
		null as FromDate,
		null as ToDate,
		MaxSeats,
		null as SectionId,
		null as CourseId
	FROM ManheimMusicCombinedCourses, LearningPathway, Department
		--A Cartesian join for LearningPathway and Department
	WHERE LearningPathway.Name = 'MUS'
		and Department.Name = 'MUS'

	UNION

	SELECT
		CourseScheduledIdGu as Id,
		CourseScheduledIdGu as Value,
		CourseName + ' - (combined)' as Label,
		CourseScheduledIdGu as CourseEntryId,
		CourseScheduledIdGu as CourseScheduledId,
		Convert(bit,1) as HasSpringSemester,
		CASE WHEN First1A is not null and First1A != '' THEN Convert(bit,1) ELSE Convert(bit,0) END as HasFallSemester,
		Department.DepartmentId,
		LearningPathway.LearningPathwayId,
		LearningPathway.Name as LearningPathwayName,
		CourseName,
		null as CourseType,
		'Combined' as CourseTypeName,
		Credits,
		'Combined music classes' as Description,
		'Combined' as Code,
		null as Section,
		@schoolYearId as SchoolYearId,
		@firstClassPeriodId as ClassPeriodId,
		'1' as ClassPeriodName,
		null as FacilitatorPersonId,
		null as FacilitatorName,
		null as Location,
		null as OffCampusName,
		'On campus' as OnCampusName,
		null as OnlineName,
		null as SelfPacedName,
		null as FromDate,
		null as ToDate,
		MaxSeats,
		null as SectionId,
		null as CourseId
	FROM ManheimMusicCombinedCourses,  LearningPathway, Department
		--A Cartesian join for LearningPathway and Department
	WHERE LearningPathway.Name = 'MUS'
		and Department.Name = 'MUS'

	UNION

	--D getManheimLearningSupportCourses
	SELECT
		CourseScheduledIdGu as Id,
		CourseScheduledIdGu as Value,
		CourseName + ' - (combined)' as Label,
		CourseScheduledIdGu as CourseEntryId,
		CourseScheduledIdGu as CourseScheduledId,
		Convert(bit,1) as HasSpringSemester,
		Convert(bit,1) as HasFallSemester,
		Department.DepartmentId,
		LearningPathway.LearningPathwayId,
		LearningPathway.Name as LearningPathwayName,
		CourseName,
		null as CourseType,
		'Combined' as CourseTypeName,
		Credits,
		'Combined learning support classes' as Description,
		'Combined' as Code,
		null as Section,
		@schoolYearId as SchoolYearId,
		ClassPeriod.ClassPeriodId,
		ClassPeriod.PeriodNumber as ClassPeriodName,
		null as FacilitatorPersonId,
		null as FacilitatorName,
		null as Location,
		null as OffCampusName,
		'On campus' as OnCampusName,
		null as OnlineName,
		null as SelfPacedName,
		null as FromDate,
		null as ToDate,
		29 as MaxSeats,
		null as SectionId,
		null as CourseId
	FROM ManheimLearningSupportCombinedCourses, ClassPeriod, LearningPathway, Department
		--A Cartesian join for LearningPathway and Department
	WHERE LearningPathway.Name = 'SUPPORT'
		and Department.Name = 'LS'
		and ManheimLearningSupportCombinedCourses.ClassPeriodId = ClassPeriod.ClassPeriodId

	UNION

	SELECT
		CourseScheduledIdGu as Id,
		CourseScheduledIdGu as Value,
		CourseName + ' - (combined)' as Label,
		CourseScheduledIdGu as CourseEntryId,
		CourseScheduledIdGu as CourseScheduledId,
		Convert(bit,1) as HasSpringSemester,
		Convert(bit,1) as HasFallSemester,
		Department.DepartmentId,
		LearningPathway.LearningPathwayId,
		LearningPathway.Name as LearningPathwayName,
		CourseName,
		null as CourseType,
		'Combined' as CourseTypeName,
		Credits,
		'Combined learning support classes' as Description,
		'Combined' as Code,
		null as Section,
		@schoolYearId as SchoolYearId,
		ClassPeriod.ClassPeriodId,
		ClassPeriod.PeriodNumber as ClassPeriodName,
		null as FacilitatorPersonId,
		null as FacilitatorName,
		null as Location,
		null as OffCampusName,
		'On campus' as OnCampusName,
		null as OnlineName,
		null as SelfPacedName,
		null as FromDate,
		null as ToDate,
		29 as MaxSeats,
		null as SectionId,
		null as CourseId
	FROM ManheimLearningSupportCombinedCourses, ClassPeriod,  LearningPathway, Department
		--A Cartesian join for LearningPathway and Department
	WHERE LearningPathway.Name = 'SUPPORT'
		and Department.Name = 'LS'
		and ManheimLearningSupportCombinedCourses.ClassPeriodId = ClassPeriod.ClassPeriodId

) as ManheimQuery
Order by CourseName

SELECT * FROM #manheimCourses

--1 Get getStudentList (courses and just the Ids of each student in that course)
--accumulate all of the tables to get the courses
SELECT distinct
	CourseScheduled.CourseScheduledId,
	CourseScheduled.FacilitatorPersonId,
	CourseScheduled.CourseEntryId,
	CourseIntervalAssign.IntervalId,
	Interval.Code as IntervalCode,
	CourseEntry.ExternalId as CourseId,
	CASE WHEN Online = 1 THEN 'Online' ELSE '' END as OnlineName,
	PersonId as StudentPersonId
FROM LearnerCourseAssign
	INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
WHERE CourseScheduled.CourseScheduledId in (Select CourseScheduledId from #manheimCourses)
	and CourseScheduled.SchoolYearId = @schoolYearId

UNION
SELECT distinct
	ManheimMusicCombinedCourses.CourseScheduledIdGu as CourseScheduledId,
	null as FacilitatorPersonId,
	null as CourseEntryId,
	null as IntervalId,
	null as IntervalCode,
	null as CourseId,
	null as OnlineName,
	LearnerCourseAssign.PersonId as StudentPersonId
FROM LearnerCourseAssign
	INNER JOIN ManheimMusicCombinedCourses on (LearnerCourseAssign.CourseScheduledId = ManheimMusicCombinedCourses.CourseScheduledIdGu)

UNION
SELECT distinct
	ManheimLearningSupportCombinedCourses.CourseScheduledIdGu as CourseScheduledId,
	null as FacilitatorPersonId,
	null as CourseEntryId,
	null as IntervalId,
	null as IntervalCode,
	null as CourseId,
	null as OnlineName,
	LearnerCourseAssign.PersonId as StudentPersonId
FROM LearnerCourseAssign
	INNER JOIN ManheimLearningSupportCombinedCourses on (LearnerCourseAssign.CourseScheduledId = ManheimLearningSupportCombinedCourses.CourseScheduledIdGu)
Order by CourseScheduled.CourseScheduledId

--2 The ClassperiodIds and names for all of the courses (but despite the monday through friday records, we are just going to get a distinct classPeriod since in Manheim's case, they don't vary day by day.
SELECT distinct
	DaysScheduled.CourseScheduledId,
	ClassPeriod.ClassPeriodId,
	ClassPeriod.PeriodNumber as ClassPeriodName,
	DaysScheduled.StartTime,
	DaysScheduled.Duration
FROM DaysScheduled
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
WHERE DaysScheduled.CourseScheduledId in (Select CourseScheduledId from #manheimCourses)

--3  Intervals for the CourseScheduled
SELECT
	Interval.IntervalId,
	Interval.Code,
	Interval.Name,
	Interval.Sequence,
	CourseScheduledId
FROM Interval
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.IntervalId = Interval.IntervalId)
WHERE CourseIntervalAssign.CourseScheduledId in (Select CourseScheduledId from #manheimCourses)


DROP TABLE #manheimCompany
DROP TABLE IF EXISTS #notManheimCourses
DROP TABLE IF EXISTS #manheimCourses


END
GO
/****** Object:  StoredProcedure [dbo].[GetCoursesScheduled]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCoursesScheduled]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = '08F6AC0D-EC26-4A8F-8E92-B98CBB8DE26E' --'1243ECC4-D0F7-4035-922D-DB754BA6AEEB' --'a3c75ff5-3e6b-464a-b4e0-d6767841e461' --(select personid from person where username = 'ssorensen')


Declare @gradeLevelName as nvarchar(100)
Declare @companyID as UniqueIdentifier
DECLARE @schoolYearId as UniqueIdentifier
DECLARE @intervalId as UniqueIdentifier

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName,
	Company.StudentNameFirst,
	PersonConfigure.SchoolYearId as PersonConfigureSchoolYearId,
	Company.SchoolYearId as CompanySchoolYearId,
	PersonConfigure.IntervalId as PersonConfigureIntervalId,
	Company.IntervalId as CompanyIntervalId
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId)
WHERE PersonAccessRoleAssign.PersonId = @personId

Set @companyID = (Select CompanyId from #selectedAccess)
Set @gradeLevelName = (Select top 1 GradeLevel.Name from GradeLevel, RegistrationStudent where GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId and RegistrationStudent.StudentPersonId = @personId)

SET @schoolYearId = (SELECT PersonConfigureSchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (SELECT CompanySchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (Select SchoolYearId from SchoolYear where YearInt = 2020)

SET @intervalId = (SELECT PersonConfigureIntervalId from #selectedAccess)
if (@intervalId is null or @intervalId = '00000000-0000-0000-0000-000000000000')
	SET @intervalId = (SELECT CompanyIntervalId from #selectedAccess)

--0  CoursesScheduled
SELECT distinct
	Id,
	Value,
	Label,
	CourseEntryId,
	CourseScheduledId,
	--FacilitatorPersonId, --This is particularly for Manheim since TeacherCourseAssign is the official, multiple teacher list.
	GradeScaleTableId,
	StandardsRatingTableId,
	IsCombinedMusic,
	HasFallSemester,
	HasSpringSemester,
	DepartmentId,
	LearningPathwayId,
	LearningPathwayName,
	CourseName,
	CourseTypeId,
	CourseTypeName,
	Credits,
	Description,
	Code,
	Section,
	SchoolYearId,
	ClassPeriodId,
	ClassPeriodName,
	Location,
	GradingType,
	OffCampusName,
	OnCampusName,
	OnlineName,
	SelfPacedName,
	FromDate,
	ToDate,
	MaxSeats,
	SectionId,
	CourseId,
	CourseGradeLevelSeventh,
	CourseGradeLevelEighth,
	CourseGradeLevelNinth,
	CourseGradeLevelTenth,
	CourseGradeLevelEleventh,
	CourseGradeLevelTwelfth,
	CourseGradeLevelThirteenth,
	GradeLevelName,
	AdministrativeWhereTaught,
	SchoolWhereTaught,
	ExcludeFromGPA,
	ExcludeFromClassRank,
	ExcludeFromHonorRoll,
	UseTheCourseForLunch,
	ExcludeOnGradeReport,
	ExcludeFromStateReports,
	GrantingCreditCollegeId,
	WhereTaughtCampus,
	InstructionalSetting,
	VocationalMultiplier
INTO #courses
FROM (
	SELECT distinct
		CourseScheduled.CourseScheduledId as Id,
		CourseScheduled.CourseScheduledId as Value,
		CourseName as Label,
		CourseScheduled.CourseEntryId,
		CourseScheduled.CourseScheduledId,
		--CourseScheduled.FacilitatorPersonId, --This is particularly for Manheim since TeacherCourseAssign is the official, multiple teacher list.
		CourseScheduled.GradeScaleTableId,
		CourseScheduled.StandardsRatingTableId,
		Convert(bit,0) as IsCombinedMusic,
		Convert(bit,1) as HasFallSemester,
		Convert(bit,1) as HasSpringSemester,
		CourseEntry.DepartmentId,
		LearningPathway.LearningPathwayId,
		LearningPathway.Name as LearningPathwayName,
		CourseName,
		CourseType.CourseTypeId,
		CourseType.Name as CourseTypeName,
		Credits,
		CourseEntry.Description,
		CourseScheduled.Code,
		CourseScheduled.Section,
		CourseScheduled.SchoolYearId,
		null as ClassPeriodId,
		null as ClassPeriodName,
		Location,
		CourseScheduled.GradingType,
		CASE WHEN OffCampus = 1 THEN 'Off campus' ELSE '' END as OffCampusName,
		CASE WHEN OnCampus = 1 THEN 'On campus' ELSE '' END as OnCampusName,
		CASE WHEN Online = 1 THEN 'Online' ELSE '' END as OnlineName,
		CASE WHEN CourseScheduled.SelfPaced = 1 THEN 'Self-paced' ELSE '' END as SelfPacedName,
		FromDate,
		ToDate,
		MaxSeats,
		CourseScheduled.ExternalId as SectionId,
		CourseEntry.ExternalId as CourseId,
		Convert(bit,1) as CourseGradeLevelSeventh,
		Convert(bit,1) as CourseGradeLevelEighth,
		Convert(bit,1) as CourseGradeLevelNinth,
		Convert(bit,1) as CourseGradeLevelTenth,
		Convert(bit,1) as CourseGradeLevelEleventh,
		Convert(bit,1) as CourseGradeLevelTwelfth,
		Convert(bit,1) as CourseGradeLevelThirteenth,
		@gradeLevelName as GradeLevelName,
		CourseScheduled.AdministrativeWhereTaught,
		CourseScheduled.SchoolWhereTaught,
		CourseScheduled.ExcludeFromGPA,
		CourseScheduled.ExcludeFromClassRank,
		CourseScheduled.ExcludeFromHonorRoll,
		CourseScheduled.UseTheCourseForLunch,
		CourseScheduled.ExcludeOnGradeReport,
		CourseScheduled.ExcludeFromStateReports,
		CourseScheduled.GrantingCreditCollegeId,
		CourseScheduled.WhereTaughtCampus,
		CourseScheduled.InstructionalSetting,
		CourseScheduled.VocationalMultiplier
	From CourseScheduled
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
			--and (CourseEntry.IsInactive is null or CourseEntry.IsInactive != 1)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseEntry.CompanyId)
		LEFT JOIN CourseType on (CourseScheduled.CourseTypeId = CourseType.CourseTypeId)
		LEFT JOIN LearningPathway on (CourseEntry.LearningPathwayId = LearningPathway.LearningPathwayId)
		INNER JOIN CourseEntryGradeLevel on (CourseEntryGradeLevel.CourseEntryId = CourseEntry.CourseEntryId)
		INNER JOIN PersonAccessGradeLevel on (PersonAccessGradeLevel.GradeLevelId = CourseEntryGradeLevel.GradeLevelId
			and PersonAccessGradeLevel.PersonId = PersonAccessRoleAssign.PersonId)
	Where PersonAccessRoleAssign.PersonId = @personId
		and CourseScheduled.SchoolYearId = @schoolYearId

	UNION

	SELECT distinct
		CourseScheduled.CourseScheduledId as Id,
		CourseScheduled.CourseScheduledId as Value,
		CourseName as Label,
		CourseScheduled.CourseEntryId,
		CourseScheduled.CourseScheduledId,
		--CourseScheduled.FacilitatorPersonId, --This is particularly for Manheim since TeacherCourseAssign is the official, multiple teacher list.
		CourseScheduled.GradeScaleTableId,
		CourseScheduled.StandardsRatingTableId,
		Convert(bit,0) as IsCombinedMusic,
		Convert(bit,1) as HasFallSemester,
		Convert(bit,1) as HasSpringSemester,
		CourseEntry.DepartmentId,
		LearningPathway.LearningPathwayId,
		LearningPathway.Name as LearningPathwayName,
		CourseName,
		CourseType.CourseTypeId,
		CourseType.Name as CourseTypeName,
		Credits,
		CourseEntry.Description,
		CourseScheduled.Code,
		CourseScheduled.Section,
		CourseScheduled.SchoolYearId,
		null as ClassPeriodId,
		null as ClassPeriodName,
		Location,
		CourseScheduled.GradingType,
		CASE WHEN OffCampus = 1 THEN 'Off campus' ELSE '' END as OffCampusName,
		CASE WHEN OnCampus = 1 THEN 'On campus' ELSE '' END as OnCampusName,
		CASE WHEN Online = 1 THEN 'Online' ELSE '' END as OnlineName,
		CASE WHEN CourseScheduled.SelfPaced = 1 THEN 'Self-paced' ELSE '' END as SelfPacedName,
		FromDate,
		ToDate,
		MaxSeats,
		CourseScheduled.ExternalId as SectionId,
		CourseEntry.ExternalId as CourseId,
		Convert(bit,1) as CourseGradeLevelSeventh,
		Convert(bit,1) as CourseGradeLevelEighth,
		Convert(bit,1) as CourseGradeLevelNinth,
		Convert(bit,1) as CourseGradeLevelTenth,
		Convert(bit,1) as CourseGradeLevelEleventh,
		Convert(bit,1) as CourseGradeLevelTwelfth,
		Convert(bit,1) as CourseGradeLevelThirteenth,
		@gradeLevelName as GradeLevelName,
		CourseScheduled.AdministrativeWhereTaught,
		CourseScheduled.SchoolWhereTaught,
		CourseScheduled.ExcludeFromGPA,
		CourseScheduled.ExcludeFromClassRank,
		CourseScheduled.ExcludeFromHonorRoll,
		CourseScheduled.UseTheCourseForLunch,
		CourseScheduled.ExcludeOnGradeReport,
		CourseScheduled.ExcludeFromStateReports,
		CourseScheduled.GrantingCreditCollegeId,
		CourseScheduled.WhereTaughtCampus,
		CourseScheduled.InstructionalSetting,
		CourseScheduled.VocationalMultiplier
	From CourseScheduled
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
			--and (CourseEntry.IsInactive is null or CourseEntry.IsInactive != 1)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseEntry.CompanyId)
		LEFT JOIN CourseType on (CourseScheduled.CourseTypeId = CourseType.CourseTypeId)
		LEFT JOIN LearningPathway on (CourseEntry.LearningPathwayId = LearningPathway.LearningPathwayId)
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId
			and PersonAccessRoleAssign.PersonId = LearnerCourseAssign.PersonId)
	Where LearnerCourseAssign.PersonId = @personId
		and CourseScheduled.SchoolYearId = @schoolYearId
) as UnionQuery

--0
select * from #courses

--1 Get getStudentList (courses and just the Ids of each student in that course)
--accumulate all of the tables to get the courses
SELECT
	CourseScheduled.CourseScheduledId,
	CourseScheduled.CourseEntryId,
	null as ClassPeriodId,
	CourseEntry.ExternalId as CourseId,
	PersonId as StudentPersonId,
	CASE WHEN Online = 1 THEN 'Online' ELSE '' END as OnlineName
FROM LearnerCourseAssign, CourseScheduled, CourseEntry
WHERE LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId
	and CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId
	and CourseScheduled.CourseScheduledId in (Select CourseScheduledId from #courses)
	and CourseScheduled.SchoolYearId = @schoolYearId
Order by CourseScheduled.CourseScheduledId


--2 Get the recommended courses for this user. (LearnerCourseRecommended)
	SELECT distinct
		ExternalId
	FROM LearnerCourseRecommended
		--LEFT JOIN CourseEntry on (LearnerCourseRecommended.CourseEntryId = CourseEntry.CourseEntryId
		--	and (CourseEntry.IsInactive is null or CourseEntry.IsInactive != 1))
		--INNER JOIN CourseScheduled on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
		--INNER JOIN Interval on (CourseScheduled.IntervalId = Interval.IntervalId)
		----PersonConfigInterval,
		--INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = LearnerCourseRecommended.PersonId)
		--INNER JOIN Company on (Company.CompanyId = PersonAccessRoleAssign.CompanyId)
	Where ExternalId is not null and ExternalId != '' and PersonId = @personId
	--Company.Name like 'Manheim%'
	--and CourseScheduled.IntervalId = PersonConfigInterval.IntervalId
	--and PersonConfigInterval.PersonId = PersonConfigure.PersonId
	--and CourseScheduled.SchoolYearId = @schoolYearId
	--and LearnerCourseRecommended.PersonId = @personId


--3 The ClassperiodIds and names for all of the courses (but despite the monday through friday records, we are just going to get a distinct classPeriod since in Manheim's case, they don't vary day by day.
SELECT distinct
	DaysScheduled.DayOfTheWeek,
	DaysScheduled.CourseScheduledId,
	ClassPeriod.ClassPeriodId,
	ClassPeriod.PeriodNumber as ClassPeriodName,
	DaysScheduled.StartTime,
	DaysScheduled.Duration
FROM DaysScheduled
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
WHERE DaysScheduled.CourseScheduledId in (Select CourseScheduledId from #courses)

--4 TeacherCourseAssign
SELECT DISTINCT
	CourseScheduled.CourseScheduledId,
	TeacherCourseAssign.PersonId as TeacherPersonId,
	Person.Fname + ' ' + Person.Lname as TeacherName
FROM CourseScheduled
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN Person on (Person.PersonId = TeacherCourseAssign.PersonId)
	INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
WHERE CourseScheduled.CourseScheduledId in (Select CourseScheduledId from #courses)

--5  Intervals for the CourseScheduled
SELECT
	Interval.IntervalId,
	Interval.Code,
	Interval.Name,
	Interval.Sequence,
	CourseScheduledId,
	Interval.FromMonth,
	Interval.FromDay,
	Interval.ToMonth,
	Interval.ToDay
FROM Interval
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.IntervalId = Interval.IntervalId)
WHERE CourseIntervalAssign.CourseScheduledId in (Select CourseScheduledId from #courses)


DROP TABLE #selectedAccess
DROP TABLE IF EXISTS #courses

END
GO
/****** Object:  StoredProcedure [dbo].[GetCourseWaitListCount]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCourseWaitListCount]
	( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personId from person where username = 'manheim')

--0 the main table.
SELECT distinct
    CourseScheduledId,
    CourseName,
    IntervalId,
    IntervalName,
	IfOpenSeat
INTO #coursesScheduled
FROM (
	SELECT
		CourseScheduled.CourseScheduledId,
		CourseEntry.CourseName,
		Interval.IntervalId,
		Interval.Name as IntervalName,
		AlertWhen.IfOpenSeat
	FROM CourseScheduled
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseScheduled.CompanyId)
		INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = CourseScheduled.SchoolYearId
			and PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId)
		INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
		INNER JOIN AlertWhen on (AlertWhen.CourseScheduledId = CourseScheduled.CourseScheduledId)
	WHERE PersonAccessRoleAssign.PersonId = @personId
	UNION
	SELECT
		ManheimMusicCombinedCourses.CourseScheduledIdGu as CourseScheduledId,
		CourseName,
		null as IntervalId,
		null as IntervalName,
		AlertWhen.IfOpenSeat
	FROM ManheimMusicCombinedCourses
		INNER JOIN AlertWhen on (AlertWhen.CourseScheduledId = ManheimMusicCombinedCourses.CourseScheduledIdGu)
	UNION
	SELECT
		ManheimLearningSupportCombinedCourses.CourseScheduledIdGu as CourseScheduledId,
		CourseName,
		null as IntervalId,
		null as IntervalName,
		AlertWhen.IfOpenSeat
	FROM ManheimLearningSupportCombinedCourses
		INNER JOIN AlertWhen on (AlertWhen.CourseScheduledId = ManheimLearningSupportCombinedCourses.CourseScheduledIdGu)
) as JoinedQuery

select * from #coursesScheduled Order By CourseName


--1 the Class Preferences
SELECT
    CourseScheduledId,
    CourseEntryId,
    PersonId,
    FirstPrefClassPeriodId,
    SecondPrefClassPeriodId,
	FirstPrefClassPeriod.PeriodNumber as FirstPrefClassPeriodName,
	SecondPrefClassPeriod.PeriodNumber as SecondPrefClassPeriodName,
	IfOpenSeat
FROM AlertWhen
	INNER JOIN ClassPeriod as FirstPrefClassPeriod on (FirstPrefClassPeriod.ClassPeriodId = Alertwhen.FirstPrefClassPeriodId)
	INNER JOIN ClassPeriod as SecondPrefClassPeriod on (SecondPrefClassPeriod.ClassPeriodId = Alertwhen.SecondPrefClassPeriodId)
WHERE AlertWhen.CourseScheduledId in (Select CourseScheduledId from #coursesScheduled)

--2 DaysScheduled for ClassPeriod for IfOpenSeat
SELECT distinct
	DaysScheduled.DayOfTheWeek,
	DaysScheduled.CourseScheduledId,
	ClassPeriod.ClassPeriodId,
	ClassPeriod.PeriodNumber as ClassPeriodName
FROM DaysScheduled
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
WHERE DaysScheduled.CourseScheduledId in (Select CourseScheduledId from #coursesScheduled)


DROP TABLE If Exists #coursesScheduled

END
GO
