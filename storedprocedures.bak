/****** Object:  StoredProcedure [dbo].[GetPSWorkSummary]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetPSWorkSummary]
	(@personId uniqueidentifier, @workId uniqueidentifier)
AS
BEGIN
--Declare @personId  as uniqueidentifier
--Declare @workId  as uniqueidentifier
--SET @personId  = '8392A37E-CAFA-4B27-B6DA-44B1729F6003' -- tiara
--SET @workId  = 'E5686B19-5DE6-4565-8BE5-2C8D80150BF8'

--0 Work
--1  FriendWorkAssign
--2  LanguageOptions - separate call according to author or editor.
--3  RecentWorks
--4  LastUpdateDate
--5  WorkLanguageOptions - friend work assign as well as EditDetail since the friend work assign could be taken away after the work is done.
--6  EditorAssign - If this is the editor, it is all editors.  If not, just the editor who is making this query as the user.
--7  CurrentChapter The first chapter of this work, which will be used in case there is not a recent chapter visited by this user.
--8  EditDetails - select * from editdetail
--9  Chapters
--10 Editor Comments about the chapter
--11 AccessRole of the user (to determine teacher or student)


--0 Work
SELECT top 1
    Work.WorkId,
    Work.PersonId,
    AuthorPerson.PersonId as AuthorPersonId,
    GroupWorkAssign.GroupId,
    Groups.GroupName,
    AuthorPerson.fname + ' ' + AuthorPerson.lname as Author,  --redundant, I know.
    AuthorPerson.fname + ' ' + AuthorPerson.lname as AuthorName,
    AuthorPerson.fname as FirstName,
    AuthorPerson.lname as LastName,
    Work.WorkName,
    Work.WorkName as Title,
    Work.Description,
    Work.InternalId,
    Work.EntryDate,
    Work.WorkStatusId,
    CASE WHEN work.WorkStatusId != 1 THEN 1 ELSE 0 END as Completed,
    CASE WHEN work.WorkStatusId = 1 THEN 1 ELSE 0 END as Active,
    WorkStatus.Name as WorkStatusName,
    Work.LanguageId as NativeLanguageId,
    NativeLanguage.Name as NativeLanguageName,
    CASE WHEN OpenCommunityEntry.EditNativeLanguage is null THEN 0 ELSE OpenCommunityEntry.EditNativeLanguage END as EditNativeLanguage,
    --WorkWordCount, --this needs to come from the chapter sum of words per chapter.
    --WorkSentenceCount, -- same as the word count from the chapter loop;
    --LanguagesCount,  --this comes from the FriendWorkAssign count
    --SectionCount, --this comes from the count of chapters present.
    --LanguageId_current, -- this comes from the RecentWorks call, if any
    --LanguageName_current, --same as above.
    --LanguageOptions, --separate call according to author or editor.
    --WorkLanguageOptions, --separate call below.
    --EditorAssign, --separate call below
    --HrefId, -- this comes from the RecentWorks call.
    Work.FileName,
	CASE WHEN OpenCommunityEntry.OpenCommunityEntryId is null THEN 0 ELSE 1 END as HasOpenCommunityEntry,
    Work.GroupWorkStatusId,
    GroupWorkStatus.Name as GroupWorkStatusName,
	StudentAssignmentResponse.StudentAssignmentResponseId,
	Assignment.TotalPoints,
	StudentAssignmentScore.Score,
    CASE WHEN StudentAssignmentResponse.PenspringWorkId is null THEN 0 ELSE 1 END as IsHomework,
    CASE WHEN StudentAssignmentResponse.IsPenspringSubmitted is null THEN 0 ELSE StudentAssignmentResponse.IsPenspringSubmitted END as IsHomeworkSubmitted,
    CASE WHEN StudentAssignmentResponse.PenspringSubmittedDate is null THEN null ELSE PenspringSubmittedDate END as HomeworkSubmittedDate,
	AssignmentGradedBy.GradingType,
	Work.IsDistributableAssignment,
	Work.PublishedDate
INTO #work
FROM Work
    INNER JOIN WorkStatus on (WorkStatus.WorkStatusId = Work.WorkStatusId)
    INNER JOIN Person as AuthorPerson on (Work.Personid = AuthorPerson.PersonId)
    INNER JOIN Language as NativeLanguage on (Work.LanguageId = NativeLanguage.LanguageId)
    LEFT JOIN OpenCommunityEntry on (OpenCommunityEntry.WorkId = Work.WorkId)
    LEFT JOIN GroupWorkStatus on (GroupWorkStatus.GroupWorkStatusId = Work.GroupWorkStatusId)
    LEFT JOIN StudentAssignmentResponse on (StudentAssignmentResponse.PenspringWorkId = Work.WorkId)
    LEFT JOIN Assignment on (Assignment.AssignmentId = StudentAssignmentResponse.AssignmentId)
    LEFT JOIN StudentAssignmentScore on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId
		and StudentAssignmentScore.StudentPersonId = AuthorPerson.PersonId)
	LEFT JOIN GroupWorkAssign on (GroupWorkAssign.GroupWorkAssignId = Work.GroupWorkAssignId)
	LEFT JOIN Groups on (Groups.GroupId = GroupWorkAssign.GroupId)
	LEFT JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = @personId)
	--This is intentionally set here as @personId since it will be null if the user is someone other than the student.
	LEFT JOIN AssignmentGradedBy ON (AssignmentGradedBy.AssignmentId = Assignment.AssignmentId
		and RegistrationStudent.CourseTypeId = AssignmentGradedBy.CourseTypeId)
WHERE Work.WorkId = @workId

SELECT * FROM #work  --we at least need to get the author's PersonId which is the only reason we bother to do this.

----1  FriendWorkAssign
Select distinct
	Friend_PersonId,
	ChapterId,
	EntryDate,
	HideFlag,
	Sequence,
	LanguageId,
	ActiveStatusId,
	OpenCommunityFlag,
	DueDate,
	WorkId
From FriendWorkAssign
Where WorkId = @workId

----2  LanguageOptions - separate call according to author or editor.
IF @personId in (Select PersonId from #work)

	SELECT
		LanguageId,
		Name
	FROM Language

ELSE

	SELECT
		FriendWorkAssign.LanguageId,
		Language.Name
	FROM Language
		INNER JOIN FriendWorkAssign on (FriendWorkAssign.LanguageId = Language.LanguageId)
	WHERE WorkId = @workId
		and Friend_PersonId = @personId

--3  RecentWorks
SELECT top 1
	RecentWorks.LanguageId,
	Language.Name as LanguageName,
	ChapterId,
	currentHrefId,
	RecentDate
FROM RecentWorks
	LEFT JOIN Language on (Language.LanguageId = RecentWorks.LanguageId)
WHERE workId = @workId
Order by RecentDate desc

--4 LastUpdateDate
SELECT top 1
	Chapter.EntryDate
FROM EditDetail
	INNER JOIN Chapter on (Chapter.ChapterId = EditDetail.ChapterId)
WHERE WorkId = @workId
ORDER BY Chapter.EntryDate DESC


--5  WorkLanguageOptions - friend work assign as well as EditDetail since the friend work assign could be taken away after the work is done.
SELECT distinct
	LanguageId,
	Name
FROM (
	SELECT distinct
		Language.LanguageId,
		Language.Name
	FROM EditDetail
		INNER JOIN Chapter on (Chapter.ChapterId = EditDetail.ChapterId)
		INNER JOIN Language on (EditDetail.LanguageId = Language.languageId)
	WHERE Chapter.WorkId = @workId
	UNION
	SELECT distinct
		Language.LanguageId,
		Language.Name as LanguageName
	FROM FriendWorkAssign
		INNER JOIN Language on (FriendWorkAssign.LanguageId = Language.languageId)
	WHERE FriendWorkAssign.WorkId = @workId
) as LanguageQuery


--6  EditorAssign - If this is the editor, it is all editors.  If not, just the editor who is making this query as the user.
IF @personId in (Select PersonId from #work)
	SELECT distinct
		FriendWorkAssign.Friend_PersonId as EditorPersonId,
		Person.Fname as EditorFirstName,
		Person.Lname as EditorLastName,
		WorkId,
		ChapterId,
		Language.LanguageId,
		Language.Name as LanguageName
	FROM FriendWorkAssign
		INNER JOIN Language on (Language.LanguageId = FriendWorkAssign.LanguageId)
		INNER JOIN Person on (Person.PersonId = FriendWorkAssign.Friend_PersonId)
	WHERE FriendWorkAssign.WorkId = @workId

ELSE
	SELECT distinct
		FriendWorkAssign.Friend_PersonId as EditorPersonId,
		Person.Fname as EditorFirstName,
		Person.Lname as EditorLastName,
		WorkId,
		ChapterId,
		Language.LanguageId,
		Language.Name as LanguageName
	FROM FriendWorkAssign
		INNER JOIN Language on (Language.LanguageId = FriendWorkAssign.LanguageId)
		INNER JOIN Person on (Person.PersonId = FriendWorkAssign.Friend_PersonId)
	WHERE FriendWorkAssign.WorkId = @workId
		and Person.PersonId = @personId

--7  current Chapter (or first one in the work) The first chapter of this work, which will be used in case there is not a recent chapter visited by this user.
IF @personId in (Select PersonId from #work)
	SELECT top 1
		Chapter.ChapterId,
		Chapter.Name,
		DueDate,
		WorkStatus.workStatusId,
		workStatus.Name as WorkStatusName
	FROM Chapter
		LEFT JOIN WorkStatus on (WorkStatus.WorkStatusId = Chapter.WorkStatusId)
	WHERE Chapter.WorkId = @workId
	ORDER BY ChapterNbr desc

ELSE
	SELECT top 1
		Chapter.ChapterId,
		Chapter.Name,
		Chapter.DueDate,
		workStatus.workStatusId,
		workStatus.Name as WorkStatusName
	FROM Chapter
		LEFT JOIN WorkStatus on (WorkStatus.WorkStatusId = Chapter.WorkStatusId)
		INNER JOIN FriendWorkAssign on (FriendWorkAssign.ChapterId = Chapter.ChapterId
			and FriendWorkAssign.Friend_PersonId = @personId)
	WHERE Chapter.WorkId = @workId
	ORDER BY ChapterNbr desc


--8 EditDetails - select * from editdetail
SELECT distinct
	Chapter.ChapterId,
	EditType.Name as EditTypeName,
	isComment,
	EditDetail.PersonId,
	EditDetail.HrefId,
	Language.LanguageId,
	Language.Name as LanguageName,
	EditDetail.PendingFlag,
	EditDetail.AgreeCount,
	EditDetail.DisagreeCount,
	EditDetail.TrollCount,
	EditDetail.CopyCount,
	EditDetail.AuthorAccepted,
	EditDetail.Score,
	EditDetail.EntryDate
FROM EditDetail
	INNER JOIN Chapter on (Chapter.ChapterId = EditDetail.ChapterId)
	INNER JOIN EditType on (EditType.EditTypeId = EditDetail.EditTypeId)
	INNER JOIN Language on (Language.LanguageId = EditDetail.LanguageId)
WHERE Chapter.WorkId = @workId

--9  Chapters
SELECT distinct
    Chapter.ChapterId,
    Chapter.Name,
    ChapterNbr,
    --SectionCount, --We get this from other queries
    WorkStatusId,
    WordCount,
    SentenceCount,
    LastUpdate,
    DueDate,
    --EditsPending,  --We get this from other queries
    --EditsProcessed,  --We get this from other queries
    --EditorsCount,  --We get this from other queries
    --WorkStatusName,  --We get this from other queries
    EditSeverity.Name as EditSeverityName,
    ChapterComment.Comment as AuthorComment
	--Editorcomments --comes from another query.
FROM Chapter
	LEFT JOIN EditSeverity on (EditSeverity.EditSeverityId = Chapter.EditSeverityId)
	LEFT JOIN ChapterComment on (ChapterComment.ChapterId = Chapter.ChapterId
		and ChapterComment.PersonId = (Select personId from #work))
WHERE Chapter.WorkId = @workId


--10 Editor Comments about the chapter
SELECT distinct
	ChapterComment.PersonId,
	ChapterComment.ChapterId,
    ChapterComment.EntryDate,
    person.Fname + ' ' + person.Lname as FullName,
    ChapterComment.Comment
FROM ChapterComment
	INNER JOIN Chapter on (Chapter.ChapterId = ChapterComment.ChapterId)
	INNER JOIN Person on (Person.PersonId = ChapterComment.PersonId)
WHERE Chapter.WorkId = @workId

drop table #work

--11 AccessRole of the user (to determine teacher or student)
SELECT top 1
	AccessRoleLearner.Name as AccessRoleName
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
WHERE PersonId = @personId

END
GO
/****** Object:  StoredProcedure [dbo].[GetRecommendByStudent]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetRecommendByStudent]
	( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = 'BD11B536-0EE1-4282-928B-B49A1025BB47'

SELECT StudentPerson.Lname as StudentLastName,
		StudentPerson.Fname as StudentFirstName,
		CourseEntry.CourseName,
		CourseEntry.ExternalId as CourseId,
		FacilitarPerson.Lname as FacilitatorLastName,
		FacilitarPerson.Fname as FacilitatorFirstName
	FROM PersonAccessRoleAssign, LearnerCourseRecommended, CourseEntry, Person as FacilitarPerson, Person as StudentPerson
	WHERE PersonAccessRoleAssign.CompanyId = CourseEntry.CompanyId
		and LearnerCourseRecommended.CourseEntryId = CourseEntry.CourseEntryId
		and FacilitarPerson.PersonId = LearnerCourseRecommended.Entry_PersonId
		and StudentPerson.PersonId = LearnerCourseRecommended.PersonId
		and PersonAccessRoleAssign.PersonId = @personId
	ORDER BY StudentPerson.Lname, StudentPerson.Fname, CourseEntry.CourseName, CourseEntry.ExternalId, FacilitarPerson.Lname, FacilitarPerson.Fname

END
GO
/****** Object:  StoredProcedure [dbo].[GetRecommendByTeacher]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetRecommendByTeacher]
	( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = 'BD11B536-0EE1-4282-928B-B49A1025BB47'

SELECT FacilitarPerson.Lname as FacilitatorLastName,
		FacilitarPerson.Fname as FacilitatorFirstName,
		GradeLevel.Code as GradeLevelName,
		StudentAccess.ExternalId as StudentId,
		CourseEntry.CourseName,
		CourseEntry.ExternalId as CourseId,
		StudentPerson.Lname as StudentLastName,
		StudentPerson.Fname as StudentFirstName
	FROM PersonAccessRoleAssign as UserAccess
		INNER JOIN CourseEntry on (UserAccess.CompanyId = CourseEntry.CompanyId)
		INNER JOIN LearnerCourseRecommended on (LearnerCourseRecommended.CourseEntryId = CourseEntry.CourseEntryId)
		INNER JOIN Person as FacilitarPerson on (FacilitarPerson.PersonId = LearnerCourseRecommended.Entry_PersonId)
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = LearnerCourseRecommended.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign as StudentAccess on (StudentAccess.PersonId = StudentPerson.PersonId)
		INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
	WHERE UserAccess.PersonId = @personId
	ORDER BY FacilitarPerson.Lname, FacilitarPerson.Fname, CourseEntry.CourseName, CourseEntry.ExternalId, StudentPerson.Lname, StudentPerson.Fname

END
GO
/****** Object:  StoredProcedure [dbo].[GetRecommendCourseCount]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetRecommendCourseCount]( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = 'BD11B536-0EE1-4282-928B-B49A1025BB47'

SELECT CourseEntry.CourseName, CourseEntry.ExternalId, count(*) as StudentCount
	FROM PersonAccessRoleAssign, LearnerCourseRecommended, CourseEntry
	WHERE PersonAccessRoleAssign.CompanyId = CourseEntry.CompanyId
		and LearnerCourseRecommended.CourseEntryId = CourseEntry.CourseEntryId
		and PersonAccessRoleAssign.PersonId = @personId
	GROUP BY CourseEntry.CourseName, CourseEntry.ExternalId
	ORDER BY CourseEntry.CourseName

END
GO
/****** Object:  StoredProcedure [dbo].[GetRegistrationPending]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetRegistrationPending]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')

select distinct
	RegistrationTable.RegistrationTableId,
	FinalizedDate,
	RegistrationStatus,
	RegistrationTable.PaidDate,
	RegistrationTable.Account,
	RegistrationTable.CardNumber,
	RegistrationTable.BillingType,
	RegistrationTable.BillingFrequency,
	RegistrationTable.ResponsiblePersonId,
	RegistrationTable.ResponsibleFirstName,
	RegistrationTable.ResponsibleLastName,
	RegistrationTable.SchoolYearId
into #registration
from RegistrationTable
	INNER JOIN PersonAccessRoleAssign as regAccess on (regAccess.PersonId = RegistrationTable.PersonId)
	INNER JOIN PersonAccessRoleAssign as adminAccess on (adminAccess.CompanyId = regAccess.CompanyId)
where adminAccess.PersonId = @personId
	and ((RegistrationTable.PaidDate is null and RegistrationTable.FinalizedDate is not null)
		or RegistrationTable.RegistrationTableId in
			(select RegistrationStudent.RegistrationTableId
			 from RegistrationStudent
			 where RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId
				and FinalizedDate is not null
				and (RegistrationStudent.RegApprovedOrDenied is null or RegistrationStudent.RegApprovedOrDenied = '')))

--0
Select * from #registration

--1
select
	RegistrationGuardianContact.RegistrationTableId,
	RegistrationGuardianContact.PersonId,
	Person.Fname as FirstName,
	Person.Lname as LastName,
	Person.Address1,
	Person.Address2,
	Person.City,
	UsState.Name as UsStateName,
	Country.Name as CountryName,
	Person.Phone,
	Person.EmailAddress,
	CASE WHEN PersonType = 'PRIMARYGUARDIAN' THEN 1 ELSE
		CASE WHEN PersonType = 'SECONDARYGUARDIAN' THEN 2 ELSE
		3 END END as Sequence,
	CASE WHEN PersonType = 'PRIMARYGUARDIAN' THEN 'Primary' ELSE
		CASE WHEN PersonType = 'SECONDARYGUARDIAN' THEN 'Secondary' ELSE
		'Emergency' END END as GuardianType
from RegistrationGuardianContact, Person
	LEFT JOIN UsState on (UsState.USStateID = Person.USStateID)
	LEFT JOIN Country on (Country.CountryID = Person.CountryID)
where RegistrationTableId in (select RegistrationTableId from #registration)
	and RegistrationGuardianContact.PersonId = Person.PersonId
order by Sequence

--2
select
	RegistrationStudent.RegistrationTableId,
	RegistrationStudent.StudentPersonId,
	Person.Fname as FirstName,
	Person.Lname as LastName,
	CourseType.Name as StudentType,
	GradeLevel.Name as GradeLevelName,
	GradeLevel.GradeLevelId,
	RegistrationStudent.Accredited,
	RegistrationStudent.RegApprovedOrDenied,
	RegistrationStudent.RegReviewNote
from Person, RegistrationStudent
	LEFT JOIN CourseType on (CourseType.CourseTypeID = RegistrationStudent.CourseTypeId)
	LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
where RegistrationTableId in (select RegistrationTableId from #registration)
	and Person.PersonId = RegistrationStudent.StudentPersonId
	--and (RegistrationStudent.IsIncomplete is null or RegistrationStudent.IsIncomplete != 1)

--3
select
	RegistrationCourse.RegistrationCourseId,
	RegistrationCourseStudentRequest.StudentPersonId,
	CourseEntry.CourseName,
	LearningPathway.Name as LearningPathwayName,
	RegistrationCourseStudentRequest.Accredited
from CourseEntry, CourseScheduled, RegistrationCourse, LearningPathway, RegistrationCourseStudentRequest
where CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId
	and CourseScheduled.CourseScheduledId = RegistrationCourse.CourseScheduledId
	and CourseEntry.LearningPathwayId = LearningPathway.LearningPathwayId
	and RegistrationCourseStudentRequest.RegistrationCourseId = RegistrationCourse.RegistrationCourseId
	and RegistrationTableId in (select RegistrationTableId from #registration)

DROP TABLE #registration

END
GO
/****** Object:  StoredProcedure [dbo].[GetReportStudentRegistration]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetReportStudentRegistration]
	( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personId from person where username = '23TempalskiA88')

Declare @schoolYearId as UniqueIdentifier
Set @schoolYearId = (Select SchoolYearId from PersonConfigure where PersonID = @personId)


--0 the main table.
select
	StudentPersonId,
	StudentName,
	StudentId,
	GradeLevelName,
	sum(Credits) as Credits
into #students
FROM (
	SELECT
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentName,
		StudentAccess.ExternalId as StudentId,
		GradeLevel.Name as GradeLevelName,
		LearnerCourseAssign.CourseScheduledId,
		sum(CourseEntry.Credits) as Credits
	FROM PersonAccessRoleAssign as UserAccess
		INNER JOIN PersonAccessRoleAssign as StudentAccess on (UserAccess.CompanyId = StudentAccess.CompanyId)
		INNER JOIN Person as StudentPerson on (StudentAccess.PersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (StudentPerson.PersonId = PersonAccessRoleAssign.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
		LEFT JOIN LearnerCourseAssign on (StudentPerson.PersonId = LearnerCourseAssign.PersonId)
		LEFT JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId
			and CourseScheduled.SchoolYearId = @schoolYearId)
		LEFT JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	WHERE UserAccess.PersonId = @personId
	GROUP BY StudentPerson.PersonId, StudentPerson.Lname + ', ' + StudentPerson.Fname, StudentAccess.ExternalId, GradeLevel.Name, LearnerCourseAssign.CourseScheduledId

	UNION

	SELECT
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentName,
		PersonAccessRoleAssign.ExternalId as StudentId,
		GradeLevel.Name as GradeLevelName,
		LearnerCourseAssign.CourseScheduledId,
		sum(Credits * 2) as Credits
	FROM ManheimLearningSupportCombinedCourses
		INNER JOIN LearnerCourseAssign on (ManheimLearningSupportCombinedCourses.CourseScheduledIdGu = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN Person as StudentPerson on (LearnerCourseAssign.PersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (StudentPerson.PersonId = PersonAccessRoleAssign.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
	GROUP BY StudentPerson.PersonId, StudentPerson.Lname + ', ' + StudentPerson.Fname, PersonAccessRoleAssign.ExternalId, GradeLevel.Name, LearnerCourseAssign.CourseScheduledId
	UNION
	SELECT
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentName,
		PersonAccessRoleAssign.ExternalId as StudentId,
		GradeLevel.Name as GradeLevelName,
		LearnerCourseAssign.CourseScheduledId,
		sum(Credits) as Credits
	FROM ManheimMusicCombinedCourses
		INNER JOIN LearnerCourseAssign on (ManheimMusicCombinedCourses.CourseScheduledIdGu = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN Person as StudentPerson on (LearnerCourseAssign.PersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (StudentPerson.PersonId = PersonAccessRoleAssign.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
	GROUP BY StudentPerson.PersonId, StudentPerson.Lname + ', ' + StudentPerson.Fname, PersonAccessRoleAssign.ExternalId, GradeLevel.Name, LearnerCourseAssign.CourseScheduledId
) as UnionQuery
group by StudentPersonId, StudentName, StudentId, GradeLevelName

select * from #students

--1 Semester 1 Block 1
SELECT distinct
	CourseEntry.CourseName,
	PersonId as StudentPersonId
FROM CourseEntry
	INNER JOIN CourseScheduled on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN LearnerCourseAssign on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	INNER JOIN Interval on (CourseIntervalAssign.IntervalId = Interval.IntervalId)
	INNER JOIN DaysScheduled on (CourseScheduled.CourseScheduledId = DaysScheduled.CourseScheduledId)
	INNER JOIN ClassPeriod on (DaysScheduled.ClassPeriodId = ClassPeriod.ClassPeriodId)
WHERE LearnerCourseAssign.PersonId in (select StudentPersonId from #students)
	and (Interval.Code like '%M1%' or  Interval.Code like '%M2%')
	and ClassPeriod.PeriodNumber in ('1', '1A', '1B')
	and CourseScheduled.SchoolYearId = @schoolYearId
UNION
SELECT
	ManheimLearningSupportCombinedCourses.CourseName,
	PersonId as StudentPersonId
FROM ManheimLearningSupportCombinedCourses
	INNER JOIN LearnerCourseAssign on (ManheimLearningSupportCombinedCourses.CourseScheduledIdGu = LearnerCourseAssign.CourseScheduledId)
	INNER JOIN ClassPeriod on (ManheimLearningSupportCombinedCourses.ClassPeriodId = ClassPeriod.ClassPeriodId)
WHERE LearnerCourseAssign.PersonId in (select StudentPersonId from #students)
	and ClassPeriod.PeriodNumber = '1'
UNION
