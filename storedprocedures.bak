/****** Object:  StoredProcedure [dbo].[GetCurbsideCheckInOrOut]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetCurbsideCheckInOrOut]
	(@personId AS UniqueIdentifier,
	@curbsideCheckInOrOutId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'sisbybee@gmail.com')

Declare @accessRoleName as nvarchar(25)

Select top 1 AccessRoleLearner.Name
into #accessRole
From PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
Where PersonAccessRoleAssign.PersonId = @personId

Set @accessRoleName = (select Name from #accessRole);

if @accessRoleName = 'Admin' BEGIN
	SELECT distinct
		CurbsideCheckInOrOutId,
		CheckInOrOut,
		ParentPerson.PersonId as ParentPersonId,
		ParentPerson.Fname + ' ' + ParentPerson.Lname as ParentName,
		CurbsideCheckInOrOut.FileUploadId,
		CurbsideCheckInOrOut.FileUrl,
		ReasonOther,
		CheckInOrOutReasonType.CheckInOrOutReasonTypeId,
		CheckInOrOutReasonType.Name as ReasonTypeName,
		Acknowledged_PersonId,
		AdminPerson.Fname + ' ' + AdminPerson.Lname as AdminName,
		AcknowledgedDate,
		ParentComment,
		AdminComment,
		AcknowledgedType,
		CurbsideCheckInOrOut.EntryDate
	into #curbsideCheckInOrOut
	FROM CurbsideCheckInOrOut
		INNER JOIN Person as ParentPerson on (ParentPerson.PersonId = CurbsideCheckInOrOut.PersonId)
		LEFT JOIN Person as AdminPerson on (AdminPerson.PersonId = CurbsideCheckInOrOut.Acknowledged_PersonId)
		INNER JOIN PersonAccessRoleAssign as ParentAccess on (ParentAccess.PersonId = CurbsideCheckInOrOut.PersonId)
		INNER JOIN PersonAccessRoleAssign as AdminAccess on (AdminAccess.CompanyId = ParentAccess.CompanyId)
		LEFT JOIN CheckInOrOutReasonType on (CheckInOrOutReasonType.CheckInOrOutReasonTypeId = CurbsideCheckInOrOut.CheckInOrOutReasonTypeId)
	WHERE AdminAccess.PersonId = @personId
		and CurbsideCheckInOrOut.EntryDate > DATEADD(day, -1, getDate())
	Order by CurbsideCheckInOrOut.EntryDate desc

	select * from #curbsideCheckInOrOut

	Select
		CurbsideCheckInOrOutStudent.CurbsideCheckInOrOutId,
		StudentPerson.Fname + ' ' + StudentPerson.Lname as StudentName,
		CurbsideCheckInOrOutStudent.StudentPersonId
	FROM CurbsideCheckInOrOutStudent
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = StudentPersonId)
	WHERE CurbsideCheckInOrOutStudent.CurbsideCheckInOrOutId in (Select CurbsideCheckInOrOutId from #curbsideCheckInOrOut)

END
else if @accessRoleName = 'Observer' BEGIN

	SELECT top 1
		CurbsideCheckInOrOutId,
		CheckInOrOut,
		ParentPerson.PersonId as ParentPersonId,
		ParentPerson.Fname + ' ' + ParentPerson.Lname as ParentName,
		CurbsideCheckInOrOut.FileUploadId,
		CurbsideCheckInOrOut.FileUrl,
		ReasonOther,
		CheckInOrOutReasonType.CheckInOrOutReasonTypeId,
		CheckInOrOutReasonType.Name as ReasonTypeName,
		Acknowledged_PersonId,
		AdminPerson.Fname + ' ' + AdminPerson.Lname as AdminName,
		AcknowledgedDate,
		ParentComment,
		AdminComment,
		AcknowledgedType,
		CurbsideCheckInOrOut.EntryDate
	into #curbsideCheckInOrOutParent
	FROM CurbsideCheckInOrOut
		INNER JOIN Person as ParentPerson on (ParentPerson.PersonId = CurbsideCheckInOrOut.PersonId)
		LEFT JOIN Person as AdminPerson on (AdminPerson.PersonId = CurbsideCheckInOrOut.Acknowledged_PersonId)
		LEFT JOIN CheckInOrOutReasonType on (CheckInOrOutReasonType.CheckInOrOutReasonTypeId = CurbsideCheckInOrOut.CheckInOrOutReasonTypeId)
	WHERE CurbsideCheckInOrOut.PersonId = @personId
		and CurbsideCheckInOrOut.EntryDate > DATEADD(day, -1, getDate())
		and ((@curbsideCheckInOrOutId is null or @curbsideCheckInOrOutId = '00000000-0000-0000-0000-000000000000')
			or (@curbsideCheckInOrOutId is not null and @curbsideCheckInOrOutId != '00000000-0000-0000-0000-000000000000'
				and @curbsideCheckInOrOutId = CurbsideCheckInOrOut.CurbsideCheckInOrOutId))
	Order by CurbsideCheckInOrOut.EntryDate desc

	select * from #curbsideCheckInOrOutParent

	Select
		CurbsideCheckInOrOutStudent.CurbsideCheckInOrOutId,
		StudentPerson.Fname + ' ' + StudentPerson.Lname as StudentName,
		CurbsideCheckInOrOutStudent.StudentPersonId
	FROM CurbsideCheckInOrOutStudent
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = StudentPersonId)
	WHERE CurbsideCheckInOrOutStudent.CurbsideCheckInOrOutId in (Select CurbsideCheckInOrOutId from #curbsideCheckInOrOutParent)

END

DROP TABLE IF EXISTS #curbsideCheckInOrOut
DROP TABLE IF EXISTS #curbsideCheckInOrOutParent
DROP TABLE IF EXISTS #accessRole

END
GO
/****** Object:  StoredProcedure [dbo].[GetDiscussionEntries]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO


CREATE PROCEDURE [dbo].[GetDiscussionEntries]
(@personId AS UniqueIdentifier, @courseEntryId as Uniqueidentifier, @assignmentId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @courseEntryId as Uniqueidentifier
--Declare @assignmentId as UniqueIdentifier
--SET @courseEntryId = 'cde106e2-bb4b-4f62-abc5-d8ac8491a014'
--Set @personId = '4E66E25A-8EA6-4801-8BA2-922F65BB3D02'
--Set @assignmentId = (select assignmentId from assignment where discussionentryid = 'acb1bb3a-efdd-432b-a90d-84ce7c43b375')



SELECT distinct
DiscussionEntry.DiscussionEntryId,
DiscussionEntry.ReplyToDiscussionEntryId,
Assignment.AssignmentId,
Assignment.Title as AssignmentTitle,
DiscussionMinPost,
DiscussionWordCount,
DiscussionMinComment,
DiscussionEntry.CourseEntryId,
DiscussionEntry.PersonId,
DiscussionEntry.Subject,
DiscussionEntry.Comment,
Person.Fname as EntryPersonFirstName,
Person.Lname as EntryPersonLastName,
DiscussionEntry.EntryDate
INTO #selectedDiscussionEntries
FROM DiscussionEntry
INNER JOIN Person on (DiscussionEntry.PersonId = person.PersonId)
INNER JOIN Assignment on (DiscussionEntry.AssignmentId = Assignment.AssignmentId)
INNER JOIN CourseScheduled on (DiscussionEntry.CourseEntryId = CourseScheduled.CourseEntryId)
INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
INNER JOIN PersonConfigure on (CourseIntervalAssign.IntervalId = PersonConfigure.IntervalId)
WHERE DiscussionEntry.CourseEntryId = @courseEntryId
and PersonConfigure.PersonID = @personId
and Assignment.AssignmentId = @assignmentId
Order by DiscussionEntry.EntryDate

--0
select * from #selectedDiscussionEntries

--1
SELECT distinct
DiscussionEntry.DiscussionEntryId,
DiscussionEntry.ReplyToDiscussionEntryId,
Assignment.AssignmentId,
Assignment.Title as AssignmentTitle,
DiscussionMinPost,
DiscussionWordCount,
DiscussionMinComment,
DiscussionEntry.CourseEntryId,
DiscussionEntry.PersonId,
DiscussionEntry.Subject,
DiscussionEntry.Comment,
Person.Fname as EntryPersonFirstName,
Person.Lname as EntryPersonLastName,
DiscussionEntry.EntryDate
FROM DiscussionEntry
INNER JOIN Person on (DiscussionEntry.PersonId = person.PersonId)
INNER JOIN Assignment on (DiscussionEntry.AssignmentId = Assignment.AssignmentId)
INNER JOIN CourseScheduled on (DiscussionEntry.CourseEntryId = CourseScheduled.CourseEntryId)
INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
INNER JOIN PersonConfigure on (CourseIntervalAssign.IntervalId = PersonConfigure.IntervalId)
WHERE DiscussionEntry.CourseEntryId = @courseEntryId
and PersonConfigure.PersonID = @personId
and ReplyToDiscussionEntryId is null
and Assignment.AssignmentId is not null
Order by DiscussionEntry.EntryDate

--2
SELECT DiscussionFileUploadId,
DiscussionEntryId,
FileUpload.Name,
FileUpload.FileUploadId,
FileUpload.Url
FROM DiscussionFileUpload
INNER JOIN FileUpload on (FileUpload.FileUPloadId = DiscussionFileUpload.FileUploadId)
WHERE DiscussionEntryId IN ( SELECT DiscussionEntryId FROM #selectedDiscussionEntries)

--3
SELECT DiscussionWebsiteLinkId,
DiscussionEntryId,
Url
FROM DiscussionWebsiteLink
WHERE DiscussionEntryId IN ( SELECT DiscussionEntryId FROM #selectedDiscussionEntries)
and Url is not null and URL != ''


DROP TABLE #selectedDiscussionEntries

END
GO
/****** Object:  StoredProcedure [dbo].[GetDistributedCourses]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[GetDistributedCourses]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

--0
Select distinct
	DistributedCourseTable.DistributedCourseTableId,
	Person.PersonId as StudentPersonId,
	Person.Fname + ' ' + Person.Lname as StudentName,
	DistributedCourseTable.SchoolYearId,
	DistributedCourseTable.Sequence,
	DistributedCourseTable.UnresolvedCount,
	DistributedCourseTable.RequiredClassUnassigned,
	GradeLevel.Name as GradeLevelName,
	DistributedCourseTable.IsChosen
into #distributedCourses
From DistributedCourseTable
	INNER JOIN DistributedCourseDetail on (DistributedCourseDetail.DistributedCourseTableId = DistributedCourseTable.DistributedCourseTableId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = DistributedCourseTable.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = DistributedCourseTable.SchoolYearId
		and PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId)
	INNER JOIN Person on (Person.PersonId = DistributedCourseTable.StudentPersonId)
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Person.PersonId)
	INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
Where PersonAccessRoleAssign.PersonId = @personId
	and DistributedCourseTable.UnresolvedCount is not null
	and DistributedCourseTable.UnresolvedCount > 0
	and RegistrationStudent.StudentPersonId not in
		(Select DistributedCourseTable.StudentPersonId
		 from DistributedCourseTable
		 where IsCompletelyScheduled = 1
			and DistributedCourseTable.StudentPersonId = RegistrationStudent.StudentPersonId)

UNION

Select distinct
	null as DistributedCourseTableId,
	Person.PersonId as StudentPersonId,
	Person.Fname + ' ' + Person.Lname as StudentName,
	StudentBaseCourseRequest.SchoolYearId,
	null as Sequence,
	null as UnresolvedCount,
	null as RequiredClassUnassigned,
	GradeLevel.Name as GradeLevelName,
	null as IsChosen
From StudentBaseCourseRequest
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentBaseCourseRequest.StudentPersonId)
	INNER JOIN PersonAccessRoleAssign as StudentAccess on (StudentAccess.PersonId = StudentBaseCourseRequest.StudentPersonId)
	INNER JOIN PersonAccessRoleAssign as UserAccess on (UserAccess.PersonId = @personId
		and StudentAccess.CompanyId = UserAccess.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = StudentBaseCourseRequest.SchoolYearId
		and PersonConfigure.PersonId = UserAccess.PersonId)
	INNER JOIN Person on (Person.PersonId = StudentBaseCourseRequest.StudentPersonId)
	INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
Where FinalizedDate is not null

select * from #distributedCourses

--1
Select
	DistributedCourseDetail.DistributedCourseDetailId,
	DistributedCourseDetail.DistributedCourseTableId,
	CourseEntry.CourseEntryId,
	CourseEntry.CourseName
From DistributedCourseDetail
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = DistributedCourseDetail.CourseEntryId)
Where DistributedCourseDetail.DistributedCourseTableId in (Select DistributedCourseTableId from #distributedCourses)


Drop Table IF EXISTS #distributedCourses

END
GO
/****** Object:  StoredProcedure [dbo].[GetDoctorNoteInvite]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetDoctorNoteInvite]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')

Select
	DoctorNoteInvite.DoctorNoteInviteId,
	DoctorNoteInvite.CompanyId,
	Company.Name as SchoolName,
	DoctorNoteInvite.AdminPersonId,
	AdminPerson.fname + ' ' + AdminPerson.lname as AdminName,
	DoctorNoteInvite.AdminEntryDate,
	DoctorNoteInvite.DoctorPersonId,
	DoctorOffice.fname + ' ' + DoctorOffice.lname as DoctorOfficeName,
	DoctorNoteInvite.DoctorEmailAddress,
	DoctorNoteInvite.StudentPersonId,
	StudentPerson.fname + ' ' + StudentPerson.lname as StudentName,
	DoctorNoteInvite.FromDate,
	DoctorNoteInvite.ToDate,
	DoctorNoteInvite.AdminNote,
	DoctorNoteInvite.DoctorDeclineNote,
	DoctorNoteInvite.DoctorResponseDate,
	DoctorNoteInvite.IsDecline
From DoctorNoteInvite
	INNER JOIN Company on (Company.CompanyId = DoctorNoteInvite.CompanyId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = DoctorNoteInvite.CompanyId)
	INNER JOIN Person as AdminPerson on (AdminPerson.PersonId = DoctorNoteInvite.AdminPersonId)
	INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = DoctorNoteInvite.StudentPersonId)
	LEFT JOIN Person as DoctorOffice on (DoctorOffice.PersonId = DoctorNoteInvite.DoctorPersonId)
Where  PersonAccessRoleAssign.PersonId = @personId


END
GO
/****** Object:  StoredProcedure [dbo].[GetDoctorNotes]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetDoctorNotes]
( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select top 1 PersonId from person where username = 'jef')

DECLARE @accessRoleName as varchar(15)

SELECT top 1
	AccessRoleLearner.Name as AccessRoleName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
WHERE PersonAccessRoleAssign.PersonId = @personId

SET @accessRoleName = (SELECT top 1 AccessRoleName FROM #selectedAccess)

IF (@accessRoleName = 'Doctor') BEGIN

	SELECT distinct
		DoctorNote.DoctorNoteId,
		DoctorNote.CompanyId,
		DoctorNote.DoctorName,
		DoctorNote.DataEntryName,
		DoctorNote.FromDate,
		DoctorNote.ToDate,
		DoctorNote.Note,
		DoctorNote.EntryDate,
		DoctorNote.DeclineOrApprove,
		DoctorNote.AdminPersonId,
		AdminPerson.fname + ' ' + AdminPerson.lname as AdminName,
		AdminEntryDate,
		DoctorNote.StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentName,
		'Doctor' as EntryPersonRole,
		DoctorNote.DoctorPersonId,
		DoctorOffice.fname as DoctorOfficeName,
		DoctorOffice.Address1 as DoctorAddress,
		DoctorOffice.City as DoctorCity,
		UsState.Name as DoctorState,
		DoctorOffice.Phone as DoctorPhone,
		DoctorOffice.EmailAddress as DoctorEmailAddress
	INTO #doctorList
	FROM DoctorNote
		INNER JOIN Person as DoctorOffice on (DoctorOffice.PersonId = DoctorNote.DoctorPersonId)
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = DoctorNote.StudentPersonId)
		LEFT JOIN Person as AdminPerson on (AdminPerson.PersonId = DoctorNote.AdminPersonId)
		LEFT JOIN UsState on (USState.UsStateId = DoctorOffice.UsStateId)
	WHERE DoctorNote.DoctorPersonId = @personId

	--0 Absence Unexcused
	select * from #doctorList

	--1 File Uploads
	SELECT
		DoctorNote.DoctorNoteId,
		FileUploadId,
		FileUrl,
		Note
	From DoctorNoteFile
		INNER JOIN DoctorNote on (DoctorNote.DoctorNoteId = DoctorNoteFile.DoctorNoteId)
	WHERE DoctorNote.DoctorNoteId in (select DoctorNoteId from #doctorList)

	END

ELSE IF (@accessRoleName = 'Admin') BEGIN

	SELECT distinct
		DoctorNote.DoctorNoteId,
		DoctorNote.CompanyId,
		DoctorNote.DoctorName,
		DoctorNote.DataEntryName,
		DoctorNote.FromDate,
		DoctorNote.ToDate,
		DoctorNote.Note,
		DoctorNote.EntryDate,
		DoctorNote.DeclineOrApprove,
		DoctorNote.AdminPersonId,
		AdminPerson.fname + ' ' + AdminPerson.lname as AdminName,
		AdminEntryDate,
		DoctorNote.StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentName,
		'Doctor' as EntryPersonRole,
		DoctorNote.DoctorPersonId,
		DoctorOffice.fname as DoctorOfficeName,
		DoctorOffice.Address1 as DoctorAddress,
		DoctorOffice.City as DoctorCity,
		UsState.Name as DoctorState,
		DoctorOffice.Phone as DoctorPhone,
		DoctorOffice.EmailAddress as DoctorEmailAddress
	INTO #adminList
	FROM DoctorNote
		INNER JOIN Person as DoctorOffice on (DoctorOffice.PersonId = DoctorNote.DoctorPersonId)
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = DoctorNote.StudentPersonId)
		LEFT JOIN Person as AdminPerson on (AdminPerson.PersonId = DoctorNote.AdminPersonId)
		LEFT JOIN UsState on (USState.UsStateId = DoctorOffice.UsStateId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = DoctorNote.CompanyId)
	WHERE PersonAccessRoleAssign.PersonId = @personId

	--0 Absence Unexcused
	select * from #adminList

	--1 File Uploads
	SELECT
		DoctorNote.DoctorNoteId,
		FileUploadId,
		FileUrl,
		Note
	From DoctorNoteFile
		INNER JOIN DoctorNote on (DoctorNote.DoctorNoteId = DoctorNoteFile.DoctorNoteId)
	WHERE DoctorNote.DoctorNoteId in (select DoctorNoteId from #adminList)

	END

Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #doctorList
Drop Table IF EXISTS #adminList

END
GO
/****** Object:  StoredProcedure [dbo].[GetEssayPendingReview]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetEssayPendingReview]
	@facilitatorPersonId uniqueidentifier
AS
BEGIN
--Declare @facilitatorPersonId as uniqueidentifier
--SET @facilitatorPersonId = (select personid from person where fname = 'rochelle' and lname = 'rudd')

	-- SET NOCOUNT ON added to prevent extra result sets from
	-- interfering with SELECT statements.
	SET NOCOUNT ON;

Select
	Assessment.AssessmentId,
	AssessmentLearnerAnswer.PenspringWorkId,
    Person.PersonId as StudentPersonId,
    company.StudentNameFirst,
    Person.Fname as StudentFirstName,
    Person.Lname as StudentLastName,
    CourseEntry.CourseName,
    Assignment.Title as AssignmentTitle,
    AssessmentQuestion.QuestionText,
    AssessmentQuestion.PointsPossible,
    WorkWordCount.WordCount,
    AssessmentLearnerAnswer.EntryDate
from Assessment
	INNER JOIN AssessmentQuestion on (Assessment.AssessmentId  = AssessmentQuestion.AssessmentId)
    INNER JOIN AssessmentLearnerAnswer on (AssessmentQuestion.AssessmentQuestionId = AssessmentLearnerAnswer.AssessmentQuestionId)
	INNER JOIN Work on (Work.WorkId = AssessmentLearnerAnswer.PenspringWorkId)
    INNER JOIN Assignment on (Assignment.AssessmentId = Assessment.AssessmentId)
    INNER JOIN CourseEntry on (Assignment.CourseEntryId = CourseEntry.CourseEntryId)
    INNER JOIN CourseScheduled on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
    INNER JOIN LearnerCourseAssign on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
    INNER JOIN TeacherCourseAssign on (CourseScheduled.CourseScheduledId = TeacherCourseAssign.CourseScheduledId)
    INNER JOIN Person on (LearnerCourseAssign.PersonId = Person.PersonId),
	Company
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = Company.CompanyId),
	(Select top 1 WorkId, sum(wordCount) as WordCount from Chapter group by workId) as WorkWordCount
		where AssessmentLearnerAnswer .IsSubmitted = 1
		and AssessmentLearnerAnswer .PendingCorrection = 1
		and (AssessmentLearnerAnswer.Score = 0 or AssessmentLearnerAnswer.Score is null)
		and LearnerCourseAssign.PersonId = AssessmentLearnerAnswer .PersonId
		and WorkWordCount.WorkId = Work.WorkId
		and TeacherCourseAssign.PersonId = @facilitatorPersonId

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinanceAccountSummaries]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetFinanceAccountSummaries]
( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'kdunford') --'A2812ACA-BA8D-445F-BFAB-86EF44B9C27F' --'91E033D9-6D29-4A4C-A767-29D499A6D11D'

DECLARE @companyId as UniqueIdentifier
DECLARE @schoolYearId as UniqueIdentifier
DECLARE @intervalId as UniqueIdentifier
DECLARE @accessRoleName as varchar(15)
DECLARE @companyName as varchar(100)

SELECT
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName,
	Company.StudentNameFirst,
	PersonConfigure.SchoolYearId as PersonConfigureSchoolYearId,
	Company.SchoolYearId as CompanySchoolYearId,
	PersonConfigure.IntervalId as PersonConfigureIntervalId,
	Company.IntervalId as CompanyIntervalId
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId)
WHERE PersonAccessRoleAssign.PersonId = @personId

SET @companyId = (SELECT top 1 CompanyId FROM #selectedAccess)
SET @accessRoleName = (SELECT top 1 AccessRoleName FROM #selectedAccess)
SET @companyName = (SELECT top 1 CompanyName FROM #selectedAccess)

SET @schoolYearId = (SELECT top 1 PersonConfigureSchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
SET @schoolYearId = (SELECT top 1 CompanySchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
SET @schoolYearId = (Select SchoolYearId from PersonConfigure where PersonId = @personId)

SET @intervalId = (SELECT top 1 PersonConfigureIntervalId from #selectedAccess)
if (@intervalId is null or @intervalId = '00000000-0000-0000-0000-000000000000')
SET @intervalId = (SELECT top 1 CompanyIntervalId from #selectedAccess)

--0
SELECT StudentNameFirst FROM #selectedAccess

IF @accessRoleName = 'Admin'
BEGIN
	--1
	SELECT distinct
		StudentPerson.PersonId,
		CASE WHEN StudentPerson.PreferredName is not null and StudentPerson.PreferredName != '' THEN StudentPerson.PreferredName ELSE StudentPerson.Fname END as FirstName,
		StudentPerson.Lname as LastName,
		GradeLevel.Name as GradeLevelName,
		RegistrationStudent.GradeLevelId,
		RegistrationGuardianContact.PersonId as PrimaryGuardianPersonId
	INTO #studentListAdmin
	FROM Person as StudentPerson
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign as StudentAccess on (StudentAccess.PersonID = RegistrationStudent.StudentPersonId
			and StudentPerson.PersonId = StudentAccess.PersonId)
		INNER JOIN PersonAccessRoleAssign as UserAccess on (UserAccess.CompanyId = StudentAccess.CompanyId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = StudentAccess.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
			and RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN')
		INNER JOIN PersonAccessGradeLevel on (PersonAccessGradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId
			and PersonAccessGradeLevel.PersonId = UserAccess.PersonId)
		INNER JOIN Person as ParentPerson on (ParentPerson.PersonId = RegistrationGuardianContact.PersonId)
		LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
	WHERE UserAccess.PersonId = @personId
	and RegistrationStudent.SchoolYearId = @schoolYearId

	select * from #studentListAdmin

	--2 Billings
	SELECT
		PersonId,
		sum(Amount) as Amount
	FROM FinanceBilling
	Where PersonId in (Select PersonId from #studentListAdmin)
		and FinanceBillingId not in (Select FinanceBillingId from FinancePaymentDetail where FinanceBillingId is not null)
		and Amount is not null
	Group by PersonId

	--3 Credit accounts
	SELECT
		PersonId,
		Amount
	FROM FinanceCreditAccount
	Where PersonId in (Select PersonId from #studentListAdmin)

	--4 Credit accounts
	SELECT
		PersonId,
		Amount
	FROM FinanceLunchAccount
	Where PersonId in (Select PersonId from #studentListAdmin)

END
ELSE IF (@accessRoleName = 'Observer')
BEGIN

	SELECT distinct
		Person.PersonId,
		CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
		Person.Lname as LastName,
		RegistrationStudent.GradeLevelId,
		GradeLevel.Name as GradeLevelName,
		RegistrationGuardianContact.PersonId as PrimaryGuardianPersonId
	INTO #studentListObserver
	FROM Person
		INNER JOIN PersonAccessRoleAssign on (Person.PersonId = PersonAccessRoleAssign.PersonId )
		INNER JOIN RegistrationStudent on (Person.PersonId = RegistrationStudent.StudentPersonId)
		INNER JOIN RegistrationTable on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN RegistrationGuardianContact on (RegistrationTable.RegistrationTableId = RegistrationGuardianContact.RegistrationTableId
		and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and RegistrationGuardianContact.PersonId = @personId
		and RegistrationStudent.SchoolYearId = @schoolYearId

	select * from #studentListObserver

	--2 Billings
	SELECT
		PersonId,
		sum(Amount) as Amount
	FROM FinanceBilling
	Where PersonId in (Select PersonId from #studentListObserver)
		and FinanceBillingId not in (Select FinanceBillingId from FinancePaymentDetail where FinanceBillingId is not null)
	Group by PersonId

	--3 Credit accounts
	SELECT
		PersonId,
		Amount
	FROM FinanceCreditAccount
	Where PersonId in (Select PersonId from #studentListObserver)

	--4 Credit accounts
	SELECT
		PersonId,
		Amount
	FROM FinanceLunchAccount
	Where PersonId in (Select PersonId from #studentListObserver)


END
ELSE IF (@accessRoleName = 'Learner')
BEGIN

	SELECT DISTINCT
		Person.PersonId,
		CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
		Person.Lname as LastName,
		RegistrationStudent.GradeLevelId,
		GradeLevel.Name as GradeLevelName,
		RegistrationGuardianContact.PersonId as PrimaryGuardianPersonId
	FROM Person
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = Person.PersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Person.PersonId)
		INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
		and RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN')
		INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and PersonAccessRoleAssign.PersonId = @personId
		and RegistrationStudent.SchoolYearId = @schoolYearId

	--2 Billings
	SELECT
		PersonId,
		sum(Amount) as Amount
	FROM FinanceBilling
	Where PersonId = @personId
		and FinanceBillingId not in (Select FinanceBillingId from FinancePaymentDetail where FinanceBillingId is not null)
	Group by PersonId

	--3 Credit accounts
	SELECT
		PersonId,
		Amount
	FROM FinanceCreditAccount
	Where PersonId = @personId

	--4 Credit accounts
	SELECT
		PersonId,
		Amount
	FROM FinanceLunchAccount
	Where PersonId = @personId
END

DROP TABLE #selectedAccess
drop table if exists #studentListAdmin
drop table if exists #studentListObserver

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinanceBillings]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetFinanceBillings]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

Declare @accessRole as nvarchar(50)
Declare @companyId as UniqueIdentifier
Set @accessRole = (select AccessRoleName from #selectedAccess)
Set @companyId = (select CompanyId from #selectedAccess)

if (@accessRole = 'Admin')
	BEGIN

	--0
	SELECT distinct
		FinanceBilling.FinanceBillingId,
		FinanceFeeType.Name as FinanceFeeTypeName,
		FinanceFeeType.FinanceFeeTypeId,
		BilledPerson.fname + ' ' + BilledPerson.lname as BilledPersonName,
		FinanceBilling.Amount,
		FinanceBilling.Description,
		FinanceBilling.CourseScheduledId,
		FinanceBilling.FinanceGlcodeId,
		FinanceGlcode.Name as FinanceGlcodeName,
		FinanceBilling.FinanceGroupTableId,
		FinanceGroupTable.Name as FinanceGroupTableName,
		FinanceBilling.FinanceWaiverScheduleId,
		FinanceWaiverSchedule.Name as FinanceWaiverScheduleName,
		FinanceBilling.FinanceLowIncomeWaiverId,
		FinanceLowIncomeWaiver.Name as FinanceLowIncomeWaiverName,
		FinanceBilling.RefundType,
		FinanceBilling.MandatoryOrOptional,
		FinanceBilling.PartialPayment,
		FinanceBilling.PartialPaymentComment,
		FinanceBilling.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceBilling.PersonId,
		FinanceBilling.EntryDate
	INTO #financeBillingAdmin
	FROM FinanceBilling
		INNER JOIN FinanceFeeType on (FinanceFeeType.FinanceFeeTypeId = FinanceBilling.FinanceFeeTypeId)
		INNER JOIN Person as BilledPerson on (BilledPerson.PersonId = FinanceBilling.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceBilling.EntryPersonId)
		LEFT JOIN FinanceGlcode on (FinanceGlcode.FinanceGlcodeId = FinanceBilling.FinanceGlcodeId)
		LEFT JOIN FinanceGroupTable on (FinanceGroupTable.FinanceGroupTableId = FinanceBilling.FinanceGroupTableId)
		LEFT JOIN FinanceWaiverSchedule on (FinanceWaiverSchedule.FinanceWaiverScheduleid = FinanceBilling.FinanceWaiverScheduleId)
		LEFT JOIN FinanceLowIncomeWaiver on (FinanceLowIncomeWaiver.FinanceLowIncomeWaiverId = FinanceBilling.FinanceLowIncomeWaiverId)
	WHERE FinanceBilling.CompanyId = @companyId
	Order by FinanceBilling.EntryDate

	select * from #financeBillingAdmin

	--1
	SELECT distinct
		FinanceBillingId,
		FileUploadId,
		FileUrl
	FROM FinanceBillingFile
	WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingAdmin)

	--2 Paid billing entries
	SELECT distinct
		FinanceBillingId
	FROM FinancePaymentDetail
	WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingAdmin)

	--3 Refunds
	SELECT distinct
		FinanceRefundId,
		FinanceBillingId,
		PersonId,
		Amount,
		Description,
		CourseScheduledId,
		EntryPersonId,
		EntryDate
	FROM FinanceRefund
	WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingAdmin)


	END

ELSE if (@accessRole = 'Observer')
	BEGIN

	--0
	SELECT distinct
		FinanceBilling.FinanceBillingId,
		FinanceFeeType.Name as FinanceFeeTypeName,
		FinanceFeeType.FinanceFeeTypeId,
		BilledPerson.fname + ' ' + BilledPerson.lname as BilledPersonName,
		FinanceBilling.Amount,
		FinanceBilling.Description,
		FinanceBilling.FinanceGlcodeId,
		FinanceGlcode.Name as FinanceGlcodeName,
		FinanceBilling.FinanceGroupTableId,
		FinanceGroupTable.Name as FinanceGroupTableName,
		FinanceBilling.CourseScheduledId,
		FinanceBilling.FinanceWaiverScheduleId,
		FinanceWaiverSchedule.Name as FinanceWaiverScheduleName,
		FinanceBilling.FinanceLowIncomeWaiverId,
		FinanceLowIncomeWaiver.Name as FinanceLowIncomeWaiverName,
		FinanceBilling.RefundType,
		FinanceBilling.MandatoryOrOptional,
		FinanceBilling.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceBilling.PersonId,
		FinanceBilling.PartialPayment,
		FinanceBilling.PartialPaymentComment,
		FinanceBilling.EntryDate
	INTO #financeBillingObserver
	FROM FinanceBilling
		INNER JOIN FinanceFeeType on (FinanceFeeType.FinanceFeeTypeId = FinanceBilling.FinanceFeeTypeId)
		INNER JOIN Person as BilledPerson on (BilledPerson.PersonId = FinanceBilling.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceBilling.EntryPersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = BilledPerson.PersonId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = @personId
			and RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
		LEFT JOIN FinanceGlcode on (FinanceGlcode.FinanceGlcodeId = FinanceBilling.FinanceGlcodeId)
		LEFT JOIN FinanceGroupTable on (FinanceGroupTable.FinanceGroupTableId = FinanceBilling.FinanceGroupTableId)
		LEFT JOIN FinanceWaiverSchedule on (FinanceWaiverSchedule.FinanceWaiverScheduleid = FinanceBilling.FinanceWaiverScheduleId)
		LEFT JOIN FinanceLowIncomeWaiver on (FinanceLowIncomeWaiver.FinanceLowIncomeWaiverId = FinanceBilling.FinanceLowIncomeWaiverId)
	WHERE FinanceBilling.CompanyId = @companyId
	Order by FinanceBilling.EntryDate

	select * from #financeBillingObserver

	--1
	SELECT distinct
		FinanceBillingId,
		FileUploadId,
		FileUrl
	FROM FinanceBillingFile
	WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingObserver)

	--2 Paid billing entries
	SELECT distinct
		FinanceBillingId
	FROM FinancePaymentDetail
	WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingObserver)

	--3 Refunds
	SELECT distinct
		FinanceRefundId,
		FinanceBillingId,
		PersonId,
		Amount,
		Description,
		CourseScheduledId,
		EntryPersonId,
		EntryDate
	FROM FinanceRefund
	WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingObserver)


	END

ELSE if (@accessRole = 'Learner')
	BEGIN

	--0
	SELECT distinct
		FinanceBilling.FinanceBillingId,
		FinanceFeeType.Name as FinanceFeeTypeName,
		FinanceFeeType.FinanceFeeTypeId,
		BilledPerson.fname + ' ' + BilledPerson.lname as BilledPersonName,
		FinanceBilling.Amount,
		FinanceBilling.Description,
		FinanceBilling.FinanceGlcodeId,
		FinanceGlcode.Name as FinanceGlcodeName,
		FinanceBilling.FinanceGroupTableId,
		FinanceBilling.CourseScheduledId,
		FinanceGroupTable.Name as FinanceGroupTableName,
		FinanceBilling.FinanceWaiverScheduleId,
		FinanceWaiverSchedule.Name as FinanceWaiverScheduleName,
		FinanceBilling.FinanceLowIncomeWaiverId,
		FinanceLowIncomeWaiver.Name as FinanceLowIncomeWaiverName,
		FinanceBilling.RefundType,
		FinanceBilling.MandatoryOrOptional,
		FinanceBilling.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceBilling.PersonId,
		FinanceBilling.PartialPayment,
		FinanceBilling.PartialPaymentComment,
		FinanceBilling.EntryDate
	INTO #financeBillingLearner
	FROM FinanceBilling
		INNER JOIN FinanceFeeType on (FinanceFeeType.FinanceFeeTypeId = FinanceBilling.FinanceFeeTypeId)
		INNER JOIN Person as BilledPerson on (BilledPerson.PersonId = FinanceBilling.PersonId
			and BilledPerson.PersonId = @personId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceBilling.EntryPersonId)
		LEFT JOIN FinanceGlcode on (FinanceGlcode.FinanceGlcodeId = FinanceBilling.FinanceGlcodeId)
		LEFT JOIN FinanceGroupTable on (FinanceGroupTable.FinanceGroupTableId = FinanceBilling.FinanceGroupTableId)
		LEFT JOIN FinanceWaiverSchedule on (FinanceWaiverSchedule.FinanceWaiverScheduleid = FinanceBilling.FinanceWaiverScheduleId)
		LEFT JOIN FinanceLowIncomeWaiver on (FinanceLowIncomeWaiver.FinanceLowIncomeWaiverId = FinanceBilling.FinanceLowIncomeWaiverId)
	WHERE FinanceBilling.CompanyId = @companyId
	Order by FinanceBilling.EntryDate

	select * from #financeBillingLearner

	--1
	SELECT distinct
		FinanceBillingId,
		FileUploadId,
		FileUrl
	FROM FinanceBillingFile
	WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingLearner)


	--2 Paid billing entries
	SELECT distinct
		FinanceBillingId
	FROM FinancePaymentDetail
	WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingLearner)

	--3 Refunds
	SELECT distinct
		FinanceRefundId,
		FinanceBillingId,
		PersonId,
		Amount,
		Description,
		CourseScheduledId,
		EntryPersonId,
		EntryDate
	FROM FinanceRefund
	WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingLearner)

	END


Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #financeBillingAdmin
Drop Table IF EXISTS #financeBillingObserver
Drop Table IF EXISTS #financeBillingLearner

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinanceCourseFees]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetFinanceCourseFees]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

Declare @accessRole as nvarchar(50)
Declare @companyId as UniqueIdentifier
Set @accessRole = (select AccessRoleName from #selectedAccess)
Set @companyId = (select CompanyId from #selectedAccess)

--0
SELECT distinct
	FinanceCourseFee.FinanceCourseFeeId,
	FinanceFeeType.Name as FinanceFeeTypeName,
	FinanceFeeType.FinanceFeeTypeId,
	FinanceCourseFee.Amount,
	FinanceCourseFee.Description,
	FinanceCourseFee.FinanceGlcodeId,
	FinanceGlcode.Name as FinanceGlcodeName,
	FinanceCourseFee.FinanceLowIncomeWaiverId,
	FinanceLowIncomeWaiver.Name as FinanceLowIncomeWaiverName,
	FinanceCourseFee.RefundType,
	FinanceCourseFee.MandatoryOrOptional,
	FinanceCourseFee.EntryPersonId,
	EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
	CourseEntry.CourseEntryId,
	CourseEntry.CourseName,
	FinanceCourseFee.EntryDate
INTO #courseEntrieFinanceFees
FROM CourseEntry
	LEFT JOIN FinanceCourseFee on (CourseEntry.CourseEntryId = FinanceCourseFee.CourseEntryId)
	LEFT JOIN FinanceFeeType on (FinanceFeeType.FinanceFeeTypeId = FinanceCourseFee.FinanceFeeTypeId)
	LEFT JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceCourseFee.EntryPersonId)
	LEFT JOIN FinanceGlcode on (FinanceGlcode.FinanceGlcodeId = FinanceCourseFee.FinanceGlcodeId)
	LEFT JOIN FinanceLowIncomeWaiver on (FinanceLowIncomeWaiver.FinanceLowIncomeWaiverId = FinanceCourseFee.FinanceLowIncomeWaiverId)
WHERE CourseEntry.CompanyId = @companyId
Order by FinanceCourseFee.EntryDate

select * from #courseEntrieFinanceFees

--1 Grade levels
select
	CourseEntryId,
	GradeLevel.GradeLevelId,
	GradeLevel.Name,
	GradeLevel.Code,
	GradeLevel.Sequence
FROM CourseEntryGradeLevel
	INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = CourseEntryGradeLevel.GradeLevelId)
WHERE CourseEntryGradeLevel.CourseEntryId in (Select CourseEntryId from #courseEntrieFinanceFees)


Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #courseEntrieFinanceFees

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinanceCredits]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetFinanceCredits]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

Declare @accessRole as nvarchar(50)
Declare @companyId as UniqueIdentifier
Set @accessRole = (select AccessRoleName from #selectedAccess)
Set @companyId = (select CompanyId from #selectedAccess)

if (@accessRole = 'Admin')
	BEGIN

	--0
	SELECT
		Id,
		CompanyId,
		FinanceCreditTypeName,
		FinanceCreditTypeId,
		CreditPersonName,
		Amount,
		Description,
		EntryPersonId,
		EntryPersonName,
		PersonId,
		EntryDate
	INTO #FinanceCreditTransactionAdmin
	FROM (

		SELECT distinct
			FinanceTransfer.FinanceTransferId as Id,
			FinanceTransfer.CompanyId,
			'Transfer From' as FinanceCreditTypeName,
			null as FinanceCreditTypeId,
			StudentPerson.fname + ' ' + StudentPerson.lname as CreditPersonName,
			FinanceTransfer.Amount * -1 as Amount,
			'Transfer to ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.ToAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
			FinanceTransfer.EntryPersonId,
			EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
			FinanceTransfer.FromPersonId as PersonId,
			FinanceTransfer.EntryDate
		FROM FinanceTransfer
			INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.FromPersonId)
			INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.ToPersonId)
			INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
		WHERE FinanceTransfer.CompanyId = @companyId
			and FinanceTransfer.FromAccountType = 'CREDIT'

		UNION

		SELECT distinct
			FinanceTransfer.FinanceTransferId as Id,
			FinanceTransfer.CompanyId,
			'Transfer To' as FinanceCreditTypeName,
			null as FinanceCreditTypeId,
			StudentPerson.fname + ' ' + StudentPerson.lname as CreditPersonName,
			FinanceTransfer.Amount * -1 as Amount,
			'Transfer from ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.FromAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
			FinanceTransfer.EntryPersonId,
			EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
			FinanceTransfer.ToPersonId as PersonId,
			FinanceTransfer.EntryDate
		FROM FinanceTransfer
			INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.ToPersonId)
			INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.FromPersonId)
			INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
		WHERE FinanceTransfer.CompanyId = @companyId
			and FinanceTransfer.ToAccountType = 'CREDIT'

		UNION

		SELECT distinct
			FinanceCreditTransaction.FinanceCreditTransactionId as Id,
			FinanceCreditTransaction.CompanyId,
			FinanceCreditType.Name as FinanceCreditTypeName,
			FinanceCreditType.FinanceCreditTypeId,
			CreditPerson.fname + ' ' + CreditPerson.lname as CreditPersonName,
			FinanceCreditTransaction.Amount,
			FinanceCreditTransaction.Description,
			FinanceCreditTransaction.EntryPersonId,
			EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
			FinanceCreditTransaction.PersonId,
			FinanceCreditTransaction.EntryDate
		FROM FinanceCreditTransaction
			INNER JOIN FinanceCreditType on (FinanceCreditType.FinanceCreditTypeId = FinanceCreditTransaction.FinanceCreditTypeId)
			INNER JOIN Person as CreditPerson on (CreditPerson.PersonId = FinanceCreditTransaction.PersonId)
			INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceCreditTransaction.EntryPersonId)
		WHERE FinanceCreditTransaction.CompanyId = @companyId
	) as UnionQuery
	Order by EntryDate

	select * from #FinanceCreditTransactionAdmin

	--1
	SELECT distinct
		FinanceCreditTransactionId,
		FileUploadId,
		FileUrl
	FROM FinanceCreditTransactionFile
	WHERE FinanceCreditTransactionId in (select FinanceCreditTransactionId from #FinanceCreditTransactionAdmin)

	END

ELSE if (@accessRole = 'Observer')
	BEGIN

	--0
	SELECT
		Id,
		CompanyId,
		FinanceCreditTypeName,
		FinanceCreditTypeId,
		CreditPersonName,
		Amount,
		Description,
		EntryPersonId,
		EntryPersonName,
		PersonId,
		EntryDate
	INTO #FinanceCreditTransactionObserver
	FROM (

		SELECT distinct
			FinanceTransfer.FinanceTransferId as Id,
			FinanceTransfer.CompanyId,
			'Transfer From' as FinanceCreditTypeName,
			null as FinanceCreditTypeId,
			StudentPerson.fname + ' ' + StudentPerson.lname as CreditPersonName,
			FinanceTransfer.Amount * -1 as Amount,
			'Transfer to ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.ToAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
			FinanceTransfer.EntryPersonId,
			EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
			FinanceTransfer.FromPersonId as PersonId,
			FinanceTransfer.EntryDate
		FROM FinanceTransfer
			INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.FromPersonId)
			INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.ToPersonId)
			INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
			INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
			INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = @personId
				and RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
				and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
			INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
		WHERE FinanceTransfer.CompanyId = @companyId
			and FinanceTransfer.FromAccountType = 'CREDIT'

		UNION

		SELECT distinct
			FinanceTransfer.FinanceTransferId as Id,
			FinanceTransfer.CompanyId,
			'Transfer To' as FinanceCreditTypeName,
			null as FinanceCreditTypeId,
			StudentPerson.fname + ' ' + StudentPerson.lname as CreditPersonName,
			FinanceTransfer.Amount * -1 as Amount,
			'Transfer from ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.FromAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
			FinanceTransfer.EntryPersonId,
			EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
			FinanceTransfer.ToPersonId as PersonId,
			FinanceTransfer.EntryDate
		FROM FinanceTransfer
			INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.ToPersonId)
			INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.FromPersonId)
			INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
			INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
			INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = @personId
				and RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
				and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
			INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
		WHERE FinanceTransfer.CompanyId = @companyId
			and FinanceTransfer.ToAccountType = 'CREDIT'

		UNION

		SELECT distinct
			FinanceCreditTransaction.FinanceCreditTransactionId,
			FinanceCreditTransaction.CompanyId,
			FinanceCreditType.Name as FinanceCreditTypeName,
			FinanceCreditType.FinanceCreditTypeId,
			CreditPerson.fname + ' ' + CreditPerson.lname as CreditPersonName,
			FinanceCreditTransaction.Amount,
			FinanceCreditTransaction.Description,
			FinanceCreditTransaction.EntryPersonId,
			EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
			FinanceCreditTransaction.PersonId,
			FinanceCreditTransaction.EntryDate
		FROM FinanceCreditTransaction
			INNER JOIN FinanceCreditType on (FinanceCreditType.FinanceCreditTypeId = FinanceCreditTransaction.FinanceCreditTypeId)
			INNER JOIN Person as CreditPerson on (CreditPerson.PersonId = FinanceCreditTransaction.PersonId)
			INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceCreditTransaction.EntryPersonId)
			INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = CreditPerson.PersonId)
			INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = @personId
				and RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
				and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
			INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
		WHERE FinanceCreditTransaction.CompanyId = @companyId
	) as UnionQuery
	Order by EntryDate

	select * from #FinanceCreditTransactionObserver

	--1
	SELECT distinct
		FinanceCreditTransactionId,
		FileUploadId,
		FileUrl
	FROM FinanceCreditTransactionFile
	WHERE FinanceCreditTransactionId in (select FinanceCreditTransactionId from #FinanceCreditTransactionObserver)

	END

ELSE if (@accessRole = 'Learner')
	BEGIN

	--0
	SELECT
		Id,
		CompanyId,
		FinanceCreditTypeName,
		FinanceCreditTypeId,
		CreditPersonName,
		Amount,
		Description,
		EntryPersonId,
		EntryPersonName,
		PersonId,
		EntryDate
	INTO #FinanceCreditTransactionLearner
	FROM (

		SELECT distinct
			FinanceTransfer.FinanceTransferId as Id,
			FinanceTransfer.CompanyId,
			'Transfer From' as FinanceCreditTypeName,
			null as FinanceCreditTypeId,
			StudentPerson.fname + ' ' + StudentPerson.lname as CreditPersonName,
			FinanceTransfer.Amount * -1 as Amount,
			'Transfer to ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.ToAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
			FinanceTransfer.EntryPersonId,
			EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
			FinanceTransfer.FromPersonId as PersonId,
			FinanceTransfer.EntryDate
		FROM FinanceTransfer
			INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.FromPersonId
				and StudentPerson.PersonId = @personId)
			INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.ToPersonId)
			INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
		WHERE FinanceTransfer.CompanyId = @companyId
			and FinanceTransfer.FromAccountType = 'CREDIT'

		UNION

		SELECT distinct
			FinanceTransfer.FinanceTransferId as Id,
			FinanceTransfer.CompanyId,
			'Transfer To' as FinanceCreditTypeName,
			null as FinanceCreditTypeId,
			StudentPerson.fname + ' ' + StudentPerson.lname as CreditPersonName,
			FinanceTransfer.Amount * -1 as Amount,
			'Transfer from ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.FromAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
			FinanceTransfer.EntryPersonId,
			EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
			FinanceTransfer.ToPersonId as PersonId,
			FinanceTransfer.EntryDate
		FROM FinanceTransfer
			INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.ToPersonId
				and StudentPerson.PersonId = @personId)
			INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.FromPersonId)
			INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
		WHERE FinanceTransfer.CompanyId = @companyId
			and FinanceTransfer.ToAccountType = 'CREDIT'

		UNION

		SELECT distinct
			FinanceCreditTransaction.FinanceCreditTransactionId,
			FinanceCreditTransaction.CompanyId,
			FinanceCreditType.Name as FinanceCreditTypeName,
			FinanceCreditType.FinanceCreditTypeId,
			CreditPerson.fname + ' ' + CreditPerson.lname as CreditPersonName,
			FinanceCreditTransaction.Amount,
			FinanceCreditTransaction.Description,
			FinanceCreditTransaction.EntryPersonId,
			EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
			FinanceCreditTransaction.PersonId,
			FinanceCreditTransaction.EntryDate
		FROM FinanceCreditTransaction
			INNER JOIN FinanceCreditType on (FinanceCreditType.FinanceCreditTypeId = FinanceCreditTransaction.FinanceCreditTypeId)
			INNER JOIN Person as CreditPerson on (CreditPerson.PersonId = FinanceCreditTransaction.PersonId
				and CreditPerson.PersonId = @personId)
			INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceCreditTransaction.EntryPersonId)
		WHERE FinanceCreditTransaction.CompanyId = @companyId
	) as UnionQuery
	Order by EntryDate

	select * from #FinanceCreditTransactionLearner

	--1
	SELECT distinct
		FinanceCreditTransactionId,
		FileUploadId,
		FileUrl
	FROM FinanceCreditTransactionFile
	WHERE FinanceCreditTransactionId in (select FinanceCreditTransactionId from #FinanceCreditTransactionLearner)

	END


Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #FinanceCreditTransactionAdmin
Drop Table IF EXISTS #FinanceCreditTransactionObserver
Drop Table IF EXISTS #FinanceCreditTransactionLearner

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinanceFeeTypes]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetFinanceFeeTypes]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

--0
SELECT distinct
    FinanceFeeTypeId,
    RefundType,
    Description,
    Name,
    FinanceGlcodeId,
	FinanceLowIncomeWaiverId,
    IsLunch,
    IsCredit,
    IsCourse,
    IsCourseTypeByUser
INTO #financeFeeTypes
FROM FinanceFeeType
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = FinanceFeeType.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId
Order by FinanceFeeType.Name

select * from #financeFeeTypes

--1 School Years
SELECT distinct
	FinanceFeeTypeSchoolYear.FinanceFeeTypeId,
	SchoolYear.SchoolYearId,
	YearInt,
	Name,
	Description
FROM SchoolYear
	INNER JOIN FinanceFeeTypeSchoolYear on (FinanceFeeTypeSchoolYear.SchoolYearId = SchoolYear.SchoolYearId)
WHERE FinanceFeeTypeId in (select FinanceFeeTypeId from #financeFeeTypes)

--2 Usd in
SELECT distinct
	FinanceBilling.FinanceFeeTypeId,
	count(*) as usedIn
FROM FinanceBilling
WHERE FinanceFeeTypeId in (select FinanceFeeTypeId from #financeFeeTypes)
Group by FinanceFeeTypeId


Drop Table IF EXISTS #financeFeeTypes

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinanceLunches]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetFinanceLunches]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

Declare @accessRole as nvarchar(50)
Declare @companyId as UniqueIdentifier
Set @accessRole = (select AccessRoleName from #selectedAccess)
Set @companyId = (select CompanyId from #selectedAccess)

if (@accessRole = 'Admin')

	--0
	SELECT distinct
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentPersonName,
		FinanceTransfer.FinanceTransferId,
		FinanceTransfer.CompanyId,
		FinanceTransfer.Amount * -1 as Amount,
		'Transfer to ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.ToAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
		FinanceTransfer.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceTransfer.EntryDate
	FROM FinanceTransfer
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.FromPersonId)
		INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.ToPersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
	WHERE FinanceTransfer.CompanyId = @companyId
		and FinanceTransfer.FromAccountType = 'LUNCH'

	UNION

	SELECT distinct
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentPersonName,
		FinanceTransfer.FinanceTransferId,
		FinanceTransfer.CompanyId,
		FinanceTransfer.Amount,
		'Transfer from ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.FromAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
		FinanceTransfer.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceTransfer.EntryDate
	FROM FinanceTransfer
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.ToPersonId)
		INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.FromPersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
	WHERE FinanceTransfer.CompanyId = @companyId
		and FinanceTransfer.ToAccountType = 'LUNCH'

	UNION

	SELECT distinct
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentPersonName,
		FinanceLunchTransaction.FinanceLunchTransactionId,
		FinanceLunchTransaction.CompanyId,
		FinanceLunchTransaction.Amount,
		'Payment for lunch credit. ' + IsNull(FinanceLunchTransaction.Description , '') as Description,
		FinanceLunchTransaction.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceLunchTransaction.EntryDate
	FROM FinanceLunchTransaction
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceLunchTransaction.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceLunchTransaction.EntryPersonId)
	WHERE FinanceLunchTransaction.CompanyId = @companyId


ELSE if (@accessRole = 'Observer')

	SELECT distinct
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentPersonName,
		FinanceTransfer.FinanceTransferId,
		FinanceTransfer.CompanyId,
		FinanceTransfer.Amount * -1 as Amount,
		'Transfer to ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.ToAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
		FinanceTransfer.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceTransfer.EntryDate
	FROM FinanceTransfer
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.FromPersonId)
		INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.ToPersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson .PersonId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = @personId
			and RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
	WHERE FinanceTransfer.CompanyId = @companyId
		and FinanceTransfer.FromAccountType = 'LUNCH'

	UNION

	SELECT distinct
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentPersonName,
		FinanceTransfer.FinanceTransferId,
		FinanceTransfer.CompanyId,
		FinanceTransfer.Amount,
		'Transfer from ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.FromAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
		FinanceTransfer.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceTransfer.EntryDate
	FROM FinanceTransfer
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.ToPersonId)
		INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.FromPersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson .PersonId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = @personId
			and RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
	WHERE FinanceTransfer.CompanyId = @companyId
		and FinanceTransfer.ToAccountType = 'LUNCH'

	UNION

	SELECT distinct
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentPersonName,
		FinanceLunchTransaction.FinanceLunchTransactionId,
		FinanceLunchTransaction.CompanyId,
		FinanceLunchTransaction.Amount,
		'Payment for lunch credit. ' + IsNull(FinanceLunchTransaction.Description , '') as Description,
		FinanceLunchTransaction.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceLunchTransaction.EntryDate
	FROM FinanceLunchTransaction
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceLunchTransaction.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceLunchTransaction.EntryPersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson .PersonId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = @personId
			and RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
	WHERE FinanceLunchTransaction.CompanyId = @companyId

ELSE if (@accessRole = 'Learner')

	SELECT distinct
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentPersonName,
		FinanceTransfer.FinanceTransferId,
		FinanceTransfer.CompanyId,
		FinanceTransfer.Amount * -1 as Amount,
		'Transfer to ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.ToAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
		FinanceTransfer.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceTransfer.EntryDate
	FROM FinanceTransfer
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.FromPersonId and StudentPerson.PersonId = @personId)
		INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.ToPersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
	WHERE FinanceTransfer.CompanyId = @companyId
		and FinanceTransfer.FromAccountType = 'LUNCH'

	UNION

	SELECT distinct
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentPersonName,
		FinanceTransfer.FinanceTransferId,
		FinanceTransfer.CompanyId,
		FinanceTransfer.Amount,
		'Transfer from ' + OtherPerson.fname + ' ' + OtherPerson.lname + ' (' + FinanceTransfer.FromAccountType + ') ' + IsNull(FinanceTransfer.Description , '') as Description,
		FinanceTransfer.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceTransfer.EntryDate
	FROM FinanceTransfer
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceTransfer.FromPersonId
			and StudentPerson.PersonId = @personId)
		INNER JOIN Person as OtherPerson on (OtherPerson.PersonId = FinanceTransfer.FromPersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
	WHERE FinanceTransfer.CompanyId = @companyId
		and FinanceTransfer.ToAccountType = 'LUNCH'

	UNION

	SELECT distinct
		StudentPerson.PersonId as StudentPersonId,
		StudentPerson.fname + ' ' + StudentPerson.lname as StudentPersonName,
		FinanceLunchTransaction.FinanceLunchTransactionId,
		FinanceLunchTransaction.CompanyId,
		FinanceLunchTransaction.Amount,
		'Payment for lunch credit. ' + IsNull(FinanceLunchTransaction.Description , '') as Description,
		FinanceLunchTransaction.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceLunchTransaction.EntryDate
	FROM FinanceLunchTransaction
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = FinanceLunchTransaction.PersonId
			 and StudentPerson.PersonId = @personId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceLunchTransaction.EntryPersonId)
	WHERE FinanceLunchTransaction.CompanyId = @companyId


Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #FinanceLunchTransactionAdmin
Drop Table IF EXISTS #FinanceLunchTransactionObserver
Drop Table IF EXISTS #FinanceLunchTransactionLearner

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinancePaymentBillings]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetFinancePaymentBillings]
	(@personId AS UniqueIdentifier,
	 @financePaymentTableId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @financePaymentTableId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')
--Set @financePaymentTableId = '3B4890C2-0C5E-489F-85F5-3B4AC4372C69'

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

Declare @accessRole as nvarchar(50)
Declare @companyId as UniqueIdentifier
Set @accessRole = (select AccessRoleName from #selectedAccess)
Set @companyId = (select CompanyId from #selectedAccess)

--0 Billings


SELECT distinct
	FinancePaymentTableId,
	FinanceBillingId,
	FinanceCreditTransactionId,
	FinanceLunchTransactionId,
	FinanceFeeTypeName,
	FinanceFeeTypeId,
	BilledPersonName,
	Amount,
	Description,
	FinanceGlcodeId,
	FinanceGlcodeName,
	FinanceGroupTableId,
	FinanceGroupTableName,
	FinanceWaiverScheduleId,
	FinanceWaiverScheduleName,
	FinanceLowIncomeWaiverId,
	FinanceLowIncomeWaiverName,
	RefundType,
	MandatoryOrOptional,
	EntryPersonId,
	EntryPersonName,
	PersonId,
	EntryDate
INTO #financeBilling
FROM (
	--FinanceBilling
	SELECT distinct
		FinancePaymentDetail.FinancePaymentTableId,
		FinanceBilling.FinanceBillingId,
		null as FinanceCreditTransactionId,
		null as FinanceLunchTransactionId,
		FinanceFeeType.Name as FinanceFeeTypeName,
		FinanceFeeType.FinanceFeeTypeId,
		BilledPerson.fname + ' ' + BilledPerson.lname as BilledPersonName,
		FinanceBilling.Amount,
		FinanceBilling.Description,
		FinanceBilling.FinanceGlcodeId,
		FinanceGlcode.Name as FinanceGlcodeName,
		FinanceBilling.FinanceGroupTableId,
		FinanceGroupTable.Name as FinanceGroupTableName,
		FinanceBilling.FinanceWaiverScheduleId,
		FinanceWaiverSchedule.Name as FinanceWaiverScheduleName,
		FinanceBilling.FinanceLowIncomeWaiverId,
		FinanceLowIncomeWaiver.Name as FinanceLowIncomeWaiverName,
		FinanceBilling.RefundType,
		FinanceBilling.MandatoryOrOptional,
		FinanceBilling.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceBilling.PersonId,
		FinanceBilling.EntryDate
	FROM FinanceBilling
		INNER JOIN FinancePaymentDetail on (FinancePaymentDetail.FinanceBillingId = FinanceBilling.FinanceBillingId)
		INNER JOIN FinanceFeeType on (FinanceFeeType.FinanceFeeTypeId = FinanceBilling.FinanceFeeTypeId)
		INNER JOIN Person as BilledPerson on (BilledPerson.PersonId = FinanceBilling.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceBilling.EntryPersonId)
		LEFT JOIN FinanceGlcode on (FinanceGlcode.FinanceGlcodeId = FinanceBilling.FinanceGlcodeId)
		LEFT JOIN FinanceGroupTable on (FinanceGroupTable.FinanceGroupTableId = FinanceBilling.FinanceGroupTableId)
		LEFT JOIN FinanceWaiverSchedule on (FinanceWaiverSchedule.FinanceWaiverScheduleid = FinanceBilling.FinanceWaiverScheduleId)
		LEFT JOIN FinanceLowIncomeWaiver on (FinanceLowIncomeWaiver.FinanceLowIncomeWaiverId = FinanceBilling.FinanceLowIncomeWaiverId)
	WHERE FinancePaymentDetail.FinancePaymentTableId = @financePaymentTableId

	UNION

	--Credit
	SELECT distinct
		FinancePaymentDetail.FinancePaymentTableId,
		null as FinanceBillingId,
		FinanceCreditTransaction.FinanceCreditTransactionId,
		null as FinanceLunchTransactionId,
		'Credit' as FinanceFeeTypeName,
		null as FinanceFeeTypeId,
		BilledPerson.fname + ' ' + BilledPerson.lname as BilledPersonName,
		FinanceCreditTransaction.Amount,
		FinanceCreditTransaction.Description,
		null as FinanceGlcodeId,
		null as FinanceGlcodeName,
		null as FinanceGroupTableId,
		null as FinanceGroupTableName,
		null as FinanceWaiverScheduleId,
		null as FinanceWaiverScheduleName,
		null as FinanceLowIncomeWaiverId,
		null as FinanceLowIncomeWaiverName,
		null as RefundType,
		null as MandatoryOrOptional,
		FinanceCreditTransaction.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceCreditTransaction.PersonId,
		FinanceCreditTransaction.EntryDate
	FROM FinanceCreditTransaction
		INNER JOIN FinancePaymentDetail on (FinancePaymentDetail.FinanceCreditTransactionId = FinanceCreditTransaction.FinanceCreditTransactionId)
		INNER JOIN Person as BilledPerson on (BilledPerson.PersonId = FinanceCreditTransaction.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceCreditTransaction.EntryPersonId)
	WHERE FinancePaymentDetail.FinancePaymentTableId = @financePaymentTableId

	UNION

	--Lunch
	SELECT distinct
		FinancePaymentDetail.FinancePaymentTableId,
		null as FinanceBillingId,
		null as FinanceCreditTransactionId,
		FinanceLunchTransaction.FinanceLunchTransactionId,
		'Lunch' as FinanceFeeTypeName,
		null as FinanceFeeTypeId,
		BilledPerson.fname + ' ' + BilledPerson.lname as BilledPersonName,
		FinanceLunchTransaction.Amount,
		FinanceLunchTransaction.Description,
		null as FinanceGlcodeId,
		null as FinanceGlcodeName,
		null as FinanceGroupTableId,
		null as FinanceGroupTableName,
		null as FinanceWaiverScheduleId,
		null as FinanceWaiverScheduleName,
		null as FinanceLowIncomeWaiverId,
		null as FinanceLowIncomeWaiverName,
		null as RefundType,
		null as MandatoryOrOptional,
		FinanceLunchTransaction.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceLunchTransaction.PersonId,
		FinanceLunchTransaction.EntryDate
	FROM FinanceLunchTransaction
		INNER JOIN FinancePaymentDetail on (FinancePaymentDetail.FinanceLunchTransactionId = FinanceLunchTransaction.FinanceLunchTransactionId)
		INNER JOIN Person as BilledPerson on (BilledPerson.PersonId = FinanceLunchTransaction.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceLunchTransaction.EntryPersonId)
	WHERE FinancePaymentDetail.FinancePaymentTableId = @financePaymentTableId

) as UnionQuery

select * from #financeBilling

--1 Files for Billings
SELECT distinct
	FinanceBillingId,
	FileUploadId,
	FileUrl
FROM FinanceBillingFile
WHERE FinanceBillingId in (select FinanceBillingId from #financeBilling)

Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #financeBilling

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinancePayments]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[GetFinancePayments]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

Declare @accessRole as nvarchar(50)
Declare @companyId as UniqueIdentifier
Set @accessRole = (select AccessRoleName from #selectedAccess)
Set @companyId = (select CompanyId from #selectedAccess)

if (@accessRole = 'Admin')
	BEGIN
	--0
	SELECT distinct
		FinancePaymentTable.FinancePaymentTableId,
		FinancePaymentTable.PersonId,
		Person.fname + ' ' + Person.lname as PersonName,
		FinancePaymentType.Name as FinancePaymentTypeName,
		FinancePaymentType.FinancePaymentTypeId,
		FinancePaymentTable.TotalAmount,
		FinancePaymentTable.ApplyFundsTo,
		FinancePaymentTable.Description,
		FinancePaymentTable.ReferenceCode,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinancePaymentTable.EntryPersonId,
		FinancePaymentTable.EntryDate
	INTO #FinancePaymentTableAdmin
	FROM FinancePaymentTable
		INNER JOIN FinancePaymentDetail on (FinancePaymentTable.FinancePaymentTableId = FinancePaymentDetail.FinancePaymentTableId)
		INNER JOIN FinancePaymentType on (FinancePaymentType.FinancePaymentTypeId = FinancePaymentTable.FinancePaymentTypeId)
		INNER JOIN Person on (Person.PersonId = FinancePaymentTable.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinancePaymentTable.EntryPersonId)
	WHERE FinancePaymentTable.CompanyId = @companyId
	Order by FinancePaymentTable.EntryDate

	select * from #FinancePaymentTableAdmin

	--1
	SELECT distinct
		FinancePaymentTableId,
		FileUploadId,
		FileUrl
	FROM FinancePaymentTableFile
	WHERE FinancePaymentTableId in (select FinancePaymentTableId from #FinancePaymentTableAdmin)

	END

ELSE if (@accessRole = 'Observer')
	BEGIN

	--0
	SELECT distinct
		FinancePaymentTable.FinancePaymentTableId,
		FinancePaymentTable.PersonId,
		FinancePaymentType.Name as FinancePaymentTypeName,
		FinancePaymentType.FinancePaymentTypeId,
		Person.fname + ' ' + Person.lname as PersonName,
		FinancePaymentTable.TotalAmount,
		FinancePaymentTable.ApplyFundsTo,
		FinancePaymentTable.Description,
		FinancePaymentTable.ReferenceCode,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinancePaymentTable.EntryPersonId,
		FinancePaymentTable.EntryDate
	INTO #FinancePaymentTableObserver
	FROM FinancePaymentTable
		INNER JOIN FinancePaymentDetail on (FinancePaymentTable.FinancePaymentTableId = FinancePaymentDetail.FinancePaymentTableId)
		INNER JOIN FinancePaymentType on (FinancePaymentType.FinancePaymentTypeId = FinancePaymentTable.FinancePaymentTypeId)
		INNER JOIN Person on (Person.PersonId = FinancePaymentTable.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinancePaymentTable.EntryPersonId)
	WHERE FinancePaymentTable.CompanyId = @companyId
		and (FinancePaymentTable.PersonId = @personId
			or FinancePaymentDetail.FinanceBillingId in (Select financeBillingId
				FROM FinanceBilling
					INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = FinanceBilling.PersonId)
					INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
						and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
					INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
				WHERE RegistrationGuardianContact.PersonId = @personId)
			or FinancePaymentDetail.FinanceLunchTransactionId in (Select FinanceLunchTransactionId
				FROM FinanceLunchTransaction
					INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = FinanceLunchTransaction.PersonId)
					INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
						and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
					INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
				WHERE RegistrationGuardianContact.PersonId = @personId)
			or FinancePaymentDetail.FinanceCreditTransactionId in (Select FinanceCreditTransactionId
				FROM FinanceCreditTransaction
					INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = FinanceCreditTransaction.PersonId)
					INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
						and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
					INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
				WHERE RegistrationGuardianContact.PersonId = @personId))

	select * from #FinancePaymentTableObserver

	--1
	SELECT distinct
		FinancePaymentTableId,
		FileUploadId,
		FileUrl
	FROM FinancePaymentTableFile
	WHERE FinancePaymentTableId in (select FinancePaymentTableId from #FinancePaymentTableObserver)

	END

ELSE if (@accessRole = 'Learner')
	BEGIN

	--0
	SELECT distinct
		FinancePaymentTable.FinancePaymentTableId,
		FinancePaymentTable.PersonId,
		FinancePaymentType.Name as FinancePaymentTypeName,
		FinancePaymentType.FinancePaymentTypeId,
		Person.fname + ' ' + Person.lname as PersonName,
		FinancePaymentTable.TotalAmount,
		FinancePaymentTable.ApplyFundsTo,
		FinancePaymentTable.Description,
		FinancePaymentTable.ReferenceCode,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinancePaymentTable.EntryPersonId,
		FinancePaymentTable.EntryDate
	INTO #FinancePaymentTableLearner
	FROM FinancePaymentTable
		INNER JOIN FinancePaymentDetail on (FinancePaymentTable.FinancePaymentTableId = FinancePaymentDetail.FinancePaymentTableId)
		INNER JOIN FinancePaymentType on (FinancePaymentType.FinancePaymentTypeId = FinancePaymentTable.FinancePaymentTypeId)
		INNER JOIN Person on (Person.PersonId = FinancePaymentTable.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinancePaymentTable.EntryPersonId)
	WHERE FinancePaymentTable.CompanyId = @companyId
		and (FinancePaymentTable.PersonId = @personId
			or FinancePaymentDetail.FinanceBillingId in (Select financeBillingId from FinanceBilling where PersonId = @personId)
			or FinancePaymentDetail.FinanceLunchTransactionId in (Select FinanceLunchTransactionId from FinanceLunchTransaction where PersonId = @personId)
			or FinancePaymentDetail.FinanceCreditTransactionId in (Select FinanceCreditTransactionId from FinanceCreditTransaction where PersonId = @personId))
	Order by FinancePaymentTable.EntryDate

	select * from #FinancePaymentTableLearner

	--1
	SELECT distinct
		FinancePaymentTableId,
		FileUploadId,
		FileUrl
	FROM FinancePaymentTableFile
	WHERE FinancePaymentTableId in (select FinancePaymentTableId from #FinancePaymentTableLearner)

	END

Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #FinancePaymentTableAdmin
Drop Table IF EXISTS #FinancePaymentTableObserver
Drop Table IF EXISTS #FinancePaymentTableLearner

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinanceRefunds]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetFinanceRefunds]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

Declare @accessRole as nvarchar(50)
Declare @companyId as UniqueIdentifier
Set @accessRole = (select AccessRoleName from #selectedAccess)
Set @companyId = (select CompanyId from #selectedAccess)

if (@accessRole = 'Admin')
	BEGIN
	--0
	SELECT distinct
        FinanceRefund.FinanceRefundId,
        FinanceFeeType.Name as FinanceFeeTypeName,
		FinanceFeeType.FinanceFeeTypeId,
        FinanceRefund.FinanceBillingId,
        FinanceRefund.PersonId,
		CreditPerson.fname + ' ' + CreditPerson.lname as CreditPersonName,
		FinanceRefund.Amount,
		FinanceRefund.Description,
		FinanceRefund.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceRefund.EntryDate
	INTO #FinanceRefundAdmin
	FROM FinanceRefund
		INNER JOIN FinanceBilling on (FinanceRefund.FinanceBillingId = FinanceBilling.FinanceBillingId)
		INNER JOIN FinanceFeeType on (FinanceFeeType.FinanceFeeTypeId = FinanceBilling.FinanceFeeTypeId)
		INNER JOIN Person as CreditPerson on (CreditPerson.PersonId = FinanceRefund.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceRefund.EntryPersonId)
	WHERE FinanceBilling.CompanyId = @companyId
	Order by FinanceRefund.EntryDate

	select * from #FinanceRefundAdmin

	--1
	SELECT distinct
		FinanceRefundId,
		FileUploadId,
		FileUrl
	FROM FinanceRefundFile
	WHERE FinanceRefundId in (select FinanceRefundId from #FinanceRefundAdmin)

	END

ELSE if (@accessRole = 'Observer')
	BEGIN

	--0
	SELECT distinct
        FinanceRefund.FinanceRefundId,
        FinanceFeeType.Name as FinanceFeeTypeName,
		FinanceFeeType.FinanceFeeTypeId,
        FinanceRefund.FinanceBillingId,
        FinanceRefund.PersonId,
		CreditPerson.fname + ' ' + CreditPerson.lname as CreditPersonName,
		FinanceRefund.Amount,
		FinanceRefund.Description,
		FinanceRefund.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceRefund.EntryDate
	INTO #FinanceRefundObserver
	FROM FinanceRefund
		INNER JOIN FinanceBilling on (FinanceRefund.FinanceBillingId = FinanceBilling.FinanceBillingId)
		INNER JOIN FinanceFeeType on (FinanceFeeType.FinanceFeeTypeId = FinanceBilling.FinanceFeeTypeId)
		INNER JOIN Person as CreditPerson on (CreditPerson.PersonId = FinanceRefund.PersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceRefund.EntryPersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = CreditPerson.PersonId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = @personId
			and RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
	WHERE FinanceBilling.CompanyId = @companyId
	Order by FinanceRefund.EntryDate

	select * from #FinanceRefundObserver

	--1
	SELECT distinct
		FinanceRefundId,
		FileUploadId,
		FileUrl
	FROM FinanceRefundFile
	WHERE FinanceRefundId in (select FinanceRefundId from #FinanceRefundObserver)

	END

ELSE if (@accessRole = 'Learner')
	BEGIN

	--0
	SELECT distinct
        FinanceRefund.FinanceRefundId,
        FinanceFeeType.Name as FinanceFeeTypeName,
		FinanceFeeType.FinanceFeeTypeId,
        FinanceRefund.FinanceBillingId,
        FinanceRefund.PersonId,
		CreditPerson.fname + ' ' + CreditPerson.lname as CreditPersonName,
		FinanceRefund.Amount,
		FinanceRefund.Description,
		FinanceRefund.EntryPersonId,
		EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
		FinanceRefund.EntryDate
	INTO #FinanceRefundLearner
	FROM FinanceRefund
		INNER JOIN FinanceBilling on (FinanceRefund.FinanceBillingId = FinanceBilling.FinanceBillingId)
		INNER JOIN FinanceFeeType on (FinanceFeeType.FinanceFeeTypeId = FinanceBilling.FinanceFeeTypeId)
		INNER JOIN Person as CreditPerson on (CreditPerson.PersonId = FinanceRefund.PersonId
			and CreditPerson.PersonId = @personId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceRefund.EntryPersonId)
	WHERE FinanceBilling.CompanyId = @companyId
	Order by FinanceRefund.EntryDate

	select * from #FinanceRefundLearner

	--1
	SELECT distinct
		FinanceRefundId,
		FileUploadId,
		FileUrl
	FROM FinanceRefundFile
	WHERE FinanceRefundId in (select FinanceRefundId from #FinanceRefundLearner)

	END


Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #FinanceRefundAdmin
Drop Table IF EXISTS #FinanceRefundObserver
Drop Table IF EXISTS #FinanceRefundLearner

END
GO
/****** Object:  StoredProcedure [dbo].[GetFinanceTransfers]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetFinanceTransfers]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'kdunford')

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId

Declare @accessRole as nvarchar(50)
Declare @companyId as UniqueIdentifier
Set @accessRole = (select AccessRoleName from #selectedAccess)
Set @companyId = (select CompanyId from #selectedAccess)

if (@accessRole = 'Admin')
	BEGIN

	--0
	SELECT distinct
		FinanceTransfer.FinanceTransferId,
        FromPersonId,
		FromPerson.fname + ' ' + FromPerson.lname as FromPersonName,
        ToPersonId,
		ToPerson.fname + ' ' + ToPerson.lname as ToPersonName,
        FromAccountType,
        ToAccountType,
        Amount,
        Description,
        EntryPerson.Fname + ' ' + EntryPerson.Lname as EntryPersonName,
        FinanceTransfer.EntryPersonId,
        FinanceTransfer.EntryDate
	INTO #financeTransfersAdmin
	FROM FinanceTransfer
		INNER JOIN Person as FromPerson on (FromPerson.PersonId = FinanceTransfer.FromPersonId)
		INNER JOIN Person as ToPerson on (ToPerson.PersonId = FinanceTransfer.ToPersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)

	WHERE FinanceTransfer.CompanyId = @companyId
	Order by FinanceTransfer.EntryDate

	select * from #financeTransfersAdmin

	--1
	SELECT distinct
		FinanceTransferId,
		FileUploadId,
		FileUrl
	FROM FinanceTransferFile
	WHERE FinanceTransferId in (select FinanceTransferId from #financeTransfersAdmin)

	END

ELSE if (@accessRole = 'Observer')
	BEGIN

	--0
	SELECT distinct
		FinanceTransfer.FinanceTransferId,
        FromPersonId,
		FromPerson.fname + ' ' + FromPerson.lname as FromPersonName,
        ToPersonId,
		ToPerson.fname + ' ' + ToPerson.lname as ToPersonName,
        FromAccountType,
        ToAccountType,
        Amount,
        Description,
        EntryPerson.Fname + ' ' + EntryPerson.Lname as EntryPersonName,
        FinanceTransfer.EntryPersonId,
        FinanceTransfer.EntryDate
	INTO #FinanceTransferObserver
	FROM FinanceTransfer
		INNER JOIN Person as FromPerson on (FromPerson.PersonId = FinanceTransfer.FromPersonId)
		INNER JOIN Person as ToPerson on (ToPerson.PersonId = FinanceTransfer.ToPersonId)
		INNER JOIN Person as CreditPerson on (CreditPerson.PersonId = FinanceTransfer.FromPersonId
			or CreditPerson.PersonId = FinanceTransfer.ToPersonId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = CreditPerson.PersonId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = @personId
			and RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = @personId and PersonConfigure.SchoolYearId = RegistrationStudent.SchoolYearId)
	WHERE FinanceTransfer.CompanyId = @companyId
	Order by FinanceTransfer.EntryDate

	select * from #FinanceTransferObserver

	--1
	SELECT distinct
		FinanceTransferId,
		FileUploadId,
		FileUrl
	FROM FinanceTransferFile
	WHERE FinanceTransferId in (select FinanceTransferId from #FinanceTransferObserver)

	END

ELSE if (@accessRole = 'Learner')
	BEGIN

	--0
	SELECT distinct
		FinanceTransfer.FinanceTransferId,
        FromPersonId,
		FromPerson.fname + ' ' + FromPerson.lname as FromPersonName,
        ToPersonId,
		ToPerson.fname + ' ' + ToPerson.lname as ToPersonName,
        FromAccountType,
        ToAccountType,
        Amount,
        Description,
        EntryPerson.Fname + ' ' + EntryPerson.Lname as EntryPersonName,
        FinanceTransfer.EntryPersonId,
        FinanceTransfer.EntryDate
	INTO #FinanceTransferLearner
	FROM FinanceTransfer
		INNER JOIN Person as FromPerson on (FromPerson.PersonId = FinanceTransfer.FromPersonId)
		INNER JOIN Person as ToPerson on (ToPerson.PersonId = FinanceTransfer.ToPersonId)
		INNER JOIN Person as CreditPerson on ((CreditPerson.PersonId = FinanceTransfer.FromPersonId
			or CreditPerson.PersonId = FinanceTransfer.ToPersonId)
			and CreditPerson.PersonId = @personId)
		INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceTransfer.EntryPersonId)
	WHERE FinanceTransfer.CompanyId = @companyId
	Order by FinanceTransfer.EntryDate

	select * from #FinanceTransferLearner

	--1
	SELECT distinct
		FinanceTransferId,
		FileUploadId,
		FileUrl
	FROM FinanceTransferFile
	WHERE FinanceTransferId in (select FinanceTransferId from #FinanceTransferLearner)

	END


Drop Table IF EXISTS #selectedAccess
Drop Table IF EXISTS #financeTransfersAdmin
Drop Table IF EXISTS #financeTransfersObserver
Drop Table IF EXISTS #financeTransfersLearner

END
GO
/****** Object:  StoredProcedure [dbo].[GetGradebookAssignments]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetGradebookAssignments]
(@personId AS UniqueIdentifier, @courseScheduledId as Uniqueidentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @courseScheduledId as Uniqueidentifier
--SET @courseScheduledId = '736dd4e7-015f-44aa-8806-9f98ff7ca60a'
--Set @personId = (select personid from person where username = 'jef')

--temporary
--Declare @studentPersonId as UniqueIdentifier
--Set @studentPersonId = (select personid from person where lname='carter' and fname='mary')

DECLARE @courseEntryId as Uniqueidentifier
DECLARE @facilitatorPersonId as UniqueIdentifier
DECLARE @courseTypeId as Uniqueidentifier
DECLARE @weightedScoreCount as INT

SELECT top 1 CourseEntry.CourseEntryId,
	CourseEntry.CourseName,
	CourseEntry.CompanyId,
	Company.StudentNameFirst,
	--CourseScheduled.ClassPeriodId,
	--ClassPeriod.PeriodNumber as ClassPeriodNumber,
	--ClassPeriod.StartTime as ClassPeriodStartTime,
	--ClassPeriod.EndTime as ClassPeriodEndTime,
	CourseScheduled.CourseTypeId,
	CourseScheduled.CourseScheduledId,
	CourseScheduled.GradeScaleTableId,
	FacilitatorPersonId,
	Person.Fname as FacilitatorFirstName,
	Person.LName as FacilitatorLastName
INTO #selectedCourse
FROM CourseScheduled
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN Person on (Person.personId = TeacherCourseAssign.PersonId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	INNER JOIN Company on (Company.CompanyId = CourseEntry.CompanyId)
WHERE CourseScheduled.CourseScheduledId = @courseScheduledId

SET @courseEntryId= (SELECT CourseEntryId FROM #selectedCourse)

--0
select * from #selectedCourse

SELECT distinct Assignment.AssignmentId,
	Assignment.Title,
	Assignment.Instructions,
	Assignment.Sequence,
	Assignment.TotalPoints,
	Assignment.ExtraCredit,
	Assignment.DueDate,
	Assignment.AssessmentId,
	Assignment.BenchmarkTestId,
	Assessment.IsPublished,
	Assignment.ContentTypeId,
	ContentType.Code AS ContentTypeCode,
	ContentType.Name AS ContentTypeName
INTO #selectedAssignments
FROM Assignment
	INNER JOIN CourseScheduled on (CourseScheduled.CourseEntryId = Assignment.CourseEntryId)
	INNER JOIN AssignmentCourseSpecific on (AssignmentCourseSpecific.AssignmentId = Assignment.AssignmentId
		and AssignmentCourseSpecific.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN PersonConfigure  on (PersonConfigure.IntervalId = Assignment.IntervalId)
	INNER JOIN ContentType ON (ContentType.ContentTypeId = Assignment.ContentTypeId)
	LEFT JOIN Assessment ON (Assessment.AssessmentId = Assignment.AssessmentId)
WHERE PersonConfigure.PersonId = @personId
	and CourseScheduled.CourseScheduledId = @courseScheduledId
ORDER BY Assignment.Sequence

--1
SELECT * from #selectedAssignments

SELECT Person.PersonId,
	CASE WHEN Person.preferredName is not null and Len(Person.preferredName) > 1  THEN Person.preferredName ELSE Person.Fname End as FirstName,
	Person.Lname as LastName,
	RegistrationStudent.Accredited,
	RegistrationStudent.SelfPaced,
	RegistrationStudent.WithdrawnDate
INTO #selectedStudentsInCourse
FROM LearnerCourseAssign, Person, RegistrationStudent, CourseScheduled
WHERE LearnerCourseAssign.PersonId = Person.PersonId
	and CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId
	and Person.PersonId = RegistrationStudent.StudentPersonId
	and LearnerCourseAssign.CourseScheduledId = @courseScheduledId
	and RegistrationStudent.SchoolYearId = courseScheduled.SchoolYearId
	--and Person.PersonId = @studentPersonId

--2
SELECT * from #selectedStudentsInCourse

--3
--  If this course has a set of CourseWeightedScore records
-- then calculate the contentTypes and add up all of the grouped records for this student to get the percent
--  Otherwise
--      just get all of the total points and total scores in order to calculate the percentage.
select ContentTypeId, ScorePercent
into #courseWeightedScore
from CourseWeightedScore
where CourseEntryId = @courseEntryId

SET @weightedScoreCount = (SELECT count(*) FROM #courseWeightedScore)

IF @weightedScoreCount > 0 BEGIN
	SELECT StudentAssignmentScore.StudentPersonId as PersonId,
		Assignment.ContentTypeId,
		CourseWeightedScore.ScorePercent,
		CASE WHEN sum(Assignment.TotalPoints) > 0 THEN sum(StudentAssignmentScore.Score) / sum(Assignment.TotalPoints) * (CourseWeightedScore.ScorePercent / 100) ELSE 0 END as PercentGrade
	INTO #selectedStudentOverallGrades
	FROM StudentAssignmentScore, Assignment, CourseWeightedScore
	WHERE StudentAssignmentScore.StudentPersonId IN (select PersonId from #selectedStudentsInCourse)
		and Assignment.ContentTypeId = CourseWeightedScore.ContentTypeId
		and CourseWeightedScore.CourseEntryId = Assignment.CourseEntryId
		and StudentAssignmentScore.AssignmentId = Assignment.AssignmentId
		and StudentAssignmentScore.CourseScheduledId = @courseScheduledId
		and StudentAssignmentScore.AssignmentId IN (select AssignmentId from #selectedAssignments)
		and (StudentAssignmentScore.IsPrevScore = 0 or StudentAssignmentScore.IsPrevScore is null)
		and (StudentAssignmentScore.ScoreNotIncluded = 0 or StudentAssignmentScore.ScoreNotIncluded is null)
		and (StudentAssignmentScore.HasPendingEssayReview is null or StudentAssignmentScore.HasPendingEssayReview = 0)
		and StudentAssignmentScore.Score is not null
	Group BY StudentAssignmentScore.StudentPersonId, Assignment.ContentTypeId, CourseWeightedScore.ScorePercent

	SELECT * from #selectedStudentOverallGrades

END

 ELSE BEGIN
	SELECT StudentAssignmentScore.StudentPersonId as PersonId,
		null as ContentTypeId,
		100 as ScorePercent,
		CASE WHEN sum(Assignment.TotalPoints) > 0 THEN sum(StudentAssignmentScore.Score) / sum(Assignment.TotalPoints) ELSE 0 END as PercentGrade
	INTO #selectedStudentOverallGradesSingle
	FROM StudentAssignmentScore, Assignment
	WHERE StudentAssignmentScore.StudentPersonId IN (select PersonId from #selectedStudentsInCourse)
		and StudentAssignmentScore.AssignmentId = Assignment.AssignmentId
		and StudentAssignmentScore.AssignmentId IN (select AssignmentId from #selectedAssignments)
		and StudentAssignmentScore.CourseScheduledId = @courseScheduledId
		and (StudentAssignmentScore.IsPrevScore = 0 or StudentAssignmentScore.IsPrevScore is null)
		and (StudentAssignmentScore.ScoreNotIncluded = 0 or StudentAssignmentScore.ScoreNotIncluded is null)
		and (StudentAssignmentScore.HasPendingEssayReview is null or StudentAssignmentScore.HasPendingEssayReview = 0)
		and StudentAssignmentScore.Score is not null
	Group BY StudentAssignmentScore.StudentPersonId

	SELECT * from #selectedStudentOverallGradesSingle

   END


--4 All Student Assignment Responses (including the teachers' versions)
SELECT distinct PersonId,
	AssignmentId,
	StudentAssignmentResponse.StudentAssignmentResponseId,
	FileUPload.Url as StudentFileUploadUrl,
	Instructions as StudentTextResponse,
	WebsiteLink as StudentWebsiteLink,
	PenspringWorkId as StudentPenspringWorkId,
	IsPenspringSubmitted,
	PenspringSubmittedDate,
	IsTeacherResponse,
	StudentAssignmentResponse.EntryDate as ResponseEntryDate,
	ResponseVisitedType.Code as ResponseVisitedTypeCode
FROM StudentAssignmentResponse
	LEFT JOIN FileUPload on (FileUPload.FileUPloadId = StudentAssignmentResponse.FileUploadId)
	LEFT JOIN StudentAssignmentResponseVisited on (StudentAssignmentResponseVisited.StudentAssignmentResponseId = StudentAssignmentResponse.StudentAssignmentResponseId and StudentAssignmentResponseVisited.FacilitatorPersonId = @personId)
	LEFT JOIN ResponseVisitedType on (ResponseVisitedType.ResponseVisitedTypeId = StudentAssignmentResponseVisited.ResponseVisitedTypeId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)
	and PersonId IN (select PersonId from #selectedStudentsInCourse)
	and (isDeleted is null or isDeleted = 0)
ORDER BY StudentAssignmentResponse.EntryDate

--5
SELECT AssignmentId,
	FileUpload.FileUploadId,
	FileUpload.Url
FROM AssignmentFile
	LEFT JOIN FileUpload on (FileUpload.FileUPloadId = AssignmentFile.FileUploadId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)

--6
SELECT AssignmentId,
	AssignmentWebsiteLinkId,
	WebsiteLink
FROM AssignmentWebsiteLink
WHERE AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)

--7
SELECT StudentNameFirst FROM #selectedCourse

--8
SELECT companyId FROM #selectedCourse

--9
--All other assigments other than BenchmarkTest (notice that the Assignments with assessment questions get their score from StudentAssignmentScore
--  since it can be a teacher override but also because the final correction of the test saves the total score in StudentAssignmentScore
SELECT distinct
	StudentAssignmentScore.StudentPersonId,
	StudentAssignmentScore.AssignmentId,
	StudentAssignmentScore.ScoreNotIncluded,
	StudentAssignmentScore.HasPendingEssayReview,
	StudentAssignmentScore.KnowledgeRatingSequence,
	StudentAssignmentScore.PassFailSequence,
	Assignment.AssessmentId,
	null as BenchmarkTestId,
	Assignment.ContentTypeId,
	Assignment.TotalPoints as PointsPossible,
	StudentAssignmentScore.Score
FROM StudentAssignmentScore
	INNER JOIN Assignment on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId)
WHERE StudentAssignmentScore.StudentPersonId IN (select PersonId from #selectedStudentsInCourse)
	and StudentAssignmentScore.AssignmentId IN (select AssignmentId from #selectedAssignments)
	and StudentAssignmentScore.CourseScheduledId = @courseScheduledId
	and (StudentAssignmentScore.IsPrevScore = 0 or StudentAssignmentScore.IsPrevScore is null)
	and StudentAssignmentScore.CourseScheduledId = @courseScheduledId
	and (Assignment.BenchmarkTestId is null or Assignment.BenchmarkTestId = '00000000-0000-0000-0000-000000000000')

UNION

--Benchmark Test Assessments
SELECT distinct
	AssessmentLearnerAnswer.PersonId,
	Assignment.AssignmentId,
	'' as ScoreNotIncluded,
	null as HasPendingEssayReview,
	null as KnowledgeRatingSequence,
	null as PassFailSequence,
	BenchmarkTest.AssessmentId,
	Assignment.BenchmarkTestId,
	Assignment.ContentTypeId,
	sum(AssessmentQuestion.PointsPossible) as PointsPossible,
	Sum(AssessmentLearnerAnswer.Score)
FROM Assignment
	INNER JOIN BenchmarkTest on (BenchmarkTest.BenchmarkTestId = Assignment.BenchmarkTestId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = BenchmarkTest.AssessmentId)
	LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
		and AssessmentLearnerAnswer.IsSubmitted = 1
		and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
WHERE AssessmentLearnerAnswer.PersonId IN (select PersonId from #selectedStudentsInCourse)
	and Assignment.AssignmentId IN (select AssignmentId from #selectedAssignments)
Group by Assignment.BenchmarkTestId,
	Assignment.AssignmentId,
	BenchmarkTest.AssessmentId,
	AssessmentLearnerAnswer.PersonId,
	Assignment.ContentTypeId

--UNION

----Assessments (other than BenchmarkTest) which have AssessmentQuestions: ASSESSMENT, Exam, Final or Midterm
--SELECT distinct
--	AssessmentLearnerAnswer.PersonId,
--	Assignment.AssignmentId,
--	'' as ScoreNotIncluded,
--	null as HasPendingEssayReview,
--	null as KnowledgeRatingSequence,
--	null as PassFailSequence,
--	Assessment.AssessmentId,
--	Assignment.BenchmarkTestId,
--	Assignment.ContentTypeId,
--	sum(AssessmentQuestion.PointsPossible) as PointsPossible,
--	Sum(AssessmentLearnerAnswer.Score)
--FROM Assignment
--	INNER JOIN Assessment on (Assessment.AssessmentId = Assignment.AssessmentId)
--	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
--	LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
--		and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
--WHERE AssessmentLearnerAnswer.PersonId IN (select PersonId from #selectedStudentsInCourse)
--	and Assignment.AssignmentId IN (select AssignmentId from #selectedAssignments)
--Group by Assignment.BenchmarkTestId,
--	Assignment.AssignmentId,
--	Assessment.AssessmentId,
--	AssessmentLearnerAnswer.PersonId,
--	Assignment.ContentTypeId


--10
SELECT StudentAssignmentScore.StudentPersonId,
	ContentType.ContentTypeId,
	ContentType.Name as ContentTypeName,
	ContentType.Sequence,
	sum(Assignment.TotalPoints) as TotalPoints,
	sum(StudentAssignmentScore.Score) as TotalScores
INTO #selectedStudentContentTypeScores
FROM StudentAssignmentScore, Assignment, ContentType
WHERE StudentAssignmentScore.StudentPersonId IN (select PersonId from #selectedStudentsInCourse)
	and StudentAssignmentScore.AssignmentId = Assignment.AssignmentId
	and Assignment.ContentTypeId = ContentType.ContentTypeId
	and StudentAssignmentScore.CourseScheduledId = @courseScheduledId
	and StudentAssignmentScore.AssignmentId IN (select AssignmentId from #selectedAssignments)
	and (StudentAssignmentScore.IsPrevScore = 0 or StudentAssignmentScore.IsPrevScore is null)
	and (StudentAssignmentScore.ScoreNotIncluded = 0 or StudentAssignmentScore.ScoreNotIncluded is null)
	and StudentAssignmentScore.Score is not null
	and (StudentAssignmentScore.HasPendingEssayReview is null or StudentAssignmentScore.HasPendingEssayReview = 0)
Group BY StudentAssignmentScore.StudentPersonId, ContentType.Sequence, ContentType.ContentTypeId, ContentType.Name

--(10)
SELECT * from #selectedStudentContentTypeScores

SELECT Distinct
	ContentType.Sequence,
	ContentType.ContentTypeId,
	ContentType.Name as ContentTypeName,
	ContentType.Code as ContentTypeCode
INTO #selectedContentTypes
FROM Assignment, ContentType
WHERE Assignment.ContentTypeId = ContentType.ContentTypeId
	and Assignment.AssignmentId IN (select AssignmentId from #selectedAssignments)

--11
SELECT * from #selectedContentTypes

--12
SELECT
	AssignmentId,
	StudentPersonId
FROM StudentAssignmentAssign
WHERE StudentAssignmentAssign.StudentPersonId in (Select PersonId from #selectedStudentsInCourse)
	and StudentAssignmentAssign.AssignmentId in (SELECT AssignmentId from #selectedAssignments)

--13
SELECT distinct
	DaysScheduled.CourseScheduledId,
	ClassPeriod.ClassPeriodId,
	ClassPeriod.PeriodNumber as ClassPeriodName,
	DaysScheduled.StartTime,
	DaysScheduled.Duration
FROM DaysScheduled
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
WHERE DaysScheduled.CourseScheduledId in (Select CourseScheduledId from #selectedCourse)

--14
SELECT distinct
	CourseScheduledId,
	StudentPersonId,
	SchoolYearId,
	IntervalId,
	GradePercent,
	Incomplete,
	Passed
FROM StudentGradeOverwrite
WHERE CourseScheduledId in (Select CourseScheduledId from #selectedCourse)

--15
SELECT top 1
	StudentGradeFinalId,
	EntryDate
FROM StudentGradeFinal
Where StudentGradeFinal.CoursescheduledId = @coursescheduledId

--16
Select distinct
	BenchmarkTest.BenchmarkTestId,
	AssessmentLearnerAnswer.PersonId,
	Assignment.AssignmentId,
	Assessment.AssessmentId,
	Assessment.IsPublished,
	AssessmentQuestion.AssessmentQuestionId,
	AssessmentLearnerAnswer.Score
INTO #benchmarkTests
FROM Assignment
	INNER JOIN BenchmarkTest on (BenchmarkTest.BenchmarkTestId = Assignment.BenchmarkTestId)
	INNER JOIN Assessment on (Assessment.AssessmentId = BenchmarkTest.AssessmentId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
	LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
		and AssessmentLearnerAnswer.IsSubmitted = 1
		and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
WHERE Assignment.AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)

select * from #benchmarkTests

--17  Scored answers
SELECT distinct
	StudentPersonId,
	AssignmentId,
	BenchmarkTestId,
	AssessmentLearnerAnswerId,
	AssessmentQuestionId,
	LearnerAnswer,
	CorrectAnswer,
	FileUploadId,
	PendingCorrection,
	Score,
	TeacherEssayResponse,
	EssayCorrectionWorkId,
	IsCorrect,
	EntryDate,
	AssessmentId,
	QuestionTypeId,
	QuestionText,
	PointsPossible,
	Sequence,
	IsSubmitted
INTO #assessmentQuestion
FROM (
	--Assessments (other than BenchmarkTest) which have AssessmentQuestions: ASSESSMENT, Exam, Final or Midterm
	SELECT
		AssessmentLearnerAnswer.PersonId as StudentPersonId,
		Assignment.AssignmentId,
		null as BenchmarkTestId,
		AssessmentLearnerAnswer.AssessmentLearnerAnswerId,
		AssessmentLearnerAnswer.AssessmentQuestionId,
		AssessmentLearnerAnswer.LearnerAnswer,
		AssessmentQuestion.CorrectAnswer,
		AssessmentLearnerAnswer.FileUploadId,
		AssessmentLearnerAnswer.PendingCorrection,
		AssessmentLearnerAnswer.Score,
		AssessmentLearnerAnswer.TeacherEssayResponse,
		AssessmentLearnerAnswer.EssayCorrectionWorkId,
		AssessmentLearnerAnswer.IsCorrect,
		AssessmentLearnerAnswer.EntryDate,
		AssessmentQuestion.AssessmentId,
		AssessmentQuestion.QuestionTypeId,
		AssessmentQuestion.QuestionText,
		AssessmentQuestion.PointsPossible,
		AssessmentQuestion.Sequence,
		AssessmentLearnerAnswer.IsSubmitted
	FROM Assignment
		INNER JOIN Assessment on (Assessment.AssessmentId = Assignment.AssessmentId)
		INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
		LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
			and AssessmentLearnerAnswer.IsSubmitted = 1
			and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
	WHERE Assignment.AssignmentId in (select AssignmentId from #selectedAssignments)

	UNION

	--Assignments that do not have an assessment with questions, but an assessment can have an assessment record such as ASSESSMENT, Exam, Final or Midterm
	SELECT
		StudentAssignmentScore.StudentPersonId,
		Assignment.AssignmentId,
		null as BenchmarkTestId,
		null as AssessmentLearnerAnswerId,
		null AssessmentQuestionId,
		null as LearnerAnswer,
		null as CorrectAnswer,
		null as FileUploadId,
		StudentAssignmentScore.HasPendingEssayReview as PendingCorrection,
		StudentAssignmentScore.Score,
		null as TeacherEssayResponse,
		null as EssayCorrectionWorkId,
		null as IsCorrect,
		StudentAssignmentScore.EntryDate,
		null as AssessmentId,
		null as QuestionTypeId,
		null as QuestionText,
		Assignment.TotalPoints as PointsPossible,
		null as Sequence,
		null as IsSubmitted
	FROM Assignment
		INNER JOIN StudentAssignmentScore on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId
			and StudentAssignmentScore.CourseScheduledId = @courseScheduledId)
	WHERE (Assignment.AssessmentId is null or Assignment.AssessmentId = '00000000-0000-0000-0000-000000000000'
			or Assignment.AssessmentId not in (Select AssessmentId from AssessmentQuestion))
		and Assignment.AssignmentId in (select AssignmentId from #selectedAssignments)

	UNION

	--Benchmark Test Assessments
	SELECT
		AssessmentLearnerAnswer.PersonId as StudentPersonId,
		Assignment.AssignmentId,
		#benchmarkTests.BenchmarkTestId,
		AssessmentLearnerAnswer.AssessmentLearnerAnswerId,
		AssessmentLearnerAnswer.AssessmentQuestionId,
		AssessmentLearnerAnswer.LearnerAnswer,
		AssessmentQuestion.CorrectAnswer,
		AssessmentLearnerAnswer.FileUploadId,
		AssessmentLearnerAnswer.PendingCorrection,
		AssessmentLearnerAnswer.Score,
		AssessmentLearnerAnswer.TeacherEssayResponse,
		AssessmentLearnerAnswer.EssayCorrectionWorkId,
		AssessmentLearnerAnswer.IsCorrect,
		AssessmentLearnerAnswer.EntryDate,
		AssessmentQuestion.AssessmentId,
		AssessmentQuestion.QuestionTypeId,
		AssessmentQuestion.QuestionText,
		AssessmentQuestion.PointsPossible,
		AssessmentQuestion.Sequence,
		AssessmentLearnerAnswer.IsSubmitted
	FROM Assignment
		INNER JOIN #benchmarkTests on (#benchmarkTests.AssignmentId = Assignment.AssignmentId)
		INNER JOIN Assessment on (Assessment.AssessmentId = #benchmarkTests.AssessmentId)
		INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
		LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
			and AssessmentLearnerAnswer.IsSubmitted = 1
			and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
	WHERE AssessmentQuestion.AssessmentId in (Select AssessmentId from #benchmarkTests)
) as UnionQuery

Select * from #assessmentQuestion

--18  Standards assigned to assessment questions, if any.
Select distinct
	AssessmentQuestion.AssessmentQuestionId,
	StandardSchool.StandardSchoolId,
	StandardSchool.LearningPathwayId,
	StandardSchool.Name,
	StandardSchool.Code,
	StandardSchool.Sequence
From AssessmentQuestionStandard
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentQuestionStandard.AssessmentQuestionId)
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssessmentQuestionStandard.StandardSchoolId)
Where AssessmentQuestion.AssessmentQuestionId in (Select AssessmentQuestionId from #assessmentQuestion)

--19  Standards assigned to non-assessment-questions assignments, if any.
Select distinct
	AssignmentStandard.AssignmentId,
	StandardSchool.StandardSchoolId,
	StandardSchool.LearningPathwayId,
	StandardSchool.Name,
	StandardSchool.Code,
	StandardSchool.Sequence
From AssignmentStandard
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssignmentStandard.StandardSchoolId)
Where AssignmentStandard.AssignmentId in (Select AssignmentId from #selectedAssignments)

--20  Assessments with assessment questions
Select distinct
	Assignment.AssessmentId,
	null as BenchmarkTestId,
	AssessmentQuestion.AssessmentQuestionId
From Assignment
	INNER JOIN Assessment on (Assessment.AssessmentId = Assignment.AssessmentId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
Where Assignment.AssignmentId in (Select AssignmentId from #selectedAssignments)

UNION

Select distinct
	BenchmarkTest.AssessmentId,
	BenchmarkTest.BenchmarkTestId,
	AssessmentQuestion.AssessmentQuestionId
From Assignment
	INNER JOIN BenchmarkTest on (BenchmarkTest.BenchmarkTestId = Assignment.BenchmarkTestId)
	INNER JOIN Assessment on (Assessment.AssessmentId = BenchmarkTest.AssessmentId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
Where Assignment.AssignmentId in (Select AssignmentId from #selectedAssignments)


DROP TABLE if exists #selectedCourse
DROP TABLE if exists #courseWeightedScore
DROP TABLE if exists #selectedStudentOverallGrades
DROP TABLE if exists #selectedStudentOverallGradesSingle
DROP TABLE if exists #selectedAssignments
DROP TABLE if exists #selectedStudentsInCourse
DROP TABLE if exists #selectedStudentContentTypeScores
DROP TABLE if exists #selectedContentTypes
DROP TABLE if exists #benchmarkTests
DROP TABLE if exists #assessmentQuestion

END
GO
/****** Object:  StoredProcedure [dbo].[GetGradeReport]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetGradeReport]
	(@personId AS UniqueIdentifier,
	 @studentPersonId AS UniqueIdentifier,
	 @schoolYearId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Declare @schoolYearId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'jef')
--Set @studentPersonId = (Select personid from person where username = 'tiara')
--Set @schoolYearId = (Select SchoolYearId from PersonConfigure where PersonId = @personId)

SELECT
	StudentPerson.PersonId as StudentPersonId,
	StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentFullName,
	SchoolYear.SchoolYearId,
	SchoolYear.Name as SchoolYearName,
	GradeLevel.GradeLevelId,
	GradeLevel.Name as GradeLevelName,
	RegistrationStudent.Accredited as StudentAccredited
From SchoolYear, Person as StudentPerson
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId
		and RegistrationStudent.SchoolYearId = @schoolYearId)
	LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
Where SchoolYear.SchoolYearId = @schoolYearId
	and StudentPerson.PersonId = @studentPersonId

select 	CourseEntry.credits,
    CourseScheduled.CourseScheduledId,
    CourseEntry.CourseName,
    Interval.IntervalId as IntervalId,
    Interval.Name as IntervalName,
	StudentGradeFinal.Accredited as CourseAssignAccredited,
	StudentGradeFinal.GPA as GradePointAverage,
    StudentGradeFinal.LetterGrade
from coursescheduled
	INNER JOIN courseentry on (courseentry.courseentryId = coursescheduled.courseentryId and (CourseEntry.IsInactive is null or CourseEntry.IsInactive != 1))
	INNER JOIN StudentGradeFinal on (StudentGradeFinal.courseScheduledId = courseScheduled.courseScheduledId)
	INNER JOIN Interval on (Interval.Intervalid = StudentGradeFinal.Intervalid)
where StudentGradeFinal.StudentPersonId = @studentPersonId
	and CourseScheduled.SchoolYearId = @schoolYearId
	and CourseEntry.CourseName != 'Seminary'


END
GO
/****** Object:  StoredProcedure [dbo].[GetGraduationRequirements]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetGraduationRequirements]
(@studentPersonId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @studentPersonId as UniqueIdentifier
--Set @studentPersonId = 'FCA622C9-1ED0-4A0D-B976-048CB62F691C' --'EDA92C06-4F8E-4C05-B724-03E9E54F1F1B'  -- 'DD26DD2F-B384-416E-8BF0-1876E830B351' --'8392A37E-CAFA-4B27-B6DA-44B1729F6003'

Declare @currentSchoolYearInt as int
Declare @nextSchoolYearInt as int
Declare @graduationSchoolYearInt as int
Declare @hasIEP as bit

--Get the current school year int.  Find the student's grade level.  Determine the graduation year by schoolYearInt
--If month is 6 or more, then add 1 to the year and match that year up to the schoolYearInt
--Take the gradelevel.  Take 12 minus the gradelevel and add that number to the current SchoolYearInt.  That is the graduation year.
select CASE WHEN MONTH(getdate()) >= 6 THEN YEAR(getdate()) + 1 ELSE YEAR(getdate()) END as CurrentSchoolYearInt into #currentSchoolYear

Set @currentSchoolYearInt = (Select CurrentSchoolYearInt from #currentSchoolYear)
set @nextSchoolYearInt = @currentSchoolYearInt + 1

SELECT top 1
	GradeLevel.Code as GradeLevelCode,
	ISNULL(IEP,0) as IEP
INTO #regStudent
FROM RegistrationStudent
	INNER JOIN GradeLevel on (RegistrationStudent.GradeLevelId = GradeLevel.GradeLevelId)
	INNER JOIN PersonAccessRoleAssign on (RegistrationStudent.StudentPersonId = PersonAccessRoleAssign.PersonId)
WHERE RegistrationStudent.StudentPersonId = @studentPersonId

Set @hasIEP = (select IEP from #regStudent)
Set @graduationSchoolYearInt = (Select 12 - Convert(int, GradeLevelCode) + @currentSchoolYearInt from #regStudent)

--SELECT
--	GraduationRequirement.GraduationRequirementId,
--	GraduationRequirement.CourseName,
--    GraduationRequirement.Notes,
--    GraduationRequirement.CreditsRequired,
--    GraduationRequirement.LearningPathwayId,
--	GraduationRequirement.OrCoursesSpecific1,
--	GraduationRequirement.OrCoursesSpecific2
--into #graduationRequirement_CourseSpecific
--FROM GraduationRequirement
--	INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
--WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
--	and GraduationRequirement.IEP = (SELECT IEP FROM #regStudent)
--	and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt

--select @graduationSchoolYearInt

--Check to see if this student has fulfilled the graduation requirements
--a. How many credits does the student have that match the LearningPathwayId...
--		i. From transcripts (before 2018-2019)
--		ii. From transcripts for graduating class 2021+ (Math) from 8th grade '181', '0181', '184', '0184','184v', '0184v','185V', '0185V','680V', '0680V'
--		iii. From transcripts for graduating class 2023+ (HUM) from 8th grade '680V', '0680V'
--		iv. From current enrollment for both fall and spring 2018-2019
--b. How many credits from specific courses does the student have that match the OrCoursesSpecific1 and/or OrCoursesSpecific2 classes...
--		i. From transcripts (before 2018-2019)
--			1. From the query that matches the 'or' conditions of OrCoursesSpecific1 classes (that don't require OrCoursesSpecific2)
--			2. From the query that fulfilles the Or conditions of both the OrCoursesSpecific1 and OrCoursesSpecific2 classes
--		ii. From current enrollment for both fall and spring 2018-2019
--			1. From the query that matches the 'or' conditions of OrCoursesSpecific1 classes (that don't require OrCoursesSpecific2)
--			2. From the query that fulfilles the Or conditions of both the OrCoursesSpecific1 and OrCoursesSpecific2 classes
--Don't forget the CourseSpecifci_GradeLevelId to compare gradeLevelId or blank.

SELECT
	GraduationRequirementId,
	CourseName,
    Notes,
    CreditsRequired,
    LearningPathwayId,
	Sequence,
	Sum(CreditsEarnedOrInProgress) as CreditsEarnedOrInProgress
FROM (
--a. How many credits does the student have that match the LearningPathwayId...
--		i. From transcripts (before 2018-2019)
SELECT
	GraduationRequirement.GraduationRequirementId,
	GraduationRequirement.CourseName,
    GraduationRequirement.Notes,
    GraduationRequirement.CreditsRequired,
    GraduationRequirement.LearningPathwayId,
	Sequence,
	Sum(CourseEntry.Credits) as CreditsEarnedOrInProgress
FROM GraduationRequirement
	INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN StudentTranscript on (PersonAccessRoleAssign.ExternalId = StudentTranscript.StudentId and StudentTranscript.CreditsEarned > 0)
	LEFT JOIN CourseEntry on ((CourseEntry.ExternalId = StudentTranscript.CourseId)
		and CourseEntry.LearningPathwayId = GraduationRequirement.LearningPathwayId
		and CourseEntry.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
	and GraduationRequirement.IEP = @hasIEP
	and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
	and CourseEntry.ExternalId not in ('181', '0181', '184', '0184','184v', '0184v','185V', '0185V','680V', '0680V')
GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId, Sequence

UNION
--a. How many credits does the student have that match the LearningPathwayId...
--		ii. From transcripts for graduating class 2021+ (Math) from 8th grade '181', '0181', '184', '0184','184v', '0184v','185V', '0185V','680V', '0680V'
SELECT
	GraduationRequirement.GraduationRequirementId,
	GraduationRequirement.CourseName,
    GraduationRequirement.Notes,
    GraduationRequirement.CreditsRequired,
    GraduationRequirement.LearningPathwayId,
	Sequence,
	Sum(CourseEntry.Credits) as CreditsEarnedOrInProgress
FROM GraduationRequirement
	INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN StudentTranscript on (PersonAccessRoleAssign.ExternalId = StudentTranscript.StudentId and StudentTranscript.CreditsEarned > 0)
	LEFT JOIN CourseEntry on ((CourseEntry.ExternalId = StudentTranscript.CourseId)
		and CourseEntry.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
	and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
	and @graduationSchoolYearInt >= 2021
	and CourseEntry.ExternalId in ('181', '0181', '184', '0184','184v', '0184v','185V', '0185V','680V')
GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId, Sequence

UNION
--a. How many credits does the student have that match the LearningPathwayId...
--		iii. From transcripts for graduating class 2023+ (HUM) from 8th grade '680V', '0680V'
SELECT
	GraduationRequirement.GraduationRequirementId,
	GraduationRequirement.CourseName,
    GraduationRequirement.Notes,
    GraduationRequirement.CreditsRequired,
    GraduationRequirement.LearningPathwayId,
	Sequence,
	Sum(CourseEntry.Credits) as CreditsEarnedOrInProgress
FROM GraduationRequirement
	INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN StudentTranscript on (PersonAccessRoleAssign.ExternalId = StudentTranscript.StudentId and StudentTranscript.CreditsEarned > 0)
	LEFT JOIN CourseEntry on ((CourseEntry.ExternalId = StudentTranscript.CourseId)
		and CourseEntry.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
	and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
	and @graduationSchoolYearInt >= 2023
	and CourseEntry.ExternalId in ('680V', '0680V')
GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId, Sequence

UNION
--a. How many credits does the student have that match the LearningPathwayId...
--		iv.  From current enrollment for both fall and spring 2018-2019
SELECT
	GraduationRequirement.GraduationRequirementId,
	GraduationRequirement.CourseName,
    GraduationRequirement.Notes,
    GraduationRequirement.CreditsRequired,
    GraduationRequirement.LearningPathwayId,
	Sequence,
	Sum(CourseEntry.Credits) as CreditsEarnedOrInProgress
FROM GraduationRequirement
	INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN LearnerCourseAssign on (PersonAccessRoleAssign.PersonId = LearnerCourseAssign.PersonId)
	LEFT JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	LEFT JOIN SchoolYear on (SchoolYear.SchoolYearId = CourseScheduled.SchoolYearId)
	LEFT JOIN CourseEntry on (CourseEntry.CourseEntryId  = CourseScheduled.CourseEntryId
		and CourseEntry.LearningPathwayId = GraduationRequirement.LearningPathwayId
		and CourseEntry.Credits > 0
		and CourseEntry.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
	and GraduationRequirement.IEP = @hasIEP
	and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
	and SchoolYear.YearInt = @currentSchoolYearInt
GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId, Sequence

UNION
--b. How many credits from specific courses does the student have that match the OrCoursesSpecific1 and/or OrCoursesSpecific2 classes...
--		i. From transcripts (before 2018-2019)
--			1. From the query that matches the 'or' conditions of OrCoursesSpecific1 classes (that don't require OrCoursesSpecific2)
SELECT
	GraduationRequirement.GraduationRequirementId,
	GraduationRequirement.CourseName,
    GraduationRequirement.Notes,
    GraduationRequirement.CreditsRequired,
    GraduationRequirement.LearningPathwayId,
	Sequence,
	Sum(CourseEntry.Credits) as CreditsEarnedOrInProgress
FROM GraduationRequirement
	INNER JOIN GraduationRequirementCourseSpecific on (GraduationRequirement.GraduationRequirementId = GraduationRequirementCourseSpecific.GraduationRequirementId)
	INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN StudentTranscript on (PersonAccessRoleAssign.ExternalId = StudentTranscript.StudentId)
	LEFT JOIN CourseEntry on ((CourseEntry.ExternalId = StudentTranscript.CourseId)
		and CourseEntry.ExternalId = GraduationRequirementCourseSpecific.CourseId
		and CourseEntry.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
	and GraduationRequirement.IEP = @hasIEP
	and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
	and StudentTranscript.CreditsEarned > 0
	and GraduationRequirement.OrCoursesSpecific1 is not null and GraduationRequirement.OrCoursesSpecific1 != ''
	and (GraduationRequirement.OrCoursesSpecific2 is null or GraduationRequirement.OrCoursesSpecific2 = '')
	and GraduationRequirementCourseSpecific.CourseGroup = 1
GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId, Sequence

UNION
--b. How many credits from specific courses does the student have that match the OrCoursesSpecific1 and/or OrCoursesSpecific2 classes...
--		i. From transcripts (before 2018-2019)
--			2. From the query that fulfilles the Or conditions of both the OrCoursesSpecific1 and OrCoursesSpecific2 classes
SELECT
	GraduationRequirement.GraduationRequirementId,
	GraduationRequirement.CourseName,
    GraduationRequirement.Notes,
    GraduationRequirement.CreditsRequired,
    GraduationRequirement.LearningPathwayId,
	Sequence,
	Sum(CourseEntry1.Credits) as CreditsEarnedOrInProgress
FROM GraduationRequirement
	INNER JOIN GraduationRequirementCourseSpecific as CourseSpecific1 on (GraduationRequirement.GraduationRequirementId = CourseSpecific1.GraduationRequirementId)
	INNER JOIN GraduationRequirementCourseSpecific as CourseSpecific2 on (GraduationRequirement.GraduationRequirementId = CourseSpecific2.GraduationRequirementId)
	INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN StudentTranscript on (PersonAccessRoleAssign.ExternalId = StudentTranscript.StudentId)
	LEFT JOIN CourseEntry as CourseEntry1 on ((CourseEntry1.ExternalId = StudentTranscript.CourseId)
		and CourseEntry1.ExternalId = CourseSpecific1.CourseId
		and CourseEntry1.CompanyId = PersonAccessRoleAssign.CompanyId)
	INNER JOIN CourseEntry as CourseEntry2 on ((CourseEntry2.ExternalId = StudentTranscript.CourseId)
		and CourseEntry2.ExternalId = CourseSpecific2.CourseId
		and CourseEntry2.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
	and GraduationRequirement.IEP = @hasIEP
	and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
	and StudentTranscript.CreditsEarned > 0
	and GraduationRequirement.OrCoursesSpecific1 is not null and GraduationRequirement.OrCoursesSpecific1 != ''
	and GraduationRequirement.OrCoursesSpecific2 is not null and GraduationRequirement.OrCoursesSpecific2 != ''
	and CourseSpecific1.CourseGroup = 1
	and CourseSpecific2.CourseGroup = 2
GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId, Sequence

UNION
--b. How many credits from specific courses does the student have that match the OrCoursesSpecific1 and/or OrCoursesSpecific2 classes...
--		ii. From current enrollment for both fall and spring 2018-2019
--			1. From the query that matches the 'or' conditions of OrCoursesSpecific1 classes (that don't require OrCoursesSpecific2)
SELECT
	GraduationRequirement.GraduationRequirementId,
	GraduationRequirement.CourseName,
    GraduationRequirement.Notes,
    GraduationRequirement.CreditsRequired,
    GraduationRequirement.LearningPathwayId,
	Sequence,
	Sum(CourseEntry.Credits) as CreditsEarnedOrInProgress
FROM GraduationRequirement
		INNER JOIN GraduationRequirementCourseSpecific on (GraduationRequirement.GraduationRequirementId = GraduationRequirementCourseSpecific.GraduationRequirementId)
	INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN LearnerCourseAssign on (PersonAccessRoleAssign.PersonId = LearnerCourseAssign.PersonId)
	LEFT JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	LEFT JOIN SchoolYear on (SchoolYear.SchoolYearId = CourseScheduled.SchoolYearId)
	LEFT JOIN CourseEntry on (CourseEntry.CourseEntryId  = CourseScheduled.CourseEntryId
		and CourseEntry.ExternalId = GraduationRequirementCourseSpecific.CourseId
		and CourseEntry.Credits > 0
		and CourseEntry.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
	and GraduationRequirement.IEP = @hasIEP
	and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
	and SchoolYear.YearInt = @currentSchoolYearInt
	and GraduationRequirement.OrCoursesSpecific1 is not null and GraduationRequirement.OrCoursesSpecific1 != ''
	and (GraduationRequirement.OrCoursesSpecific2 is null or GraduationRequirement.OrCoursesSpecific2 = '')
	and GraduationRequirementCourseSpecific.CourseGroup = 1
GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId, Sequence

UNION
--b. How many credits from specific courses does the student have that match the OrCoursesSpecific1 and/or OrCoursesSpecific2 classes...
--		ii. From current enrollment for both fall and spring 2018-2019
--			2. From the query that fulfilles the Or conditions of both the OrCoursesSpecific1 and OrCoursesSpecific2 classes
--HERE
SELECT
	GraduationRequirement.GraduationRequirementId,
	GraduationRequirement.CourseName,
    GraduationRequirement.Notes,
    GraduationRequirement.CreditsRequired,
    GraduationRequirement.LearningPathwayId,
	Sequence,
	Sum(CourseEntry1.Credits) as CreditsEarnedOrInProgress
FROM GraduationRequirement
	INNER JOIN GraduationRequirementCourseSpecific as CourseSpecific1 on (GraduationRequirement.GraduationRequirementId = CourseSpecific1.GraduationRequirementId)
	INNER JOIN GraduationRequirementCourseSpecific as CourseSpecific2 on (GraduationRequirement.GraduationRequirementId = CourseSpecific2.GraduationRequirementId)
	INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN LearnerCourseAssign on (PersonAccessRoleAssign.PersonId = LearnerCourseAssign.PersonId)
	LEFT JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	LEFT JOIN SchoolYear on (SchoolYear.SchoolYearId = CourseScheduled.SchoolYearId)
	LEFT JOIN CourseEntry as CourseEntry1 on (CourseEntry1.CourseEntryId  = CourseScheduled.CourseEntryId
		and CourseEntry1.ExternalId = CourseSpecific1.CourseId
		and CourseEntry1.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN CourseEntry as CourseEntry2 on (CourseEntry2.CourseEntryId  = CourseScheduled.CourseEntryId
		and CourseEntry2.ExternalId = CourseSpecific2.CourseId
		and CourseEntry2.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
	and GraduationRequirement.IEP = @hasIEP
	and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
	and SchoolYear.YearInt = @currentSchoolYearInt
	and GraduationRequirement.OrCoursesSpecific1 is not null and GraduationRequirement.OrCoursesSpecific1 != ''
	and GraduationRequirement.OrCoursesSpecific2 is not null and GraduationRequirement.OrCoursesSpecific2 != ''
	and CourseSpecific1.CourseGroup = 1
	and CourseSpecific1.CourseGroup = 2
GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId, Sequence
) as CreditMerge
GROUP BY GraduationRequirementId, CourseName, Notes, CreditsRequired, LearningPathwayId, Sequence


--The next year credits that are scheduled for this student
--   a. How many credits does the student have that match the LearningPathwayId...
--	 b. From the query that matches the 'or' conditions of OrCoursesSpecific1 classes (that don't require OrCoursesSpecific2)
--	 c. From the query that fulfilles the Or conditions of both the OrCoursesSpecific1 and OrCoursesSpecific2 classes
SELECT
	GraduationRequirementId,
	CourseName,
    Notes,
    CreditsRequired,
    LearningPathwayId,
	Sum(ScheduledForNextYear) as ScheduledForNextYear
FROM (

	--The next year credits that are scheduled for this student
	--   a. How many credits does the student have that match the LearningPathwayId...
	SELECT
		GraduationRequirement.GraduationRequirementId,
		GraduationRequirement.CourseName,
		GraduationRequirement.Notes,
		GraduationRequirement.CreditsRequired,
		GraduationRequirement.LearningPathwayId,
		Sum(CourseEntry.Credits) as ScheduledForNextYear
	FROM GraduationRequirement
		INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
		INNER JOIN LearnerCourseAssign on (PersonAccessRoleAssign.PersonId = LearnerCourseAssign.PersonId)
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN SchoolYear on (SchoolYear.SchoolYearId = CourseScheduled.SchoolYearId)
		INNER JOIN CourseEntry on (CourseEntry.CourseEntryId  = CourseScheduled.CourseEntryId
			and CourseEntry.LearningPathwayId = GraduationRequirement.LearningPathwayId
			and CourseEntry.Credits > 0
			and CourseEntry.CompanyId = PersonAccessRoleAssign.CompanyId)
	WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
		and GraduationRequirement.IEP = @hasIEP
		and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
		and SchoolYear.YearInt = @nextSchoolYearInt
	GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId

	UNION
	--The next year credits that are scheduled for this student
	--	 b. From the query that matches the 'or' conditions of OrCoursesSpecific1 classes (that don't require OrCoursesSpecific2)
	SELECT
		GraduationRequirement.GraduationRequirementId,
		GraduationRequirement.CourseName,
		GraduationRequirement.Notes,
		GraduationRequirement.CreditsRequired,
		GraduationRequirement.LearningPathwayId,
		Sum(CourseEntry.Credits) as ScheduledForNextYear
	FROM GraduationRequirement
		INNER JOIN GraduationRequirementCourseSpecific on (GraduationRequirement.GraduationRequirementId = GraduationRequirementCourseSpecific.GraduationRequirementId)
		INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
		INNER JOIN LearnerCourseAssign on (PersonAccessRoleAssign.PersonId = LearnerCourseAssign.PersonId)
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN SchoolYear on (SchoolYear.SchoolYearId = CourseScheduled.SchoolYearId)
		INNER JOIN CourseEntry on (CourseEntry.CourseEntryId  = CourseScheduled.CourseEntryId
			and CourseEntry.ExternalId = GraduationRequirementCourseSpecific.CourseId
			and CourseEntry.Credits > 0
			and CourseEntry.CompanyId = PersonAccessRoleAssign.CompanyId)
	WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
		and GraduationRequirement.IEP = @hasIEP
		and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
		and SchoolYear.YearInt = GraduationRequirement.SchoolYearInt
		and GraduationRequirement.OrCoursesSpecific1 is not null and GraduationRequirement.OrCoursesSpecific1 != ''
		and (GraduationRequirement.OrCoursesSpecific2 is null or GraduationRequirement.OrCoursesSpecific2 = '')
		and GraduationRequirementCourseSpecific.CourseGroup = 1
	GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId

	UNION

	--The next year credits that are scheduled for this student
	--	 b. From the query that matches the 'or' conditions of OrCoursesSpecific1 classes (that don't require OrCoursesSpecific2)
	SELECT
		GraduationRequirement.GraduationRequirementId,
		GraduationRequirement.CourseName,
		GraduationRequirement.Notes,
		GraduationRequirement.CreditsRequired,
		GraduationRequirement.LearningPathwayId,
		Sum(CourseEntry1.Credits) as ScheduledForNextYear
	FROM GraduationRequirement
		INNER JOIN GraduationRequirementCourseSpecific as CourseSpecific1 on (GraduationRequirement.GraduationRequirementId = CourseSpecific1.GraduationRequirementId)
		INNER JOIN GraduationRequirementCourseSpecific as CourseSpecific2 on (GraduationRequirement.GraduationRequirementId = CourseSpecific2.GraduationRequirementId)
		INNER JOIN PersonAccessRoleAssign on (GraduationRequirement.CompanyId = PersonAccessRoleAssign.CompanyId)
		INNER JOIN LearnerCourseAssign on (PersonAccessRoleAssign.PersonId = LearnerCourseAssign.PersonId)
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN SchoolYear on (SchoolYear.SchoolYearId = CourseScheduled.SchoolYearId)
		INNER JOIN CourseEntry as CourseEntry1 on (CourseEntry1.CourseEntryId  = CourseScheduled.CourseEntryId
			and CourseEntry1.ExternalId = CourseSpecific1.CourseId
			and CourseEntry1.CompanyId = PersonAccessRoleAssign.CompanyId)
		INNER JOIN CourseEntry as CourseEntry2 on (CourseEntry2.CourseEntryId  = CourseScheduled.CourseEntryId
			and CourseEntry2.ExternalId = CourseSpecific2.CourseId
			and CourseEntry2.CompanyId = PersonAccessRoleAssign.CompanyId)
	WHERE PersonAccessRoleAssign.PersonId = @studentPersonId
		and GraduationRequirement.IEP = @hasIEP
		and GraduationRequirement.SchoolYearInt = @graduationSchoolYearInt
		and SchoolYear.YearInt = GraduationRequirement.SchoolYearInt
		and GraduationRequirement.OrCoursesSpecific1 is not null and GraduationRequirement.OrCoursesSpecific1 != ''
		and GraduationRequirement.OrCoursesSpecific2 is not null and GraduationRequirement.OrCoursesSpecific2 != ''
		and CourseSpecific1.CourseGroup = 1
		and CourseSpecific1.CourseGroup = 2
	GROUP BY GraduationRequirement.GraduationRequirementId, GraduationRequirement.CourseName, GraduationRequirement.Notes, GraduationRequirement.CreditsRequired, GraduationRequirement.LearningPathwayId
) as NextYearMerge
GROUP BY GraduationRequirementId, CourseName, Notes, CreditsRequired, LearningPathwayId


DROP TABLE IF EXISTS #currentSchoolYear
DROP TABLE IF EXISTS #regStudent
DROP TABLE IF EXISTS #graduationRequirement_CourseSpecific

END
GO
