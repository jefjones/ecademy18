/****** Object:  StoredProcedure [dbo].[GetSafetyAlert]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetSafetyAlert]
	(@personId AS UniqueIdentifier,
	@safetyAlertId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @safetyAlertId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')
--Set @safetyAlertId = 'F025865C-9CFD-4E02-B86A-6C99DCE39F53' --'00000000-0000-0000-0000-000000000000'

Declare @accessRoleName as nvarchar(25)

Select top 1 AccessRoleLearner.Name
into #accessRole
From PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
Where PersonAccessRoleAssign.PersonId = @personId

Set @accessRoleName = (select Name from #accessRole);

if @accessRoleName = 'Admin' BEGIN
	SELECT distinct
		safetyAlertId,
		SafetyAlert.safetyAlertTypeId,
		safetyAlertType.Name as safetyAlertTypeName,
		AlertReviewType,
		AlertPerson.PersonId as AlertPersonId,
		AlertPerson.Fname + ' ' + AlertPerson.Lname as AlertPersonName,
		SafetyAlert.FileUploadId,
		SafetyAlert.FileUrl,
		ApprovedByPersonId ,
		AdminPerson.Fname + ' ' + AdminPerson.Lname as AdminName,
		ApprovedDate,
		AlertNote,
		AdminNote,
		safetyAlert.EntryDate
	into #safetyAlert
	FROM SafetyAlert
		INNER JOIN Person as AlertPerson on (AlertPerson.PersonId = safetyAlert.PersonId)
		LEFT JOIN Person as AdminPerson on (AdminPerson.PersonId = safetyAlert.ApprovedByPersonId)
		INNER JOIN PersonAccessRoleAssign as AlertAccess on (AlertAccess.PersonId = safetyAlert.PersonId)
		INNER JOIN PersonAccessRoleAssign as AdminAccess on (AdminAccess.CompanyId = AlertAccess.CompanyId)
		LEFT JOIN SafetyAlertType on (SafetyAlertType.SafetyAlertTypeId = safetyAlert.SafetyAlertTypeId)
	WHERE AdminAccess.PersonId = @personId
		and (SafetyAlert.DismissFlag is null or SafetyAlert.DismissFlag = 0)
		--and safetyAlert.EntryDate > DATEADD(day, -1, getDate())
	Order by safetyAlert.EntryDate desc

	select * from #safetyAlert

	Select
		SafetyAlertStudentInvolved.SafetyAlertId,
		StudentPerson.Fname + ' ' + StudentPerson.Lname as StudentName,
		SafetyAlertStudentInvolved.StudentPersonId,
		Note,
		HowInvolved.HowInvolvedId,
		HowInvolved.Name as HowInvolvedName
	FROM SafetyAlertStudentInvolved
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = StudentPersonId)
		INNER JOIN HowInvolved on (HowInvolved.HowInvolvedId = SafetyAlertStudentInvolved.HowInvolvedId)
	WHERE SafetyAlertStudentInvolved.safetyAlertId in (Select SafetyAlertId from #safetyAlert)

END
else
	BEGIN

	SELECT top 1
		safetyAlertId,
		SafetyAlert.safetyAlertTypeId,
		safetyAlertType.Name as safetyAlertTypeName,
		AlertReviewType,
		AlertPerson.PersonId as AlertPersonId,
		SafetyAlert.FileUploadId,
		SafetyAlert.FileUrl,
		AlertPerson.Fname + ' ' + AlertPerson.Lname as AlertPersonName,
		ApprovedByPersonId ,
		AdminPerson.Fname + ' ' + AdminPerson.Lname as AdminName,
		ApprovedDate,
		AlertNote,
		AdminNote,
		safetyAlert.EntryDate
	into #safetyAlertPerson
	FROM SafetyAlert
		INNER JOIN Person as AlertPerson on (AlertPerson.PersonId = safetyAlert.PersonId)
		LEFT JOIN Person as AdminPerson on (AdminPerson.PersonId = safetyAlert.ApprovedByPersonId)
		LEFT JOIN SafetyAlertType on (SafetyAlertType.SafetyAlertTypeId = safetyAlert.SafetyAlertTypeId)
	WHERE safetyAlert.PersonId = @personId
		and safetyAlert.EntryDate > DATEADD(day, -1, getDate())
		and ((@safetyAlertId is null or @safetyAlertId != '00000000-0000-0000-0000-000000000000')
			or (@safetyAlertId is not null and @safetyAlertId != '00000000-0000-0000-0000-000000000000'
				and @safetyAlertId = safetyAlert.safetyAlertId))
	Order by safetyAlert.EntryDate desc

	select * from #safetyAlertPerson

	Select
		SafetyAlertStudentInvolved.SafetyAlertId,
		StudentPerson.Fname + ' ' + StudentPerson.Lname as StudentName,
		SafetyAlertStudentInvolved.StudentPersonId,
		Note,
		HowInvolved.HowInvolvedId,
		HowInvolved.Name as HowInvolvedName
	FROM SafetyAlertStudentInvolved
		INNER JOIN Person as StudentPerson on (StudentPerson.PersonId = StudentPersonId)
		INNER JOIN HowInvolved on (HowInvolved.HowInvolvedId = SafetyAlertStudentInvolved.HowInvolvedId)
	WHERE SafetyAlertStudentInvolved.safetyAlertId in (Select SafetyAlertId from #safetyAlertPerson)

END

DROP TABLE IF EXISTS #safetyAlert
DROP TABLE IF EXISTS #safetyAlertPerson
DROP TABLE IF EXISTS #accessRole

END
GO
/****** Object:  StoredProcedure [dbo].[GetSetStudentGradesFinal]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetSetStudentGradesFinal]
	(@personId AS UniqueIdentifier,
	 @courseScheduledId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @courseScheduledId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')
--Set @courseScheduledId  = '5aa11282-78e3-4304-93b7-8ac5ca2e02a0'

--0
Select distinct
    RegistrationStudent.StudentPersonId,
    Company.IntervalType,
    RegistrationStudent.GradeLevelId,
    CourseScheduled.CourseScheduledId,
    CourseScheduled.SchoolYearId,
	Assignment.IntervalId,
    CourseEntry.Credits,
    StudentAssignmentScore.Accredited
From StudentAssignmentScore
    INNER JOIN Assignment on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId)
    INNER JOIN CourseScheduled on (StudentAssignmentScore.CourseScheduledId = CourseScheduled.CourseScheduledId)
    INNER JOIN RegistrationStudent on (StudentAssignmentScore.StudentPersonId = RegistrationStudent.StudentPersonId
		and RegistrationStudent.SchoolYearId = CourseScheduled.SchoolYearId)
    INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
    INNER JOIN Company on (CourseScheduled.CompanyId = Company.CompanyId)
Where StudentAssignmentScore.CourseScheduledId = @courseScheduledId

--1 GradeScale
Select
    GradeScaleDetailId,
    GradeScaleTable.GradeScaleTableId,
    Letter,
    LowValue,
    HighValue,
    Scale40Value
From GradeScaleTable
    INNER JOIN CourseScheduled on (CourseScheduled.GradeScaleTableId = GradeScaleTable.GradeScaleTableId)
    INNER JOIN GradeScaleDetail on (GradeScaleDetail.GradeScaleTableId = GradeScaleTable.GradeScaleTableId)
    where CourseScheduledId = @courseScheduledId


--2 StudentGradeOverwrite
Select
	StudentGradeOverwriteId,
    StudentPersonId,
	SchoolYearId,
	IntervalId,
    GradePercent,
    Incomplete,
    Passed
From StudentGradeOverwrite
Where CourseScheduledId = @courseScheduledId


END
GO
/****** Object:  StoredProcedure [dbo].[GetStandardsRating]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStandardsRating]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')

Declare @schoolYearId as UniqueIdentifier
Declare @CompanyId as UniqueIdentifier

SELECT top 1
	CompanyId,
	SchoolYearId
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN PersonConfigure on (PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId)
WHERE PersonAccessRoleAssign.PersonId = @personId

SET @schoolYearId = (SELECT SchoolYearId from #selectedAccess)
SET @companyId = (SELECT CompanyId from #selectedAccess)

--According to the user's grade level access, we cut back the standard rating table view or their choice for their classes.
SELECT distinct
    StandardsRatingTable.StandardsRatingTableId,
    StandardsRatingTable.StandardsRatingName,
    StandardsRatingDetail.StandardsRatingDetailId,
    StandardsRatingDetail.Name,
    StandardsRatingDetail.Description,
    StandardsRatingDetail.Score,
    StandardsRatingDetail.FromPercent,
    StandardsRatingDetail.ToPercent,
    StandardsRatingDetail.Sequence,
    StandardsRatingDetail.Color,
	StandardsRatingDetail.LevelAbbrev,
	StandardsRatingTable.IsLevelOnly
INTO #standardsRatingDetailTemp
FROM StandardsRatingTable
	LEFT JOIN StandardsRatingDetail on (StandardsRatingDetail.StandardsRatingTableId = StandardsRatingTable.StandardsRatingTableId)
	INNER JOIN StandardsRatingGradeLevel on (StandardsRatingGradeLevel.StandardsRatingTableId = StandardsRatingTable.StandardsRatingTableId)
	INNER JOIN PersonAccessGradeLevel on (PersonAccessGradeLevel.GradeLevelId = StandardsRatingGradeLevel.GradeLevelId
		and PersonAccessGradeLevel.PersonId = @personId)
WHERE StandardsRatingTable.CompanyId = @companyId

--0
select * from #standardsRatingDetailTemp

--1
SELECT distinct
	StandardsRatingTableId,
	GradeLevel.GradeLevelId,
    GradeLevel.Code,
    GradeLevel.Name,
    GradeLevel.Sequence
FROM StandardsRatingGradeLevel
	INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = StandardsRatingGradeLevel.GradeLevelId)
	INNER JOIN PersonAccessGradeLevel on (PersonAccessGradeLevel.GradeLevelId = GradeLevel.GradeLevelId
		and PersonAccessGradeLevel.PersonId = @personId)
Where StandardsRatingTableId in (select StandardsRatingTableId from #standardsRatingDetailTemp)


drop table if exists #standardsRatingDetailTemp
drop table if exists #selectedAccess

END
GO
/****** Object:  StoredProcedure [dbo].[getStudentAllClassesByDay]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[getStudentAllClassesByDay]
	(@personId AS UniqueIdentifier,
	@studentPersonId AS UniqueIdentifier,
	@dayOfWeek AS nvarchar(20))
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Declare @dayOfWeek AS varchar(20)
--Set @personId = '24D0EC95-DEF1-4939-A9D8-D0DC4BCFBF01'
--Set @studentPersonId = 'E4729BAA-E133-45E9-A744-FA512C5D7B0E'
--Set @dayOfWeek = 'friday'

Select
	CourseScheduled.CourseScheduledId,
	ClassPeriodOthers.StartTime as ClassPeriodOthersStartTime
From CourseScheduled
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN LearnerCourseAssign on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId
		and LearnerCourseAssign.PersonId = @studentPersonId)
	INNER JOIN CourseScheduled as courseSchedOthers on (LearnerCourseAssign.CourseScheduledId = courseSchedOthers.CourseScheduledId)
	INNER JOIN CourseIntervalAssign as CourseIntervalAssignOthers on (CourseIntervalAssignOthers.CourseScheduledId = courseSchedOthers.CourseScheduledId)
	INNER JOIN PersonConfigure on (CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId
		and PersonConfigure.PersonId = @personId)
	INNER JOIN DaysScheduled as daysScheduledThis on (CourseScheduled.CourseScheduledId = daysScheduledThis.CourseScheduledId)
	INNER JOIN DaysScheduled as daysScheduledOthers on (courseSchedOthers.CourseScheduledId = daysScheduledOthers.CourseScheduledId)
	INNER JOIN ClassPeriod as ClassPeriodOthers on (ClassPeriodOthers.ClassPeriodId = daysScheduledOthers.ClassPeriodId)
Where CourseScheduled.SchoolYearId = courseSchedOthers.SchoolYearId
    and CourseIntervalAssign.IntervalId = CourseIntervalAssignOthers.IntervalId
	and daysScheduledOthers.DayOfTheWeek = daysScheduledThis.DayOfTheWeek
    and daysScheduledThis.DayOfTheWeek = @dayOfWeek


END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentAssignmentAssign]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStudentAssignmentAssign]
	(@personId AS UniqueIdentifier, @courseScheduledId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @courseScheduledId as UniqueIdentifier
--SET @courseScheduledId = 'F780958E-8B1E-4408-AC14-0028A8EA381E'
--Set @personId = '4E66E25A-8EA6-4801-8BA2-922F65BB3D02'

DECLARE @courseEntryId as UniqueIdentifier
DECLARE @facilitatorPersonId as UniqueIdentifier
DECLARE @courseTypeId as UniqueIdentifier
DECLARE @weightedScoreCount as INT

SELECT distinct
	CourseEntry.CourseEntryId,
	CourseEntry.CourseName,
	CourseEntry.CompanyId,
	Company.StudentNameFirst,
	--CourseScheduled.ClassPeriodId,  //This is changed to the new structure, DaysScheduled.  See query #7 below.
	--ClassPeriod.PeriodNumber as ClassPeriodNumber,
	--ClassPeriod.StartTime as ClassPeriodStartTime,
	--ClassPeriod.EndTime as ClassPeriodEndTime,
	CourseScheduled.CourseTypeId,
	CourseScheduled.CourseScheduledId,
	FacilitatorPersonId,
	Person.Fname as FacilitatorFirstName,
	Person.LName as FacilitatorLastName
INTO #selectedCourse
FROM Person
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.PersonId = Person.PersonId)
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = TeacherCourseAssign.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	INNER JOIN Company on (Company.CompanyId = CourseEntry.CompanyId)
	--LEFT JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = CourseScheduled.ClassPeriodId)
WHERE TeacherCourseAssign.PersonId = @personId
	and CourseScheduled.CourseScheduledId = @courseScheduledId

SET @courseEntryId= (SELECT CourseEntryId FROM #selectedCourse)

--0
select * from #selectedCourse

SELECT distinct	Assignment.AssignmentId,
	Assignment.Title,
	Assignment.Instructions,
	Assignment.Sequence,
	Assignment.TotalPoints,
	Assignment.ExtraCredit,
	Assignment.DueDate,
	Assignment.AssessmentId,
	Assessment.IsPublished,
	Assignment.ContentTypeId,
	ContentType.Code AS ContentTypeCode,
	ContentType.Name AS ContentTypeName
INTO #selectedAssignments
FROM AssignmentCourseSpecific
	INNER JOIN CourseScheduled on (AssignmentCourseSpecific.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN Assignment on (AssignmentCourseSpecific.AssignmentId = Assignment.AssignmentId
		and CourseScheduled.CourseEntryId = Assignment.CourseEntryId)
	INNER JOIN PersonConfigure on (PersonConfigure.IntervalId = Assignment.IntervalId)
	INNER JOIN ContentType ON (ContentType.ContentTypeId = Assignment.ContentTypeId)
	LEFT JOIN Assessment ON (Assessment.AssessmentId = Assignment.AssessmentId)
WHERE CourseScheduled.CourseScheduledId = @courseScheduledId
	and PersonConfigure.PersonId = @personId
ORDER BY Assignment.Sequence

--1
SELECT * from #selectedAssignments

SELECT Person.PersonId,
	Person.Fname as FirstName,
	Person.Lname as LastName,
	RegistrationStudent.Accredited
INTO #selectedStudentsInCourse
FROM LearnerCourseAssign
	INNER JOIN Person on (LearnerCourseAssign.PersonId = Person.PersonId)
	INNER JOIN RegistrationStudent on (Person.PersonId = RegistrationStudent.StudentPersonId)
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
WHERE LearnerCourseAssign.CourseScheduledId = @courseScheduledId
	and RegistrationStudent.SchoolYearId = courseScheduled.SchoolYearId

--2
SELECT * from #selectedStudentsInCourse

--3
SELECT
	AssignmentId,
	StudentPersonId
FROM StudentAssignmentAssign
WHERE StudentAssignmentAssign.StudentPersonId in (Select PersonId from #selectedStudentsInCourse)
	and StudentAssignmentAssign.AssignmentId in (SELECT AssignmentId from #selectedAssignments)

--4
SELECT StudentNameFirst FROM #selectedCourse

--5
SELECT companyId FROM #selectedCourse

--6
SELECT Distinct ContentType.Sequence, ContentType.ContentTypeId, ContentType.Name as ContentTypeName, ContentType.Code as ContentTypeCode
FROM Assignment, ContentType
WHERE Assignment.ContentTypeId = ContentType.ContentTypeId
	and Assignment.AssignmentId IN (select AssignmentId from #selectedAssignments)

--7
SELECT distinct
	DaysScheduled.CourseScheduledId,
	ClassPeriod.ClassPeriodId,
	ClassPeriod.PeriodNumber as ClassPeriodName,
	DaysScheduled.StartTime,
	DaysScheduled.Duration
FROM DaysScheduled
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
WHERE DaysScheduled.CourseScheduledId in (Select CourseScheduledId from #selectedCourse)


DROP TABLE If Exists #selectedCourse
DROP TABLE If Exists #selectedAssignments
DROP TABLE If Exists #selectedStudentsInCourse

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentAssignments]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStudentAssignments]
(@personId AS UniqueIdentifier, @studentPersonId AS UniqueIdentifier, @courseScheduledId AS UniqueIdentifier)
 AS
BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Declare @courseScheduledId as UniqueIdentifier
--Set @personId = '3CF24968-B14A-4826-BB16-1DC4D5B46F1D' --(select Personid from person where lname = 'aldrich' and fname = 'audrey')
--Set @studentPersonId = 'c064a36b-3f07-4d2b-a4d9-6735740aa0a9' --(select Personid from person where lname = 'aldrich' and fname = 'audrey')
--SET @courseScheduledid = '2ca99f75-da14-45c9-b171-3e18c733338a'

DECLARE @courseEntryId as UniqueIdentifier
DECLARE @intervalId as UniqueIdentifier
DECLARE @facilitatorPersonId as UniqueIdentifier
DECLARE @courseTypeId as UniqueIdentifier
DECLARE @schoolYearId as UniqueIdentifier

Select top 1 Personconfigure.SchoolYearId,
	Personconfigure.IntervalId
INTO #personConfig
FROM PersonConfigure
WHERE PersonId = @personId

SET @schoolYearId=(select SchoolYearId FROM #personConfig)
SET @intervalId=(select IntervalId FROM #personConfig)

--0
Select top 1 StudentPerson.PersonId,
	StudentPerson.Fname as FirstName,
	StudentPerson.Lname as LastName,
	RegistrationStudent.Accredited
INTO #studentRegistration
From person as StudentPerson
INNER JOIN RegistrationStudent ON (RegistrationStudent.StudentPersonId = StudentPerson.PersonId
	and RegistrationStudent.SchoolYearId = @schoolYearId)
WHERE StudentPerson.PersonId = @studentPersonId

select * from #studentRegistration

SELECT CourseEntryId,
	CourseScheduled.CourseTypeId,
	CourseScheduled.CourseScheduledId,
	CourseIntervalAssign.IntervalId,
	FacilitatorPersonId,
	StudentGradeOverwrite.GradePercent as GradeOverwrite
INTO #selectedCourse
FROM CourseScheduled
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	LEFT JOIN StudentGradeOverwrite on (StudentGradeOverwrite.StudentPersonId = @studentPersonId
		and StudentGradeOverwrite.CourseScheduledId = @courseScheduledId)
WHERE CourseScheduled.CourseScheduledId = @courseScheduledId

SET @courseEntryId= (SELECT top 1 CourseEntryId FROM #selectedCourse)
SET @facilitatorPersonId=(select top 1 FacilitatorPersonId FROM #selectedCourse)


SELECT CourseTypeId, Accredited
INTO #selectedRegistrationStudent
FROM RegistrationStudent
WHERE StudentPersonId = @studentPersonId
and SchoolYearId = @schoolYearId

SET @courseTypeId=(SELECT CourseTypeId FROM #selectedRegistrationStudent)

--1
SELECT CourseEntry.CourseName FROM CourseEntry WHERE CourseEntry.CourseEntryId = @courseEntryId

SELECT distinct Assignment.AssignmentId,
	Assignment.Title as AssignmentTitle,
	Assignment.Instructions as AssignmentInstructions,
	Assignment.Sequence as AssignmentSequence,
	Assignment.TotalPoints,
	Assignment.ExtraCredit,
	Assignment.DueDate,
	Assignment.AssessmentId,
	Assignment.BenchmarkTestId,
	Assignment.DiscussionEntryId,
	Assignment.DiscussionMinPost,
	Assignment.DiscussionWordCount,
	Assignment.DiscussionMinComment,
	Assessment.IsPublished, --Assessment
	Assignment.CourseEntryId,
	Assignment.ContentTypeId,
	StudentAssignmentScore.HasPendingEssayReview,
	StudentAssignmentScore.Score,
	StudentAssignmentScore.ScoreNotIncluded,
	StudentAssignmentScore.KnowledgeRatingSequence,
	StudentAssignmentScore.PassFailSequence,
	ContentType.Code AS ContentTypeCode,
	ContentType.Name AS ContentTypeName,
	AssignmentGradedBy.GradingType
INTO #selectedAssignments
FROM Assignment
	INNER JOIN AssignmentCourseSpecific on (AssignmentCourseSpecific.AssignmentId = Assignment.AssignmentId
		and AssignmentCourseSpecific.CourseScheduledId = @courseScheduledId)
	INNER JOIN ContentType ON (ContentType.ContentTypeId = Assignment.ContentTypeId)
	LEFT JOIN Assessment ON (Assessment.AssessmentId = Assignment.AssessmentId)
	LEFT JOIN AssignmentGradedBy ON (AssignmentGradedBy.AssignmentId = Assignment.AssignmentId and CourseTypeId = @courseTypeId)
	LEFT JOIN StudentAssignmentScore on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId
		and StudentAssignmentScore.StudentPersonId = @studentPersonId
		--and (IsPrevScore = 0 or IsPrevScore is null)
		)
WHERE CourseEntryId = @courseEntryId
	and Assignment.IntervalId = @intervalId
ORDER BY Assignment.Sequence

--2
SELECT * FROM #selectedAssignments

--3
Select
	Assessment.AssessmentId,
	Assessment.IsPublished,
	AssessmentQuestion.AssessmentQuestionId
FROM Assessment
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
WHERE Assessment.AssessmentId IN ( SELECT AssessmentId FROM #selectedAssignments)

--4
SELECT * FROM #selectedCourse

--5
SELECT Fname, LName FROM Person WHERE PersonID = @facilitatorPersonId

--6 File Upload response
SELECT distinct AssignmentId,
	StudentAssignmentResponse.StudentAssignmentResponseId,
	FileUPload.Url as StudentFileUploadUrl,
	IsTeacherResponse,
	StudentAssignmentResponse.EntryDate as ResponseEntryDate,
	ResponseVisitedType.Code as ResponseVisitedTypeCode
FROM FileUPload , StudentAssignmentResponse
	LEFT JOIN StudentAssignmentResponseVisited on (StudentAssignmentResponseVisited.StudentAssignmentResponseId = StudentAssignmentResponse.StudentAssignmentResponseId and StudentAssignmentResponseVisited.FacilitatorPersonId = @facilitatorPersonId)
	LEFT JOIN ResponseVisitedType on (ResponseVisitedType.ResponseVisitedTypeId = StudentAssignmentResponseVisited.ResponseVisitedTypeId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)
	and FileUPload.FileUPloadId = StudentAssignmentResponse.FileUploadId
	and PersonId = @studentPersonId
	and (isDeleted is null or isDeleted = 0)
Order by StudentAssignmentResponse.EntryDate

--7 Text response
SELECT distinct AssignmentId,
	StudentAssignmentResponse.StudentAssignmentResponseId,
	Instructions as StudentTextResponse,
	IsTeacherResponse,
	StudentAssignmentResponse.EntryDate as ResponseEntryDate,
	ResponseVisitedType.Code as ResponseVisitedTypeCode
FROM StudentAssignmentResponse
	LEFT JOIN StudentAssignmentResponseVisited on (StudentAssignmentResponseVisited.StudentAssignmentResponseId = StudentAssignmentResponse.StudentAssignmentResponseId and StudentAssignmentResponseVisited.FacilitatorPersonId = @facilitatorPersonId)
	LEFT JOIN ResponseVisitedType on (ResponseVisitedType.ResponseVisitedTypeId = StudentAssignmentResponseVisited.ResponseVisitedTypeId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)
	and PersonId = @studentPersonId
	and (isDeleted is null or isDeleted = 0)
	and Instructions is not null
	and Instructions != ''
Order by StudentAssignmentResponse.EntryDate

--8 Website Link response
SELECT distinct AssignmentId,
	StudentAssignmentResponse.StudentAssignmentResponseId,
	WebsiteLink as StudentWebsiteLink,
	IsTeacherResponse,
	StudentAssignmentResponse.EntryDate as ResponseEntryDate,
	ResponseVisitedType.Code as ResponseVisitedTypeCode
FROM StudentAssignmentResponse
	LEFT JOIN StudentAssignmentResponseVisited on (StudentAssignmentResponseVisited.StudentAssignmentResponseId = StudentAssignmentResponse.StudentAssignmentResponseId and StudentAssignmentResponseVisited.FacilitatorPersonId = @facilitatorPersonId)
	LEFT JOIN ResponseVisitedType on (ResponseVisitedType.ResponseVisitedTypeId = StudentAssignmentResponseVisited.ResponseVisitedTypeId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)
	and PersonId = @studentPersonId
	and (isDeleted is null or isDeleted = 0)
	and WebsiteLink is not null
	and WebsiteLink != ''
Order by StudentAssignmentResponse.EntryDate

--9
SELECT distinct AssignmentId,
	StudentAssignmentResponse.StudentAssignmentResponseId,
	PenspringWorkId as StudentPenspringWorkId,
	StudentAssignmentResponse.IsPenspringSubmitted,
	StudentAssignmentResponse.PenspringSubmittedDate,
	Work.WorkName as PenspringWorkName,
	IsTeacherResponse,
	StudentAssignmentResponse.EntryDate as ResponseEntryDate,
	ResponseVisitedType.Code as ResponseVisitedTypeCode
FROM Work, StudentAssignmentResponse
	LEFT JOIN StudentAssignmentResponseVisited on (StudentAssignmentResponseVisited.StudentAssignmentResponseId = StudentAssignmentResponse.StudentAssignmentResponseId and StudentAssignmentResponseVisited.FacilitatorPersonId = @facilitatorPersonId)
	LEFT JOIN ResponseVisitedType on (ResponseVisitedType.ResponseVisitedTypeId = StudentAssignmentResponseVisited.ResponseVisitedTypeId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)
	and Work.WorkId = PenspringWorkId
	and StudentAssignmentResponse.PersonId = @studentPersonId
	and (isDeleted is null or isDeleted = 0)
	and PenspringWorkId is not null
	and PenspringWorkId != '00000000-0000-0000-0000-000000000000'
Order by StudentAssignmentResponse.EntryDate

--10
SELECT AssignmentId,
	Url as AssignmentFileUploadUrl
FROM AssignmentFile
	LEFT JOIN FileUpload on (FileUpload.FileUPloadId = AssignmentFile.FileUploadId)
WHERE AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)

--11
SELECT AssignmentId,
	WebsiteLink as AssignmentWebsiteLink,
	AssignmentWebsiteLink.AssignmentWebsiteLinkId
FROM AssignmentWebsiteLink
WHERE AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)

--12
SELECT distinct
	DaysScheduled.CourseScheduledId,
	ClassPeriod.ClassPeriodId,
	ClassPeriod.PeriodNumber as ClassPeriodName,
	ClassPeriod.StartTime as ClassPeriodStartTime,
	ClassPeriod.EndTime as ClassPeriodEndTime
FROM DaysScheduled
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
WHERE DaysScheduled.CourseScheduledId = @courseScheduledId

--13
Select distinct
	Assignment.AssignmentId,
	BenchmarkTest.BenchmarkTestId,
	Assessment.AssessmentId,
	Assessment.IsPublished,
	AssessmentQuestion.AssessmentQuestionId,
	AssessmentLearnerAnswer.Score
INTO #benchmarkTests
FROM Assignment
	INNER JOIN BenchmarkTest on (BenchmarkTest.BenchmarkTestId = Assignment.BenchmarkTestId)
	INNER JOIN Assessment on (Assessment.AssessmentId = BenchmarkTest.AssessmentId)
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
	LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
		and AssessmentLearnerAnswer.PersonId = @studentPersonId
		and AssessmentLearnerAnswer.IsSubmitted = 1
		and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
WHERE Assignment.AssignmentId IN ( SELECT AssignmentId FROM #selectedAssignments)
	and Assignment.IntervalId = @intervalId

select * from #benchmarkTests

--14  Scored answers
SELECT distinct
	AssignmentId,
	AssessmentLearnerAnswerId,
	StudentPersonId,
	AssessmentQuestionId,
	LearnerAnswer,
	CorrectAnswer,
	FileUploadId,
	PendingCorrection,
	Score,
	TeacherEssayResponse,
	EssayCorrectionWorkId,
	IsCorrect,
	EntryDate,
	AssessmentId,
	QuestionTypeId,
	QuestionText,
	PointsPossible,
	Sequence,
	IsSubmitted
INTO #assessmentQuestion
FROM (
	--Assessments (other than BenchmarkTest) which have AssessmentQuestions: ASSESSMENT, Exam, Final or Midterm
	SELECT
		Assignment.AssignmentId,
		AssessmentLearnerAnswer.AssessmentLearnerAnswerId,
		AssessmentLearnerAnswer.PersonId as StudentPersonId,
		AssessmentLearnerAnswer.AssessmentQuestionId,
		AssessmentLearnerAnswer.LearnerAnswer,
		AssessmentQuestion.CorrectAnswer,
		AssessmentLearnerAnswer.FileUploadId,
		AssessmentLearnerAnswer.PendingCorrection,
		AssessmentLearnerAnswer.Score,
		AssessmentLearnerAnswer.TeacherEssayResponse,
		AssessmentLearnerAnswer.EssayCorrectionWorkId,
		AssessmentLearnerAnswer.IsCorrect,
		AssessmentLearnerAnswer.EntryDate,
		AssessmentQuestion.AssessmentId,
		AssessmentQuestion.QuestionTypeId,
		AssessmentQuestion.QuestionText,
		AssessmentQuestion.PointsPossible,
		AssessmentQuestion.Sequence,
		AssessmentLearnerAnswer.IsSubmitted
	FROM Assignment
		INNER JOIN Assessment on (Assessment.AssessmentId = Assignment.AssessmentId)
		INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
		LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
			and AssessmentLearnerAnswer.PersonId = @studentPersonId
			and AssessmentLearnerAnswer.IsSubmitted = 1
			and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
	WHERE AssessmentQuestion.AssessmentId in (Select AssessmentId from #selectedAssignments where AssessmentId is not null)

	UNION

	--Assignments that do not have an assessment with questions, but an assessment can have an assessment record such as ASSESSMENT, Exam, Final or Midterm
	SELECT
		Assignment.AssignmentId,
		null as AssessmentLearnerAnswerId,
		StudentAssignmentScore.StudentPersonId,
		null AssessmentQuestionId,
		null as LearnerAnswer,
		null as CorrectAnswer,
		null as FileUploadId,
		StudentAssignmentScore.HasPendingEssayReview,
		StudentAssignmentScore.Score,
		null as TeacherEssayResponse,
		null as EssayCorrectionWorkId,
		null as IsCorrect,
		StudentAssignmentScore.EntryDate,
		null as AssessmentId,
		null as QuestionTypeId,
		null as QuestionText,
		Assignment.TotalPoints,
		null as Sequence,
		null as IsSubmitted
	FROM Assignment
		INNER JOIN StudentAssignmentScore on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId
			and StudentAssignmentScore.StudentPersonId = @studentPersonId
			and StudentAssignmentScore.CourseScheduledId = @courseScheduledId)
	WHERE (Assignment.AssessmentId is null or Assignment.AssessmentId = '00000000-0000-0000-0000-000000000000'
			or Assignment.AssessmentId not in (Select AssessmentId from AssessmentQuestion))
		and Assignment.AssignmentId in (select AssignmentId from #selectedAssignments)

	UNION

	--Benchmark Test Assessments
	SELECT
		Assignment.AssignmentId,
		AssessmentLearnerAnswer.AssessmentLearnerAnswerId,
		AssessmentLearnerAnswer.PersonId as StudentPersonId,
		AssessmentLearnerAnswer.AssessmentQuestionId,
		AssessmentLearnerAnswer.LearnerAnswer,
		AssessmentQuestion.CorrectAnswer,
		AssessmentLearnerAnswer.FileUploadId,
		AssessmentLearnerAnswer.PendingCorrection,
		AssessmentLearnerAnswer.Score,
		AssessmentLearnerAnswer.TeacherEssayResponse,
		AssessmentLearnerAnswer.EssayCorrectionWorkId,
		AssessmentLearnerAnswer.IsCorrect,
		AssessmentLearnerAnswer.EntryDate,
		AssessmentQuestion.AssessmentId,
		AssessmentQuestion.QuestionTypeId,
		AssessmentQuestion.QuestionText,
		AssessmentQuestion.PointsPossible,
		AssessmentQuestion.Sequence,
		AssessmentLearnerAnswer.IsSubmitted
	FROM Assignment
		INNER JOIN BenchmarkTest on (BenchmarkTest.BenchmarkTestId = Assignment.BenchmarkTestId)
		INNER JOIN Assessment on (Assessment.AssessmentId = BenchmarkTest.AssessmentId)
		INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentId = Assessment.AssessmentId)
		LEFT JOIN AssessmentLearnerAnswer on (AssessmentLearnerAnswer.AssessmentQuestionId = AssessmentQuestion.AssessmentQuestionId
			and AssessmentLearnerAnswer.PersonId = @studentPersonId
			and AssessmentLearnerAnswer.IsSubmitted = 1
			and AssessmentLearnerAnswer.AssignmentId = Assignment.AssignmentId)
	WHERE AssessmentQuestion.AssessmentId in (Select AssessmentId from #benchmarkTests)
) as QueryJoin

Select * from #assessmentQuestion

--15  Standards assigned to assessment questions, if any.
Select distinct
	AssessmentQuestion.AssessmentQuestionId,
	StandardSchool.StandardSchoolId,
	StandardSchool.LearningPathwayId,
	StandardSchool.Name,
	StandardSchool.Code,
	StandardSchool.Sequence
From AssessmentQuestionStandard
	INNER JOIN AssessmentQuestion on (AssessmentQuestion.AssessmentQuestionId = AssessmentQuestionStandard.AssessmentQuestionId)
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssessmentQuestionStandard.StandardSchoolId)
Where AssessmentQuestion.AssessmentQuestionId in (Select AssessmentQuestionId from #assessmentQuestion)


--16  Standards assigned to non-assessment-questions assignments, if any.
Select distinct
	AssignmentStandard.AssignmentId,
	StandardSchool.StandardSchoolId,
	StandardSchool.LearningPathwayId,
	StandardSchool.Name,
	StandardSchool.Code,
	StandardSchool.Sequence
From AssignmentStandard
	INNER JOIN StandardSchool on (StandardSchool.StandardSchoolId = AssignmentStandard.StandardSchoolId)
Where AssignmentStandard.AssignmentId in (Select AssignmentId from #selectedAssignments)


DROP TABLE if exists #personConfig
DROP TABLE if exists #selectedCourse
DROP TABLE if exists #selectedRegistrationStudent
DROP TABLE if exists #selectedAssignments
DROP TABLE if exists #studentRegistration
DROP TABLE if exists #benchmarkTests
DROP TABLE if exists #assessmentQuestion

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentAssignmentsPendingReview]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStudentAssignmentsPendingReview]
	( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select top 1 personId from person where username = 'rochellerudd@liahonaed.com')

/*
	1. The students which belong to this teacher.
	2. The assignments which have a student response but don't have a score, yet
	3. Make note of if this is an assignment that the student can respond to but to which she has not yet responded.

	Be aware that there is a StudentResponsePendingReview that is being maintained (painstakingly - but worth it) through the process in order
		to set assignments as pending or not ... which gets updated as scores are entered.
*/
select distinct
	PersonAccessRoleAssign.CompanyId,
	CourseScheduled.CourseScheduledId,
	CourseScheduled.CourseEntryId,
	CourseIntervalAssign.IntervalId,
	StudentPerson.PersonId,
	StudentPerson.Fname as FirstName,
	StudentPerson.Lname as LastName,
	CourseEntry.CourseName,
	null as ClassPeriodId,
	CourseScheduled.CourseTypeId,
	Assignment.AssignmentId,
	Assignment.Title as AssignmentTitle,
	Assignment.Instructions as AssignmentInstructions,
	Assignment.Sequence as AssignmentSequence,
	Assignment.TotalPoints,
	Assignment.ExtraCredit,
	Assignment.DueDate,
	Assignment.AssessmentId,
	StudentResponsePendingReview.GradingType,
	ContentType.ContentTypeId,
	ContentType.Code as ContentTypeCode,
	ContentType.Name as ContentTypeName,
	RegistrationStudent.Accredited,
	CourseType.Name as StudentTypeName,
	StudentAssignmentResponse.StudentAssignmentResponseId,
	StudentAssignmentResponse.Instructions as StudentTextResponse,
	StudentAssignmentResponse.WebsiteLink as StudentWebsiteLink,
	StudentAssignmentResponse.PenspringWorkId as StudentPenspringWorkId,
	StudentAssignmentResponse.IsTeacherResponse,
	StudentAssignmentResponse.EntryDate as ResponseEntryDate,
	StudentResponseFileUpload.Url as StudentFileUploadUrl,
	AssignmentWebsiteLink.WebsiteLink as AssignmentWebsiteLink,
	AssignmentFileUpload.Url as AssignmentFileUploadUrl,
	AssignmentPenspringWork.WorkId as AssignmentPenspringWorkId,
	ResponseVisitedType.Code as ResponseVisitedTypeCode
into #pendingAssignment
from StudentResponsePendingReview
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = StudentResponsePendingReview.CourseScheduledId)
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	INNER JOIN Person as StudentPerson  on (StudentResponsePendingReview.StudentPersonId = StudentPerson.PersonID)
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonID)
	INNER JOIN CourseType on (CourseType.CourseTypeId = CourseScheduled.CourseTypeId)
	INNER JOIN Person as FacilitatorPerson on (StudentResponsePendingReview.FacilitatorPersonId = FacilitatorPerson.PersonID)
	INNER JOIN Assignment on (Assignment.AssignmentId = StudentResponsePendingReview.AssignmentId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = StudentPerson.PersonID)
	INNER JOIN ContentType on (Assignment.ContentTypeId = ContentType.ContentTypeId)
	INNER JOIN StudentAssignmentResponse on (StudentAssignmentResponse.AssignmentId = Assignment.AssignmentId
		and StudentAssignmentResponse.PersonId = StudentPerson.PersonId)
	LEFT JOIN FileUpload as StudentResponseFileUpload on (StudentResponseFileUpload.FileUPloadId = StudentAssignmentResponse.FileUploadId)
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	LEFT JOIN StudentAssignmentResponseVisited on (StudentAssignmentResponseVisited.StudentAssignmentResponseId = StudentAssignmentResponse.StudentAssignmentResponseId
		and StudentAssignmentResponseVisited.FacilitatorPersonId = TeacherCourseAssign.PersonId)
	LEFT JOIN ResponseVisitedType on (ResponseVisitedType.ResponseVisitedTypeId = StudentAssignmentResponseVisited.ResponseVisitedTypeId)
	LEFT JOIN AssignmentFile on (AssignmentFile.AssignmentId = Assignment.AssignmentId)
	LEFT JOIN FileUpload as AssignmentFileUpload on (AssignmentFileUpload.FileUPloadId = AssignmentFile.FileUploadId)
	LEFT JOIN AssignmentWebsiteLink on (AssignmentWebsiteLink.AssignmentId = Assignment.AssignmentId)
	LEFT JOIN AssignmentPenspringWork on (AssignmentPenspringWork.AssignmentId = Assignment.AssignmentId)
where TeacherCourseAssign.PersonId = @personId

select * from #pendingAssignment

SELECT distinct
	DaysScheduled.CourseScheduledId,
	ClassPeriod.ClassPeriodId,
	ClassPeriod.PeriodNumber as ClassPeriodName
FROM DaysScheduled
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
WHERE DaysScheduled.CourseScheduledId in (Select CourseScheduledId from #pendingAssignment)

Drop Table if exists #pendingAssignment

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentBaseCourseRequest]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[GetStudentBaseCourseRequest]
	(@personId AS UniqueIdentifier, @studentPersonId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Set @personId = '43D8C718-52BA-4580-821C-F69C668F1228' --(select personid from person where username = 'kdunford')
--Set @studentPersonId = '43D8C718-52BA-4580-821C-F69C668F1228' --(select personid from person where username = 'kdunford')

--Request records from the student
Select
    StudentBaseCourseRequestId,
	null as CourseAssignByAdminId,
	null as LearnerCourseRecommendedId,
    CourseEntry.CourseName,
    CourseEntry.CourseEntryId,
    CourseEntry.ExternalId,
    CourseEntry.Credits,
    StudentBaseCourseRequest.SchoolYearId,
    StudentBaseCourseRequest.FinalizedDate,
	0 as SuggestionOnly
From StudentBaseCourseRequest
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = StudentBaseCourseRequest.CourseEntryId)
	INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = StudentBaseCourseRequest.SchoolYearId
		and PersonConfigure.PersonId = @personId)
Where StudentBaseCourseRequest.StudentPersonId = @studentPersonId

UNION

--Admin course assignments (required or suggested) BY GRADE LEVEL in general
Select
    null as StudentBaseCourseRequestId,
	CourseAssignByAdminId,
	null as LearnerCourseRecommendedId,
    CourseEntry.CourseName,
    CourseEntry.CourseEntryId,
    CourseEntry.ExternalId,
    CourseEntry.Credits,
    CourseAssignByAdmin.SchoolYearId,
    null as FinalizedDate,
	CourseAssignByAdmin.SuggestionOnly
From CourseAssignByAdmin
	INNER JOIN GradeLevel on (CourseAssignByAdmin.GradeLevelId = GradeLevel.GradeLevelId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseAssignByAdmin.CourseEntryId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseEntry.CompanyId)
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = @studentPersonId
		and RegistrationStudent.GradeLevelId = GradeLevel.GradeLevelId)
Where PersonAccessRoleAssign.PersonId = @personId
	and CourseAssignByAdmin.CourseAssignByAdminId not in (Select CourseAssignByAdminId from CourseAssignByAdminDeclined where StudentPersonId = @studentPersonId)

UNION

--Admin course assignments (required or suggested) SPECIFIC TO THIS STUDENT
Select
    null as StudentBaseCourseRequestId,
	CourseAssignByAdminId,
	null as LearnerCourseRecommendedId,
    CourseEntry.CourseName,
    CourseEntry.CourseEntryId,
    CourseEntry.ExternalId,
    CourseEntry.Credits,
    CourseAssignByAdmin.SchoolYearId,
    null as FinalizedDate,
	CourseAssignByAdmin.SuggestionOnly
From CourseAssignByAdmin
	INNER JOIN Person on (Person.PersonId = CourseAssignByAdmin.StudentPersonId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseAssignByAdmin.CourseEntryId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.CompanyId = CourseEntry.CompanyId)
Where PersonAccessRoleAssign.PersonId = @personId
	and CourseAssignByAdmin.StudentPersonId = @studentPersonId
	and CourseAssignByAdmin.CourseAssignByAdminId not in (Select CourseAssignByAdminId from CourseAssignByAdminDeclined where StudentPersonId = @studentPersonId)

UNION

--Course recommendations from students or counselors.
Select
    null as StudentBaseCourseRequestId,
	null as CourseAssignByAdminId,
	LearnerCourseRecommendedId,
    CourseEntry.CourseName,
    CourseEntry.CourseEntryId,
    CourseEntry.ExternalId,
    CourseEntry.Credits,
    null as SchoolYearId,
    null as FinalizedDate,
	1 as SuggestionOnly
From LearnerCourseRecommended
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = LearnerCourseRecommended.CourseEntryId)
Where LearnerCourseRecommended.PersonId = @studentPersonId
	and (LearnerCourseRecommended.ResponseType != 'Removed'
		or LearnerCourseRecommended.ResponseType is null)

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentCourseAssign]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStudentCourseAssign]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'manheim')

Declare @schoolYearId as UniqueIdentifier
Declare @companyId as UniqueIdentifier
Set @schoolYearId = (Select SchoolYearId from personConfigure where personId = @personId);

SELECT top 1
	Name,
	Company.CompanyId
INTO #manheimCompany
FROM Company
WHERE Name like 'Manheim%'

Set @companyId = (Select CompanyId from #manheimCompany)

--Big Group with UNIONS for Manheim courses
SELECT distinct
	StudentName,
	StudentId,
	GradeLevelName,
	CourseName,
	CourseId,
	SectionId,
	TeacherName,
	ClassPeriodNumber,
	IntervalName,
	Credits
into #manheimCourses
FROM (
	--A  Manheim course list
	SELECT
		StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentName,
		PersonAccessRoleAssign.ExternalId as StudentId,
		GradeLevel.Name as GradeLevelName,
		CourseEntry.CourseName,
		CourseEntry.ExternalId as CourseId,
		CourseScheduled.ExternalId as SectionId,
		Facilitator.Lname + ', ' + Facilitator.Fname as TeacherName,
		ClassPeriod.PeriodNumber as ClassPeriodNumber,
		Interval.Name as IntervalName,
		CourseEntry.Credits
	From CourseScheduled
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId
			and (CourseEntry.IsInactive is null or CourseEntry.IsInactive != 1))
		INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
		INNER JOIN DaysScheduled on (CourseScheduled.CourseScheduledId = DaysScheduled.CourseScheduledId)
		INNER JOIN ClassPeriod on (DaysScheduled.ClassPeriodId = ClassPeriod.ClassPeriodId)
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN Person as StudentPerson on (LearnerCourseAssign.PersonId = StudentPerson.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = StudentPerson.PersonId)
		LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
		LEFT JOIN Person as Facilitator on (facilitator.PersonID = CourseScheduled.FacilitatorPersonId)
	Where CourseScheduled.SchoolYearId = @schoolYearId
	and PersonAccessRoleAssign.CompanyId = @companyId

	UNION

	--C getManheimMusicCombinedCourses
	SELECT
		StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentName,
		PersonAccessRoleAssign.ExternalId as StudentId,
		GradeLevel.Name as GradeLevelName,
		CourseName,
		null as CourseId,
		null as SectionId,
		null as TeacherName,
		'1' as ClassPeriodNumber,
		'Fall Semester (MP1, MP2)' as IntervalName,
		Credits
	FROM ManheimMusicCombinedCourses
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = ManheimMusicCombinedCourses.CourseScheduledIdGu)
		INNER JOIN Person as StudentPerson on (LearnerCourseAssign.PersonId = StudentPerson.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = StudentPerson.PersonId)
		LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)

	UNION

	SELECT
		StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentName,
		PersonAccessRoleAssign.ExternalId as StudentId,
		GradeLevel.Name as GradeLevelName,
		CourseName,
		null as CourseId,
		null as SectionId,
		null as TeacherName,
		'1' as ClassPeriodNumber,
		'Spring Semester (MP3, MP4)' as IntervalName,
		Credits
	FROM ManheimMusicCombinedCourses
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = ManheimMusicCombinedCourses.CourseScheduledIdGu)
		INNER JOIN Person as StudentPerson on (LearnerCourseAssign.PersonId = StudentPerson.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = StudentPerson.PersonId)
		LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)

	UNION

	--D getManheimLearningSupportCourses
	SELECT
		StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentName,
		PersonAccessRoleAssign.ExternalId as StudentId,
		GradeLevel.Name as GradeLevelName,
		CourseName,
		null as CourseId,
		null as SectionId,
		null as TeacherName,
		'1' as ClassPeriodNumber,
		'Fall Semester (MP1, MP2)' as IntervalName,
		Credits
	FROM ManheimLearningSupportCombinedCourses
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = ManheimLearningSupportCombinedCourses.CourseScheduledIdGu)
		INNER JOIN Person as StudentPerson on (LearnerCourseAssign.PersonId = StudentPerson.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = StudentPerson.PersonId)
		LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)

	UNION

	SELECT
		StudentPerson.Lname + ', ' + StudentPerson.Fname as StudentName,
		PersonAccessRoleAssign.ExternalId as StudentId,
		GradeLevel.Name as GradeLevelName,
		CourseName,
		null as CourseId,
		null as SectionId,
		null as TeacherName,
		'1' as ClassPeriodNumber,
		'Spring Semester (MP3, MP4)' as IntervalName,
		Credits
	FROM ManheimLearningSupportCombinedCourses
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = ManheimLearningSupportCombinedCourses.CourseScheduledIdGu)
		INNER JOIN Person as StudentPerson on (LearnerCourseAssign.PersonId = StudentPerson.PersonId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = StudentPerson.PersonId)
		LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)

) as ManheimQuery
Order by StudentName

SELECT * FROM #manheimCourses

DROP TABLE #manheimCompany
DROP TABLE IF EXISTS #manheimCourses

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentList]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStudentList]
( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'ssorensen') --'A2812ACA-BA8D-445F-BFAB-86EF44B9C27F' --'91E033D9-6D29-4A4C-A767-29D499A6D11D'

DECLARE @companyId as UniqueIdentifier
DECLARE @schoolYearId as UniqueIdentifier
DECLARE @intervalId as UniqueIdentifier
DECLARE @accessRoleName as varchar(15)
DECLARE @companyName as varchar(100)

SELECT
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName,
	Company.StudentNameFirst,
	PersonConfigure.SchoolYearId as PersonConfigureSchoolYearId,
	Company.SchoolYearId as CompanySchoolYearId,
	PersonConfigure.IntervalId as PersonConfigureIntervalId,
	Company.IntervalId as CompanyIntervalId
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId)
WHERE PersonAccessRoleAssign.PersonId = @personId

SET @companyId = (SELECT top 1 CompanyId FROM #selectedAccess)
SET @accessRoleName = (SELECT top 1 AccessRoleName FROM #selectedAccess)
SET @companyName = (SELECT top 1 CompanyName FROM #selectedAccess)

SET @schoolYearId = (SELECT top 1 PersonConfigureSchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
SET @schoolYearId = (SELECT top 1 CompanySchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
SET @schoolYearId = (Select SchoolYearId from PersonConfigure where PersonId = @personId)

SET @intervalId = (SELECT top 1 PersonConfigureIntervalId from #selectedAccess)
if (@intervalId is null or @intervalId = '00000000-0000-0000-0000-000000000000')
SET @intervalId = (SELECT top 1 CompanyIntervalId from #selectedAccess)

--0
SELECT StudentNameFirst FROM #selectedAccess

IF (@accessRoleName IN ('Admin', 'Counselor', 'Doctor') OR (@accessRoleName = 'Facilitator' and @companyName = 'Manheim Central'))

	SELECT distinct
		StudentAccess.CompanyId,
		StudentPerson.PersonId,
		CASE WHEN StudentPerson.PreferredName is not null and StudentPerson.PreferredName != '' THEN StudentPerson.PreferredName ELSE StudentPerson.Fname END as FirstName,
		StudentPerson.Lname as LastName,
		StudentPerson.EmailAddress,
		StudentPerson.BirthDate,
		StudentPerson.BestContactEmail,
		StudentPerson.BestContactPhoneText,
		ParentPerson.city,
		UsState.Name as StateName,
		ParentPerson.fname as firstNameParent1,
		ParentPerson.lname as lastNameParent1,
		GradeLevel.Name as GradeLevelName,
		RegistrationStudent.GradeLevelId,
		RegistrationStudent.AcademyOrDistanceEd,
		RegistrationStudent.Accredited,
		RegistrationStudent.IsFinalized,
		RegistrationStudent.IEP,
		RegistrationStudent.CarsonSmith,
		RegistrationStudent.withdrawnDate,
		RegistrationStudent.FosterChild,
		RegistrationStudent.HomelessRunawayMigrant,
		RegistrationStudent.HispanicOrLatino,
		RegistrationStudent.RaceId,
		Race.Name as RaceName,
		RegistrationGuardianContact.PersonId as PrimaryGuardianPersonId
	INTO #selectedStudents_1
	FROM Person as StudentPerson
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentPerson.PersonId)
		INNER JOIN PersonAccessRoleAssign as StudentAccess on (StudentAccess.PersonID = RegistrationStudent.StudentPersonId
			and StudentPerson.PersonId = StudentAccess.PersonId)
		INNER JOIN PersonAccessRoleAssign as UserAccess on (UserAccess.CompanyId = StudentAccess.CompanyId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = StudentAccess.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
			and RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN')
		INNER JOIN PersonAccessGradeLevel on (PersonAccessGradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId
			and PersonAccessGradeLevel.PersonId = UserAccess.PersonId)
		INNER JOIN Person as ParentPerson on (ParentPerson.PersonId = RegistrationGuardianContact.PersonId)
		LEFT JOIN USState on (USState.USStateID = ParentPerson.USStateID)
		LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
		LEFT JOIN Race on (Race.RaceId = RegistrationStudent.RaceId)
	WHERE UserAccess.PersonId = @personId
	and RegistrationStudent.SchoolYearId = @schoolYearId

ELSE IF (@accessRoleName = 'Facilitator')

	SELECT distinct
		PersonAccessRoleAssign.CompanyId,
		Person.PersonId,
		CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
		Person.Lname as LastName,
		Person.EmailAddress,
		Person.BirthDate,
		Person.BestContactEmail,
		Person.BestContactPhoneText,
		RegistrationStudent.GradeLevelId,
		RegistrationStudent.AcademyOrDistanceEd,
		RegistrationStudent.Accredited,
		RegistrationStudent.IsFinalized,
		RegistrationGuardianContact.PersonId as PrimaryGuardianPersonId,
		null as city,
		null as StateName,
		null as firstNameParent1,
		null as lastNameParent1,
		GradeLevel.Name as GradeLevelName,
		RegistrationStudent.IEP,
		RegistrationStudent.withdrawnDate,
		RegistrationStudent.CarsonSmith,
		RegistrationStudent.FosterChild,
		RegistrationStudent.HomelessRunawayMigrant,
		RegistrationStudent.HispanicOrLatino,
		RegistrationStudent.RaceId,
		Race.Name as RaceName
	INTO #selectedStudents_2
	FROM Person
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = Person.PersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Person.PersonID
		and Person.PersonId = PersonAccessRoleAssign.PersonId )
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
		and RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN')
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.PersonId = RegistrationStudent.StudentPersonId)
		INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
		LEFT JOIN Race on (Race.RaceId = RegistrationStudent.RaceId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and TeacherCourseAssign.PersonId = @personId
		and CourseIntervalAssign.IntervalId = @intervalId
		and RegistrationStudent.SchoolYearId = @schoolYearId

ELSE IF (@accessRoleName = 'Observer')

	SELECT distinct
		PersonAccessRoleAssign.CompanyId,
		Person.PersonId,
		CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
		Person.Lname as LastName,
		Person.EmailAddress,
		Person.BirthDate,
		Person.BestContactEmail,
		Person.BestContactPhoneText,
		RegistrationStudent.GradeLevelId,
		RegistrationStudent.AcademyOrDistanceEd,
		RegistrationStudent.Accredited,
		RegistrationStudent.IsFinalized,
		null as city,
		null as StateName,
		null as firstNameParent1,
		null as lastNameParent1,
		GradeLevel.Name as GradeLevelName,
		null as IEP,
		null as CarsonSmith,
		RegistrationStudent.withdrawnDate,
		RegistrationGuardianContact.PersonId as PrimaryGuardianPersonId,
		RegistrationStudent.FosterChild,
		RegistrationStudent.HomelessRunawayMigrant,
		RegistrationStudent.HispanicOrLatino,
		RegistrationStudent.RaceId,
		Race.Name as RaceName
	INTO #selectedStudents_3
	FROM Person
		INNER JOIN PersonAccessRoleAssign on (Person.PersonId = PersonAccessRoleAssign.PersonId )
		INNER JOIN RegistrationStudent on (Person.PersonId = RegistrationStudent.StudentPersonId)
		INNER JOIN RegistrationTable on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN RegistrationGuardianContact on (RegistrationTable.RegistrationTableId = RegistrationGuardianContact.RegistrationTableId
		and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
		INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
		LEFT JOIN Race on (Race.RaceId = RegistrationStudent.RaceId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and RegistrationGuardianContact.PersonId = @personId
		and RegistrationStudent.SchoolYearId = @schoolYearId

ELSE IF (@accessRoleName = 'Learner')

	SELECT DISTINCT PersonAccessRoleAssign.CompanyId,
		Person.PersonId,
		CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
		Person.Lname as LastName,
		Person.EmailAddress,
		Person.BirthDate,
		Person.BestContactEmail,
		Person.BestContactPhoneText,
		RegistrationStudent.GradeLevelId,
		RegistrationStudent.AcademyOrDistanceEd,
		RegistrationStudent.Accredited,
		RegistrationStudent.IsFinalized,
		null as city,
		null as StateName,
		null as firstNameParent1,
		null as lastNameParent1,
		GradeLevel.Name as GradeLevelName,
		null as IEP,
		null as CarsonSmith,
		RegistrationStudent.withdrawnDate,
		RegistrationGuardianContact.PersonId as PrimaryGuardianPersonId,
		RegistrationStudent.FosterChild,
		RegistrationStudent.HomelessRunawayMigrant,
		RegistrationStudent.HispanicOrLatino,
		RegistrationStudent.RaceId,
		Race.Name as RaceName
	INTO #selectedStudents_4
	FROM Person
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonID = Person.PersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name = 'Learner')
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Person.PersonId)
		INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationStudent.RegistrationTableId
		and RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN')
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.PersonId = RegistrationStudent.StudentPersonId)
		INNER JOIN LearnerCourseAssign as thisLearnerCourseAssign  on (thisLearnerCourseAssign.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
		LEFT JOIN Race on (Race.RaceId = RegistrationStudent.RaceId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and RegistrationStudent.SchoolYearId = @schoolYearId
		and thisLearnerCourseAssign.PersonId = @personId

--1
IF (@accessRoleName IN ('Admin', 'Counselor', 'Doctor') OR (@accessRoleName = 'Facilitator' and @companyName = 'Manheim Central'))
BEGIN
	SELECT * FROM #selectedStudents_1

	--2 CourseScheduledId and FacilitatorPersonId list
	SELECT DISTINCT LearnerCourseAssign.PersonId,
		LearnerCourseAssign.CourseScheduledId,
		LearnerCourseAssign.PersonId as StudentPersonId,
		TeacherCourseAssign.PersonId as TeacherPersonId,
		CourseEntry.Credits
	FROM LearnerCourseAssign
		INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	WHERE LearnerCourseAssign.PersonId IN ( SELECT PersonId FROM #selectedStudents_1)
		and CourseScheduled.SchoolYearId = @schoolYearId

	--3 Get last log in date.
	SELECT PersonId,
		max(EntryDate) as EntryDate
	FROM PageVisitor
	WHERE PersonId IN ( SELECT PersonId FROM #selectedStudents_1)
		and PageName = 'login'
	GROUP BY PersonId

END

ELSE IF (@accessRoleName = 'Facilitator')

BEGIN

	SELECT * FROM #selectedStudents_2

	--2 CourseScheduledId and FacilitatorPersonId list
	SELECT DISTINCT LearnerCourseAssign.PersonId,
		LearnerCourseAssign.CourseScheduledId,
		LearnerCourseAssign.PersonId as StudentPersonId,
		TeacherCourseAssign.PersonId as TeacherPersonId,
		CourseEntry.Credits
	FROM LearnerCourseAssign
		INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	WHERE LearnerCourseAssign.PersonId IN ( SELECT PersonId FROM #selectedStudents_2)
		and CourseScheduled.SchoolYearId = @schoolYearId

	--3 Get last log in date.
	SELECT PersonId,
		max(EntryDate) as EntryDate
	FROM PageVisitor
	WHERE PersonId IN ( SELECT PersonId FROM #selectedStudents_2)
		and PageName = 'login'
	GROUP BY PersonId

END

ELSE IF (@accessRoleName = 'Observer')

BEGIN

	SELECT * FROM #selectedStudents_3

	--2 CourseScheduledId and FacilitatorPersonId list
	SELECT DISTINCT LearnerCourseAssign.PersonId,
		LearnerCourseAssign.CourseScheduledId,
		LearnerCourseAssign.PersonId as StudentPersonId,
		TeacherCourseAssign.PersonId as TeacherPersonId,
		CourseEntry.Credits
	FROM LearnerCourseAssign
		INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	WHERE LearnerCourseAssign.PersonId IN ( SELECT PersonId FROM #selectedStudents_3)
		and CourseScheduled.SchoolYearId = @schoolYearId

	--3 Get last log in date.
	SELECT PersonId,
		max(EntryDate) as EntryDate
	FROM PageVisitor
	WHERE PersonId IN ( SELECT PersonId FROM #selectedStudents_3)
		and PageName = 'login'
	GROUP BY PersonId
END

ELSE IF (@accessRoleName = 'Learner')
BEGIN

	SELECT * FROM #selectedStudents_4

	--2 CourseScheduledId and FacilitatorPersonId list
	SELECT DISTINCT LearnerCourseAssign.PersonId,
		LearnerCourseAssign.CourseScheduledId,
		LearnerCourseAssign.PersonId as StudentPersonId,
		TeacherCourseAssign.PersonId as TeacherPersonId,
		CourseEntry.Credits
	FROM LearnerCourseAssign
		INNER JOIN CourseScheduled on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
	WHERE LearnerCourseAssign.PersonId IN ( SELECT PersonId FROM #selectedStudents_4)
		and CourseScheduled.SchoolYearId = @schoolYearId

	--3 Get last log in date.
	SELECT PersonId,
		max(EntryDate) as EntryDate
	FROM PageVisitor
	WHERE PersonId IN ( SELECT PersonId FROM #selectedStudents_4)
		and PageName = 'login'
	GROUP BY PersonId

END

DROP TABLE #selectedAccess
IF OBJECT_ID('tempdb.dbo.#selectedStudents_1', 'U') IS NOT NULL
  DROP TABLE #selectedStudents_1;
IF OBJECT_ID('tempdb.dbo.#selectedStudents_2', 'U') IS NOT NULL
  DROP TABLE #selectedStudents_2;
IF OBJECT_ID('tempdb.dbo.#selectedStudents_3', 'U') IS NOT NULL
  DROP TABLE #selectedStudents_3;
IF OBJECT_ID('tempdb.dbo.#selectedStudents_4', 'U') IS NOT NULL
  DROP TABLE #selectedStudents_4;

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentListSimple]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO


CREATE PROCEDURE [dbo].[GetStudentListSimple]
	( @personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (Select personid from person where username = 'ssorensen')

DECLARE @companyId as UniqueIdentifier
DECLARE @accessRoleName as varchar(15)
DECLARE @schoolYearId as UniqueIdentifier
DECLARE @intervalId as UniqueIdentifier

SELECT distinct
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.StudentNameFirst,
	PersonConfigure.SchoolYearId as PersonConfigureSchoolYearId,
	Company.SchoolYearId as CompanySchoolYearId,
	PersonConfigure.IntervalId as PersonConfigureIntervalId,
	Company.IntervalId as CompanyIntervalId
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId)
WHERE PersonAccessRoleAssign.PersonId = @personId

SET @companyId = (SELECT top 1 CompanyId FROM #selectedAccess)
SET @accessRoleName = (SELECT top 1 AccessRoleName FROM #selectedAccess)

SET @schoolYearId = (SELECT top 1 PersonConfigureSchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (SELECT top 1 CompanySchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (Select SchoolYearId from PersonConfigure where PersonId = @personId)

SET @intervalId = (SELECT top 1 PersonConfigureIntervalId from #selectedAccess)
if (@intervalId is null or @intervalId = '00000000-0000-0000-0000-000000000000')
	SET @intervalId = (SELECT top 1 CompanyIntervalId from #selectedAccess)

--0
SELECT StudentNameFirst FROM #selectedAccess

IF (@accessRoleName != 'Facilitator' and @accessRoleName != 'Learner' and @accessRoleName != 'Observer')
	SELECT distinct
		Person.PersonId,
		CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
		Person.Lname as LastName
	FROM Person
		INNER JOIN PersonAccessRoleAssign as studentAccess on (studentAccess.PersonId = Person.PersonId)
		INNER JOIN AccessRoleLearner as studentRole on (studentRole.AccessRoleLearnerId = studentAccess.AccessRoleLearnerId
			and studentRole.Name = 'Learner')
		INNER JOIN PersonAccessRoleAssign as adminAccess on (adminAccess.CompanyId = studentAccess.CompanyId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Person.PersonId)
		INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN PersonAccessGradeLevel on (PersonAccessGradeLevel.PersonId = adminAccess.PersonId
			and PersonAccessGradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
	WHERE adminAccess.PersonId = @personId
		and adminAccess.CompanyId = @companyId
		and RegistrationTable.SchoolYearId = @schoolYearId

ELSE IF (@accessRoleName = 'Facilitator')
	SELECT distinct
		Person.PersonId,
		CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
		Person.Lname as LastName
	FROM Person
		INNER JOIN PersonAccessRoleAssign as studentAccess on (studentAccess.PersonId = Person.PersonId)
		INNER JOIN AccessRoleLearner as studentRole on (studentRole.AccessRoleLearnerId = studentAccess.AccessRoleLearnerId
			and studentRole.Name = 'Learner')
		INNER JOIN PersonAccessRoleAssign as teacherAccess on (teacherAccess.CompanyId = studentAccess.CompanyId)
		INNER JOIN AccessRoleLearner as teacherRole on (teacherRole.AccessRoleLearnerId = teacherAccess.AccessRoleLearnerId
			and teacherRole.Name = 'Facilitator')
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Person.PersonId)
		INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.PersonId = Person.PersonId)
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId
			and TeacherCourseAssign.PersonId = teacherAccess.PersonId)
	WHERE teacherAccess.PersonId = @personId
		and teacherAccess.CompanyId = @companyId
		and RegistrationTable.SchoolYearId = @schoolYearId

ELSE IF (@accessRoleName = 'Observer')
	SELECT distinct
		Person.PersonId,
		CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
		Person.Lname as LastName
	FROM Person
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Person.PersonId)
		INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
		INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationTable.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
	WHERE RegistrationGuardianContact.PersonId = @personId
		and RegistrationTable.SchoolYearId = @schoolYearId

ELSE IF (@accessRoleName = 'Learner')
	SELECT distinct
		Person.PersonId,
		CASE WHEN Person.PreferredName is not null and Person.PreferredName != '' THEN Person.PreferredName ELSE Person.Fname END as FirstName,
		Person.Lname as LastName
	FROM Person
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.PersonId = Person.PersonId)
		INNER JOIN LearnerCourseAssign as thisLearnerCourseAssign on (thisLearnerCourseAssign.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN PersonConfigure on (PersonConfigure.PersonId = thisLearnerCourseAssign.PersonId)
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
		INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	WHERE thisLearnerCourseAssign.PersonId = @personId
		and Person.PersonId != @personId
		and CourseScheduled.SchoolYearId = @schoolYearId


drop table #selectedAccess

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentOverallGrade]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO


CREATE PROCEDURE [dbo].[GetStudentOverallGrade]
(@personId AS UniqueIdentifier, @studentPersonId AS UniqueIdentifier, @courseScheduledId as Uniqueidentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Declare @courseScheduledId as Uniqueidentifier
--SET @courseScheduledId = 26408
--Set @personId = 'e726e316-ed28-4e14-8a5a-e31f33b4f349'
--Set @studentPersonId = 'd4899952-8ee4-4975-87aa-f541000cf7d3'

DECLARE @courseEntryId as Uniqueidentifier
DECLARE @facilitatorPersonId as UniqueIdentifier
DECLARE @courseTypeId as Uniqueidentifier
DECLARE @weightedScoreCount as INT

SELECT top 1 CourseEntry.CourseEntryId,
CourseEntry.CourseName,
CourseEntry.CompanyId,
Company.StudentNameFirst,
CourseScheduled.CourseTypeId,
CourseScheduled.CourseScheduledId,
CourseScheduled.GradeScaleTableId,
FacilitatorPersonId,
Person.Fname as FacilitatorFirstName,
Person.LName as FacilitatorLastName
INTO #selectedCourse
FROM CourseScheduled
INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
INNER JOIN Person on (Person.personId = TeacherCourseAssign.PersonId)
INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
INNER JOIN Company on (Company.CompanyId = CourseEntry.CompanyId)
WHERE CourseScheduled.CourseScheduledId = @courseScheduledId

SET @courseEntryId= (SELECT CourseEntryId FROM #selectedCourse)

SELECT distinct Assignment.AssignmentId,
Assignment.Title,
Assignment.Instructions,
Assignment.Sequence,
Assignment.TotalPoints,
Assignment.ExtraCredit,
Assignment.DueDate,
Assignment.AssessmentId,
Assessment.IsPublished,
Assignment.ContentTypeId,
ContentType.Code AS ContentTypeCode,
ContentType.Name AS ContentTypeName
INTO #selectedAssignments
FROM CourseScheduled
INNER JOIN AssignmentCourseSpecific on (AssignmentCourseSpecific.CourseScheduledId = CourseScheduled.CourseScheduledId)
INNER JOIN Assignment on (AssignmentCourseSpecific.AssignmentId = Assignment.AssignmentId
and CourseScheduled.CourseEntryId = Assignment.CourseEntryId)
INNER JOIN ContentType ON (ContentType.ContentTypeId = Assignment.ContentTypeId)
INNER JOIN PersonConfigure on (PersonConfigure.IntervalId = Assignment.IntervalId)
LEFT JOIN Assessment ON (Assessment.AssessmentId = Assignment.AssessmentId)
WHERE CourseScheduled.CourseScheduledId = @courseScheduledId
and PersonConfigure.PersonId = @personId
ORDER BY Assignment.Sequence

--0
--  If this course has a set of CourseWeightedScore records
-- then calculate the contentTypes and add up all of the grouped records for this student to get the percent
--  Otherwise
--      just get all of the total points and total scores in order to calculate the percentage.
select ContentTypeId, ScorePercent
into #courseWeightedScore
from CourseWeightedScore
where CourseEntryId = @courseEntryId

SET @weightedScoreCount = (SELECT count(*) FROM #courseWeightedScore)

IF @weightedScoreCount > 0 BEGIN
SELECT StudentAssignmentScore.StudentPersonId as PersonId,
Assignment.ContentTypeId,
CourseWeightedScore.ScorePercent,
CASE WHEN sum(Assignment.TotalPoints) > 0 THEN sum(StudentAssignmentScore.Score) / sum(Assignment.TotalPoints) * (CourseWeightedScore.ScorePercent / 100) ELSE 0 END as PercentGrade
INTO #selectedStudentOverallGrades
FROM StudentAssignmentScore
INNER JOIN Assignment on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId)
INNER JOIN CourseWeightedScore on (CourseWeightedScore.CourseEntryId = Assignment.CourseEntryId
and Assignment.ContentTypeId = CourseWeightedScore.ContentTypeId)
WHERE StudentAssignmentScore.StudentPersonId = @studentPersonId
and StudentAssignmentScore.AssignmentId IN (select AssignmentId from #selectedAssignments)
and (StudentAssignmentScore.IsPrevScore = 0 or StudentAssignmentScore.IsPrevScore is null)
and (StudentAssignmentScore.ScoreNotIncluded = 0 or StudentAssignmentScore.ScoreNotIncluded is null)
and (StudentAssignmentScore.HasPendingEssayReview is null or StudentAssignmentScore.HasPendingEssayReview = 0)
and StudentAssignmentScore.Score is not null
Group BY StudentAssignmentScore.StudentPersonId, Assignment.ContentTypeId, CourseWeightedScore.ScorePercent

SELECT * from #selectedStudentOverallGrades

END

 ELSE BEGIN
SELECT StudentAssignmentScore.StudentPersonId as PersonId,
null as ContentTypeId,
100 as ScorePercent,
CASE WHEN sum(Assignment.TotalPoints) > 0 THEN sum(StudentAssignmentScore.Score) / sum(Assignment.TotalPoints) ELSE 0 END as PercentGrade
INTO #selectedStudentOverallGradesSingle
FROM StudentAssignmentScore
INNER JOIN Assignment on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId)
WHERE StudentAssignmentScore.StudentPersonId = @studentPersonId
and StudentAssignmentScore.AssignmentId IN (select AssignmentId from #selectedAssignments)
and (StudentAssignmentScore.IsPrevScore = 0 or StudentAssignmentScore.IsPrevScore is null)
and (StudentAssignmentScore.ScoreNotIncluded = 0 or StudentAssignmentScore.ScoreNotIncluded is null)
and (StudentAssignmentScore.HasPendingEssayReview is null or StudentAssignmentScore.HasPendingEssayReview = 0)
and StudentAssignmentScore.Score is not null
Group BY StudentAssignmentScore.StudentPersonId

SELECT * from #selectedStudentOverallGradesSingle

   END

--1
SELECT StudentAssignmentScore.StudentPersonId,
ContentType.ContentTypeId,
ContentType.Name as ContentTypeName,
ContentType.Sequence,
sum(Assignment.TotalPoints) as TotalPoints,
sum(StudentAssignmentScore.Score) as TotalScores
FROM StudentAssignmentScore
INNER JOIN Assignment on (StudentAssignmentScore.AssignmentId = Assignment.AssignmentId)
INNER JOIN ContentType on (Assignment.ContentTypeId = ContentType.ContentTypeId)
WHERE StudentAssignmentScore.StudentPersonId = @studentPersonId
and StudentAssignmentScore.AssignmentId IN (select AssignmentId from #selectedAssignments)
and (StudentAssignmentScore.IsPrevScore = 0 or StudentAssignmentScore.IsPrevScore is null)
and (StudentAssignmentScore.ScoreNotIncluded = 0 or StudentAssignmentScore.ScoreNotIncluded is null)
and StudentAssignmentScore.Score is not null
and (StudentAssignmentScore.HasPendingEssayReview is null or StudentAssignmentScore.HasPendingEssayReview = 0)
Group BY StudentAssignmentScore.StudentPersonId, ContentType.Sequence, ContentType.ContentTypeId, ContentType.Name


DROP TABLE IF EXISTS #selectedCourse
DROP TABLE IF EXISTS #selectedAssignments
DROP TABLE IF EXISTS #courseWeightedScore
DROP TABLE IF EXISTS #selectedStudentOverallGrades
DROP TABLE IF EXISTS #selectedStudentOverallGradesSingle

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentProfile]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStudentProfile]
	(@personId AS UniqueIdentifier, @studentPersonId as UniqueIdentifier, @schoolYearId as UniqueIdentifier)
	--We are going to be ignoring the schoolYearId passed here and go with the user's PersonConfigure setting.
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Declare @schoolYearID as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')
--Set @studentPersonId = '6A491B8A-7354-42E5-830D-CAC5E5B07B1C' --Abigail Killough
--SET @schoolYearId = (Select SchoolYearId from PersonConfigure where PersonId = @personId)

SELECT top 1
	Company.CompanyId,
	AccessRoleLearner.Name as AccessRoleName,
	Company.Name as CompanyName,
	Company.StudentNameFirst,
	PersonConfigure.SchoolYearId as PersonConfigureSchoolYearId,
	Company.SchoolYearId as CompanySchoolYearId
INTO #selectedAccess
FROM PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
	INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
	INNER JOIN PersonConfigure on (PersonConfigure.PersonId = PersonAccessRoleAssign.PersonId)
WHERE PersonAccessRoleAssign.PersonId = @personId

SET @schoolYearId = (SELECT PersonConfigureSchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (SELECT CompanySchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (Select SchoolYearId from PersonConfigure where PersonId = @personId)

--0 Student - and accredited, medical, background
--1 Primary Guardian (technically, there should only be one)
--2 Secondary Guardians (0 to many)
--3 Emergency Contact (0 to many)
--4 Requested Classes (DE)

select distinct
	RegistrationStudent.RegistrationStudentId,
	RegistrationStudent.RegistrationTableId,
	RegistrationStudent.StudentPersonId,
	RegistrationTable.EntryDate,
	RegistrationTable.PaidDate,
	RegistrationTable.Account,
	RegistrationTable.CardNumber,
	RegistrationTable.BillingType,
	RegistrationTable.ResponsiblePersonId,
	RegistrationTable.ResponsibleFirstName,
	RegistrationTable.ResponsibleLastName,
	RegistrationTable.SchoolYearId,
	Person.fname as FirstName,
	Person.mname as MiddleName,
	Person.lname as LastName,
	Person.BirthDate,
	Person.username,
	Person.FirstTimeEntry,
	Person.EmailAddress,
	Person.BestContactEmail,
	Person.BestContactPhoneText,
	person.Address1,
	person.Address2,
	Person.City,
	Person.USStateID,
	UsState.Name as UsStateName,
	Person.CountryID,
	Country.Name as CountryName,
	Person.PostalCode,
    Person.Phone,
	CourseType.Name as StudentType,
	GradeLevel.Name as GradeLevelName,
    RegistrationStudent.GradeLevelId,
	RegistrationStudent.Accredited,
	RegistrationStudent.RegApprovedOrDenied,
	RegistrationStudent.RegReviewNote,
	RegistrationStudent.AcademyOrDistanceEd,
    RegistrationStudent.Iep,
    RegistrationStudent.CarsonSmith,
    RegistrationStudent.NoInsurance,
    RegistrationStudent.InsuranceCompany,
    RegistrationStudent.InsuranceGroupNumber,
    RegistrationStudent.InsuranceClientNumber,
    RegistrationStudent.DentistName,
    RegistrationStudent.DentistPhone,
    RegistrationStudent.PhysicianName,
    RegistrationStudent.PhysicianPhone,
    RegistrationStudent.SeizureMentalEmotional,
    RegistrationStudent.SeizureMentalEmotionalNote,
    RegistrationStudent.PrescriptionMedication,
    RegistrationStudent.OverTheCounterMeds,
    RegistrationStudent.LearningDisability,
    RegistrationStudent.LearningDisabilityNote,
    RegistrationStudent.ObtainEmergencyCare,
    FileUpload.Url as VaccinationFileURL,
    RegistrationStudent.FileUploadId as VaccinationFileUploadId,
    RegistrationStudent.VaccinationFileUpload,
    RegistrationStudent.VaccinationBringToOffice,
    RegistrationStudent.VaccinationMailToOffice,
	RegistrationStudent.PrimaryLanguageId,
    RegistrationStudent.BothParentsLiving,
    RegistrationStudent.HowLearnOfUsId,
    RegistrationStudent.ReferredByWhom,
    RegistrationStudent.EverExpelled,
    RegistrationStudent.TreatmentCenter,
    RegistrationStudent.CriminalRecord,
    RegistrationStudent.SupervisedCourt,
	RegistrationStudent.FosterChild,
	RegistrationStudent.HomelessRunawayMigrant,
	RegistrationStudent.HispanicOrLatino,
	RegistrationStudent.RaceId,
	Race.Name as RaceName,
    RegistrationStudent.WithdrawnDate,
    RegistrationStudent.SelfPaced,
	Gender.Name as GenderName,
	Language.Name as LanguageName,
	HowLearnOfUs.Name as HowLearnOfUsName,
	RegistrationStudent.PrescriptionMedicationNote,
	RegistrationStudent.EverExpelledNote,
	RegistrationStudent.TreatmentCenterNote,
	RegistrationStudent.CriminalRecordNote,
	RegistrationStudent.SupervisedCourtNote
into #regStudent
from Person
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = Person.PersonId)
	INNER JOIN RegistrationTable on (RegistrationTable.RegistrationTableId = RegistrationStudent.RegistrationTableId)
	LEFT JOIN UsState on (Person.UsstateId = UsState.USStateID)
	LEFT JOIN Country on (Person.CountryId = Country.CountryID)
	LEFT JOIN CourseType on (CourseType.CourseTypeID = RegistrationStudent.CourseTypeId)
	LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = RegistrationStudent.GradeLevelId)
	LEFT JOIN FileUpload on (FileUpload.FileUploadId = RegistrationStudent.FileUploadId)
	LEFT JOIN Gender on (Gender.GenderId = Person.GenderId)
	LEFT JOIN Language on (Language.LanguageId = RegistrationStudent.PrimaryLanguageId)
	LEFT JOIN HowLearnOfUs on (HowLearnOfUs.HowLearnOfUsId = RegistrationStudent.HowLearnOfUsId)
	LEFT JOIN Race on (Race.RaceId = RegistrationStudent.RaceId)
where RegistrationStudent.StudentPersonId = @studentPersonId
	and RegistrationTable.SchoolYearId = @schoolYearId
	and RegistrationStudent.SchoolYearId = @schoolYearId

--0 Student - and accreditation
Select * from #regStudent

--1 Primary Guardian (technically, there can only be one.)
select distinct
	RegistrationGuardianContact.RegistrationTableId,
	RegistrationGuardianContact.PersonId,
	Person.Fname as FirstName,
	Person.Mname as MiddleName,
	Person.Lname as LastName,
	Person.Address1,
	Person.Address2,
	Person.City,
	UsState.Name as UsStateName,
	Country.Name as CountryName,
	Person.Phone,
	Person.UserName,
	Person.FirstTimeEntry,
	Person.EmailAddress,
	RegistrationGuardianContact.PersonType as GuardianType,
	RegistrationGuardianContactRelation.RelationTypeId,
	RelationType.Name as RelationTypeName,
	RegistrationGuardianContactCustody.RegistrationCustodyId,
	RegistrationCustody.Name as RegistrationCustodyName,
	Gender.Name as GenderName,
	Language.Name as LanguageName
From Person
	INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = Person.PersonId)
	LEFT JOIN UsState on (UsState.USStateID = Person.USStateID)
	LEFT JOIN Country on (Country.CountryID = Person.CountryID)
	LEFT JOIN RegistrationGuardianContactRelation on (RegistrationGuardianContactRelation.RegistrationGuardianContactId = RegistrationGuardianContact.RegistrationGuardianContactId)
	LEFT JOIN RelationType on (RelationType.RelationTypeId = RegistrationGuardianContactRelation.RelationTypeId)
	LEFT JOIN RegistrationGuardianContactCustody on (RegistrationGuardianContactCustody.RegistrationGuardianContactId = RegistrationGuardianContact.RegistrationGuardianContactId)
	LEFT JOIN RegistrationCustody on (RegistrationCustody.RegistrationCustodyId = RegistrationGuardianContactCustody.RegistrationCustodyId)
	LEFT JOIN Gender on (Gender.GenderId = Person.GenderId)
	LEFT JOIN Language on (Language.LanguageId = Person.LanguageId)
where RegistrationTableId in (select RegistrationTableId from #regStudent)
	and RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN'


--2 Secondary Guardians (0 to many)
select distinct
	RegistrationGuardianContact.RegistrationTableId,
	RegistrationGuardianContact.PersonId,
	Person.Fname as FirstName,
	Person.Mname as MiddleName,
	Person.Lname as LastName,
	Person.Address1,
	Person.Address2,
	Person.City,
	UsState.Name as UsStateName,
	Country.Name as CountryName,
	Person.Phone,
	Person.UserName,
	Person.FirstTimeEntry,
	Person.EmailAddress,
	RegistrationGuardianContact.PersonType as GuardianType,
	RegistrationGuardianContactRelation.RelationTypeId,
	RelationType.Name as RelationTypeName,
	RegistrationGuardianContactCustody.RegistrationCustodyId,
	RegistrationCustody.Name as RegistrationCustodyName,
	Gender.Name as GenderName,
	Language.Name as LanguageName
from Person
	INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = Person.PersonId)
	LEFT JOIN UsState on (UsState.USStateID = Person.USStateID)
	LEFT JOIN Country on (Country.CountryID = Person.CountryID)
	LEFT JOIN RegistrationGuardianContactRelation on (RegistrationGuardianContactRelation.RegistrationGuardianContactId = RegistrationGuardianContact.RegistrationGuardianContactId)
	LEFT JOIN RelationType on (RelationType.RelationTypeId = RegistrationGuardianContactRelation.RelationTypeId)
	LEFT JOIN RegistrationGuardianContactCustody on (RegistrationGuardianContactCustody.RegistrationGuardianContactId = RegistrationGuardianContact.RegistrationGuardianContactId)
	LEFT JOIN RegistrationCustody on (RegistrationCustody.RegistrationCustodyId = RegistrationGuardianContactCustody.RegistrationCustodyId)
	LEFT JOIN Gender on (Gender.GenderId = Person.GenderId)
	LEFT JOIN Language on (Language.LanguageId = Person.LanguageId)
where RegistrationTableId in (select RegistrationTableId from #regStudent)
	and RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'

--3 Emergency Contact (0 to many)
select distinct
	RegistrationGuardianContact.RegistrationTableId,
	RegistrationGuardianContact.PersonId,
	Person.Fname as FirstName,
	Person.Mname as MiddleName,
	Person.Lname as LastName,
	Person.Address1,
	Person.Address2,
	Person.City,
	UsState.Name as UsStateName,
	Country.Name as CountryName,
	Person.Phone,
	Person.UserName,
	Person.EmailAddress,
	RegistrationGuardianContact.PersonType as GuardianType,
	RegistrationGuardianContactRelation.RelationTypeId,
	RelationType.Name as RelationTypeName,
	RegistrationGuardianContactCustody.RegistrationCustodyId,
	RegistrationCustody.Name as RegistrationCustodyName,
	Gender.Name as GenderName,
	Language.Name as LanguageName
from Person
	INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.PersonId = Person.PersonId)
	LEFT JOIN UsState on (UsState.USStateID = Person.USStateID)
	LEFT JOIN Country on (Country.CountryID = Person.CountryID)
	LEFT JOIN RegistrationGuardianContactRelation on (RegistrationGuardianContactRelation.RegistrationGuardianContactId = RegistrationGuardianContact.RegistrationGuardianContactId)
	LEFT JOIN RelationType on (RelationType.RelationTypeId = RegistrationGuardianContactRelation.RelationTypeId)
	LEFT JOIN RegistrationGuardianContactCustody on (RegistrationGuardianContactCustody.RegistrationGuardianContactId = RegistrationGuardianContact.RegistrationGuardianContactId)
	LEFT JOIN RegistrationCustody on (RegistrationCustody.RegistrationCustodyId = RegistrationGuardianContactCustody.RegistrationCustodyId)
	LEFT JOIN Gender on (Gender.GenderId = Person.GenderId)
	LEFT JOIN Language on (Language.LanguageId = Person.LanguageId)
where RegistrationTableId in (select RegistrationTableId from #regStudent)
	and RegistrationGuardianContact.PersonType = 'EMERGENCYCONTACT'

--4 Requested Classes (DE)
select
	RegistrationCourse.RegistrationCourseId,
	RegistrationCourseStudentRequest.StudentPersonId,
	CourseEntry.CourseName,
	LearningPathway.Name as LearningPathwayName,
	RegistrationCourseStudentRequest.Accredited
from CourseEntry
	INNER JOIN CourseScheduled on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	INNER JOIN RegistrationCourse on (CourseScheduled.CourseScheduledId = RegistrationCourse.CourseScheduledId)
	INNER JOIN LearningPathway on (CourseEntry.LearningPathwayId = LearningPathway.LearningPathwayId)
	INNER JOIN RegistrationCourseStudentRequest on (RegistrationCourseStudentRequest.RegistrationCourseId = RegistrationCourse.RegistrationCourseId)
where RegistrationCourseStudentRequest.StudentPersonId = @studentPersonId

--5 Student Admin Note
Select
	StudentAdminNoteId,
	StudentPersonId,
	Note,
	EntryPersonId,
	StudentAdminNote.EntryDate,
	Person.Fname + ' ' + Person.Lname as EntryPersonName
From StudentAdminNote
	INNER JOIN Person on (Person.PersonId = StudentAdminNote.EntryPersonId)
Where StudentAdminNote.StudentPersonId in (select studentPersonId from #regStudent)


DROP TABLE if exists #regStudent
Drop table if exists #selectedAccess

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentSchedule]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStudentSchedule]
(@personId AS UniqueIdentifier, @studentPersonId AS UniqueIdentifier, @schoolYearId as UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Declare @schoolYearId as UniqueIdentifier
--Set @personId = (select personId from person where username = '20AbrahamsonK98') --'91E033D9-6D29-4A4C-A767-29D499A6D11D' --'2E7C5BDB-6527-4CD2-8DED-251F683CEC4A' --'8392A37E-CAFA-4B27-B6DA-44B1729F6003' --'91E033D9-6D29-4A4C-A767-29D499A6D11D' --Jef
--Set @studentPersonId = (select personId from person where username = '20AbrahamsonK98') --'D7A228F2-FC8F-4346-A0F5-6A4BA0E876EC' --'2E7C5BDB-6527-4CD2-8DED-251F683CEC4A'-- '8392A37E-CAFA-4B27-B6DA-44B1729F6003' --'FCA622C9-1ED0-4A0D-B976-048CB62F691C' --Kelly Abrahamson
--Set @schoolYearId = (Select SchoolYearId from SchoolYear where YearInt = 2020);

Declare @IntervalId as UniqueIdentifier
Declare @isManheimStudent as nvarchar(100)
Declare @companyId as UniqueIdentifier

Set @companyId = (Select top 1 CompanyId from PersonAccessRoleAssign where PersonId = @personId)

SELECT top 1
	SchoolYearId,
	IntervalId
INTO #personConfig
FROM PersonConfigure
WHERE  PersonId = @personId --This should be personId and not studentPersonId because of the choices that the admin might be making to see the schedule.  Otherwise, if the student is logged in, it will be their control choice on the page for (particularly) IntervalId

Set @IntervalId = (Select top 1 IntervalId from #personConfig)

if @schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000'
	Set @schoolYearId = (select top 1 SchoolYearId from #personConfig)

if @schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000'
	Set @schoolYearId = (select top 1 SchoolYearId from #personConfig)

SELECT distinct
	baseCourse.CompanyId,
	baseCourse.CourseEntryId,
	baseCourse.credits,
	baseCourse.description,
	sched.CourseScheduledId,
	null as ManheimLearningSupportCombinedCoursesId,
	null as ManheimMusicCombinedCoursesId,
	Convert(bit, 1) as HasFallSemester,
	Convert(bit, 1) as HasSpringSemester,
	null as IsCombinedManheimClass,
	sched.SchoolYearId,
	baseCourse.DepartmentId,
	LearningPathway.LearningPathwayId,
	LearningPathway.Name as LearningPathwayName,
	baseCourse.CourseName,
	courseType.CourseTypeId,
	courseType.Name as courseTypeName,
	baseCourse.externalId as CourseId,
	sched.externalId as SectionId,
	sched.Code,
	sched.Section,
	sched.ExternalId,
	null as ClassPeriodId,
	null as ClassPeriodName,
	facilitator.PersonId as FacilitatorPersonId,
	facilitator.LName + ', ' + facilitator.FName as FacilitatorName,
	sched.Location,
	sched.OffCampus,
	sched.OnCampus,
	sched.Online,
	sched.SelfPaced,
	sched.FromDate,
	sched.ToDate,
	sched.MaxSeats,
	LearnerCourseAssign.PersonId as StudentPersonId,
	RegistrationStudent.IsFinalized,
	LearnerCourseAssign.LearnerCourseAssignId,
	LearnerCourseAssign.Accredited as CourseAssignAccredited,
	RegistrationStudent.Accredited as StudentAccredited
INTO #selectedCourses
FROM
	CourseEntry as baseCourse
	LEFT JOIN CourseScheduled as sched on (sched.CourseEntryId = baseCourse.CourseEntryId)
	LEFT JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = sched.CourseScheduledId)
	LEFT JOIN Person as Facilitator on (facilitator.PersonID = sched.FacilitatorPersonId)
	LEFT JOIN Interval on (CourseIntervalAssign.IntervalId = Interval.IntervalId)
	LEFT JOIN CourseType on (sched.CourseTypeId = CourseType.CourseTypeId)
	LEFT JOIN LearnerCourseAssign on (sched.CourseScheduledId = LearnerCourseAssign.CourseScheduledId)
	LEFT JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = LearnerCourseAssign.PersonId
		and RegistrationStudent.SchoolYearId = sched.SchoolYearId)
	LEFT JOIN LearningPathway on (baseCourse.LearningPathwayId = LearningPathway.LearningPathwayId)
WHERE (baseCourse.IsInactive is null or baseCourse.IsInactive != 1)
and LearnerCourseAssign.PersonId = @studentPersonId
and sched.SchoolYearId = (select top 1 SchoolYearId from #personConfig)
and CourseIntervalAssign.IntervalId = (select top 1 IntervalId from #personConfig)

SELECT * FROM #selectedCourses

--1
--Get getStudentList (courses and just the Ids of each student in that course)
--accumulate all of the tables to get the courses
SELECT
	CourseScheduled.CourseScheduledId,
	CourseScheduled.CourseEntryId,
	CourseEntry.ExternalId as CourseId,
	PersonId as StudentPersonId
FROM LearnerCourseAssign, CourseScheduled, CourseEntry
WHERE LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId
	and CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId
	and CourseScheduled.CourseScheduledId in (Select CourseScheduledId from #selectedCourses)
Order by CourseScheduled.CourseScheduledId



--2 The ClassperiodIds and names for all of the courses (but despite the monday through friday records, we are just going to get a distinct classPeriod since in Manheim's case, they don't vary day by day.
SELECT distinct
	DaysScheduled.DayOfTheWeek,
	DaysScheduled.CourseScheduledId,
	ClassPeriod.ClassPeriodId,
	ClassPeriod.PeriodNumber as ClassPeriodName,
	DaysScheduled.StartTime,
	DaysScheduled.Duration
FROM DaysScheduled
	INNER JOIN ClassPeriod on (ClassPeriod.ClassPeriodId = DaysScheduled.ClassPeriodId)
WHERE DaysScheduled.CourseScheduledId in (Select CourseScheduledId from #selectedCourses)

--3 TeacherCourseAssign
SELECT DISTINCT
	CourseScheduled.CourseScheduledId,
	TeacherCourseAssign.PersonId as TeacherPersonId,
	Person.Fname + ' ' + Person.Lname as TeacherName
FROM CourseScheduled
	INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN Person on (Person.PersonId = TeacherCourseAssign.PersonId)
	INNER JOIN CourseEntry on (CourseScheduled.CourseEntryId = CourseEntry.CourseEntryId)
WHERE CourseScheduled.CourseScheduledId in (Select CourseScheduledId from #selectedCourses)

--4 CourseIntervalAssign and Interval
SELECT DISTINCT
	CourseScheduledId,
	Interval.IntervalId,
	Interval.Code,
	Interval.Name,
	Interval.Sequence
From CourseIntervalAssign
	INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
Where CourseIntervalAssign.CourseScheduledId in (Select CourseScheduledId from #selectedCourses)


--5
SELECT distinct
	FinanceBilling.FinanceBillingId,
	FinanceFeeType.Name as FinanceFeeTypeName,
	FinanceFeeType.FinanceFeeTypeId,
	BilledPerson.fname + ' ' + BilledPerson.lname as BilledPersonName,
	FinanceBilling.Amount,
	FinanceBilling.Description,
	FinanceBilling.CourseScheduledId,
	FinanceBilling.FinanceGlcodeId,
	FinanceGlcode.Name as FinanceGlcodeName,
	FinanceBilling.FinanceGroupTableId,
	FinanceGroupTable.Name as FinanceGroupTableName,
	FinanceBilling.FinanceWaiverScheduleId,
	FinanceWaiverSchedule.Name as FinanceWaiverScheduleName,
	FinanceBilling.FinanceLowIncomeWaiverId,
	FinanceLowIncomeWaiver.Name as FinanceLowIncomeWaiverName,
	FinanceBilling.RefundType,
	FinanceBilling.MandatoryOrOptional,
	FinanceBilling.EntryPersonId,
	EntryPerson.fname + ' ' + EntryPerson.lname as EntryPersonName,
	FinanceBilling.PersonId,
	FinanceBilling.EntryDate
INTO #financeBillingAdmin
FROM FinanceBilling
	INNER JOIN FinanceFeeType on (FinanceFeeType.FinanceFeeTypeId = FinanceBilling.FinanceFeeTypeId)
	INNER JOIN Person as BilledPerson on (BilledPerson.PersonId = FinanceBilling.PersonId)
	INNER JOIN Person as EntryPerson on (EntryPerson.PersonId = FinanceBilling.EntryPersonId)
	LEFT JOIN FinanceGlcode on (FinanceGlcode.FinanceGlcodeId = FinanceBilling.FinanceGlcodeId)
	LEFT JOIN FinanceGroupTable on (FinanceGroupTable.FinanceGroupTableId = FinanceBilling.FinanceGroupTableId)
	LEFT JOIN FinanceWaiverSchedule on (FinanceWaiverSchedule.FinanceWaiverScheduleid = FinanceBilling.FinanceWaiverScheduleId)
	LEFT JOIN FinanceLowIncomeWaiver on (FinanceLowIncomeWaiver.FinanceLowIncomeWaiverId = FinanceBilling.FinanceLowIncomeWaiverId)
WHERE FinanceBilling.CompanyId = @companyId
	and financeBilling.CourseScheduledId in (Select CourseScheduledId from #selectedCourses)
Order by FinanceBilling.EntryDate

select * from #financeBillingAdmin

--6
SELECT distinct
	FinanceBillingId,
	FileUploadId,
	FileUrl
FROM FinanceBillingFile
WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingAdmin)

--7 Paid billing entries
SELECT distinct
	FinanceBillingId
FROM FinancePaymentDetail
WHERE FinanceBillingId in (select FinanceBillingId from #financeBillingAdmin)

--8 Assigned intervals to student
SELECT distinct
	CourseScheduledId,
	IntervalId
FROM LearnerCourseAssignInterval
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.LearnerCourseAssignId = LearnerCourseAssignInterval.LearnerCourseAssignId)
WHERE LearnerCourseAssign.PersonId in (select StudentPersonId from #selectedCourses)


DROP TABLE IF EXISTS #personConfig
DROP TABLE IF EXISTS #selectedCourses
DROP TABLE IF EXISTS #financeBillingAdmin

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentScheduleWeek]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStudentScheduleWeek]
	(@personId AS UniqueIdentifier,
	 @studentPersonId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')
--Set @studentPersonId = (select personid from person where username = 'tiara')

--0
Select
	Person.PersonId as studentPersonId,
	Person.Fname as FirstName,
	Person.Lname as LastName
From Person
Where Person.PersonId = @studentPersonId


--1
Select
	CourseScheduled.CourseScheduledId,
	CourseName,
    Location,
    Online,
	CourseScheduled.FromDate,
	CourseScheduled.ToDate
    --Interval.IntervalId,
    --Interval.Name as IntervalName,
    --Interval.FromDay as SemesterFromDay,
    --Interval.FromMonth as SemesterFromMonth,
    --Interval.ToDay as SemesterToDay,
    --Interval.ToMonth as SemesterToMonth
into #courses
From CourseScheduled
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
	INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
    INNER JOIN Person on (LearnerCourseAssign.PersonId = Person.PersonId)
    INNER JOIN PersonConfigure on (CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId
		and personConfigure.IntervalId = Interval.IntervalId)
Where LearnerCourseAssign.PersonId = @studentPersonId
    and PersonConfigure.PersonId = @personId

select * from #courses

--2
Select
	CourseScheduledId,
	DayOfTheWeek,
    ClassPeriod.PeriodNumber,
    DaysScheduled.StartTime,
    Duration,
	CASE WHEN DayOfTheWeek = 'sunday' THEN 0 Else
		CASE WHEN DayOfTheWeek = 'monday' THEN 1 Else
			CASE WHEN DayOfTheWeek = 'tuesday' THEN 2 Else
				CASE WHEN DayOfTheWeek = 'wednesday' THEN 3 Else
					CASE WHEN DayOfTheWeek = 'thursday' THEN 4 Else
						CASE WHEN DayOfTheWeek = 'friday' THEN 5 Else
							CASE WHEN DayOfTheWeek = 'saturday' THEN 6 END END END END END END END as Sequence
From DaysScheduled
    LEFT JOIN ClassPeriod on (DaysScheduled.ClassPeriodId = ClassPeriod.ClassPeriodId)
Where DaysScheduled.CourseScheduledId in (Select CourseScheduledId from #courses)


Drop Table If Exists #courses

END
GO
/****** Object:  StoredProcedure [dbo].[GetStudentTranscripts]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetStudentTranscripts]
	(@personId AS UniqueIdentifier,
	 @studentPersonId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @studentPersonId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')
--Set @studentPersonId = 'E6E78B34-4373-4CDE-8756-3C40E85173C7' --(select personid from person where username = 'Abby75A5')

Declare @companyId as UniqueIdentifier

Set @companyId = (Select top 1 companyId
					From PersonAccessRoleAssign
					Where PersonAccessRoleAssign.PersonID = @personId)

--0
SELECT distinct
    Person.PersonId as StudentPersonId,
    Person.fname as StudentFirstName,
    Person.lname as StudentLastName,
    Gender.Name as GenderName,
    Person.BirthDate,
    Person.Address1 + ' ' + Person.Address2 as StreetAddress,
    Person.City,
    USState.Abbreviation as StateAbbrev,
    Person.PostalCode,
    Person.GraduationDate
FROM Person
	LEFT JOIN Gender on (Gender.GenderId = Person.GenderId)
	LEFT JOIN USState on (USState.USStateId = Person.USStateId)
WHERE Person.PersonId = @studentPersonId

--1
SELECT distinct
	SchoolYear.Name as SchoolYearName,
	SchoolYear.SchoolYearId,
	GradeLevel.Name as GradeLevelName
FROM Transcript
	INNER JOIN SchoolYear on (SchoolYear.SchoolYearId = Transcript.SchoolYearId)
	LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = Transcript.GradeLevelId)
WHERE Transcript.StudentPersonId = @studentPersonId

--2
SELECT distinct
	SchoolYear.Name as SchoolYearName,
	GradeLevel.Name as GradeLevelName,
	GradeLevel.GradeLevelId,
	SchoolName,
	SchoolYear.SchoolYearId,
	GradeScaleTable.GradeScaleTableId,
    TranscriptId,
    IntervalType,
    FirstInterval,
    SecondInterval,
    ThirdInterval,
    FourthInterval,
    CourseName,
    Credits,
    Note
FROM GradeScaleTable, Transcript
	INNER JOIN SchoolYear on (SchoolYear.SchoolYearId = Transcript.SchoolYearId)
	LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = Transcript.GradeLevelId)
WHERE Transcript.StudentPersonId = @studentPersonId
	and GradeScaleTable.CompanyId = @companyId
	and GradeScaleTable.DefaultFlag = 1

--3
SELECT distinct
	TranscriptTestId,
	Name,
	TestDate,
	English,
	Math,
	Reading,
	Science,
	Composite,
	EnglishWriting,
	EntryPersonId,
	EntryDate
FROM TranscriptTest
WHERE TranscriptTest.StudentPersonId = @studentPersonId

--4  Current school transcript (StudentGradeFinal)
SELECT distinct
    --StudentGradeFinalId,  don't use this here since we need to make the entries distinct and there could be duplicates in this table.
	SchoolYear.Name as SchoolYearName,
	GradeLevel.Name as GradeLevelName,
	Company.Name as SchoolName,
	SchoolYear.SchoolYearId,
    StudentGradeFinal.IntervalType,
	CourseScheduled.GradeScaleTableId,
    FirstInterval,
    SecondInterval,
    ThirdInterval,
    FourthInterval,
    CourseEntry.CourseName,
    StudentGradeFinal.Credits,
    Note
FROM StudentGradeFinal
	INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = StudentGradeFinal.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = StudentGradeFinal.StudentPersonId)
	INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = StudentGradeFinal.StudentPersonId
		and RegistrationStudent.SchoolYearId = StudentGradeFinal.SchoolYearId)
	INNER JOIN Company on (Company.CompanyId = PersonAccessRoleAssign.CompanyId)
	INNER JOIN SchoolYear on (SchoolYear.SchoolYearId = StudentGradeFinal.SchoolYearId)
	LEFT JOIN GradeLevel on (GradeLevel.GradeLevelId = StudentGradeFinal.GradeLevelId)
WHERE StudentGradeFinal.StudentPersonId = @studentPersonId

END
GO
/****** Object:  StoredProcedure [dbo].[GetTeacherSchedule]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetTeacherSchedule]
	(@personId AS UniqueIdentifier,
	 @facilitatorPersonId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @facilitatorPersonId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')
--Set @facilitatorPersonId = (select personid from person where username = 'annette')

--0
Select
	Person.PersonId as FacilitatorPersonId,
	Person.Fname as FirstName,
	Person.Lname as LastName
From Person
Where Person.PersonId = @facilitatorPersonId


--1
Select
	CourseScheduled.CourseScheduledId,
	CourseName,
    Location,
    Online,
    Interval.IntervalId,
    Interval.Name as IntervalName,
    Interval.FromDay as SemesterFromDay,
    Interval.FromMonth as SemesterFromMonth,
    Interval.toDay as SemesterToDay,
    Interval.toMonth as SemesterToMonth
into #courses
From CourseScheduled
	INNER JOIN CourseIntervalAssign on (CourseIntervalAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
	INNER JOIN CourseEntry on (CourseEntry.CourseEntryId = CourseScheduled.CourseEntryId)
	INNER JOIN Interval on (Interval.IntervalId = CourseIntervalAssign.IntervalId)
    INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.CourseScheduledId = CourseScheduled.CourseScheduledId)
    INNER JOIN Person on (TeacherCourseAssign.PersonId = Person.PersonId)
    INNER JOIN PersonConfigure on (CourseScheduled.SchoolYearId = PersonConfigure.SchoolYearId)
Where Person.PersonId = @facilitatorPersonId
    and PersonConfigure.PersonId = @personId

select * from #courses

--2
Select
	CourseScheduledId,
	DayOfTheWeek,
    ClassPeriod.PeriodNumber,
    DaysScheduled.StartTime,
    Duration,
	CASE WHEN DayOfTheWeek = 'sunday' THEN 0 Else
		CASE WHEN DayOfTheWeek = 'monday' THEN 1 Else
			CASE WHEN DayOfTheWeek = 'tuesday' THEN 2 Else
				CASE WHEN DayOfTheWeek = 'wednesday' THEN 3 Else
					CASE WHEN DayOfTheWeek = 'thursday' THEN 4 Else
						CASE WHEN DayOfTheWeek = 'friday' THEN 5 Else
							CASE WHEN DayOfTheWeek = 'saturday' THEN 6 END END END END END END END as Sequence
From DaysScheduled
    LEFT JOIN ClassPeriod on (DaysScheduled.ClassPeriodId = ClassPeriod.ClassPeriodId)
Where DaysScheduled.CourseScheduledId in (Select CourseScheduledId from #courses)


Drop Table If Exists #courses

END
GO
/****** Object:  StoredProcedure [dbo].[GetTestSettings]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetTestSettings]
	(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'jef')

SELECT distinct
    Test.TestId,
    Test.Name,
    Test.PossibleScore,
    Test.Description,
	count(Testing.TestingId) as UsedIn
INTO #tests
FROM Test
	INNER JOIN PersonAccessRoleAssign on (Test.CompanyId = PersonAccessRoleAssign.CompanyId)
	LEFT JOIN Testing on (Testing.TestId = Test.TestId)
WHERE PersonAccessRoleAssign.PersonId = @personId
Group By Test.TestId, Test.Name, Test.PossibleScore, Test.Description

--0
select * from #tests

--1
SELECT
    TestComponent.Name as TestComponentName,
    TestComponentAssignId,
    TestComponentAssign.TestComponentId,
    TestId,
	TestComponentAssign.PossibleScore
FROM TestComponentAssign
	INNER JOIN TestComponent on (TestComponent.TestComponentId = TestComponentAssign.TestComponentId)
WHERE TestComponentAssign.TestId in (Select TestId from #tests)

--2
SELECT
    TestComponentId,
    Name,
    Description
FROM TestComponent
	INNER JOIN PersonAccessRoleAssign on (TestComponent.CompanyId = PersonAccessRoleAssign.CompanyId)
WHERE PersonAccessRoleAssign.PersonId = @personId
Order by Name


Drop Table If Exists #tests

END
GO
/****** Object:  StoredProcedure [dbo].[GetUsers]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[GetUsers]
(@personId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personId from person where username = 'shirlynjones@yahoo.com')

DECLARE @companyId as UniqueIdentifier
DECLARE @accessRoleName as varchar(15)
DECLARE @companyName as varchar(100)
DECLARE @schoolYearId as UniqueIdentifier

SELECT top 1
		PersonAccessRoleAssign.CompanyId,
		AccessRoleLearner.Name as AccessRoleName,
		PersonConfigure.SchoolYearId as PersonConfigureSchoolYearId,
		Company.SchoolYearId as CompanySchoolYearId,
		Company.Name as CompanyName
	INTO #selectedAccess
	FROM PersonAccessRoleAssign
		INNER JOIN AccessRoleLearner on (PersonAccessRoleAssign.AccessRoleLearnerId = AccessRoleLearner.AccessRoleLearnerId)
		LEFT JOIN PersonConfigure on (PersonAccessRoleAssign.PersonId = PersonConfigure.PersonId)
		INNER JOIN Company on (PersonAccessRoleAssign.CompanyId = Company.CompanyId)
		INNER JOIN Person on (PersonAccessRoleAssign.PersonId = Person.PersonId)
	WHERE PersonAccessRoleAssign.PersonId = @personId

SET @companyId = (SELECT top 1 CompanyId FROM #selectedAccess)
SET @accessRoleName = (SELECT top 1 AccessRoleName FROM #selectedAccess)
SET @companyName = (Select top 1 CompanyName from #selectedAccess)

SET @schoolYearId = (SELECT PersonConfigureSchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (SELECT CompanySchoolYearId from #selectedAccess)
if (@schoolYearId is null or @schoolYearId = '00000000-0000-0000-0000-000000000000')
	SET @schoolYearId = (Select SchoolYearId from SchoolYear where YearInt = 2020)

If (@accessRoleName = 'Admin' or @accessRoleName = 'Facilitator' or @accessRoleName = 'FrontDesk')
	SELECT
		AccessRoleLearner.Name as UserRole,
		Person.lname + ', ' + Person.fname as FullName,
		Person.PersonId,
		Person.fname as FirstName,
		Person.lname as LastName,
		Person.EmailAddress,
		Person.Username,
		Person.Phone,
		AccessFacilitator.ExternalId,
		Person.EntryDate
	FROM Person
		INNER JOIN PersonAccessRoleAssign as AccessFacilitator on (AccessFacilitator.PersonId = Person.PersonId)
		INNER JOIN PersonAccessRoleAssign as AccessAdmin on (AccessAdmin.CompanyId = accessFacilitator.CompanyId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = AccessFacilitator.AccessRoleLearnerId)
	WHERE AccessRoleLearner.Name != 'Learner'
		and AccessAdmin.PersonId = @personId

ELSE If (@accessRoleName = 'Observer')
	SELECT
		'Learner' as UserRole,
		Person.lname + ', ' + Person.fname as FullName,
		Person.PersonId,
		Person.fname as FirstName,
		Person.lname as LastName,
		Person.EmailAddress,
		Person.Username,
		Person.Phone,
		PersonAccessRoleAssign.ExternalId,
		Person.EntryDate
	FROM Person
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = Person.PersonId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.PersonId = Person.PersonId)
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = TeacherCourseAssign.CourseScheduledId)
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId
			and CourseScheduled.SchoolYearId = @schoolYearId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = LearnerCourseAssign.PersonId)
		INNER JOIN RegistrationTable on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
		INNER JOIN RegistrationGuardianContact on (RegistrationTable.RegistrationTableId = RegistrationGuardianContact.RegistrationTableId
			and (RegistrationGuardianContact.PersonType = 'PRIMARYGUARDIAN' or RegistrationGuardianContact.PersonType = 'SECONDARYGUARDIAN'))
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and RegistrationGuardianContact.PersonId = @personId
		and RegistrationStudent.SchoolYearId = @schoolYearId

	UNION

	SELECT
		AccessRoleLearner.Name as UserRole,
		Person.lname + ', ' + Person.fname as FullName,
		Person.PersonId,
		Person.fname as FirstName,
		Person.lname as LastName,
		Person.EmailAddress,
		Person.Username,
		Person.Phone,
		PersonAccessRoleAssign.ExternalId,
		Person.EntryDate
	FROM Person
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = Person.PersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name != 'Learner' and AccessRoleLearner.Name != 'Observer' )
	WHERE PersonAccessRoleAssign.CompanyId = @companyId


ELSE If (@accessRoleName = 'Learner')
	SELECT
		'Facilitator' as UserRole,
		Person.lname + ', ' + Person.fname as FullName,
		Person.PersonId,
		Person.fname as FirstName,
		Person.lname as LastName,
		Person.EmailAddress,
		Person.Username,
		Person.Phone,
		PersonAccessRoleAssign.ExternalId,
		Person.EntryDate
	FROM Person
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = Person.PersonId)
		INNER JOIN TeacherCourseAssign on (TeacherCourseAssign.PersonId = Person.PersonId)
		INNER JOIN LearnerCourseAssign on (LearnerCourseAssign.CourseScheduledId = TeacherCourseAssign.CourseScheduledId)
		INNER JOIN CourseScheduled on (CourseScheduled.CourseScheduledId = LearnerCourseAssign.CourseScheduledId
			and CourseScheduled.SchoolYearId = @schoolYearId)
		INNER JOIN RegistrationStudent on (RegistrationStudent.StudentPersonId = LearnerCourseAssign.PersonId)
		INNER JOIN RegistrationTable on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
	WHERE PersonAccessRoleAssign.CompanyId = @companyId
		and RegistrationStudent.StudentPersonId = @personId
		and RegistrationStudent.SchoolYearId = @schoolYearId


	UNION

	SELECT
		AccessRoleLearner.Name as UserRole,
		Person.lname + ', ' + Person.fname as FullName,
		Person.PersonId,
		Person.fname as FirstName,
		Person.lname as LastName,
		Person.EmailAddress,
		Person.Username,
		Person.Phone,
		PersonAccessRoleAssign.ExternalId,
		Person.EntryDate
	FROM Person
		INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = Person.PersonId)
		INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId
			and AccessRoleLearner.Name != 'Learner' and AccessRoleLearner.Name != 'Observer' )
	WHERE PersonAccessRoleAssign.CompanyId = @companyId

--1
SELECT
    PersonAccessGradeLevel.PersonId,
    GradeLevel.GradeLevelId,
    Name,
    Code,
    Sequence
From PersonAccessGradeLevel
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = PersonAccessGradeLevel.PersonId)
	INNER JOIN GradeLevel on (GradeLevel.GradeLevelId = PersonAccessGradeLevel.GradeLevelId)
Where PersonAccessRoleAssign.CompanyId = @companyId

Drop Table if Exists #selectedAccess

END
GO
/****** Object:  StoredProcedure [dbo].[GetVolunteerEvents]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetVolunteerEvents]
	(@personId AS UniqueIdentifier,
	@volunteerEventId AS UniqueIdentifier)
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @volunteerEventId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'shirlynjones@yahoo.com')
--Set @volunteerEventId = '9E1A03BB-B0C8-4033-B8B1-4B720D227C29'

Declare @accessRoleName as nvarchar(25)

Select top 1 AccessRoleLearner.Name
into #accessRole
From PersonAccessRoleAssign
	INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
Where PersonAccessRoleAssign.PersonId = @personId

Set @accessRoleName = (select Name from #accessRole);

if @accessRoleName = 'Admin'

	BEGIN

	SELECT distinct
		VolunteerEventId,
		VolunteerPersonId,
		VolunteerPerson.Fname + ' ' + VolunteerPerson.Lname as VolunteerPersonName,
		CheckIn,
		VolunteerEvent.FileUploadId,
		VolunteerEvent.FileUrl,
		ConfirmCheckIn,
		CheckInAdminPerson.Fname + ' ' + CheckInAdminPerson.Lname as CheckInAdminName,
		CheckInAdminPersonId,
		CheckOut,
		ConfirmCheckOut,
		CheckOutAdminPerson.Fname + ' ' + CheckOutAdminPerson.Lname as CheckOutAdminName,
		CheckOutAdminPersonId,
		VolunteerType.VolunteerTypeId,
		VolunteerType.Name as VolunteerTypeName,
		VolunteerNote,
		CheckInAdminNote,
		CheckOutAdminNote
	INTO #volunteerEvents
	FROM volunteerEvent
		INNER JOIN Person as VolunteerPerson on (VolunteerPerson.PersonId = volunteerEvent.VolunteerPersonId)
		LEFT JOIN Person as CheckInAdminPerson on (CheckInAdminPerson.PersonId = volunteerEvent.CheckInAdminPersonId)
		LEFT JOIN Person as CheckOutAdminPerson on (CheckOutAdminPerson.PersonId = volunteerEvent.CheckOutAdminPersonId)
		INNER JOIN PersonAccessRoleAssign as ParentAccess on (ParentAccess.PersonId = volunteerEvent.VolunteerPersonId)
		INNER JOIN PersonAccessRoleAssign as AdminAccess on (AdminAccess.CompanyId = ParentAccess.CompanyId)
		LEFT JOIN VolunteerType on (VolunteerType.VolunteerTypeId = volunteerEvent.VolunteerTypeId)
	WHERE AdminAccess.PersonId = @personId
	Order by volunteerEvent.Checkin desc

	--0
	select * from #volunteerEvents

	--1
	SELECT
		Registrationtable.PersonId as GuardianPersonId,
		RegistrationStudent.StudentPersonId
	FROM Registrationtable
		INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationtableId = Registrationtable.RegistrationtableId)
		INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = PersonConfigure.SchoolYearId)
	WHERE RegistrationTable.PersonId in (Select VolunteerPersonId from #volunteerEvents)
		and PersonConfigure.PersonId = @personId

	END
else

	BEGIN

	SELECT distinct
		VolunteerEventId,
		VolunteerPersonId,
		VolunteerPerson.Fname + ' ' + VolunteerPerson.Lname as VolunteerPersonName,
		CheckIn,
		VolunteerEvent.FileUploadId,
		VolunteerEvent.FileUrl,
		ConfirmCheckIn,
		CheckInAdminPerson.Fname + ' ' + CheckInAdminPerson.Lname as CheckInAdminName,
		CheckInAdminPersonId,
		CheckOut,
		ConfirmCheckOut,
		CheckOutAdminPerson.Fname + ' ' + CheckOutAdminPerson.Lname as CheckOutAdminName,
		CheckOutAdminPersonId,
		VolunteerType.VolunteerTypeId,
		VolunteerType.Name as VolunteerTypeName,
		VolunteerNote,
		CheckInAdminNote,
		CheckOutAdminNote
	INTO #volunteerEvents2
	FROM volunteerEvent
		INNER JOIN Person as VolunteerPerson on (VolunteerPerson.PersonId = volunteerEvent.VolunteerPersonId)
		LEFT JOIN Person as CheckInAdminPerson on (CheckInAdminPerson.PersonId = volunteerEvent.CheckInAdminPersonId)
		LEFT JOIN Person as CheckOutAdminPerson on (CheckOutAdminPerson.PersonId = volunteerEvent.CheckOutAdminPersonId)
		LEFT JOIN VolunteerType on (VolunteerType.VolunteerTypeId = volunteerEvent.VolunteerTypeId)
	WHERE volunteerEvent.VolunteerPersonId = @personId
		and ((@volunteerEventId is null or @volunteerEventId = '00000000-0000-0000-0000-000000000000')
			or (@volunteerEventId is not null and @volunteerEventId != '00000000-0000-0000-0000-000000000000'
				and @volunteerEventId = volunteerEvent.volunteerEventId))
	Order by volunteerEvent.CheckIn desc

	--0
	select * from #volunteerEvents2

	--1
	SELECT
		Registrationtable.PersonId as GuardianPersonId,
		RegistrationStudent.StudentPersonId
	FROM Registrationtable
		INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationtableId = Registrationtable.RegistrationtableId)
		INNER JOIN PersonConfigure on (PersonConfigure.SchoolYearId = PersonConfigure.SchoolYearId)
	WHERE RegistrationTable.PersonId in (Select VolunteerPersonId from #volunteerEvents2)
		and PersonConfigure.PersonId = @personId

	END

Drop Table If Exists #accessRole
Drop Table If Exists #volunteerEvents
Drop Table If Exists #volunteerEvents2

END
GO
/****** Object:  StoredProcedure [dbo].[GetVolunteerOpportunities]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[GetVolunteerOpportunities]
	(@personId AS UniqueIdentifier)
 AS
BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = (select personid from person where username = 'shirlynjones@yahoo.com')

--0
SELECT distinct
	VolunteerOpportunity.VolunteerOpportunityId,
	VolunteerOpportunityDate.VolunteerOpportunityDateId,
	VolunteerOpportunity.Name as VolunteerOpportunityName,
	VolunteersNeeded,
	Note,
	VolunteerType.VolunteerTypeId,
	VolunteerType.Name as VolunteerTypeName,
	StartTime,
	EndTime
INTO #opportunities
FROM VolunteerOpportunity
	LEFT JOIN VolunteerType on (VolunteerType.VolunteerTypeId = VolunteerOpportunity.VolunteerTypeId)
	LEFT JOIN PersonAccessRoleAssign as EntryPersonAccess on (EntryPersonAccess.PersonId = VolunteerOpportunity.EntryPersonId)
	LEFT JOIN PersonAccessRoleAssign as ThisPersonAccess on (ThisPersonAccess.CompanyId = EntryPersonAccess.CompanyId)
	INNER JOIN VolunteerOpportunityDate on (VolunteerOpportunityDate.VolunteerOpportunityId = VolunteerOpportunity.VolunteerOpportunityId)
WHERE ThisPersonAccess.PersonId = @personId
ORDER BY StartTime

select * from #opportunities

--1
SELECT distinct
	VolunteerOpportunitySignUp.VolunteerOpportunityDateId,
	Person.PersonId,
	Person.Fname + ' ' + person.Lname as PersonName
FROM VolunteerOpportunitySignUp
	INNER JOIN Person on (Person.PersonId = VolunteerOpportunitySignUp.PersonId)
WHERE VolunteerOpportunitySignUp.VolunteerOpportunityDateId in (select VolunteerOpportunityDateId from #opportunities)


Drop Table If Exists #opportunities

END
GO
/****** Object:  StoredProcedure [dbo].[HasEnrolledStudent]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO

CREATE PROCEDURE [dbo].[HasEnrolledStudent]
	( @personId AS UniqueIdentifier)
 AS
BEGIN
--Declare @personId as UniqueIdentifier
--Set @personId = 'F431CC2D-014C-4844-901F-2FC2AC33AC1D' --(select Personid from person where username = 'ssorensen')

--0
select RegistrationStudent.StudentPersonId
From RegistrationTable
	INNER JOIN RegistrationStudent on (RegistrationStudent.RegistrationTableId = RegistrationTable.RegistrationTableId)
	INNER JOIN RegistrationGuardianContact on (RegistrationGuardianContact.RegistrationTableId = RegistrationTable.RegistrationTableId)
	INNER JOIN PersonAccessRoleAssign on (PersonAccessRoleAssign.PersonId = RegistrationStudent.StudentPersonId)
	INNER JOIN AccessRoleLearner on (AccessRoleLearner.AccessRoleLearnerId = PersonAccessRoleAssign.AccessRoleLearnerId)
	INNER JOIN PersonConfigure as studentConfig on (studentConfig.PersonId = RegistrationTable.PersonId)
	INNER JOIN PersonConfigure as observerConfig on (observerConfig.PersonId = RegistrationGuardianContact.PersonId)
Where RegistrationGuardianContact.PersonId = @personId
    and RegistrationTable.SchoolYearId = studentConfig.SchoolYearId
    and RegistrationStudent.SchoolYearId = studentConfig.SchoolYearId
    and AccessRoleLearner.Name = 'Learner'
    and RegistrationStudent.RegApprovedOrDenied = 'Approved'

END
GO
/****** Object:  StoredProcedure [dbo].[SetNewSchool]    Script Date: 1/17/2020 6:45:57 AM ******/
SET ANSI_NULLS ON
GO
SET QUOTED_IDENTIFIER ON
GO
CREATE PROCEDURE [dbo].[SetNewSchool]
	(@newUserPersonId AS UniqueIdentifier,
	@schoolYearId as UniqueIdentifier,
	@schoolName as nvarchar(200),
	@demoDetails as bit,
	@gradingType as nvarchar(25))
 AS
 BEGIN
--Declare @personId as UniqueIdentifier
--Declare @schoolYearId as UniqueIdentifier
--Declare @schoolName as nvarchar(200)
--Declare @demoDetails as bit
--Declare @gradingType as nvarchar(25)
--Set @personId = ''
--Set @schoolYearId = (Select SchoolYearId from SchoolYear where YearInt = 2020)
--Set @schoolName = 'Stored Proc School'
--Set @demoDetails = 1
--Set @gradingType = 'TRADITIONAL'

Declare @entryPersonId as UniqueIdentifier
Set @entryPersonId = (select top 1 PersonId from Person where username = 'jef')

Insert into Company (
	Name,
	EntryDate,
	UrlCode,
	SchoolYearId,
	StudentNameFirst,
	hasOpenedSettings,
	Monday,
	Tuesday,
	Wednesday,
	Thursday,
	Friday,
	GradingType)
  values (
	@schoolName,
	getDate(),
	Replace(@schoolName, ' ', ''),
	@schoolYearId,
	'LASTNAME',
	@demoDetails,
	1,
	1,
	1,
	1,
	1,
	@gradingType)

select top 1 * into #company from company order by entryDate desc
Declare @companyId as UniqueIdentifier
Set @companyId = (select CompanyId from #company)

Insert into PersonAccessRoleAssign (PersonId, CompanyId, AccessRoleLearnerId)
Select @newUserPersonId, @companyId, AccessRoleLearnerId
From AccessRoleLearner
Where Name = 'Admin'

insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'attendance');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'calendarAndEvents');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'carpool');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'classPhotoGallery');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'classroomSeatingAssignments');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'courses');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'curbsideCheckInOut');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'facilitiesManagement');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'gradebook');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'messagesAndReminders');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'safetyAlert');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'sendStudentToOffice');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'substituteTeacher');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'teachers');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'volunteerHours');
insert into CompanyFeature(CompanyId, Feature) values (@companyId, 'votingAndSurveys');

--Copy LearningPathway and LearnerOutcomes for the new organization
insert into LearningPathway (companyId, name, description)
	select @companyId, Name, Description
	From LearningPathway
	Where companyId = '31B03385-213F-4630-A938-5F3EA0061EFC'

--Safety Alert Building and Field set up
insert into BuildingAndField (CompanyId, Name, Note, EntryDate)
	values (@companyId, 'Main', '(edit me!)', getDate())

Declare @buildingAndFieldId as UniqueIdentifier
Set @buildingAndFieldId = (Select top 1 @BuildingAndFieldId from BuildingAndField order by EntryDate desc)

insert into BuildingAndFieldLevel (BuildingandfieldId, Note, Name, EntryDate)
	values (@buildingAndFieldId, 'First', '(change me!)', getDate())

Declare @buildingAndFieldLevelId as UniqueIdentifier
Set @buildingAndFieldLevelId = (Select top 1 @BuildingAndFieldLevelId from BuildingAndFieldLevel order by EntryDate desc)

insert into LevelEntrance (Name, BuildingAndFieldId, BuildingandFieldLevelId, MapDirectionId, IsLockedDuringDay, Note)
	select 'Front', @buildingAndFieldId, @buildingAndFieldLevelId, MapDirectionId, 1, '(edit me)'
	From MapDirection where Name = 'North'

insert into LevelEntrance (Name, BuildingAndFieldId, BuildingandFieldLevelId, MapDirectionId, IsLockedDuringDay, Note)
	select 'Side door', @buildingAndFieldId, @buildingAndFieldLevelId, MapDirectionId, 1, '(edit me)'
	From MapDirection where Name = 'Southwest'

insert into LevelEntrance (Name, BuildingAndFieldId, BuildingandFieldLevelId, MapDirectionId, IsLockedDuringDay, Note)
	select 'Back door', @buildingAndFieldId, @buildingAndFieldLevelId, MapDirectionId, 1, '(edit me)'
	From MapDirection where Name = 'East'

--courseTypes
Insert into CourseType (CompanyId, name, sequence) values (@companyId, 'On campus', 1)

--KnowledgeRating options
Insert into KnowledgeRating (CompanyId, name, sequence) values (@companyId, 'Not started', 0)
Insert into KnowledgeRating (CompanyId, name, sequence) values (@companyId, 'Introduced', 1)
Insert into KnowledgeRating (CompanyId, name, sequence) values (@companyId, 'Practicing', 2)
Insert into KnowledgeRating (CompanyId, name, sequence) values (@companyId, 'Mastered', 0)

--PassFailRating options
Insert into PassFailRating (companyId, name, sequence) values (@companyId, 'Not started', 0)
Insert into PassFailRating (companyId, name, sequence) values (@companyId, 'Pass', 1)
Insert into PassFailRating (companyId, name, sequence) values (@companyId, 'Fail', 2)

--CourseContentType
Insert into CourseContentType (Code, name, description, companyId, needsGradingType, isGradable)
	Select Code, name, description, @companyId, needsGradingType, isGradable
	From CourseContentType
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'

--ContentTypes
Insert into ContentType (companyId, code, name, sequence)
	Select @companyId, code, name, sequence
	From ContentType
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'

Insert into QuestionType (companyId, code, name)
	Select @companyId, code, name
	From QuestionType
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'


Insert into Interval (companyId, code, name, fromDay, fromMonth, toDay, toMonth, sequence)
	Select @companyId, code, name, fromDay, fromMonth, toDay, toMonth, sequence
	From Interval
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'

Declare @intervalId as UniqueIdentifier
Set @intervalId = (Select IntervalId from Interval where Name like 'Fall%' and CompanyId = @companyId)

Update Company set IntervalId = @intervalId where CompanyId = @companyId

Insert into ClassPeriod (companyId, PeriodNumber, StartTime, EndTime, sequence)
	Select @companyId, PeriodNumber, StartTime, EndTime, sequence
	From ClassPeriod
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'


--Grade scale
Insert into GradeScaleTable (companyId, GradescaleName, EntryPersonId, EntryDate, DefaultFlag)
	Select @companyId, GradescaleName, @entryPersonId, getDate(), 1
	From GradeScaleTable
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'
		and DefaultFlag = 1

Declare @gradeScaleTableId as UniqueIdentifier
Set @gradeScaleTableId = (select gradeScaleTableId from gradeScaleTable where companyId = @companyId)

Insert into GradeScaleDetail (GradeScaleTableId, Letter, LowValue, HighValue, Scale40Value)
	Select @gradeScaleTableId, Letter, LowValue, HighValue, Scale40Value
	From GradeScaleDetail, GradeScaleTable
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'
		and GradeScaleDetail.GradeScaleTableId = GradeScaleTable.GradeScaleTableId
		and DefaultFlag = 1


--CheckInOrOutReasonType
Insert into CheckInOrOutReasonType (companyId, Name, Sequence)
	Select @companyId, Name, Sequence
	From CheckInOrOutReasonType
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'

--VolunteerType
Insert into VolunteerType (companyId, Name, Sequence)
	Select @companyId, Name, Sequence
	From VolunteerType
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'

--MaritalStatus
Insert into MaritalStatus(companyId, Code, Name)
	Select @companyId, Code, Name
	From MaritalStatus
	Where CompanyId = '31B03385-213F-4630-A938-5F3EA0061EFC'

Insert into PersonConfigure (
    PersonId,
    IntervalId,
    IntervalList,
    SchoolYearId,
    ChangedCourseList,
    HistorySentenceView,
    NextSentenceAuto,
    --NextSentenceAutoKeepOn,
    EditDifferenceView,
    --EditDifferenceViewKeepOn,
    TranslateInsertSuggestion,
    WorkToolsShowLabels,
    GroupToolsShowLabels,
    WorkFolderMineExpanded,
    WorkFolderOthersExpanded,
    MyWorksOrderBy)
 values (
    @newUserPersonId,
    @intervalId,
    Convert(nvarchar, @intervalId),
    @schoolYearId,
    1,
    0,
    1,
    --1,
    1,
    --1,
    0,
    1,
    1,
    1,
    1,
    'ALPHABETICAL')

Insert into PersonConfigInterval (PersonId, IntervalId)
	values (@newUserPersonId, @intervalId)

--if @demoDetails = 1
--	BEGIN
--    --addDemoPeopleAndCourses(newUserPersonId, newCompany.CompanyId, gradingType);
--	END


--Return the new companyId
select @companyId

Drop Table IF EXISTS #company

END
GO
