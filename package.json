{
  "name": "ebi",
  "version": "4.0.072",
  "description": "",
  "main": "index.js",
  "scripts": {
    "predev": "npm run build",
    "dev": "npm-run-all -p dev:*",
    "build": "npm-run-all -p build:*",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "build:client": "better-npm-run build:client",
    "build:server": "better-npm-run build:server",
    "dev:client": "better-npm-run dev:client",
    "dev:server": "better-npm-run dev:server"
  },
  "betterScripts": {
    "dev:client": {
      "command": "webpack serve --config webpack.client.cjs",
      "env": {
        "NODE_ENV": "development"
      }
    },
    "dev:server": {
      "command": "node dist/server.js",
      "env": {
        "NODE_ENV": "development"
      }
    },
    "build:client": {
      "command": "webpack --config webpack.client.cjs",
      "env": {
        "NODE_ENV": "production"
      }
    },
    "build:server": {
      "command": "webpack --config webpack.server.cjs",
      "env": {
        "NODE_ENV": "production"
      }
    }
  },
